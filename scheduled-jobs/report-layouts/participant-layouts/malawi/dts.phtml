                $labRes .= '<td style="text-align:center;">' . $dtsResultsMap[$response['labResult']] . '</td>';
                $labRes .= '<td style="text-align:center;">' . $response['referenceResult'] . '</td>';
                $labRes .= '<td style="text-align:center;">' . $evaluationResult . '</td>';
                $labRes .= '</tr>';
            }

            $labRes .= '</table>';
            $labRes .= '<span style="font-size:10px;">(R = Reactive, NR = Non Reactive, P = Positive, N = Negative, I = Invalid, Ind = Indeterminate)</span><br/>';

            // ---- RTRI panel (unchanged logic) ----
            if (
                (isset($shipmentAttributes['enableRtri']) && $shipmentAttributes['enableRtri'] == 'yes')
                &&
                (isset($result['responseResult'][0]['dts_rtri_control_line']) && !empty($result['responseResult'][0]['dts_rtri_control_line']))
            ) {
                $labRes .= '<br><span style="font-weight: bold;font-size:12px;">RTRI Results Panel : <br/></span>
                <table border="1" style="font-size:12px;">';
                $labRes .= '<tr style="background-color:#dbe4ee;">
                                <th style="text-align:center;font-weight:bold;">RTRI Tested?</th>
                                <th style="text-align:center;font-weight:bold;">Control/Sample</th>
                                <th style="text-align:center;font-weight:bold;">Control Line</th>
                                <th style="text-align:center;font-weight:bold;">Verification Line</th>
                                <th style="text-align:center;font-weight:bold;">Longterm Line</th>
                                <th style="text-align:center;font-weight:bold;">Expected Result</th>
                                <th style="text-align:center;font-weight:bold;">Final RTRI Interpretation</th>
                        </tr>';
                foreach ($result['responseResult'] as $response) {
                    $labRes .= '<tr>
                                <td style="text-align:center;">' . ucwords($response['dts_rtri_is_editable']) . '</td>
                                <td style="text-align:center;">' . ucwords($response['sample_label']) . '</td>
                                <td style="text-align:center;">' . ucwords($response['dts_rtri_control_line']) . '</td>
                                <td style="text-align:center;">' . ucwords($response['dts_rtri_diagnosis_line']) . '</td>
                                <td style="text-align:center;">' . ucwords($response['dts_rtri_longterm_line']) . '</td>
                                <td style="text-align:center;">' . $rtriResultsMap[$response['dts_rtri_reference_result']] . '</td>
                                <td style="text-align:center;">' . $rtriResultsMap[$response['dts_rtri_reported_result']] . '</td>
                            </tr>';
                }
                $labRes .= '</table>';
            }

            $pdf->SetLeftMargin(15);
            $pdf->writeHTML($labRes, true, false, true, false, '');

            if (!empty($nonMandatorySamples)) {
                $nmsTable  = "The following samples have been excluded from this evaluation : " . implode(", ", $nonMandatorySamples);
                $nmsTable .= "<br/>";
                $pdf->writeHTML($nmsTable, true, false, true, false, '');
            }

            // ---- Documentation score ----
            $documentationScore      = 0;
            $totalDocumentationItems = 0;

            if (isset($shipmentAttributes['sampleType']) && $shipmentAttributes['sampleType'] == 'dried') {
                $totalDocumentationItems = 5;
            } else {
                $totalDocumentationItems = 3;
                if ($attributes['algorithm'] == 'myanmarNationalDtsAlgo') {
                    $totalDocumentationItems -= 1;
                }
            }
            if ($attributes['algorithm'] == 'malawiNationalDtsAlgo') {
                $totalDocumentationItems += 4;
            }

            $documentationScorePerItem = round(($documentationScore / $totalDocumentationItems), 2);
            $attributes = json_decode($result['attributes'], true);

            $imgPass = WEB_ROOT . '/images/check.jpg';
            $imgFail = WEB_ROOT . '/images/cross.jpg';

            $docRes  = '<span style="font-weight:bold;font-size:12px;">Your documentation score :</span> <br/>';
            $docRes .= '<table border="1" style="font-size:12px;width:100%;">';
            $docRes .= '<tr style="background-color:#dbe4ee;">';
            $docRes .= '<td style="text-align:center;font-weight:bold;width:75%;">Documentation Item</td>';
            $docRes .= '<td style="text-align:center;font-weight:bold;width:25%;" colspan="2">Score</td>';
            $docRes .= '</tr>';

            // Receipt date
            if (isset($result['responseResult'][0]['shipment_receipt_date']) && trim($result['responseResult'][0]['shipment_receipt_date']) != "") {
                $scoreDoc = $documentationScorePerItem;
                $img      = $imgPass;
            } else {
                $scoreDoc = 0;
                $img      = $imgFail;
            }
            $docRes .= '<tr>';
            $docRes .= '<td style="text-align:left;font-weight:bold;">Panel/Shipment Receipt Date Specified</td>';
            $docRes .= '<td style="text-align:center;"><img style="width:9px;" src="' . $img . '" /></td>';
            $docRes .= '<td style="text-align:center;">' . $scoreDoc . '</td>';
            $docRes .= '</tr>';

            // Rehydration date (dried samples only)
            if (isset($attributes['sample_rehydration_date']) && trim($attributes['sample_rehydration_date']) != "" && $shipmentAttributesSampleTypeDisplay == "") {
                $scoreDoc = $documentationScorePerItem;
                $img      = $imgPass;
            } else {
                $scoreDoc = 0;
                $img      = $imgFail;
            }
            $docRes .= '<tr style="' . $shipmentAttributesSampleTypeDisplay . '">';
            $docRes .= '<td style="text-align:left;font-weight:bold;">Reporting of the Sample Rehydration Date</td>';
            $docRes .= '<td style="text-align:center;"><img style="width:9px;" src="' . $img . '" /></td>';
            $docRes .= '<td style="text-align:center;">' . $scoreDoc . '</td>';
            $docRes .= '</tr>';

            // Test date
            if (isset($result['responseResult'][0]['shipment_test_date']) && trim($result['responseResult'][0]['shipment_test_date']) != "") {
                $scoreDoc = $documentationScorePerItem;
                $img      = $imgPass;
            } else {
                $scoreDoc = 0;
                $img      = $imgFail;
            }
            $docRes .= '<tr>';
            $docRes .= '<td style="text-align:left;font-weight:bold;">Reporting of the Shipment Test Date</td>';
            $docRes .= '<td style="text-align:center;"><img style="width:9px;" src="' . $img . '" /></td>';
            $docRes .= '<td style="text-align:center;">' . $scoreDoc . '</td>';
            $docRes .= '</tr>';

            // Rehydration timing
            if ($interval->days < $sampleRehydrateDays || $interval->days > ($sampleRehydrateDays + 1)) {
                $scoreDoc = 0;
                $img      = $imgFail;
            } else {
                $scoreDoc = $documentationScorePerItem;
                $img      = $imgPass;
            }
            $docRes .= '<tr style="' . $shipmentAttributesSampleTypeDisplay . '">';
            $docRes .= '<td style="text-align:left;font-weight:bold;">Testing to be done within ' . $rehydrateHours . ' hours of rehydration.</td>';
            $docRes .= '<td style="text-align:center;"><img style="width:11px;" src="' . $img . '" /></td>';
            $docRes .= '<td style="text-align:center;">' . $scoreDoc . '</td>';
            $docRes .= '</tr>';

            // Supervisor approval (not Myanmar)
            if ($attributes['algorithm'] != 'myanmarNationalDtsAlgo') {
                if (strtolower($result['responseResult'][0]['supervisor_approval']) == 'yes' && trim($result['responseResult'][0]['participant_supervisor']) != "") {
                    $scoreDoc = $documentationScorePerItem;
                    $img      = $imgPass;
                } else {
                    $scoreDoc = 0;
                    $img      = $imgFail;
                }
                $docRes .= '<tr>';
                $docRes .= '<td style="text-align:left;font-weight:bold;">Supervisor Approval</td>';
                $docRes .= '<td style="text-align:center;"><img style="width:9px;" src="' . $img . '" /></td>';
                $docRes .= '<td style="text-align:center;">' . $scoreDoc . '</td>';
                $docRes .= '</tr>';
            }

            // Malawi-specific documentation items
            if ($attributes['algorithm'] == 'malawiNationalDtsAlgo') {
                $malawiItems = [
                    ['label' => 'Reporting the Condition of PT Samples',      'key' => 'condition_pt_samples'],
                    ['label' => 'Reporting the availability of Refridgerator', 'key' => 'refridgerator'],
                    ['label' => 'Reporting the Room Temperature',              'key' => 'room_temperature'],
                    ['label' => 'Reporting the availability of Stop Watch',    'key' => 'stop_watch'],
                ];
                foreach ($malawiItems as $item) {
                    if (!empty($attributes[$item['key']])) {
                        $scoreDoc = $documentationScorePerItem;
                        $img      = $imgPass;
                    } else {
                        $scoreDoc = 0;
                        $img      = $imgFail;
                    }
                    $docRes .= '<tr>';
                    $docRes .= '<td style="text-align:left;font-weight:bold;">' . $item['label'] . '</td>';
                    $docRes .= '<td style="text-align:center;"><img style="width:9px;" src="' . $img . '" /></td>';
                    $docRes .= '<td style="text-align:center;">' . $scoreDoc . '</td>';
                    $docRes .= '</tr>';
                }
            }

            $docRes .= '</table>';
            $pdf->writeHTML($docRes, true, false, true, false, '');

            // ---- Failure / corrective actions ----
            if (isset($result['responseResult'][0]['failure_reason']) && $result['responseResult'][0]['failure_reason'] != "" && $result['responseResult'][0]['failure_reason'] != "[]" && $result['responseResult'][0]['failure_reason'] != null) {
                $failRes  = '<span style="font-weight:bold;font-size:12px;">Suggested Corrective actions for your response :</span> <br/>';
                $failRes .= '<table border="1" style="font-size:11px;">';
                $failRes .= '<tr style="background-color:#dbe4ee;"><td style="text-align:center;font-weight:bold;">Failure Reasons (or) Warnings</td><td style="text-align:center;font-weight:bold;">Corrective Actions (if any)</td></tr>';
                $warnings = json_decode($result['responseResult'][0]['failure_reason'], true);
                foreach ($warnings as $warning) {
                    $failRes .= '<tr>';
                    $failRes .= '<td> ' . (isset($warning['warning'])         ? $warning['warning']         : "") . ' </td>';
                    $failRes .= '<td> ' . (isset($warning['correctiveAction']) ? $warning['correctiveAction'] : "") . ' </td>';
                    $failRes .= '</tr>';
                }
                $failRes .= '</table>';
                $pdf->writeHTML($failRes, true, false, true, false, '');
            }
        }

        $totalScore = $result['shipment_score'] + $result['documentation_score'];
        if ($result['is_excluded'] == 'yes') {
            $wishes = '<p>Your response was not considered for evaluation</p>';
            $pdf->SetLeftMargin(15);
            $pdf->writeHTML($wishes, true, false, true, false, '');
        } else {
            $accuracy = (($successRate / count($result['responseResult'])) * 100);
            $wishes   = '<p style="font-size:11px;"><strong>Total score</strong> ' . round($totalScore) . ' <strong>out of 100</strong><br>';
            $wishes  .= '<strong>Accuracy:</strong> ' . $accuracy . '%.<br>';
            $wishes  .= '<strong>Mean score for all Reporting Providers:</strong> ' . round($resultArray['meanScore']['mean_score'], 2) . '.<br>';
            $wishes  .= 'Method of Data evaluation is Non parametric(Qualitative)</p>';
            $pdf->SetLeftMargin(15);
            $pdf->writeHTML($wishes, true, false, true, false, '');
        }

        if (trim($result['shipment_comment']) != "" || trim($result['evaluationComments']) != "" || trim($result['optional_eval_comment']) != "") {
            $comment   = '<br><br><table border="1" style="width:100%;font-size:12px;" cellpadding="3">';
            $cmdStatus = false;
            if (trim($result['evaluationComments']) != "") {
                $cmdStatus = true;
                $comment  .= '<tr>';
                $comment  .= '<td style="font-weight:bold;width:30%;">Evaluation Comments </td>';
                $comment  .= '<td style="width:70%;">' . $result['evaluationComments'] . '</td>';
                $comment  .= '</tr>';
            }
            if (trim($result['optional_eval_comment']) != "") {
                $cmdStatus = true;
                $comment  .= '<tr>';
                $comment  .= '<td style="font-weight:bold;width:30%;">Specific Comments/Feedback</td>';
                $comment  .= '<td style="width:70%;">' . $result['optional_eval_comment'] . '</td>';
                $comment  .= '</tr>';
            }
            $comment .= '</table>';
            if ($cmdStatus) {
                $pdf->writeHTML($comment, true, false, true, false, '');
            }
        }

        $performance1 = $performance2 = $performance3 = false;
        include('summary-statistics.phtml');

        $br = '';
        if ($performance1 || $performance2 || $performance3) {
            $br = '<br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br>';
        }
        $eodReportText = "End of report";
        if ($evalRow['report_type'] == 'finalized') {
            $eodReportText = "End of final report";
        }
        $html  = $br . '<span style="font-size:11px;font-weight:bold;"><i>This is the confidential report that summarizes your performance.</i></span><br>';
        if (trim($result['shipment_comment']) != "") {
            $html .= '<span style="font-size:11px;"><b>Scheme Manager`s Comments:</b> ' . $result['shipment_comment'] . '</span><br>';
        }
        $html .= '<span style="font-size:11px;font-weight:bold;text-align:center;"><i>NPH PT all rights reserved.</i></span><br>';
        $html .= '<span style="font-size:11px;font-weight:bold;">Report Print Date: ' . $commonService->humanReadableDateFormat(date('d-m-Y')) . '</span>';
        $html .= '<br><span style="font-size:11px;text-align:center;font-weight:bold;"><u>' . $eodReportText . '</u>.</span><br>';
        $pdf->writeHTML($html, true, false, true, false, '');

        if (ob_get_contents()) {
            ob_end_clean();
        }

        if (isset($result['last_name']) && trim($result['last_name']) != "") {
            $result['last_name'] = "_" . $result['last_name'];
        }

        $nameParts = [];
        $keys = ['shipment_code', 'unique_identifier', 'region', 'state', 'district', 'city'];
        foreach ($keys as $key) {
            if (!empty($result[$key]) && strtoupper($result[$key]) != 'NULL') {
                $nameParts[] = ($key == 'shipment_code') ? $result[$key] : strtoupper($result[$key]);
            }
        }

        $fileName = implode("-", $nameParts) . "-" . $result['map_id'];
        $fileName = Application_Service_Common::makeFileNameFriendly($fileName) . ".pdf";
        $filePath = $reportsPath . DIRECTORY_SEPARATOR . $result['shipment_code'] . DIRECTORY_SEPARATOR . $fileName;
        $created  = $pdf->Output($filePath, "F");

        $loadpdf = Zend_Pdf::load($filePath);
        foreach ($loadpdf->pages as $page) {
            $pdfExtract = $extractor->clonePage($page);
            $pdfExtract->setFont($font, 8)->drawText('Page ' . $j . ' / ' . $totalPages, 280, 50);
            $pdfNew->pages[] = $pdfExtract;
        }
        $shipmentCode = $result['shipment_code'];
        $j++;
    }
}
