if (!function_exists('formatDtsResult')) {
    /**
     * Format DTS result strings for display.
     * Ensures "Nonreactive" / "Non Reactive" / "NONREACTIVE" etc. render as "Non-Reactive".
     */
    function formatDtsResult(string $value): string
    {
        $normalised = strtolower(str_replace([' ', '-'], '', $value));
        if ($normalised === 'nonreactive') {
            return 'Non-Reactive';
        }
        return ucwords(strtolower($value));
    }
}

if (!function_exists('resolveDtsDisplay')) {
    /**
     * Safe lookup helper: resolves a test result ID through both maps and returns
     * a formatted display string, or an empty string if any key is missing.
     */
    function resolveDtsDisplay(array $dtsResults, array $dtsResultsMap, $resultId): string
    {
        if (empty($resultId)) {
            return '';
        }
        $raw = $dtsResults[$resultId] ?? '';
        if ($raw === '') {
            return '';
        }
        $mapped = $dtsResultsMap[$raw] ?? '';
        if ($mapped === '') {
            return '';
        }
        return formatDtsResult($mapped);
    }
}

