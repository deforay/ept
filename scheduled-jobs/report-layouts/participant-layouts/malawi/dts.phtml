            if ($shipmentAttributesScreeningTestDisplay == "") {
                $labRes .= '<td>' . Pt_Commons_DateUtility::humanReadableDateFormat($result['responseResult'][0]['exp_date_2']) . '</td>';
            }
            if ($testThreeOptionalDisplay == "") {
                $labRes .= '<td>' . Pt_Commons_DateUtility::humanReadableDateFormat($result['responseResult'][0]['exp_date_3']) . '</td>';
            }
