                // FIX: correct column order — "Your Result" (participant) then "Expected Result" (reference)
                $labRes .= '<th style="background-color:#dbe4ee;text-align:center;font-weight:bold;width:' . $w . ';">Your Result</th>';
                $labRes .= '<th style="background-color:#dbe4ee;text-align:center;font-weight:bold;width:' . $w . ';">Expected Result</th>';
                $labRes .= '<th style="background-color:#dbe4ee;text-align:center;font-weight:bold;width:' . $w . ';">Evaluation</th>';
            }
            $labRes .= '</tr>';

            // ---- Data rows ----
            $nonMandatorySamples  = [];
            $controlSamples       = [];
            $correctSamples       = [];
            $totalProperSamples   = 0;
            $correctSamplesCount  = 0;
            $wrongSamples         = [];
            $otherSamples         = [];
            $allSamples           = [];
            $mandatorySampleCount = 0;
            $evaluationResult     = "";
            $successRate          = 0;

            foreach ($result['responseResult'] as $response) {
                $allSamples[] = $response['sample_label'];
                if ($response['control'] == 1) {
                    $controlSamples[] = $response['sample_label'];
                }
                if ($response['mandatory'] == 0) {
                    $nonMandatorySamples[] = $response['sample_label'];
                } else {
                    $mandatorySampleCount++;
                    if ($response['calculated_score'] == 'Pass') {
                        $correctSamples[] = $response['sample_label'];
                        $evaluationResult = 'Acceptable';
                        $successRate++;
                    } elseif ($response['calculated_score'] == 'Fail') {
                        $evaluationResult = 'Unacceptable';
                        $wrongSamples[]   = $response['sample_label'];
                    } else {
                        $evaluationResult = 'Unacceptable';
                        $otherSamples[]   = $response['sample_label'];
                    }
                }
            }

            $correctSamplesCount      = count($correctSamples);
            $totalProperSamples       = $correctSamplesCount + count($wrongSamples);
