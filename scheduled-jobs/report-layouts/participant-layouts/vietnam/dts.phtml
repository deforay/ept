<?php

/**
 * Vietnam (NIHE) DTS HIV serology — INDIVIDUAL participant report.
 *
 * Reproduces the NIHE individual-report layout: per-sample test breakdown
 * (Test 1/2/3 → Conclusion · Reference · Result evaluation) using the qualitative
 * Acceptable / Unacceptable / Not Evaluated vocabulary (NO numeric score).
 * Selected when the install's report-layout config = "vietnam".
 *
 * Verdict source: response_result_dts.calculated_score, written by the Vietnam branch
 * of Application_Model_Dts::evaluate (algoVietnam + diluted peer-consensus).
 *   Pass -> Acceptable, Fail -> Unacceptable, 'Not Evaluated' -> Not Evaluated, N.A. -> N.A.
 */

$schemeType = $resultArray['shipment'][0]['scheme_type'] ?? 'dts';
$pdfNew     = new Zend_Pdf();
$extractor  = new Zend_Pdf_Resource_Extractor();
$font       = Zend_Pdf_Font::fontWithName(Zend_Pdf_Font::FONT_HELVETICA);
$shipmentCode = '';

// result id -> human label, and final code -> human label
$dtsResults = $dtsCodeToLabel = [];
foreach ($schemeService->getPossibleResults('dts') as $pr) {
    $dtsResults[$pr['id']] = $pr['response'];
    if (in_array($pr['scheme_sub_group'], ['DTS_TEST', 'DTS_FINAL'], true)) {
        $dtsCodeToLabel[$pr['result_code']] = $pr['response'];
    }
}

// pretty-print an ALL-CAPS stored label e.g. "WEAK REACTIVE" -> "Weak Reactive"
$pretty = static function ($label) {
    $label = trim((string) $label);
    return $label === '' ? '-' : ucwords(strtolower($label));
};

// qualitative verdict from the stored per-sample score
$verdictText = static function ($score) {
    switch ((string) $score) {
        case 'Pass':          return 'Acceptable';
        case 'Fail':          return 'Unacceptable';
        case 'Not Evaluated': return 'Not Evaluated';
        case 'N.A.':          return 'N.A.';
        default:              return $score === '' ? 'Not Evaluated' : (string) $score;
    }
};

/**
 * NIHE Peer Group Statistics — fetch every participant response in this shipment
 * once, group by (test position, kit_id, sample_id), and compute counts, concordance
 * with the reference result, and (for kits with `additional_info='yes'`) Mean/SD/CV
 * of the reported numeric value. Returns:
 *
 *   $peer[$position][$kitId] = [
 *       'kit_name'       => string,         // r_testkitnames.TestKit_Name
 *       'has_numeric'    => bool,           // kit's attributes.additional_info='yes'
 *       'numeric_label'  => string,         // attributes.additional_info_label (if any)
 *       'samples'        => [
 *           $sampleId => [
 *               'sample_label'        => string,
 *               'rr_code'             => 'R'|'NR'|'P'|'N'|'-',
 *               'participants_n'      => int,    // n labs reporting on this kit/sample
 *               'result_n'            => int,    // n with a non-empty qualitative result
 *               'concordant_n'        => int,    // n whose result is concordant with the RR
 *               'concordant_pct'      => float|null,
 *               'statistical_n'      => int,    // n with a parseable numeric value
 *               'mean'               => float|null,
 *               'sd'                 => float|null,
 *               'cv'                 => float|null,
 *               'numeric_values'     => array<int,float>,  // map_id => value
 *               'result_codes'       => array<int,string>, // map_id => code
 *           ],
 *       ],
 *   ]
 */
$buildPeerStats = static function (int $shipmentId): array {
    $db = Zend_Db_Table_Abstract::getDefaultAdapter();

    // One row per (participant, sample, test position). Pulls the kit id at each
    // position, the qualitative result code, and the numeric value (if any).
    $sql = "
        SELECT
            spm.map_id,
            rrd.sample_id,
            ref.sample_label,
            refpr.result_code AS rr_code,
            pos.position,
            pos.kit_id,
            pos.test_result_id,
            pos.numeric_value
        FROM shipment_participant_map spm
        JOIN response_result_dts rrd ON rrd.shipment_map_id = spm.map_id
        JOIN reference_result_dts ref
          ON ref.shipment_id = spm.shipment_id AND ref.sample_id = rrd.sample_id
        LEFT JOIN r_possibleresult refpr ON refpr.id = ref.reference_result
        CROSS JOIN JSON_TABLE(
            JSON_ARRAY(
                JSON_OBJECT('p', 1, 'k', rrd.test_kit_name_1, 'r', rrd.test_result_1, 'n', JSON_UNQUOTE(JSON_EXTRACT(rrd.kit_additional_info, '$.test1'))),
                JSON_OBJECT('p', 2, 'k', rrd.test_kit_name_2, 'r', rrd.test_result_2, 'n', JSON_UNQUOTE(JSON_EXTRACT(rrd.kit_additional_info, '$.test2'))),
                JSON_OBJECT('p', 3, 'k', rrd.test_kit_name_3, 'r', rrd.test_result_3, 'n', JSON_UNQUOTE(JSON_EXTRACT(rrd.kit_additional_info, '$.test3')))
            ),
            '$[*]' COLUMNS (
                position       INT          PATH '$.p',
                kit_id         VARCHAR(50)  PATH '$.k',
                test_result_id VARCHAR(45)  PATH '$.r',
                numeric_value  VARCHAR(50)  PATH '$.n'
            )
        ) AS pos
        WHERE spm.shipment_id = ?
          AND pos.kit_id IS NOT NULL AND pos.kit_id <> ''
    ";
    $rows = $db->fetchAll($sql, [$shipmentId]);

    // Pull every kit we touched, plus its attributes / display name.
    $kitIds = [];
    foreach ($rows as $r) {
        $kitIds[$r['kit_id']] = true;
    }
    $kitMeta = [];
    if (!empty($kitIds)) {
        $kitRows = $db->fetchAll(
            $db->select()->from('r_testkitnames', ['TestKitName_ID', 'TestKit_Name', 'attributes'])
                ->where('TestKitName_ID IN (?)', array_keys($kitIds))
        );
        foreach ($kitRows as $kr) {
            $attrs = Pt_Commons_JsonUtility::safeDecode($kr['attributes']);
            $kitMeta[$kr['TestKitName_ID']] = [
                'name'           => $kr['TestKit_Name'] ?: $kr['TestKitName_ID'],
                'has_numeric'    => (($attrs['additional_info'] ?? '') === 'yes'),
                'numeric_label'  => $attrs['additional_info_label'] ?? '',
            ];
        }
    }

    // Reactive set for HIV serology: a participant is "concordant with RR" if their
    // result_code is in the reactive set when RR is reactive, or in the non-reactive
    // set when RR is non-reactive. P/REACTIVE/R/WR all read as "positive cluster".
    $isReactive = static fn (string $c) => in_array(strtoupper($c), ['R', 'WR', 'P'], true);
    $isNonReactive = static fn (string $c) => in_array(strtoupper($c), ['NR', 'N'], true);

    // Build the aggregate. result_code lookup keyed by id.
    $codeById = [];
    $allCodes = $db->fetchAll($db->select()->from('r_possibleresult', ['id', 'result_code']));
    foreach ($allCodes as $c) {
        $codeById[(string) $c['id']] = (string) $c['result_code'];
    }

    $peer = [];
    foreach ($rows as $r) {
        $pos = (int) $r['position'];
        $kid = (string) $r['kit_id'];
        $sid = (int) $r['sample_id'];

        if (!isset($peer[$pos][$kid])) {
            $peer[$pos][$kid] = [
                'kit_name'      => $kitMeta[$kid]['name'] ?? $kid,
                'has_numeric'   => $kitMeta[$kid]['has_numeric'] ?? false,
                'numeric_label' => $kitMeta[$kid]['numeric_label'] ?? '',
                'samples'       => [],
            ];
        }
        if (!isset($peer[$pos][$kid]['samples'][$sid])) {
            $peer[$pos][$kid]['samples'][$sid] = [
                'sample_label'    => $r['sample_label'] ?? '',
                'rr_code'         => strtoupper((string) ($r['rr_code'] ?? '')),
                'participants_n'  => 0,
                'result_n'        => 0,
                'concordant_n'    => 0,
                'statistical_n'   => 0,
                'numeric_values'  => [],
                'result_codes'    => [],
            ];
        }
        $bucket = &$peer[$pos][$kid]['samples'][$sid];
        $bucket['participants_n']++;

        $resCode = isset($r['test_result_id']) ? ($codeById[(string) $r['test_result_id']] ?? '') : '';
        if ($resCode !== '' && $resCode !== '-') {
            $bucket['result_n']++;
            $bucket['result_codes'][(int) $r['map_id']] = $resCode;

            $rrUp = $bucket['rr_code'];
            $concordant = false;
            if (in_array($rrUp, ['P', 'R', 'WR'], true)) {
                $concordant = $isReactive($resCode);
            } elseif (in_array($rrUp, ['N', 'NR'], true)) {
                $concordant = $isNonReactive($resCode);
            }
            if ($concordant) {
                $bucket['concordant_n']++;
            }
        }

        $num = is_numeric($r['numeric_value']) ? (float) $r['numeric_value'] : null;
        if ($num !== null) {
            $bucket['statistical_n']++;
            $bucket['numeric_values'][(int) $r['map_id']] = $num;
        }
        unset($bucket);
    }

    // Finalize stats per (position, kit, sample).
    foreach ($peer as $pos => &$kitMap) {
        foreach ($kitMap as $kid => &$kitBlock) {
            foreach ($kitBlock['samples'] as $sid => &$s) {
                $s['concordant_pct'] = $s['result_n'] > 0
                    ? round(($s['concordant_n'] / $s['result_n']) * 100, 1)
                    : null;
                if ($kitBlock['has_numeric'] && $s['statistical_n'] >= 2) {
                    $vals = array_values($s['numeric_values']);
                    $mean = array_sum($vals) / count($vals);
                    $variance = 0.0;
                    foreach ($vals as $v) {
                        $variance += ($v - $mean) ** 2;
                    }
                    $sd = sqrt($variance / (count($vals) - 1)); // sample SD
                    $cv = $mean != 0.0 ? round(($sd / $mean) * 100, 1) : null;
                    $s['mean'] = round($mean, 3);
                    $s['sd']   = round($sd, 3);
                    $s['cv']   = $cv;
                } else {
                    $s['mean'] = $s['sd'] = $s['cv'] = null;
                }
                ksort($s['result_codes']);
                ksort($s['numeric_values']);
            }
            unset($s);
            ksort($kitBlock['samples']);
        }
        unset($kitBlock);
    }
    unset($kitMap);
    ksort($peer);

    return $peer;
};

if (!empty($resultArray['shipment'])) {

    $totalPages = count($resultArray['shipment']);
    $j = 1;

    // NIHE Peer Group Statistics — computed once per shipment and reused
    // across every participant rendered below. Keyed by (position, kit_id, sample_id).
    $peerStatsByShipment = [];

    foreach ($resultArray['shipment'] as $result) {

        if (isset($result['responseResult'][0]['is_pt_test_not_performed']) && $result['responseResult'][0]['is_pt_test_not_performed'] == 'yes') {
            continue;
        }

        $shipmentDir = $reportsPath . DIRECTORY_SEPARATOR . $result['shipment_code'];
        if (!is_dir($shipmentDir)) {
            mkdir($shipmentDir);
        }

        // Always use FpdiReport for Vietnam: that class carries the NIHE Header()
        // (logo + "NATIONAL HIV REFERENCE LABORATORY" block) and Footer()
        // (www.nihe.vn / Hotline / Panel ID / Page X of Y). When a report-format
        // letterhead PDF is configured AND on disk, Header() stamps it instead.
        $reportFormat = $reportService->getReportConfigValue('report-format');
        $pdf = new Pt_Reports_FpdiReport(PDF_PAGE_ORIENTATION, PDF_UNIT, PDF_PAGE_FORMAT, true, 'UTF-8', false);
        $pdf->setParams($resultStatus, $evalRow['date_finalised'], "", $watermark, "INDIVIDUAL", $layout, $result['scheme_name']);

        $pdf->SetHeaderData(PDF_HEADER_LOGO, PDF_HEADER_LOGO_WIDTH, PDF_HEADER_TITLE, PDF_HEADER_STRING);
        $pdf->setHeaderFont(['freesans', '', PDF_FONT_SIZE_MAIN]);
        $pdf->setFooterFont(['freesans', '', PDF_FONT_SIZE_DATA]);
        $pdf->SetDefaultMonospacedFont(PDF_FONT_MONOSPACED);

        // Top margin clears either the stamped letterhead PDF (when configured) or the
        // in-code NIHE header (~26mm: 18mm logo + ~6mm address text + a small gap).
        $hasTemplate = !empty($reportFormat) && file_exists(UPLOAD_PATH . DIRECTORY_SEPARATOR . 'report-formats' . DIRECTORY_SEPARATOR . $reportFormat);
        $mt = $hasTemplate ? max(60, (int) ($templateTopMargin ?? 0) + 15) : 32;
        $pdf->SetMargins(PDF_MARGIN_LEFT, $mt, PDF_MARGIN_RIGHT);
        $pdf->SetHeaderMargin(PDF_MARGIN_HEADER);
        $pdf->SetFooterMargin(PDF_MARGIN_FOOTER);
        $pdf->SetAutoPageBreak(true, PDF_MARGIN_BOTTOM);
        $pdf->setImageScale(PDF_IMAGE_SCALE_RATIO);
        $pdf->AddPage('P', 'A4');
        $pdf->SetFont('freesans', '', 11);

        // ---- dates ----
        $responseDate = '';
        if (!empty($result['responseResult'][0]['responseDate'])) {
            $responseDate = Pt_Commons_DateUtility::humanReadableDateFormat(explode(' ', $result['responseResult'][0]['responseDate'])[0]);
        }
        $shipmentDate  = trim((string) $result['shipment_date']) !== '' ? Pt_Commons_DateUtility::humanReadableDateFormat($result['shipment_date']) : '';
        $receiptDate   = !empty($result['responseResult'][0]['shipment_receipt_date']) ? Pt_Commons_DateUtility::humanReadableDateFormat($result['responseResult'][0]['shipment_receipt_date']) : '';
        $deadlineDate  = trim((string) $result['response_deadline']) !== '' ? Pt_Commons_DateUtility::humanReadableDateFormat($result['response_deadline']) : '';

        // ---- Participant / Panel information ----
        // Resolve the per-participant testing tier (screening/confirmatory) from the map
        // attributes JSON. NIHE evaluates the two tiers under different rules, so showing
        // it on the report is part of the recipient understanding their result.
        $mapAttributes = Pt_Commons_JsonUtility::safeDecode($result['attributes'] ?? '');
        $panelType = strtolower((string) ($mapAttributes['dts_test_panel_type'] ?? ''));
        $panelTypeLabel = match ($panelType) {
            'screening'    => 'Screening',
            'confirmatory' => 'Confirmatory',
            default        => '-',
        };

        // Title block — mirrors the NIHE template (cover page intentionally skipped;
        // the FpdiReport template carries the institute letterhead).
        $titleHtml = '<div style="text-align:center;">'
            . '<span style="font-weight:bold;font-size:13px;">' . Pt_Commons_TranslateUtility::safeTranslate('PROFICIENCY TESTING PROGRAM – HIV SEROLOGY') . '</span><br/>'
            . '<span style="font-weight:bold;font-size:11px;">' . Pt_Commons_TranslateUtility::safeTranslate('INDIVIDUAL REPORT')
            . ($panelTypeLabel !== '-' ? ' — ' . Pt_Commons_TranslateUtility::safeTranslate($panelTypeLabel) : '')
            . '</span></div><br/>';
        $pdf->writeHTML($titleHtml, true, false, true, false, '');

        $info  = '<table cellpadding="3" border="1" style="font-size:11px;">';
        $info .= '<tr style="background-color:#dbe4ee;"><td colspan="4" style="vertical-align:middle;"><strong>' . Pt_Commons_TranslateUtility::safeTranslate('Participant Information') . '</strong></td></tr>';
        $info .= '<tr><td style="vertical-align:middle;"><strong>' . Pt_Commons_TranslateUtility::safeTranslate('Laboratory ID') . '</strong></td><td style="vertical-align:middle;">' . ($result['unique_identifier'] ?? '') . '</td>'
               . '<td style="vertical-align:middle;"><strong>' . Pt_Commons_TranslateUtility::safeTranslate('Laboratory') . '</strong></td><td style="vertical-align:middle;">' . ($result['labName'] ?? '') . '</td></tr>';
        $info .= '<tr><td style="vertical-align:middle;"><strong>' . Pt_Commons_TranslateUtility::safeTranslate('Testing tier') . '</strong></td><td style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate($panelTypeLabel) . '</td>'
               . '<td colspan="2" style="vertical-align:middle;"></td></tr>';
        $info .= '<tr style="background-color:#dbe4ee;"><td colspan="4" style="vertical-align:middle;"><strong>' . Pt_Commons_TranslateUtility::safeTranslate('Panel Information') . '</strong></td></tr>';
        $info .= '<tr><td style="vertical-align:middle;"><strong>' . Pt_Commons_TranslateUtility::safeTranslate('Panel ID') . '</strong></td><td style="vertical-align:middle;">' . ($result['shipment_code'] ?? '') . '</td>'
               . '<td style="vertical-align:middle;"><strong>' . Pt_Commons_TranslateUtility::safeTranslate('Shipment date') . '</strong></td><td style="vertical-align:middle;">' . $shipmentDate . '</td></tr>';
        $info .= '<tr><td style="vertical-align:middle;"><strong>' . Pt_Commons_TranslateUtility::safeTranslate('Received date') . '</strong></td><td style="vertical-align:middle;">' . $receiptDate . '</td>'
               . '<td style="vertical-align:middle;"><strong>' . Pt_Commons_TranslateUtility::safeTranslate('Results deadline') . '</strong></td><td style="vertical-align:middle;">' . $deadlineDate . '</td></tr>';
        $info .= '</table><br/>';
        $pdf->writeHTML($info, true, false, true, false, '');

        // ---- HIV proficiency results (per-sample test breakdown) ----
        // NIHE column-header style: each test position carries its kit name + Lot No + Exp date.
        // The kit set is constant across samples for a given participant, so we read it off the
        // first response row that supplies non-empty values for each position.
        if (!empty($result['responseResult'])) {
            $firstRow = $result['responseResult'][0];
            $kitHeader = static function (string $name, ?string $lot, ?string $exp, int $position) {
                $name = trim((string) $name);
                if ($name === '') {
                    return '<strong>' . Pt_Commons_TranslateUtility::safeTranslate('Test ' . $position) . '</strong>';
                }
                $h = '<strong>' . htmlspecialchars($name, ENT_QUOTES, 'UTF-8') . '</strong>';
                if (!empty($lot)) {
                    $h .= '<br/><span style="font-size:9px;">' . Pt_Commons_TranslateUtility::safeTranslate('Lot No') . ': ' . htmlspecialchars((string) $lot, ENT_QUOTES, 'UTF-8') . '</span>';
                }
                if (!empty($exp)) {
                    $h .= '<br/><span style="font-size:9px;">' . Pt_Commons_TranslateUtility::safeTranslate('Exp') . ': ' . Pt_Commons_DateUtility::humanReadableDateFormat($exp) . '</span>';
                }
                return $h;
            };

            $tbl  = '<span style="font-weight:bold;font-size:13px;">' . Pt_Commons_TranslateUtility::safeTranslate('HIV proficiency results') . '</span><br/>';
            $tbl .= '<table border="1" cellpadding="3" style="font-size:11px;border-color:#dbe4ee;">';
            $tbl .= '<tr style="background-color:#dbe4ee;text-align:center;vertical-align:middle;">'
                  . '<td rowspan="2" style="vertical-align:middle;"><strong>' . Pt_Commons_TranslateUtility::safeTranslate('Sample') . '</strong></td>'
                  . '<td colspan="4" style="vertical-align:middle;"><strong>' . Pt_Commons_TranslateUtility::safeTranslate('Result') . '</strong></td>'
                  . '<td rowspan="2" style="vertical-align:middle;"><strong>' . Pt_Commons_TranslateUtility::safeTranslate('Reference result (RR)') . '</strong></td>'
                  . '<td rowspan="2" style="vertical-align:middle;"><strong>' . Pt_Commons_TranslateUtility::safeTranslate('Result evaluation') . '</strong></td>'
                  . '</tr>';
            $tbl .= '<tr style="background-color:#dbe4ee;text-align:center;vertical-align:middle;">'
                  . '<td style="vertical-align:middle;">' . $kitHeader($firstRow['testkit1'] ?? '', $firstRow['lot_no_1'] ?? '', $firstRow['exp_date_1'] ?? '', 1) . '</td>'
                  . '<td style="vertical-align:middle;">' . $kitHeader($firstRow['testkit2'] ?? '', $firstRow['lot_no_2'] ?? '', $firstRow['exp_date_2'] ?? '', 2) . '</td>'
                  . '<td style="vertical-align:middle;">' . $kitHeader($firstRow['testkit3'] ?? '', $firstRow['lot_no_3'] ?? '', $firstRow['exp_date_3'] ?? '', 3) . '</td>'
                  . '<td style="vertical-align:middle;"><strong>' . Pt_Commons_TranslateUtility::safeTranslate('Conclusion') . '</strong></td>'
                  . '</tr>';

            foreach ($result['responseResult'] as $response) {
                $t1 = isset($response['test_result_1']) && $response['test_result_1'] != '' ? $pretty($dtsResults[$response['test_result_1']] ?? '') : '-';
                $t2 = isset($response['test_result_2']) && $response['test_result_2'] != '' ? $pretty($dtsResults[$response['test_result_2']] ?? '') : '-';
                $t3 = isset($response['test_result_3']) && $response['test_result_3'] != '' ? $pretty($dtsResults[$response['test_result_3']] ?? '') : '-';
                $conclusion = $pretty($response['labResult'] ?? '');
                $reference  = $pretty($dtsCodeToLabel[$response['referenceResultCode'] ?? ''] ?? ($response['referenceResultCode'] ?? ''));
                $evaluation = $verdictText($response['calculated_score'] ?? '');

                $tbl .= '<tr style="text-align:center;">'
                      . '<td style="vertical-align:middle;">' . ($response['sample_label'] ?? '') . '</td>'
                      . '<td style="vertical-align:middle;">' . $t1 . '</td><td style="vertical-align:middle;">' . $t2 . '</td><td style="vertical-align:middle;">' . $t3 . '</td>'
                      . '<td style="vertical-align:middle;">' . $conclusion . '</td>'
                      . '<td style="vertical-align:middle;">' . $reference . '</td>'
                      . '<td style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate($evaluation) . '</td>'
                      . '</tr>';
            }
            $tbl .= '</table>';
            $tbl .= '<span style="font-size:9px;">' . Pt_Commons_TranslateUtility::safeTranslate('R = Reactive, WR = Weak Reactive, NR = Non-reactive, Ind = Indeterminate') . '</span><br/>';
            $pdf->SetLeftMargin(15);
            $pdf->writeHTML($tbl, true, false, true, false, '');
        }

        // ---- Peer Group Statistics (NIHE template) ----
        // Per kit used in the panel, show n participants, concordance with the
        // reference result, and (for kits flagged with `additional_info='yes'`)
        // Mean / SD / CV of the reported numeric value.
        $shipmentId = (int) ($result['shipment_id'] ?? 0);
        if ($shipmentId > 0 && !empty($result['responseResult'])) {
            if (!isset($peerStatsByShipment[$shipmentId])) {
                $peerStatsByShipment[$shipmentId] = $buildPeerStats($shipmentId);
            }
            $peerStats = $peerStatsByShipment[$shipmentId];

            // Index this participant's response rows by (position, sample_id) so the
            // table can show what THIS lab reported alongside the peer aggregate.
            $myResp = [];
            $myKitsByPosition = [1 => [], 2 => [], 3 => []];
            foreach ($result['responseResult'] as $r) {
                $sid = (int) ($r['sample_id'] ?? 0);
                $myResp[1][$sid] = ['kit' => $r['test_kit_name_1'] ?? '', 'result_id' => $r['test_result_1'] ?? ''];
                $myResp[2][$sid] = ['kit' => $r['test_kit_name_2'] ?? '', 'result_id' => $r['test_result_2'] ?? ''];
                $myResp[3][$sid] = ['kit' => $r['test_kit_name_3'] ?? '', 'result_id' => $r['test_result_3'] ?? ''];
                $infoJson = !empty($r['kit_additional_info']) ? json_decode((string) $r['kit_additional_info'], true) : [];
                $myResp[1][$sid]['numeric'] = is_numeric($infoJson['test1'] ?? null) ? (float) $infoJson['test1'] : null;
                $myResp[2][$sid]['numeric'] = is_numeric($infoJson['test2'] ?? null) ? (float) $infoJson['test2'] : null;
                $myResp[3][$sid]['numeric'] = is_numeric($infoJson['test3'] ?? null) ? (float) $infoJson['test3'] : null;
                foreach ([1, 2, 3] as $p) {
                    $k = $myResp[$p][$sid]['kit'];
                    if ($k !== '' && !in_array($k, $myKitsByPosition[$p], true)) {
                        $myKitsByPosition[$p][] = $k;
                    }
                }
            }

            $hasAnyKit = !empty($myKitsByPosition[1]) || !empty($myKitsByPosition[2]) || !empty($myKitsByPosition[3]);
            if ($hasAnyKit) {
                $pdf->writeHTML('<br/><span style="font-weight:bold;font-size:12px;">' . Pt_Commons_TranslateUtility::safeTranslate('Peer Group Statistics') . '</span>', true, false, true, false, '');
                $pdf->Ln(2);

                foreach ([1, 2, 3] as $position) {
                    foreach ($myKitsByPosition[$position] as $kid) {
                        if (!isset($peerStats[$position][$kid])) {
                            continue;
                        }
                        $block = $peerStats[$position][$kid];
                        $kitDisplay = htmlspecialchars($block['kit_name'], ENT_QUOTES, 'UTF-8');
                        $hasNum = $block['has_numeric'];
                        $numLbl = $block['numeric_label'] !== '' ? $block['numeric_label'] : 'Value';

                        $pdf->writeHTML(
                            '<br/><span style="font-size:11px;"><strong>'
                            . Pt_Commons_TranslateUtility::safeTranslate('Assay') . ':</strong> ' . $kitDisplay
                            . ' &nbsp;<em>(' . Pt_Commons_TranslateUtility::safeTranslate('Test ' . $position) . ')</em></span>',
                            true,
                            false,
                            true,
                            false,
                            ''
                        );

                        // Per-sample verdict from this participant's response, for the Concordance
                        // column. The verdict is shipment-level (per sample, not per kit position),
                        // but NIHE renders it on each kit's Peer Group Stats block so the reader
                        // sees the verdict alongside the kit-level numbers.
                        $verdictPerSample = [];
                        foreach ($result['responseResult'] as $rr) {
                            $verdictPerSample[(int) $rr['sample_id']] = $verdictText($rr['calculated_score'] ?? '');
                        }

                        $tbl  = '<table border="1" cellpadding="3" style="font-size:10px;border-color:#dbe4ee;">';
                        $tbl .= '<tr style="background-color:#dbe4ee;font-weight:bold;text-align:center;">'
                              . '<td style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate('Sample') . '</td>'
                              . '<td style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate('Your result') . '</td>';
                        if ($hasNum) {
                            $tbl .= '<td style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate('Your ' . $numLbl) . '</td>';
                        }
                        $tbl .= '<td style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate('Participants (n)') . '</td>'
                              . '<td style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate('Result (n)') . '</td>';
                        if ($hasNum) {
                            $tbl .= '<td style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate('Statistical (n)') . '</td>'
                                  . '<td style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate('Mean') . '</td>'
                                  . '<td style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate('SD') . '</td>'
                                  . '<td style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate('CV (%)') . '</td>';
                        }
                        $tbl .= '<td style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate('Concordant with RR n (%)') . '</td>'
                              . '<td style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate('Reference result (RR)') . '</td>'
                              . '<td style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate('Concordance') . '</td>'
                              . '</tr>';

                        foreach ($block['samples'] as $sid => $s) {
                            $mine = $myResp[$position][$sid] ?? null;
                            $myResultCode = '';
                            if (!empty($mine['result_id']) && isset($dtsResults[$mine['result_id']])) {
                                $myResultCode = (string) $dtsResults[$mine['result_id']];
                            }
                            $myNumericDisplay = ($hasNum && isset($mine['numeric']) && $mine['numeric'] !== null) ? (string) $mine['numeric'] : '-';
                            $rrDisplay = $pretty($dtsCodeToLabel[$s['rr_code']] ?? $s['rr_code']);
                            $concordantCombined = $s['concordant_pct'] !== null
                                ? $s['concordant_n'] . ' (' . $s['concordant_pct'] . '%)'
                                : '-';
                            $verdict = $verdictPerSample[(int) $sid] ?? 'Not Evaluated';

                            $tbl .= '<tr style="text-align:center;">'
                                  . '<td style="vertical-align:middle;">' . htmlspecialchars($s['sample_label'], ENT_QUOTES, 'UTF-8') . '</td>'
                                  . '<td style="vertical-align:middle;">' . ($myResultCode !== '' ? $pretty($myResultCode) : '-') . '</td>';
                            if ($hasNum) {
                                $tbl .= '<td style="vertical-align:middle;">' . $myNumericDisplay . '</td>';
                            }
                            $tbl .= '<td style="vertical-align:middle;">' . $s['participants_n'] . '</td>'
                                  . '<td style="vertical-align:middle;">' . $s['result_n'] . '</td>';
                            if ($hasNum) {
                                $tbl .= '<td style="vertical-align:middle;">' . $s['statistical_n'] . '</td>'
                                      . '<td style="vertical-align:middle;">' . ($s['mean'] !== null ? $s['mean'] : '-') . '</td>'
                                      . '<td style="vertical-align:middle;">' . ($s['sd']   !== null ? $s['sd']   : '-') . '</td>'
                                      . '<td style="vertical-align:middle;">' . ($s['cv']   !== null ? $s['cv']   : '-') . '</td>';
                            }
                            $tbl .= '<td style="vertical-align:middle;">' . $concordantCombined . '</td>'
                                  . '<td style="vertical-align:middle;">' . $rrDisplay . '</td>'
                                  . '<td style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate($verdict) . '</td>'
                                  . '</tr>';
                        }
                        $tbl .= '</table>';
                        $pdf->writeHTML($tbl, true, false, true, false, '');

                        // NIHE box chart STRIP — one mini box-plot per sample, each with
                        // its own auto-scaled Y axis so a wide-variance sample doesn't crush
                        // narrow ones. Matches the NIHE Word template's horizontal panel of
                        // small per-sample charts. Only emitted for numeric kits (CLIA/ELISA
                        // with additional_info=yes) since qualitative kits have nothing to
                        // distribute.
                        if ($hasNum) {
                            // NIHE colour convention (from the NIHE summary template):
                            //   Acceptable    = teal circle with ✓
                            //   Unacceptable  = red circle with ✗
                            //   Not evaluated = orange circle with –
                            // We track the glyph alongside the colour so the SVG builder
                            // can stamp the icon onto the participant dot.
                            $pointSeriesMeta = [
                                'Acceptable'    => ['color' => '#1b9e8a', 'glyph' => "\u{2713}", 'label' => Pt_Commons_TranslateUtility::safeTranslate('Acceptable')],
                                'Unacceptable'  => ['color' => '#c0392b', 'glyph' => "\u{2717}", 'label' => Pt_Commons_TranslateUtility::safeTranslate('Unacceptable')],
                                'Not Evaluated' => ['color' => '#e67e22', 'glyph' => "\u{2013}", 'label' => Pt_Commons_TranslateUtility::safeTranslate('Not evaluated')],
                            ];

                            // Inline SVG built from peer stats — TCPDF's ImageSVG renders
                            // simple <rect>/<line>/<text>/<circle> reliably (see mtbept
                            // tb.phtml for the established pattern). No Node call per chart,
                            // no Chart.js complexity, output is true vector in the PDF.
                            $svgBox = static function (array $vals, ?float $partVal, ?string $partColor, ?string $partGlyph, string $label, int $w = 300, int $h = 380): string {
                                sort($vals);
                                $n = count($vals);
                                $pct = static function (array $a, float $p) {
                                    $idx = ($p / 100) * (count($a) - 1);
                                    $lo = (int) floor($idx); $hi = (int) ceil($idx);
                                    return $a[$lo] + ($a[$hi] - $a[$lo]) * ($idx - $lo);
                                };
                                $q1 = $pct($vals, 25);
                                $q2 = $pct($vals, 50);
                                $q3 = $pct($vals, 75);
                                $iqr = $q3 - $q1;
                                // Tukey whisker bounds clamped to actual data.
                                $loFence = $q1 - 1.5 * $iqr;
                                $hiFence = $q3 + 1.5 * $iqr;
                                $whiskerLo = $vals[0];
                                $whiskerHi = $vals[$n - 1];
                                foreach ($vals as $v) {
                                    if ($v >= $loFence) { $whiskerLo = $v; break; }
                                }
                                for ($i = $n - 1; $i >= 0; $i--) {
                                    if ($vals[$i] <= $hiFence) { $whiskerHi = $vals[$i]; break; }
                                }
                                $outliers = array_filter($vals, static fn ($v) => $v < $loFence || $v > $hiFence);

                                // Y axis scaling
                                $extents = array_merge([$whiskerLo, $whiskerHi, $q1, $q3, $q2], $outliers);
                                if ($partVal !== null) { $extents[] = $partVal; }
                                $dataMin = min($extents);
                                $dataMax = max($extents);
                                if ($dataMin === $dataMax) { $dataMin -= 1; $dataMax += 1; }
                                $pad = ($dataMax - $dataMin) * 0.12;
                                $axisMin = $dataMin - $pad;
                                $axisMax = $dataMax + $pad;
                                // Clamp axis bottom to 0 for S/CO-like ratios (negative is meaningless).
                                if ($dataMin >= 0) { $axisMin = max(0, $axisMin); }
                                $axisRange = max($axisMax - $axisMin, 1e-9);

                                $padTop = 14; $padBottom = 38; $padLeft = 56; $padRight = 14;
                                $plotTop = $padTop; $plotBottom = $h - $padBottom;
                                $plotLeft = $padLeft; $plotRight = $w - $padRight;
                                $plotW = $plotRight - $plotLeft; $plotH = $plotBottom - $plotTop;
                                $cx = $plotLeft + $plotW / 2;
                                $boxW = $plotW * 0.6;
                                $capW = $plotW * 0.42;

                                $toY = static fn (float $v) => $plotBottom - (($v - $axisMin) / $axisRange) * $plotH;
                                $fmt = static function (float $v): string {
                                    if (abs($v) >= 100) { return (string) (int) round($v); }
                                    if (abs($v) >= 10)  { return rtrim(rtrim(number_format($v, 1, '.', ''), '0'), '.'); }
                                    return rtrim(rtrim(number_format($v, 2, '.', ''), '0'), '.');
                                };

                                // Pick 4–5 round-ish tick values across the axis range.
                                $tickCount = 5;
                                $step = ($axisMax - $axisMin) / ($tickCount - 1);
                                $magnitude = pow(10, (int) floor(log10(max($step, 1e-9))));
                                $nice = $magnitude;
                                foreach ([1, 2, 2.5, 5, 10] as $f) {
                                    if ($f * $magnitude >= $step) { $nice = $f * $magnitude; break; }
                                }
                                $tickStart = $nice * floor($axisMin / $nice);
                                $ticks = [];
                                for ($t = $tickStart; $t <= $axisMax + $nice / 2; $t += $nice) {
                                    if ($t < $axisMin - $nice / 2) { continue; }
                                    $ticks[] = $t;
                                }

                                $svg  = '<?xml version="1.0" encoding="UTF-8"?>';
                                $svg .= '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ' . $w . ' ' . $h . '">';
                                // Background
                                $svg .= '<rect x="0" y="0" width="' . $w . '" height="' . $h . '" fill="white"/>';
                                // Y-axis ticks + gridlines (label text in black for contrast)
                                foreach ($ticks as $t) {
                                    if ($t < $axisMin || $t > $axisMax) { continue; }
                                    $ty = $toY($t);
                                    $svg .= '<line x1="' . $plotLeft . '" y1="' . $ty . '" x2="' . $plotRight . '" y2="' . $ty . '" stroke="#eee" stroke-width="0.6"/>';
                                    $svg .= '<text x="' . ($plotLeft - 6) . '" y="' . $ty . '" dominant-baseline="middle" text-anchor="end" style="fill:#222;font-family:helvetica;font-size:14pt">' . $fmt($t) . '</text>';
                                }
                                // Y axis line
                                $svg .= '<line x1="' . $plotLeft . '" y1="' . $plotTop . '" x2="' . $plotLeft . '" y2="' . $plotBottom . '" stroke="#888" stroke-width="1.2"/>';
                                // Upper whisker stem + cap
                                if ($whiskerHi > $q3) {
                                    $svg .= '<line x1="' . $cx . '" y1="' . $toY($q3) . '" x2="' . $cx . '" y2="' . $toY($whiskerHi) . '" stroke="#1f3a68" stroke-width="3"/>';
                                    $svg .= '<line x1="' . ($cx - $capW / 2) . '" y1="' . $toY($whiskerHi) . '" x2="' . ($cx + $capW / 2) . '" y2="' . $toY($whiskerHi) . '" stroke="#1f3a68" stroke-width="3"/>';
                                }
                                // Lower whisker stem + cap
                                if ($whiskerLo < $q1) {
                                    $svg .= '<line x1="' . $cx . '" y1="' . $toY($q1) . '" x2="' . $cx . '" y2="' . $toY($whiskerLo) . '" stroke="#1f3a68" stroke-width="3"/>';
                                    $svg .= '<line x1="' . ($cx - $capW / 2) . '" y1="' . $toY($whiskerLo) . '" x2="' . ($cx + $capW / 2) . '" y2="' . $toY($whiskerLo) . '" stroke="#1f3a68" stroke-width="3"/>';
                                }
                                // Box (Q1..Q3) — thicker border so the column reads bolder
                                // at the strip's narrow per-chart width (~16mm with 10 samples).
                                $boxTop = $toY($q3); $boxBot = $toY($q1);
                                $boxH = max($boxBot - $boxTop, 1);
                                $svg .= '<rect x="' . ($cx - $boxW / 2) . '" y="' . $boxTop . '" width="' . $boxW . '" height="' . $boxH . '" fill="white" stroke="#1f3a68" stroke-width="3.2"/>';
                                // Median line
                                $svg .= '<line x1="' . ($cx - $boxW / 2) . '" y1="' . $toY($q2) . '" x2="' . ($cx + $boxW / 2) . '" y2="' . $toY($q2) . '" stroke="#1f3a68" stroke-width="3.5"/>';
                                // Outliers — filled navy for stronger contrast against the page;
                                // open circles disappear at small chart widths.
                                foreach ($outliers as $o) {
                                    $svg .= '<circle cx="' . $cx . '" cy="' . $toY($o) . '" r="3" fill="#1f3a68" stroke="#1f3a68" stroke-width="1"/>';
                                }
                                // Participant dot — NIHE-style: solid coloured circle with
                                // the concordance glyph (✓ / ✗ / –) overlaid in white.
                                if ($partVal !== null && $partColor !== null) {
                                    $py = $toY($partVal);
                                    $r = 9;
                                    $svg .= '<circle cx="' . $cx . '" cy="' . $py . '" r="' . $r . '" fill="' . $partColor . '" stroke="' . $partColor . '" stroke-width="1"/>';
                                    if ($partGlyph !== null && $partGlyph !== '') {
                                        $svg .= '<text x="' . $cx . '" y="' . $py . '" dominant-baseline="central" text-anchor="middle" style="fill:#fff;font-family:helvetica;font-size:14pt;font-weight:bold">' . htmlspecialchars($partGlyph, ENT_QUOTES, 'UTF-8') . '</text>';
                                    }
                                }
                                // Sample label — solid black + bold for stronger legibility at strip scale
                                $svg .= '<text x="' . $cx . '" y="' . ($h - 14) . '" dominant-baseline="middle" text-anchor="middle" style="fill:#000;font-family:helvetica;font-size:16pt;font-weight:bold">' . htmlspecialchars($label, ENT_QUOTES) . '</text>';
                                $svg .= '</svg>';
                                return $svg;
                            };

                            $miniCharts = [];
                            $sampleIdx = 0;
                            foreach ($block['samples'] as $sid => $s) {
                                $vals = array_values(array_map('floatval', $s['numeric_values']));
                                if (count($vals) < 2) {
                                    continue;
                                }
                                $sampleLabel = $s['sample_label'] ?: ('S' . ($sampleIdx + 1));

                                $mine = $myResp[$position][$sid] ?? null;
                                $myNumeric = ($mine && isset($mine['numeric']) && $mine['numeric'] !== null) ? (float) $mine['numeric'] : null;
                                $verdict = $verdictPerSample[(int) $sid] ?? 'Not Evaluated';
                                $bucket = isset($pointSeriesMeta[$verdict]) ? $verdict : 'Not Evaluated';
                                $partColor = $myNumeric !== null ? $pointSeriesMeta[$bucket]['color'] : null;

                                $partGlyph = $myNumeric !== null ? $pointSeriesMeta[$bucket]['glyph'] : null;
                                $miniCharts[] = [
                                    'svg'   => $svgBox($vals, $myNumeric, $partColor, $partGlyph, $sampleLabel),
                                    'label' => $sampleLabel,
                                ];
                                $sampleIdx++;
                            }

                            // Render strip: N mini-charts side by side, then a shared legend row.
                            if (!empty($miniCharts)) {
                                $n = count($miniCharts);
                                $bodyW = $pdf->getPageWidth() - PDF_MARGIN_LEFT - PDF_MARGIN_RIGHT;
                                // Tighter gap when there are more samples in the strip — gives
                                // each chart ~1mm more breathing room at the 10-sample layout.
                                $gap = $n >= 8 ? 0.8 : 1.5;  // mm
                                $perW = ($bodyW - ($gap * ($n - 1))) / $n;
                                // Source SVG aspect ratio 300:380 (set in $svgBox defaults).
                                $imgH = $perW * (380 / 300);

                                // Page-break BEFORE the strip if it won't fit on the current page.
                                $stripTopY = $pdf->getY() + 2;
                                $pageH = $pdf->getPageHeight() - PDF_MARGIN_BOTTOM;
                                if ($stripTopY + $imgH + 10 > $pageH) {
                                    $pdf->AddPage();
                                    $stripTopY = $pdf->getY();
                                }

                                $xCursor = PDF_MARGIN_LEFT;
                                foreach ($miniCharts as $mc) {
                                    // '@' prefix tells TCPDF the source is a raw SVG string,
                                    // not a file path — matches the mtbept tb.phtml pattern.
                                    $pdf->ImageSVG('@' . $mc['svg'], $xCursor, $stripTopY, $perW, $imgH, '', '', '', 0, false);
                                    $xCursor += $perW + $gap;
                                }
                                $pdf->SetY($stripTopY + $imgH + 1);

                                // Shared NIHE-style legend — coloured filled circle (●) per
                                // category. Clustered in a single centred cell so the items
                                // read as one legend rather than evenly-spaced column captions
                                // under the chart strip above.
                                $legendItems = [];
                                foreach ($pointSeriesMeta as $meta) {
                                    $legendItems[] = '<span style="color:' . $meta['color'] . ';font-size:14px;">&#9679;</span>&nbsp;' . htmlspecialchars($meta['label'], ENT_QUOTES);
                                }
                                $legendHtml  = '<table cellpadding="0" style="width:100%;font-size:10px;"><tr><td style="vertical-align:middle;text-align:center;">';
                                $legendHtml .= implode('&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;', $legendItems);
                                $legendHtml .= '</td></tr></table>';
                                $pdf->writeHTML($legendHtml, true, false, true, false, '');
                                $pdf->Ln(2);
                            }
                        }
                    }
                }
            }
        }

        // ---- Recommendation for participant + Suggested corrective actions ----
        // NIHE template structure: two separate sections under the test results.
        //  - "Recommendation for participant"   — per-sample NIHE-catalogue text emitted
        //    by algoVietnam (deduplicated by recommendation text).
        //  - "Suggested corrective actions"     — same content but framed as actions to
        //    take. The algorithm currently emits a single text per outcome; until NIHE
        //    distinguishes the two, we render the same deduped recommendation here so
        //    the lab gets actionable guidance instead of an empty placeholder.
        $warnings = Pt_Commons_JsonUtility::safeDecode($result['failure_reason']);
        $grouped = [];
        if (!empty($warnings)) {
            foreach ($warnings as $warning) {
                $obs = is_array($warning) ? ($warning['warning'] ?? '') : (string) $warning;
                $rec = is_array($warning) ? ($warning['correctiveAction'] ?? '') : '';
                $key = $rec !== '' ? $rec : $obs;
                if (!isset($grouped[$key])) {
                    $grouped[$key] = ['rec' => $rec, 'obs' => []];
                }
                if ($obs !== '' && !in_array($obs, $grouped[$key]['obs'], true)) {
                    $grouped[$key]['obs'][] = $obs;
                }
            }
        }

        $renderFeedbackBlock = static function (string $heading, array $grouped, $pdf) {
            // Pre-measure the table so we page-break BEFORE the heading if the whole
            // block won't fit on the remaining page. Without this TCPDF page-breaks
            // mid-row and orphans a sample row on the next page (Sample 9, Sample 10
            // landed alone on page 3 in the field).
            $pageBottom = $pdf->getPageHeight() - PDF_MARGIN_BOTTOM;
            $bodyW = $pdf->getPageWidth() - PDF_MARGIN_LEFT - PDF_MARGIN_RIGHT;
            // Heading + ~2mm gap + header row + body rows. Estimate row height from
            // the longest observation cell (wrapped at 30% column width).
            $rowH = 7;  // mm — single-line row at font-size 11px
            $estimated = 6 + 2 + 7;  // heading + Ln + header row
            if (empty($grouped)) {
                $estimated += $rowH;
            } else {
                $cellW = $bodyW * 0.30;
                foreach ($grouped as $g) {
                    $obsText = implode(', ', $g['obs']);
                    $nLines = max(1, $pdf->getNumLines($obsText, $cellW));
                    $estimated += $nLines * $rowH;
                }
            }
            if ($pdf->getY() + $estimated > $pageBottom) {
                $pdf->AddPage();
            }

            $pdf->writeHTML('<br/><span style="font-weight:bold;font-size:12px;">' . Pt_Commons_TranslateUtility::safeTranslate($heading) . '</span>', true, false, true, false, '');
            $pdf->Ln(2);

            // valign="middle" HTML attribute alongside the CSS style — TCPDF honours
            // the HTML attribute more reliably when cells on the same row have very
            // different line counts (multi-sample list vs one-line recommendation).
            $tbl  = '<table border="1" style="font-size:11px;"><tr style="background-color:#dbe4ee;font-weight:bold;">'
                  . '<td valign="middle" style="vertical-align:middle;text-align:center;width:30%;">' . Pt_Commons_TranslateUtility::safeTranslate('Sample(s)') . '</td>'
                  . '<td valign="middle" style="vertical-align:middle;text-align:center;width:70%;">' . Pt_Commons_TranslateUtility::safeTranslate($heading) . '</td></tr>';
            if (empty($grouped)) {
                $tbl .= '<tr><td valign="middle" colspan="2" style="vertical-align:middle;text-align:center;">-</td></tr>';
            } else {
                foreach ($grouped as $g) {
                    $recText = $g['rec'] !== '' ? Pt_Commons_TranslateUtility::safeTranslate($g['rec']) : '';
                    $tbl .= '<tr nobr="true"><td valign="middle" style="vertical-align:middle;">' . implode(', ', $g['obs']) . '</td><td valign="middle" style="vertical-align:middle;">' . $recText . '</td></tr>';
                }
            }
            $tbl .= '</table>';
            $pdf->writeHTML($tbl, true, false, true, false, '');
        };

        $renderFeedbackBlock('Recommendation for participant', $grouped, $pdf);
        $renderFeedbackBlock('Suggested corrective actions', $grouped, $pdf);

        // ---- NIHE signature block ----
        // Static names per the NIHE Word templates. If the institute later needs
        // configurable signatories, the names can move to a `signatures` config key.
        $pdf->Ln(8);
        $sig = '<table cellpadding="4" style="font-size:11px;width:100%;">'
             . '<tr>'
             . '<td style="vertical-align:middle;text-align:center;width:50%;font-weight:bold;">' . Pt_Commons_TranslateUtility::safeTranslate('Scheme Coordinator') . '</td>'
             . '<td style="vertical-align:middle;text-align:center;width:50%;font-weight:bold;">' . Pt_Commons_TranslateUtility::safeTranslate('Director of program') . '</td>'
             . '</tr>'
             . '<tr><td style="vertical-align:middle;">&nbsp;</td><td style="vertical-align:middle;">&nbsp;</td></tr>'
             . '<tr><td style="vertical-align:middle;">&nbsp;</td><td style="vertical-align:middle;">&nbsp;</td></tr>'
             . '<tr><td style="vertical-align:middle;">&nbsp;</td><td style="vertical-align:middle;">&nbsp;</td></tr>'
             . '<tr>'
             . '<td style="vertical-align:middle;text-align:center;font-weight:bold;">PhD. Hoang Thi Thanh Ha</td>'
             . '<td style="vertical-align:middle;text-align:center;font-weight:bold;">Prof. PhD. Tran Nhu Duong</td>'
             . '</tr>'
             . '</table>';
        $pdf->writeHTML($sig, true, false, true, false, '');

        if (ob_get_contents()) {
            ob_end_clean();
        }

        // ---- output ----
        $nameParts = [];
        foreach (['shipment_code', 'unique_identifier', 'region', 'state', 'district', 'city'] as $key) {
            if (!empty($result[$key]) && strtoupper($result[$key]) != 'NULL') {
                $nameParts[] = ($key == 'shipment_code') ? $result[$key] : strtoupper($result[$key]);
            }
        }
        $fileName = Application_Service_Common::makeFileNameFriendly(implode('-', $nameParts) . '-' . $result['map_id']) . '.pdf';
        $filePath = $shipmentDir . DIRECTORY_SEPARATOR . $fileName;
        $pdf->Output($filePath, 'F');

        $loadpdf = Zend_Pdf::load($filePath);
        foreach ($loadpdf->pages as $page) {
            $pdfExtract = $extractor->clonePage($page);
            $pdfExtract->setFont($font, 8)->drawText('Page ' . $j . ' / ' . $totalPages, 280, 50);
            $pdfNew->pages[] = $pdfExtract;
        }
        $shipmentCode = $result['shipment_code'];
        $j++;
    }
}
