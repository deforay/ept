<?php

/**
 * Vietnam (NIHE) DTS HIV serology — SUMMARY report (one per panel tier).
 *
 * Structure mirrors the NIHE template
 * (~/Downloads/VIETNAM/1. HIV Serology _Summary _ NIHE template_09 Apr 2026.docx)
 * minus the cover page. Sections:
 *
 *   1. Participant performance overview
 *      1.1 Number of participants
 *      1.2 Participants with incorrect results (counts + IDs + per-sample concordance)
 *      1.3 List of test reagents not approved by MoH
 *          (r_testkitnames.attributes.moh_approved != 'yes')
 *   2. Result
 *      2.1 Proportion of participants by function    (group by r_network_tiers)
 *      2.2 Reporting time of participants            (<7d / 7-14d / >14d / no report)
 *      2.3 Proportion of testing method              (Rapid / ELISA / CLIA / Other)
 *      2.4 Test kit used for PT survey               (sorted desc by usage + Total)
 *      2.5 List of participants with discordant results (grouped by sample)
 *      2.6 Corrective Action overview                 (NIHE-catalogue feedback texts)
 *   3. Appendix Table A1 — Characterisation of Panel
 *          (shipment_attributes.panel_characterisation OR simplified fallback)
 *
 * Signature block (Scheme Coordinator / Director of program / static PhD names)
 * sits between the verdict pie and the EOR caption.
 *
 * Qualitative: no numeric score thresholds, no "Scoring >= 95" overview.
 * Top margin pinned to clear FpdiReport.Header()'s "All Participants Results Report"
 * line (default template-top-margin from DB collides with body otherwise).
 */

if ($resultArray['shipment'] != "") {

    if (!file_exists($reportsPath . DIRECTORY_SEPARATOR . $resultArray['shipment']['shipment_code']) && !is_dir($reportsPath . DIRECTORY_SEPARATOR . $resultArray['shipment']['shipment_code'])) {
        mkdir($reportsPath . DIRECTORY_SEPARATOR . $resultArray['shipment']['shipment_code'], 0777, true);
    }

    // Always use FpdiReport for Vietnam: that class carries the NIHE Header()
    // (logo + "NATIONAL HIV REFERENCE LABORATORY" block) and Footer()
    // (www.nihe.vn / Hotline / Panel ID / Page X of Y). When a report-format
    // letterhead PDF is configured AND on disk, Header() stamps it instead.
    $reportFormat = $reportService->getReportConfigValue('report-format');
    $pdf = new Pt_Reports_FpdiReport(PDF_PAGE_ORIENTATION, PDF_UNIT, PDF_PAGE_FORMAT, true, 'UTF-8', false);
    $pdf->setParams($resultStatus, $evalRow['date_finalised'], "", $watermark, "SUMMARY", $layout, $resultArray['shipment']['scheme_name']);

    $pdf->SetHeaderData(PDF_HEADER_LOGO, PDF_HEADER_LOGO_WIDTH, PDF_HEADER_TITLE, PDF_HEADER_STRING);
    $pdf->setHeaderFont(['freesans', '', PDF_FONT_SIZE_MAIN]);
    $pdf->setFooterFont(['freesans', '', PDF_FONT_SIZE_DATA]);
    $pdf->SetDefaultMonospacedFont(PDF_FONT_MONOSPACED);

    // Top margin clears either the stamped letterhead PDF (when configured) or the
    // in-code NIHE header (~26mm: 18mm logo + ~6mm address text + a small gap).
    $hasTemplate = !empty($reportFormat) && file_exists(UPLOAD_PATH . DIRECTORY_SEPARATOR . 'report-formats' . DIRECTORY_SEPARATOR . $reportFormat);
    $mt = $hasTemplate ? max(60, (int) ($templateTopMargin ?? 0) + 15) : 32;
    $pdf->SetMargins(PDF_MARGIN_LEFT, $mt, PDF_MARGIN_RIGHT);
    $pdf->SetHeaderMargin(PDF_MARGIN_HEADER);
    $pdf->SetFooterMargin(PDF_MARGIN_FOOTER);
    $pdf->SetAutoPageBreak(TRUE, PDF_MARGIN_BOTTOM);
    $pdf->setImageScale(PDF_IMAGE_SCALE_RATIO);

    $pdf->AddPage('P', 'A4');
    $pdf->SetFont('freesans', '', 12);

    $shipmentId = (int) $resultArray['shipment']['shipment_id'];
    $tierLabel = !empty($panelTestType) ? ucwords($panelTestType) : '';
    $db = Zend_Db_Table_Abstract::getDefaultAdapter();
    $tierClause = !empty($panelTestType)
        ? " AND JSON_EXTRACT(spm.attributes, '$.dts_test_panel_type') = " . $db->quote($panelTestType)
        : '';

    // -------- Title block (replaces NIHE cover page) --------
    $title = '<div style="text-align:center;">';
    $title .= '<span style="font-weight:bold;font-size:14px;">' . Pt_Commons_TranslateUtility::safeTranslate('PROFICIENCY TESTING PROGRAM – HIV SEROLOGY') . '</span><br/>';
    $title .= '<span style="font-weight:bold;font-size:12px;">' . Pt_Commons_TranslateUtility::safeTranslate('FINAL SUMMARY REPORT');
    if ($tierLabel !== '') {
        $title .= ' — ' . Pt_Commons_TranslateUtility::safeTranslate($tierLabel);
    }
    $title .= '</span></div><br/>';
    $pdf->writeHTML($title, true, false, true, false, '');

    if (!empty($resultArray['shipment']['referenceResult'])) {
        $panelInfo = '<table border="1" style="text-align:center;width:100%;font-size:12px;" align="center"><tr>';
        $panelInfo .= '<td style="vertical-align:middle;background-color:#dbe4ee;font-weight:bold;width:34%;">' . Pt_Commons_TranslateUtility::safeTranslate('Panel ID') . '</td>';
        $panelInfo .= '<td style="vertical-align:middle;background-color:#dbe4ee;font-weight:bold;width:33%;">' . Pt_Commons_TranslateUtility::safeTranslate('Shipment Date') . '</td>';
        $panelInfo .= '<td style="vertical-align:middle;background-color:#dbe4ee;font-weight:bold;width:33%;">' . Pt_Commons_TranslateUtility::safeTranslate('Result Due Date') . '</td>';
        $panelInfo .= '</tr><tr>';
        $panelInfo .= '<td style="vertical-align:middle;">' . $resultArray['shipment']['shipment_code'] . '</td>';
        $panelInfo .= '<td style="vertical-align:middle;">' . Pt_Commons_DateUtility::humanReadableDateFormat($resultArray['shipment']['shipment_date']) . '</td>';
        $panelInfo .= '<td style="vertical-align:middle;">' . Pt_Commons_DateUtility::humanReadableDateFormat($resultArray['shipment']['response_deadline']) . '</td>';
        $panelInfo .= '</tr></table><br/>';
        $pdf->writeHTML($panelInfo, true, false, true, false, '');
    }

    if (isset($resultArray['shipment']['summaryResult']) && count($resultArray['shipment']['summaryResult']) > 0) {
        $result = end($resultArray['shipment']['summaryResult']);
        reset($resultArray['shipment']['summaryResult']);

        $totalShipped = (int) ($participantPerformance['total_shipped'] ?? 0);
        $totalResponses = (int) ($participantPerformance['total_responses'] ?? 0);
        $notRespondedN = max(0, $totalShipped - $totalResponses);
        $acceptableCount = (int) ($participantPerformance['number_passed'] ?? 0);
        $unacceptableCount = (int) ($participantPerformance['number_failed'] ?? 0);
        $notEvaluatedCount = max(0, $totalResponses - $acceptableCount - $unacceptableCount);

        $pct = static function (int $n, int $total): string {
            return $total > 0 ? round(($n / $total) * 100, 2) . '%' : '-';
        };

        // ============================================================
        // 1. PARTICIPANT PERFORMANCE OVERVIEW
        // ============================================================
        $pdf->writeHTML('<span style="font-weight:bold;font-size:13px;">1. ' . Pt_Commons_TranslateUtility::safeTranslate('Participant Performance Overview') . '</span>', true, false, true, false, '');

        // -- 1.1 Number of participants --
        $pdf->writeHTML('<span style="font-weight:bold;font-size:12px;">1.1 ' . Pt_Commons_TranslateUtility::safeTranslate('Number of Participants') . '</span>', true, false, true, false, '');
        $numPart = '<table border="1" style="text-align:center;width:100%;font-size:12px;"><tr>';
        $numPart .= '<td style="vertical-align:middle;background-color:#dbe4ee;font-weight:bold;">' . Pt_Commons_TranslateUtility::safeTranslate('# of Participants') . '</td>';
        $numPart .= '<td style="vertical-align:middle;background-color:#dbe4ee;font-weight:bold;">' . Pt_Commons_TranslateUtility::safeTranslate('# of Responses') . '</td>';
        $numPart .= '<td style="vertical-align:middle;background-color:#dbe4ee;font-weight:bold;">' . Pt_Commons_TranslateUtility::safeTranslate('# of Not Responded') . '</td>';
        $numPart .= '<td style="vertical-align:middle;background-color:#dbe4ee;font-weight:bold;">' . Pt_Commons_TranslateUtility::safeTranslate('Acceptable') . ' / ' . Pt_Commons_TranslateUtility::safeTranslate('Unacceptable') . '</td>';
        $numPart .= '</tr><tr>';
        $numPart .= '<td style="vertical-align:middle;">' . $totalShipped . '</td>';
        $numPart .= '<td style="vertical-align:middle;">' . $totalResponses . '</td>';
        $numPart .= '<td style="vertical-align:middle;">' . $notRespondedN . '</td>';
        $numPart .= '<td style="vertical-align:middle;">' . $acceptableCount . ' / ' . $unacceptableCount . '</td>';
        $numPart .= '</tr></table><br/>';
        $pdf->writeHTML($numPart, true, false, true, false, '');

        // -- 1.2 Participants with incorrect results --
        $pdf->writeHTML('<span style="font-weight:bold;font-size:12px;">1.2 ' . Pt_Commons_TranslateUtility::safeTranslate('List of Participants with Incorrect Results') . '</span>', true, false, true, false, '');

        $incorrectIdsRows = $db->fetchAll(
            "SELECT p.unique_identifier
             FROM shipment_participant_map spm
             JOIN participant p ON p.participant_id = spm.participant_id
             WHERE spm.shipment_id = ?
               AND spm.final_result = 2
               AND spm.is_excluded != 'yes'
               $tierClause
             ORDER BY p.unique_identifier",
            $shipmentId
        );
        $incorrectIds = array_column($incorrectIdsRows, 'unique_identifier');
        $incorrectIdList = !empty($incorrectIds) ? implode(', ', $incorrectIds) : '—';

        $incTbl = '<table border="1" style="text-align:center;width:100%;font-size:12px;"><tr>';
        $incTbl .= '<td style="vertical-align:middle;background-color:#dbe4ee;font-weight:bold;width:14%;">' . Pt_Commons_TranslateUtility::safeTranslate('# of Participants') . '</td>';
        $incTbl .= '<td style="vertical-align:middle;background-color:#dbe4ee;font-weight:bold;width:18%;">' . Pt_Commons_TranslateUtility::safeTranslate('# had correct results (n / %)') . '</td>';
        $incTbl .= '<td style="vertical-align:middle;background-color:#dbe4ee;font-weight:bold;width:18%;">' . Pt_Commons_TranslateUtility::safeTranslate('# had incorrect results (n / %)') . '</td>';
        $incTbl .= '<td style="vertical-align:middle;background-color:#dbe4ee;font-weight:bold;width:50%;">' . Pt_Commons_TranslateUtility::safeTranslate('Participants with Incorrect Results') . '</td>';
        $incTbl .= '</tr><tr>';
        $incTbl .= '<td style="vertical-align:middle;">' . $totalResponses . '</td>';
        $incTbl .= '<td style="vertical-align:middle;">' . $acceptableCount . ' (' . $pct($acceptableCount, $totalResponses) . ')</td>';
        $incTbl .= '<td style="vertical-align:middle;">' . $unacceptableCount . ' (' . $pct($unacceptableCount, $totalResponses) . ')</td>';
        $incTbl .= '<td style="vertical-align:middle;text-align:left;font-size:11px;">' . $incorrectIdList . '</td>';
        $incTbl .= '</tr></table><br/>';
        $pdf->writeHTML($incTbl, true, false, true, false, '');

        // Per-sample concordance with reference
        $sampleCount = count($result['correctCount']);
        $sampleCode = '<table border="1" style="text-align:center;width:100%;font-size:12px;">';
        $sampleCode .= '<tr><td rowspan="2" style="vertical-align:middle;background-color:#dbe4ee;"></td>';
        $sampleCode .= '<td colspan="' . $sampleCount . '" style="vertical-align:middle;background-color:#dbe4ee;font-weight:bold;">' . Pt_Commons_TranslateUtility::safeTranslate('Sample ID') . '</td>';
        $sampleCode .= '<td rowspan="2" style="vertical-align:middle;background-color:#dbe4ee;font-weight:bold;">' . Pt_Commons_TranslateUtility::safeTranslate('Average') . '</td></tr>';
        $sampleCode .= '<tr>';
        foreach ($result['correctCount'] as $sample) {
            $sampleCode .= '<td style="vertical-align:middle;background-color:#dbe4ee;font-weight:bold;">' . $sample['sample_label'] . '</td>';
        }
        $sampleCode .= '</tr>';
        $sampleCode .= '<tr><td style="vertical-align:middle;background-color:#dbe4ee;font-weight:bold;">' . Pt_Commons_TranslateUtility::safeTranslate('Reference Result') . '</td>';

        $nonMandatorySamples = [];
        foreach ($resultArray['shipment']['referenceResult'] as $refRes) {
            if ($refRes['mandatory'] == 0) {
                $nonMandatorySamples[] = $refRes['sample_label'];
            }
            $sampleCode .= '<td style="vertical-align:middle;">' . ucfirst(strtolower($refRes['referenceResult'])) . '</td>';
        }
        $sampleCode .= '<td style="vertical-align:middle;"></td></tr>';
        $sampleCode .= '<tr><td style="vertical-align:middle;background-color:#BCD7EC;font-weight:bold;">' . Pt_Commons_TranslateUtility::safeTranslate('Correctly Reported') . '</td>';
        $sampAvg = 0;
        $sampPerAvg = 0;
        foreach ($result['correctCount'] as $sample) {
            $denom = (int) ($sample['number_responded'] ?? 0);
            $correct = (int) $sample['correctRes'];
            $rowPct = $denom > 0 ? round(($correct / $denom) * 100, 2) : 0;
            $sampAvg += $correct;
            $sampPerAvg += $rowPct;
            $sampleCode .= '<td style="vertical-align:middle;">' . $correct . '<br/>(' . $rowPct . '%)</td>';
        }
        $sampleCode .= '<td style="vertical-align:middle;">' . round($sampAvg / $sampleCount, 2) . '<br/>(' . round($sampPerAvg / $sampleCount, 2) . '%)</td>';
        $sampleCode .= '</tr></table><br/>';
        $pdf->writeHTML($sampleCode, true, false, true, false, '');

        if (!empty($nonMandatorySamples)) {
            $nmsTable = '<span style="font-size:11px;font-style:italic;">' . Pt_Commons_TranslateUtility::safeTranslate("The following samples have been excluded from this evaluation") . ': ' . implode(', ', $nonMandatorySamples) . '</span><br/><br/>';
            $pdf->writeHTML($nmsTable, true, false, true, false, '');
        }

        // -- 1.3 List of Test Reagents Not Approved by the Ministry of Health --
        // Lists kits used in this shipment whose r_testkitnames.pt_provider_validated is not
        // '1' (Yes). This "Is PT Provider Validated?" flag (formerly CountryAdapted) is the
        // one the Vietnam algorithm keys off, edited from Admin → Test Kits → Edit. Values:
        // 1 = Yes (approved), 0 = No, NULL = unset (treated as unapproved here so the
        // section flags kits whose status hasn't been declared).
        $pdf->writeHTML('<span style="font-weight:bold;font-size:12px;">1.3 ' . Pt_Commons_TranslateUtility::safeTranslate('List of Test Reagents Not Approved by the Ministry of Health') . '</span>', true, false, true, false, '');

        $unapprovedRows = $db->fetchAll(
            "SELECT rtk.TestKit_Name AS kit_name,
                    JSON_UNQUOTE(JSON_EXTRACT(rtk.attributes, '$.method')) AS method,
                    p.unique_identifier
             FROM shipment_participant_map spm
             JOIN response_result_dts rrd ON rrd.shipment_map_id = spm.map_id
             JOIN participant p ON p.participant_id = spm.participant_id
             JOIN r_testkitnames rtk
               ON rtk.TestKitName_ID IN (rrd.test_kit_name_1, rrd.test_kit_name_2, rrd.test_kit_name_3)
             WHERE spm.shipment_id = ?
               AND spm.is_excluded != 'yes'
               $tierClause
               AND (rtk.pt_provider_validated IS NULL OR rtk.pt_provider_validated <> 1)
             GROUP BY rtk.TestKitName_ID, p.unique_identifier
             ORDER BY rtk.TestKit_Name, p.unique_identifier",
            $shipmentId
        );

        if (!empty($unapprovedRows)) {
            $byKit = [];
            foreach ($unapprovedRows as $r) {
                $name = $r['kit_name'];
                if (!isset($byKit[$name])) {
                    $byKit[$name] = ['method' => $r['method'] ?? '', 'pids' => []];
                }
                if (!in_array($r['unique_identifier'], $byKit[$name]['pids'], true)) {
                    $byKit[$name]['pids'][] = $r['unique_identifier'];
                }
            }
            $uTbl  = '<table border="1" style="width:100%;font-size:12px;"><tr style="text-align:center;background-color:#dbe4ee;font-weight:bold;">';
            $uTbl .= '<td style="vertical-align:middle;width:6%;">' . Pt_Commons_TranslateUtility::safeTranslate('No') . '</td>';
            $uTbl .= '<td style="vertical-align:middle;width:48%;">' . Pt_Commons_TranslateUtility::safeTranslate('Reagent Name') . '</td>';
            $uTbl .= '<td style="vertical-align:middle;width:14%;">' . Pt_Commons_TranslateUtility::safeTranslate('Reagent Type') . '</td>';
            $uTbl .= '<td style="vertical-align:middle;width:32%;">' . Pt_Commons_TranslateUtility::safeTranslate('Participant ID') . '</td>';
            $uTbl .= '</tr>';
            $no = 1;
            foreach ($byKit as $kitName => $info) {
                $uTbl .= '<tr>';
                $uTbl .= '<td style="vertical-align:middle;text-align:center;">' . $no++ . '</td>';
                $uTbl .= '<td style="vertical-align:middle;text-align:left;">' . htmlspecialchars($kitName, ENT_QUOTES) . '</td>';
                $uTbl .= '<td style="vertical-align:middle;text-align:center;">' . htmlspecialchars((string) $info['method'], ENT_QUOTES) . '</td>';
                $uTbl .= '<td style="vertical-align:middle;text-align:left;font-size:11px;">' . htmlspecialchars(implode(', ', $info['pids']), ENT_QUOTES) . '</td>';
                $uTbl .= '</tr>';
            }
            $uTbl .= '</table><br/>';
            $pdf->writeHTML($uTbl, true, false, true, false, '');
        } else {
            $pdf->writeHTML('<span style="font-size:11px;font-style:italic;">' . Pt_Commons_TranslateUtility::safeTranslate('All reagents used by participants are approved.') . '</span><br/><br/>', true, false, true, false, '');
        }

        // ============================================================
        // 2. RESULT
        // ============================================================
        $pdf->AddPage();
        $pdf->writeHTML('<span style="font-weight:bold;font-size:13px;">2. ' . Pt_Commons_TranslateUtility::safeTranslate('Result') . '</span>', true, false, true, false, '');

        // -- 2.1 Proportion of participants by function --
        // Uses participant.network_tier (FK to r_network_tiers.network_name). For
        // Vietnam installs, the r_network_tiers rows are reseeded with NIHE's
        // function categories (National hospital / CDC / Military / Research / etc.)
        $functionRows = $db->fetchAll(
            "SELECT COALESCE(NULLIF(TRIM(nt.network_name), ''), 'Other') AS fn,
                    COUNT(DISTINCT spm.participant_id) AS n
             FROM shipment_participant_map spm
             JOIN participant p ON p.participant_id = spm.participant_id
             LEFT JOIN r_network_tiers nt ON nt.network_id = p.network_tier
             WHERE spm.shipment_id = ? AND spm.is_excluded != 'yes' $tierClause
             GROUP BY fn ORDER BY n DESC",
            $shipmentId
        );
        $totalForFunction = 0;
        foreach ($functionRows as $r) {
            $totalForFunction += (int) $r['n'];
        }
        if ($totalForFunction > 0) {
            $pdf->writeHTML('<span style="font-weight:bold;font-size:12px;">2.1 ' . Pt_Commons_TranslateUtility::safeTranslate('Proportion of Participants by Function') . '</span>', true, false, true, false, '');
            $palette = ['#3B82F6', '#F97316', '#10B981', '#F59E0B', '#8B5CF6', '#EC4899', '#14B8A6', '#EF4444', '#A3A3A3'];
            $sliceData = $sliceLabels = $sliceColors = [];
            foreach ($functionRows as $i => $r) {
                $n = (int) $r['n'];
                $sliceData[]   = number_format(($n / $totalForFunction) * 100, 2);
                $sliceLabels[] = $r['fn'] . ' (n=' . $n . ')';
                $sliceColors[] = $palette[$i % count($palette)];
            }
            $outputDir = $reportsPath . DIRECTORY_SEPARATOR . $resultArray['shipment']['shipment_code'];
            $fnChartPath = Pt_Reports_ChartService::render([
                'type'   => 'pie',
                'width'  => 700, 'height' => 420,
                'filename' => 'functionPie',
                'title'  => Pt_Commons_TranslateUtility::safeTranslate('The proportion of participants by their function'),
                'slices' => ['data' => $sliceData, 'labels' => $sliceLabels, 'colors' => $sliceColors],
                'legend' => ['position' => 'right'],
            ], $outputDir);
            $chartW = $pdf->getPageWidth() - PDF_MARGIN_LEFT - PDF_MARGIN_RIGHT;
            $imgW = $chartW * 0.7;
            $imgX = PDF_MARGIN_LEFT + ($chartW - $imgW) / 2;
            $imgY = $pdf->getY() + 2;
            [$pw, $ph] = getimagesize($fnChartPath);
            $imgH = ($ph / $pw) * $imgW;
            $pdf->Image($fnChartPath, $imgX, $imgY, $imgW, 0, '', '', '', false, 300);
            $pdf->SetY($imgY + $imgH + 4);
            if (file_exists($fnChartPath)) { unlink($fnChartPath); }
        }

        // -- 2.2 Reporting time of participants --
        // Bucket the gap between shipment_date and the participant's responseDate.
        // shipment_test_date is on shipment_participant_map (the day the lab tested
        // the panel). DATEDIFF(test_date - shipment_date) — null when the lab never
        // submitted a response.
        $reportingRows = $db->fetchAll(
            "SELECT spm.map_id,
                    DATEDIFF(DATE(spm.shipment_test_date), DATE(s.shipment_date)) AS days
             FROM shipment_participant_map spm
             JOIN shipment s ON s.shipment_id = spm.shipment_id
             WHERE spm.shipment_id = ? AND spm.is_excluded != 'yes' $tierClause",
            $shipmentId
        );
        if (!empty($reportingRows)) {
            $buckets = ['<7 days' => 0, '7-14 days' => 0, '>14 days' => 0, 'No sent report' => 0];
            foreach ($reportingRows as $r) {
                $d = $r['days'];
                if ($d === null || $d === '') {
                    $buckets['No sent report']++;
                } elseif ((int) $d < 7) {
                    $buckets['<7 days']++;
                } elseif ((int) $d <= 14) {
                    $buckets['7-14 days']++;
                } else {
                    $buckets['>14 days']++;
                }
            }
            $totalRT = array_sum($buckets);
            if ($totalRT > 0) {
                $pdf->writeHTML('<span style="font-weight:bold;font-size:12px;">2.2 ' . Pt_Commons_TranslateUtility::safeTranslate('Reporting Time of Participants') . '</span>', true, false, true, false, '');
                $rtData = $rtLabels = [];
                foreach ($buckets as $label => $n) {
                    $rtData[]   = $totalRT > 0 ? round(($n / $totalRT) * 100, 2) : 0;
                    $rtLabels[] = Pt_Commons_TranslateUtility::safeTranslate($label);
                }
                $outputDir = $reportsPath . DIRECTORY_SEPARATOR . $resultArray['shipment']['shipment_code'];
                $rtChartPath = Pt_Reports_ChartService::render([
                    'type'  => 'bar',
                    'width' => 700, 'height' => 380,
                    'filename' => 'reportingTime',
                    'title' => Pt_Commons_TranslateUtility::safeTranslate('The reporting time of participant'),
                    'xAxis' => ['labels' => $rtLabels],
                    'yAxis' => ['title'  => '%'],
                    'datasets' => [['data' => $rtData, 'colors' => ['#F97316', '#3B82F6', '#FBBF24', '#10B981']]],
                ], $outputDir);
                $chartW = $pdf->getPageWidth() - PDF_MARGIN_LEFT - PDF_MARGIN_RIGHT;
                $imgW = $chartW * 0.7;
                $imgX = PDF_MARGIN_LEFT + ($chartW - $imgW) / 2;
                $imgY = $pdf->getY() + 2;
                [$pw, $ph] = getimagesize($rtChartPath);
                $imgH = ($ph / $pw) * $imgW;
                $pdf->Image($rtChartPath, $imgX, $imgY, $imgW, 0, '', '', '', false, 300);
                $pdf->SetY($imgY + $imgH + 4);
                if (file_exists($rtChartPath)) { unlink($rtChartPath); }
            }
        }

        // -- 2.3 Proportion of Testing Method --
        // Derives method from kit attributes: additional_info=yes → ELISA/CLIA bucket,
        // additional_info!=yes → Rapid. If attributes.method is explicitly set on the
        // kit (e.g. 'CLIA', 'ELISA'), that label is used instead so CLIA and ELISA can
        // be distinguished.
        $methodRows = $db->fetchAll(
            "SELECT rtk.TestKitName_ID AS kit_id,
                    JSON_UNQUOTE(JSON_EXTRACT(rtk.attributes, '$.method')) AS method_attr,
                    JSON_UNQUOTE(JSON_EXTRACT(rtk.attributes, '$.additional_info')) AS additional_info,
                    COUNT(DISTINCT spm.map_id) AS n
             FROM shipment_participant_map spm
             JOIN response_result_dts rrd ON rrd.shipment_map_id = spm.map_id
             JOIN r_testkitnames rtk
               ON rtk.TestKitName_ID IN (rrd.test_kit_name_1, rrd.test_kit_name_2, rrd.test_kit_name_3)
             WHERE spm.shipment_id = ? AND spm.is_excluded != 'yes' $tierClause
             GROUP BY rtk.TestKitName_ID",
            $shipmentId
        );
        $methodBuckets = ['Rapid test' => 0, 'ELISA' => 0, 'CLIA' => 0, 'Other' => 0];
        foreach ($methodRows as $r) {
            $attr = strtolower(trim((string) ($r['method_attr'] ?? '')));
            $hasNumeric = (strtolower((string) ($r['additional_info'] ?? '')) === 'yes');
            if ($attr === 'rapid' || $attr === 'rapid test') {
                $bucket = 'Rapid test';
            } elseif ($attr === 'elisa') {
                $bucket = 'ELISA';
            } elseif ($attr === 'clia' || $attr === 'eclia') {
                $bucket = 'CLIA';
            } elseif ($hasNumeric) {
                $bucket = 'ELISA';
            } else {
                $bucket = 'Rapid test';
            }
            $methodBuckets[$bucket] += (int) $r['n'];
        }
        $totalMethod = array_sum($methodBuckets);
        if ($totalMethod > 0) {
            $pdf->writeHTML('<span style="font-weight:bold;font-size:12px;">2.3 ' . Pt_Commons_TranslateUtility::safeTranslate('Proportion of Testing Method') . '</span>', true, false, true, false, '');
            $mData = $mLabels = $mColors = [];
            $mPalette = ['Rapid test' => '#3B82F6', 'ELISA' => '#F97316', 'CLIA' => '#10B981', 'Other' => '#FBBF24'];
            foreach ($methodBuckets as $label => $n) {
                if ($n <= 0) { continue; }
                $mData[]   = round(($n / $totalMethod) * 100, 2);
                $mLabels[] = Pt_Commons_TranslateUtility::safeTranslate($label) . ' (' . round(($n / $totalMethod) * 100, 1) . '%)';
                $mColors[] = $mPalette[$label];
            }
            $outputDir = $reportsPath . DIRECTORY_SEPARATOR . $resultArray['shipment']['shipment_code'];
            $methodChartPath = Pt_Reports_ChartService::render([
                'type'   => 'pie',
                'width'  => 700, 'height' => 420,
                'filename' => 'methodPie',
                'title'  => Pt_Commons_TranslateUtility::safeTranslate('The Proportion of participant by different methods'),
                'slices' => ['data' => $mData, 'labels' => $mLabels, 'colors' => $mColors],
                'legend' => ['position' => 'left'],
            ], $outputDir);
            $chartW = $pdf->getPageWidth() - PDF_MARGIN_LEFT - PDF_MARGIN_RIGHT;
            $imgW = $chartW * 0.7;
            $imgX = PDF_MARGIN_LEFT + ($chartW - $imgW) / 2;
            $imgY = $pdf->getY() + 2;
            [$pw, $ph] = getimagesize($methodChartPath);
            $imgH = ($ph / $pw) * $imgW;
            $pdf->Image($methodChartPath, $imgX, $imgY, $imgW, 0, '', '', '', false, 300);
            $pdf->SetY($imgY + $imgH + 4);
            if (file_exists($methodChartPath)) { unlink($methodChartPath); }
        }

        // -- 2.4 Test kit used for PT survey (NIHE 2.4) --
        $pdf->writeHTML('<span style="font-weight:bold;font-size:12px;">2.4 ' . Pt_Commons_TranslateUtility::safeTranslate('Test Kit used for PT Survey') . '</span>', true, false, true, false, '');

        $kitUsage = [];
        foreach (['pieChart', 'pieChart2', 'pieChart3'] as $key) {
            if (!empty($resultArray['shipment'][$key])) {
                $countKey = ['pieChart' => 'testkit1Total', 'pieChart2' => 'testkit2Total', 'pieChart3' => 'testkit3Total'][$key];
                foreach ($resultArray['shipment'][$key] as $row) {
                    $name = trim((string) ($row['TestKit_Name'] ?? ''));
                    if ($name === '') {
                        continue;
                    }
                    $kitUsage[$name] = ($kitUsage[$name] ?? 0) + (int) ($row[$countKey] ?? 0);
                }
            }
        }
        arsort($kitUsage);
        $kitUsageTotal = array_sum($kitUsage);

        if (!empty($kitUsage)) {
            $kitTbl = '<table border="1" style="width:100%;font-size:12px;"><tr style="text-align:center;background-color:#dbe4ee;font-weight:bold;">';
            $kitTbl .= '<td style="vertical-align:middle;width:8%;">' . Pt_Commons_TranslateUtility::safeTranslate('No') . '</td>';
            $kitTbl .= '<td style="vertical-align:middle;width:62%;">' . Pt_Commons_TranslateUtility::safeTranslate('Reagent Name') . '</td>';
            $kitTbl .= '<td style="vertical-align:middle;width:15%;">' . Pt_Commons_TranslateUtility::safeTranslate('# of Participants Using') . '</td>';
            $kitTbl .= '<td style="vertical-align:middle;width:15%;">' . Pt_Commons_TranslateUtility::safeTranslate('%') . '</td>';
            $kitTbl .= '</tr>';
            $no = 1;
            foreach ($kitUsage as $kitName => $count) {
                $pctVal = $kitUsageTotal > 0 ? round(($count / $kitUsageTotal) * 100, 2) : 0;
                $kitTbl .= '<tr>';
                $kitTbl .= '<td style="vertical-align:middle;text-align:center;">' . $no++ . '</td>';
                $kitTbl .= '<td style="vertical-align:middle;text-align:left;">' . htmlspecialchars($kitName, ENT_QUOTES) . '</td>';
                $kitTbl .= '<td style="vertical-align:middle;text-align:center;">' . $count . '</td>';
                $kitTbl .= '<td style="vertical-align:middle;text-align:center;">' . $pctVal . '%</td>';
                $kitTbl .= '</tr>';
            }
            $kitTbl .= '<tr style="font-weight:bold;background-color:#f6f6f6;">';
            $kitTbl .= '<td colspan="2" style="vertical-align:middle;text-align:right;">' . Pt_Commons_TranslateUtility::safeTranslate('Total') . '</td>';
            $kitTbl .= '<td style="vertical-align:middle;text-align:center;">' . $kitUsageTotal . '</td>';
            $kitTbl .= '<td style="vertical-align:middle;text-align:center;">100%</td>';
            $kitTbl .= '</tr></table><br/>';
            $pdf->writeHTML($kitTbl, true, false, true, false, '');
        } else {
            $pdf->writeHTML('<span style="font-size:11px;font-style:italic;">' . Pt_Commons_TranslateUtility::safeTranslate('No test kit usage data') . '</span><br/><br/>', true, false, true, false, '');
        }

        // -- 2.5 Discordant results grouped by sample (NIHE 2.5) --
        $pdf->writeHTML('<span style="font-weight:bold;font-size:12px;">2.5 ' . Pt_Commons_TranslateUtility::safeTranslate('List of Participants with Discordant Results') . '</span>', true, false, true, false, '');

        $resultLabels = [];
        foreach ($db->fetchAll("SELECT id, response FROM r_possibleresult WHERE scheme_sub_group IN ('DTS_TEST','DTS_FINAL')") as $r) {
            $resultLabels[(int) $r['id']] = ucfirst(strtolower($r['response']));
        }

        $discordantRows = $db->fetchAll(
            "SELECT rs.sample_label, rs.sample_id, rs.reference_result, rrd.reported_result, p.unique_identifier
             FROM shipment_participant_map spm
             JOIN response_result_dts rrd ON rrd.shipment_map_id = spm.map_id
             JOIN reference_result_dts rs ON rs.shipment_id = spm.shipment_id AND rs.sample_id = rrd.sample_id
             JOIN participant p ON p.participant_id = spm.participant_id
             WHERE spm.shipment_id = ?
               AND rrd.calculated_score = 'Fail'
               AND spm.is_excluded != 'yes'
               $tierClause
             ORDER BY rs.sample_id, rrd.reported_result, p.unique_identifier",
            $shipmentId
        );

        if (!empty($discordantRows)) {
            $grouped = [];
            foreach ($discordantRows as $r) {
                $key = $r['sample_id'] . '|' . $r['reported_result'] . '|' . $r['reference_result'];
                if (!isset($grouped[$key])) {
                    $grouped[$key] = [
                        'sample_label' => $r['sample_label'],
                        'reference' => $resultLabels[(int) $r['reference_result']] ?? '-',
                        'reported' => $resultLabels[(int) $r['reported_result']] ?? '-',
                        'participants' => [],
                    ];
                }
                $grouped[$key]['participants'][] = $r['unique_identifier'];
            }

            $discTbl = '<table border="1" style="width:100%;font-size:12px;"><tr style="text-align:center;background-color:#dbe4ee;font-weight:bold;">';
            $discTbl .= '<td style="vertical-align:middle;width:6%;">' . Pt_Commons_TranslateUtility::safeTranslate('No') . '</td>';
            $discTbl .= '<td style="vertical-align:middle;width:18%;">' . Pt_Commons_TranslateUtility::safeTranslate('Sample ID') . '</td>';
            $discTbl .= '<td style="vertical-align:middle;width:16%;">' . Pt_Commons_TranslateUtility::safeTranslate('Reference Result') . '</td>';
            $discTbl .= '<td style="vertical-align:middle;width:16%;">' . Pt_Commons_TranslateUtility::safeTranslate('Reported Result') . '</td>';
            $discTbl .= '<td style="vertical-align:middle;width:44%;">' . Pt_Commons_TranslateUtility::safeTranslate('Participant IDs') . '</td>';
            $discTbl .= '</tr>';
            $no = 1;
            foreach ($grouped as $row) {
                $discTbl .= '<tr>';
                $discTbl .= '<td style="vertical-align:middle;text-align:center;">' . $no++ . '</td>';
                $discTbl .= '<td style="vertical-align:middle;text-align:center;">' . htmlspecialchars($row['sample_label'], ENT_QUOTES) . '</td>';
                $discTbl .= '<td style="vertical-align:middle;text-align:center;">' . htmlspecialchars($row['reference'], ENT_QUOTES) . '</td>';
                $discTbl .= '<td style="vertical-align:middle;text-align:center;">' . htmlspecialchars($row['reported'], ENT_QUOTES) . '</td>';
                $discTbl .= '<td style="vertical-align:middle;text-align:left;font-size:11px;">' . htmlspecialchars(implode(', ', $row['participants']), ENT_QUOTES) . '</td>';
                $discTbl .= '</tr>';
            }
            $discTbl .= '</table><br/>';
            $pdf->writeHTML($discTbl, true, false, true, false, '');
        } else {
            $pdf->writeHTML('<span style="font-size:11px;font-style:italic;">' . Pt_Commons_TranslateUtility::safeTranslate('No discordant results') . '</span><br/><br/>', true, false, true, false, '');
        }

        // -------- Corrective Action overview (carries NIHE feedback texts) --------
        if (!empty($correctivenessArray)) {
            $pdf->writeHTML('<span style="font-weight:bold;font-size:12px;">2.6 ' . Pt_Commons_TranslateUtility::safeTranslate('Corrective Action Overview') . '</span>', true, false, true, false, '');
            $ca = '<table border="1" style="width:100%;font-size:12px;"><tr style="text-align:center;background-color:#dbe4ee;font-weight:bold;">';
            $ca .= '<td style="vertical-align:middle;width:75%;">' . Pt_Commons_TranslateUtility::safeTranslate('Corrective Action') . '</td>';
            $ca .= '<td style="vertical-align:middle;width:25%;">' . Pt_Commons_TranslateUtility::safeTranslate('Responses having Corrective Action') . '</td></tr>';
            foreach ($correctivenessArray as $correctiveness) {
                $ca .= '<tr>';
                $ca .= '<td style="vertical-align:middle;text-align:left;">' . Pt_Commons_TranslateUtility::safeTranslate($correctiveness['corrective_action']) . '</td>';
                $ca .= '<td style="vertical-align:middle;text-align:center;">' . $correctiveness['total_corrective'] . '</td>';
                $ca .= '</tr>';
            }
            $ca .= '</table><br/>';
            $pdf->writeHTML($ca, true, false, true, false, '');
        }

        // ============================================================
        // 3. APPENDIX — Table A1: Characterisation of Panel
        // ============================================================
        // Reads from the existing DTS reference-result modal tables on the shipment
        // edit page:
        //   reference_dts_eia          — EIA assays (one kit + OD/cutoff per row)
        //   reference_dts_wb           — Western Blot (one row per sample, banded)
        //   reference_dts_rapid_hiv    — Rapid HIV kits (one kit + result per row)
        //   reference_dts_geenius      — Geenius supplemental assay (one row per sample)
        // Conclusion comes from reference_result_dts.reference_result.
        // Columns rendered are the distinct kits actually used in this shipment, so
        // a shipment characterised on Elecsys + 3 rapid kits + WB produces 5 result
        // columns. Samples with no entries against a kit show '-'.
        $pdf->AddPage();
        $pdf->writeHTML('<span style="font-weight:bold;font-size:13px;">3. ' . Pt_Commons_TranslateUtility::safeTranslate('Appendix') . '</span>', true, false, true, false, '');
        $pdf->writeHTML('<span style="font-weight:bold;font-size:12px;">' . Pt_Commons_TranslateUtility::safeTranslate('Table A1: Characterisation of Panel') . ' ' . htmlspecialchars($resultArray['shipment']['shipment_code'], ENT_QUOTES) . ' ' . Pt_Commons_TranslateUtility::safeTranslate('when testing for HIV serology') . '</span>', true, false, true, false, '');
        $pdf->Ln(2);

        $kitNameLookup = [];
        foreach ($db->fetchAll($db->select()->from('r_testkitnames', ['TestKitName_ID', 'TestKit_Name'])) as $kr) {
            $kitNameLookup[(string) $kr['TestKitName_ID']] = $kr['TestKit_Name'];
        }
        // reference_dts_eia.eia is FK to r_dbs_eia.eia_id (the admin EIA dropdown
        // lists r_dbs_eia, NOT r_testkitnames). Resolve EIA names from there.
        $eiaNameLookup = [];
        foreach ($db->fetchAll($db->select()->from('r_dbs_eia', ['eia_id', 'eia_name'])) as $er) {
            $eiaNameLookup[(string) $er['eia_id']] = $er['eia_name'];
        }
        $resultCodeLookup = [];
        foreach ($db->fetchAll($db->select()->from('r_possibleresult', ['id', 'response', 'result_code'])) as $pr) {
            $resultCodeLookup[(string) $pr['id']] = [
                'response' => $pr['response'],
                'code'     => strtoupper((string) $pr['result_code']),
            ];
        }
        $rapidSymbol = static function (string $rid) use ($resultCodeLookup): string {
            if ($rid === '' || !isset($resultCodeLookup[$rid])) {
                return '-';
            }
            $code = $resultCodeLookup[$rid]['code'];
            return match (true) {
                in_array($code, ['R', 'WR', 'P'], true)  => '+',
                in_array($code, ['NR', 'N'], true)       => '-',
                default                                  => ucfirst(strtolower($resultCodeLookup[$rid]['response'])),
            };
        };
        $finalLabel = static function (string $rid) use ($resultCodeLookup): string {
            if ($rid === '' || !isset($resultCodeLookup[$rid])) {
                return '-';
            }
            return ucfirst(strtolower($resultCodeLookup[$rid]['response']));
        };

        $eiaRows = $db->fetchAll(
            "SELECT sample_id, eia, od, cutoff, result FROM reference_dts_eia
             WHERE shipment_id = ? ORDER BY sample_id, id",
            $shipmentId
        );
        $rapidRows = $db->fetchAll(
            "SELECT sample_id, testkit, result FROM reference_dts_rapid_hiv
             WHERE shipment_id = ? ORDER BY sample_id, id",
            $shipmentId
        );
        $wbRows = $db->fetchAll(
            "SELECT sample_id, result FROM reference_dts_wb
             WHERE shipment_id = ? ORDER BY sample_id, id",
            $shipmentId
        );
        $geeniusRows = $db->fetchAll(
            "SELECT sample_id, result FROM reference_dts_geenius
             WHERE shipment_id = ? ORDER BY sample_id, id",
            $shipmentId
        );

        // Discover the distinct columns actually used in this shipment.
        $eiaKitIds = [];
        foreach ($eiaRows as $r) { $eiaKitIds[(string) $r['eia']] = true; }
        $eiaKitIds = array_keys($eiaKitIds);
        $rapidKitIds = [];
        foreach ($rapidRows as $r) { $rapidKitIds[(string) $r['testkit']] = true; }
        $rapidKitIds = array_keys($rapidKitIds);
        $hasWb      = !empty($wbRows);
        $hasGeenius = !empty($geeniusRows);

        // Index per-sample for fast row assembly.
        $eiaBySample = [];
        foreach ($eiaRows as $r) {
            $eiaBySample[(int) $r['sample_id']][(string) $r['eia']] = $r;
        }
        $rapidBySample = [];
        foreach ($rapidRows as $r) {
            $rapidBySample[(int) $r['sample_id']][(string) $r['testkit']] = $r;
        }
        $wbBySample = [];
        foreach ($wbRows as $r) {
            $wbBySample[(int) $r['sample_id']] = $r;
        }
        $geeniusBySample = [];
        foreach ($geeniusRows as $r) {
            $geeniusBySample[(int) $r['sample_id']] = $r;
        }

        // The summary's $resultArray['shipment']['referenceResult'] is shaped for the
        // sample concordance table and omits sample_id + is_sample_diluted (see the
        // DTS branch of Application_Service_Evaluation::summaryReport). Re-fetch the
        // full sample row set so we can index the modal data per sample_id.
        $sampleRows = $db->fetchAll(
            "SELECT rrd.sample_id, rrd.sample_label, rrd.is_sample_diluted,
                    refpr.response AS reference_result
             FROM reference_result_dts rrd
             LEFT JOIN r_possibleresult refpr ON refpr.id = rrd.reference_result
             WHERE rrd.shipment_id = ? ORDER BY rrd.sample_id",
            $shipmentId
        );

        $haveCharacterisation = !empty($eiaRows) || !empty($rapidRows) || !empty($wbRows) || !empty($geeniusRows);

        if ($haveCharacterisation) {
            // Build header. Total non-conclusion result columns = #EIA + #Rapid + WB + Geenius.
            $resultColCount = count($eiaKitIds) + count($rapidKitIds) + ($hasWb ? 1 : 0) + ($hasGeenius ? 1 : 0);
            $nameW = 14;
            $typeW = 12;
            $conclW = 12;
            $colW = max(6, (int) floor((100 - $nameW - $typeW - $conclW - 4) / max(1, $resultColCount)));

            $tbl  = '<table border="1" cellpadding="2" style="width:100%;font-size:9px;">';
            $tbl .= '<tr style="background-color:#dbe4ee;text-align:center;font-weight:bold;">';
            $tbl .= '<td rowspan="2" style="vertical-align:middle;width:4%;">' . Pt_Commons_TranslateUtility::safeTranslate('No') . '</td>';
            $tbl .= '<td rowspan="2" style="vertical-align:middle;width:' . $nameW . '%;">' . Pt_Commons_TranslateUtility::safeTranslate('Sample ID') . '</td>';
            $tbl .= '<td rowspan="2" style="vertical-align:middle;width:' . $typeW . '%;">' . Pt_Commons_TranslateUtility::safeTranslate('Sample Type') . '</td>';
            $tbl .= '<td colspan="' . max(1, $resultColCount) . '" style="vertical-align:middle;">' . Pt_Commons_TranslateUtility::safeTranslate('Test result') . '</td>';
            $tbl .= '<td rowspan="2" style="vertical-align:middle;width:' . $conclW . '%;">' . Pt_Commons_TranslateUtility::safeTranslate('Conclusion') . '</td>';
            $tbl .= '</tr><tr style="background-color:#dbe4ee;text-align:center;font-weight:bold;">';
            foreach ($eiaKitIds as $kid) {
                $label = htmlspecialchars((string) ($eiaNameLookup[$kid] ?? $kid), ENT_QUOTES);
                $tbl .= '<td style="vertical-align:middle;width:' . $colW . '%;">' . $label . '<br/><span style="font-size:8px;">(OD/CO)</span></td>';
            }
            foreach ($rapidKitIds as $kid) {
                $label = htmlspecialchars((string) ($kitNameLookup[$kid] ?? $kid), ENT_QUOTES);
                $tbl .= '<td style="vertical-align:middle;width:' . $colW . '%;">' . $label . '</td>';
            }
            if ($hasWb) {
                $tbl .= '<td style="vertical-align:middle;width:' . $colW . '%;">' . Pt_Commons_TranslateUtility::safeTranslate('Western Blot') . '</td>';
            }
            if ($hasGeenius) {
                $tbl .= '<td style="vertical-align:middle;width:' . $colW . '%;">' . Pt_Commons_TranslateUtility::safeTranslate('Geenius') . '</td>';
            }
            $tbl .= '</tr>';

            $no = 1;
            foreach ($sampleRows as $refRes) {
                $sid = (int) ($refRes['sample_id'] ?? 0);
                $sampleType = (!empty($refRes['is_sample_diluted']) && strtolower((string) $refRes['is_sample_diluted']) === 'yes')
                    ? Pt_Commons_TranslateUtility::safeTranslate('Pooled diluted plasma')
                    : Pt_Commons_TranslateUtility::safeTranslate('Pooled plasma');
                $tbl .= '<tr style="text-align:center;">';
                $tbl .= '<td style="vertical-align:middle;">' . $no++ . '</td>';
                $tbl .= '<td style="vertical-align:middle;background-color:#f4f7fa;">' . htmlspecialchars((string) ($refRes['sample_label'] ?? ''), ENT_QUOTES) . '</td>';
                $tbl .= '<td style="vertical-align:middle;">' . $sampleType . '</td>';
                foreach ($eiaKitIds as $kid) {
                    $row = $eiaBySample[$sid][$kid] ?? null;
                    if ($row === null) {
                        $tbl .= '<td style="vertical-align:middle;">-</td>';
                    } else {
                        $od = trim((string) ($row['od'] ?? ''));
                        $co = trim((string) ($row['cutoff'] ?? ''));
                        $cell = $od !== '' ? $od : '-';
                        if ($od !== '' && $co !== '' && is_numeric($od) && is_numeric($co) && (float) $co > 0) {
                            $cell .= '<br/><span style="font-size:8px;">(' . round((float) $od / (float) $co, 2) . ')</span>';
                        }
                        $tbl .= '<td style="vertical-align:middle;">' . $cell . '</td>';
                    }
                }
                foreach ($rapidKitIds as $kid) {
                    $row = $rapidBySample[$sid][$kid] ?? null;
                    $tbl .= '<td style="vertical-align:middle;">' . ($row === null ? '-' : $rapidSymbol((string) ($row['result'] ?? ''))) . '</td>';
                }
                if ($hasWb) {
                    $tbl .= '<td style="vertical-align:middle;">' . ($wbBySample[$sid] === null || !isset($wbBySample[$sid]) ? '-' : $finalLabel((string) ($wbBySample[$sid]['result'] ?? ''))) . '</td>';
                }
                if ($hasGeenius) {
                    $tbl .= '<td style="vertical-align:middle;">' . (!isset($geeniusBySample[$sid]) ? '-' : $finalLabel((string) ($geeniusBySample[$sid]['result'] ?? ''))) . '</td>';
                }
                $tbl .= '<td style="vertical-align:middle;"><strong>' . ucfirst(strtolower((string) ($refRes['reference_result'] ?? ''))) . '</strong></td>';
                $tbl .= '</tr>';
            }
            $tbl .= '</table><br/>';
            $pdf->writeHTML($tbl, true, false, true, false, '');
        } else {
            // Fallback when no DTS reference modal data has been entered yet.
            $tbl  = '<table border="1" cellpadding="3" style="width:100%;font-size:11px;">';
            $tbl .= '<tr style="background-color:#dbe4ee;text-align:center;font-weight:bold;">';
            $tbl .= '<td style="vertical-align:middle;width:8%;">' . Pt_Commons_TranslateUtility::safeTranslate('No') . '</td>';
            $tbl .= '<td style="vertical-align:middle;width:32%;">' . Pt_Commons_TranslateUtility::safeTranslate('Sample ID') . '</td>';
            $tbl .= '<td style="vertical-align:middle;width:30%;">' . Pt_Commons_TranslateUtility::safeTranslate('Reference Result') . '</td>';
            $tbl .= '<td style="vertical-align:middle;width:30%;">' . Pt_Commons_TranslateUtility::safeTranslate('Mandatory') . '</td>';
            $tbl .= '</tr>';
            $no = 1;
            foreach ($resultArray['shipment']['referenceResult'] ?? [] as $refRes) {
                $tbl .= '<tr style="text-align:center;">';
                $tbl .= '<td style="vertical-align:middle;">' . $no++ . '</td>';
                $tbl .= '<td style="vertical-align:middle;">' . htmlspecialchars((string) ($refRes['sample_label'] ?? ''), ENT_QUOTES) . '</td>';
                $tbl .= '<td style="vertical-align:middle;">' . ucfirst(strtolower((string) ($refRes['referenceResult'] ?? ''))) . '</td>';
                $tbl .= '<td style="vertical-align:middle;">' . ((int) ($refRes['mandatory'] ?? 0) === 1 ? Pt_Commons_TranslateUtility::safeTranslate('Yes') : Pt_Commons_TranslateUtility::safeTranslate('No')) . '</td>';
                $tbl .= '</tr>';
            }
            $tbl .= '</table>';
            $tbl .= '<br/><span style="font-size:10px;font-style:italic;">' . Pt_Commons_TranslateUtility::safeTranslate('Panel characterisation not entered for this shipment. Use the per-sample Reference Results modal on the shipment edit page to record EIA / WB / Rapid HIV / Geenius results.') . '</span><br/>';
            $pdf->writeHTML($tbl, true, false, true, false, '');
        }

        // -------- Verdict pie chart --------
        if (isset($responseResult) && count($responseResult) > 0 && $responseResult != '') {
            $total = (int) ($responseResult["total_shipped"] ?? 0);
            $passedN = max(0, (int) ($responseResult["number_passed"] ?? 0));
            $failedN = max(0, (int) ($responseResult["number_failed"] ?? 0));
            $notRespondedChart = (int) ($responseResult["not_responded"] ?? 0);
            $excludedChart = abs(((int) ($responseResult["excluded"] ?? 0)) - $notRespondedChart);

            if ($total > 0 && ($passedN > 0 || $failedN > 0 || $notRespondedChart > 0 || $excludedChart > 0)) {
                $outputDir = $reportsPath . DIRECTORY_SEPARATOR . $responseResult["shipment_code"];
                $chartW = $pdf->getPageWidth() - PDF_MARGIN_LEFT - PDF_MARGIN_RIGHT;
                $pieChartTitle = Pt_Commons_TranslateUtility::safeTranslate("Shipment Participant Result Report") . ' (N=' . $total . ')';
                if ($tierLabel !== '') {
                    $pieChartTitle .= ' — ' . Pt_Commons_TranslateUtility::safeTranslate($tierLabel);
                }
                $performancePiechart = Pt_Reports_ChartService::render([
                    'type' => 'pie',
                    'width' => 700, 'height' => 400,
                    'filename' => 'performanceChart',
                    'title' => $pieChartTitle,
                    'slices' => [
                        'data' => [
                            number_format($passedN / $total * 100, 2),
                            number_format($failedN / $total * 100, 2),
                            number_format($notRespondedChart / $total * 100, 2),
                            number_format($excludedChart / $total * 100, 2),
                        ],
                        'labels' => [
                            Pt_Commons_TranslateUtility::safeTranslate('Acceptable') . ' (N=' . $passedN . ')',
                            Pt_Commons_TranslateUtility::safeTranslate('Unacceptable') . ' (N=' . $failedN . ')',
                            Pt_Commons_TranslateUtility::safeTranslate('Not Responded') . ' (N=' . $notRespondedChart . ')',
                            Pt_Commons_TranslateUtility::safeTranslate('Excluded') . ' (N=' . $excludedChart . ')',
                        ],
                        'colors' => ['#22C55E', '#DC3545', '#F59E0B', '#94A3B8'],
                    ],
                    'legend' => ['position' => 'bottom'],
                ], $outputDir);

                $pieW = $chartW * 0.5;
                $pieX = PDF_MARGIN_LEFT + ($chartW - $pieW) / 2;
                $pieY = $pdf->getY() + 3;
                [$pngW, $pngH] = getimagesize($performancePiechart);
                $pieDisplayH = ($pngH / $pngW) * $pieW;
                $pdf->Image($performancePiechart, $pieX, $pieY, $pieW, 0, '', '', '', false, 300);
                $pdf->SetY($pieY + $pieDisplayH + 4);
                if (file_exists($performancePiechart)) {
                    unlink($performancePiechart);
                }
            }
        }

        // ---- NIHE signature block ----
        // Mirrors the cover-page signatories from the NIHE Word template. Names are
        // static here; move to a configurable signature key when other Vietnam
        // institutions need to override.
        $pdf->Ln(10);
        $sig  = '<table cellpadding="4" style="width:100%;font-size:11px;">';
        $sig .= '<tr>'
              . '<td style="vertical-align:middle;text-align:center;width:50%;font-weight:bold;">' . Pt_Commons_TranslateUtility::safeTranslate('Scheme Coordinator') . '</td>'
              . '<td style="vertical-align:middle;text-align:center;width:50%;font-weight:bold;">' . Pt_Commons_TranslateUtility::safeTranslate('Director of program') . '</td>'
              . '</tr>'
              . '<tr><td style="vertical-align:middle;">&nbsp;</td><td style="vertical-align:middle;">&nbsp;</td></tr>'
              . '<tr><td style="vertical-align:middle;">&nbsp;</td><td style="vertical-align:middle;">&nbsp;</td></tr>'
              . '<tr><td style="vertical-align:middle;">&nbsp;</td><td style="vertical-align:middle;">&nbsp;</td></tr>'
              . '<tr>'
              . '<td style="vertical-align:middle;text-align:center;font-weight:bold;">PhD. Hoang Thi Thanh Ha</td>'
              . '<td style="vertical-align:middle;text-align:center;font-weight:bold;">Prof. PhD. Tran Nhu Duong</td>'
              . '</tr></table>';
        $pdf->writeHTML($sig, true, false, true, false, '');

        // Keep the EOR caption on the chart's page. TCPDF auto-page-breaks the
        // writeHTML line if the cursor is anywhere near the bottom margin (the
        // centered line gets pessimistically measured), even when it would visually
        // fit. Disable auto-break and clamp the cursor into safe territory before
        // emitting the line.
        $pdf->SetAutoPageBreak(false);
        $maxY = $pdf->getPageHeight() - PDF_MARGIN_BOTTOM - 8;
        if ($pdf->getY() > $maxY) {
            $pdf->SetY($maxY);
        } else {
            $pdf->Ln(3);
        }
        $pdf->writeHTML('<span style="text-align:center;font-weight:bold;font-size:11px;">-- ' . Pt_Commons_TranslateUtility::safeTranslate('END OF REPORT') . ' --</span>', true, false, true, false, '');
        $pdf->SetAutoPageBreak(true, PDF_MARGIN_BOTTOM);
    } else {
        $pdf->writeHTML('<br><br><br><span style="font-weight:bold;text-align:center;">' . Pt_Commons_TranslateUtility::safeTranslate('No participants') . '</span>', true, false, true, false, '');
    }

    if (!empty($panelTestType) && $panelTestType != '') {
        $panelTestType = "-" . $panelTestType;
    }
    $fileName = $resultArray['shipment']['shipment_code'] . $panelTestType . "-summary.pdf";
    $filePath = $reportsPath . DIRECTORY_SEPARATOR . $resultArray['shipment']['shipment_code'] . DIRECTORY_SEPARATOR . $fileName;
    $pdf->Output($filePath, "F");
    if ($trainingInstance == "yes") {
        $pdf = new Pt_Reports_PdfRotate();
    }
}
