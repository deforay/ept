<!DOCTYPE html>
<html lang="en">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><?= $this->translate->_('Something went wrong'); ?> · ePT</title>
    <style>
        body {
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            color: #2d3748;
            background: #f7fafc;
        }
        .ept-err { max-width: 720px; margin: 64px auto; padding: 0 20px; }
        .ept-err__card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            padding: 40px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
            text-align: center;
        }
        .ept-err__badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: #fff5f5;
            color: #c53030;
            font-size: 30px;
            font-weight: 600;
            margin-bottom: 18px;
        }
        .ept-err__code {
            display: inline-block;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: #c53030;
            background: #fff5f5;
            padding: 4px 10px;
            border-radius: 999px;
            margin-bottom: 14px;
        }
        .ept-err__title { font-size: 26px; font-weight: 600; color: #1a202c; margin: 0 0 10px; }
        .ept-err__sub { font-size: 14.5px; color: #4a5568; line-height: 1.55; margin: 0 0 24px; }
        .ept-err__actions { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
        .ept-err__btn {
            height: 38px; padding: 0 18px; border-radius: 8px; font-size: 13.5px;
            font-weight: 500; text-decoration: none;
            display: inline-flex; align-items: center; border: 1px solid transparent;
        }
        .ept-err__btn--primary { background: #2b6cb0; color: #fff; }
        .ept-err__btn--ghost { background: #edf2f7; color: #2d3748; border-color: #e2e8f0; }
        .ept-err__details {
            margin-top: 28px; text-align: left; background: #f7fafc;
            border: 1px solid #e2e8f0; border-radius: 10px; padding: 16px 18px;
        }
        .ept-err__details summary { cursor: pointer; font-weight: 600; font-size: 13px; color: #4a5568; }
        .ept-err__details pre {
            background: #1a202c; color: #e2e8f0; padding: 12px; border-radius: 6px;
            font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
            font-size: 12px; max-height: 240px; overflow: auto; white-space: pre-wrap; word-break: break-word;
        }
        .ept-err__msg {
            font-family: ui-monospace, Menlo, Consolas, monospace;
            font-size: 13px; background: #fffaf0; border-left: 3px solid #dd6b20;
            padding: 8px 12px; border-radius: 4px; margin-top: 8px;
        }
        .ept-err__meta {
            display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; margin: 0 0 22px;
        }
        .ept-err__chip {
            display: inline-flex; align-items: center; gap: 6px;
            font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
            font-size: 12px; color: #2d3748; background: #f7fafc;
            border: 1px solid #e2e8f0; border-radius: 8px; padding: 6px 11px;
        }
        .ept-err__chip b { font-weight: 600; }
        .ept-err__chip span { color: #718096; font-family: inherit; }
        .ept-err__btn--logs { background: #fffaf0; color: #b7791f; border-color: #f6e05e; }
        .ept-err__hint { margin: 18px 0 0; font-size: 12.5px; color: #718096; }
        .ept-err__hint kbd {
            font-family: ui-monospace, Menlo, Consolas, monospace; font-size: 11px;
            background: #fff; border: 1px solid #e2e8f0; border-bottom-width: 2px;
            border-radius: 5px; padding: 1px 6px; color: #2d3748;
        }
    </style>
</head>
<body>
    <?php
    $httpCode  = (int) ($this->httpCode ?? 500);
    $codeLabel = (string) ($this->codeLabel ?? '500 · Application Error');
    $headline  = (string) ($this->message ?? 'Something went wrong');
    $detail    = (string) ($this->detail ?? 'An unexpected error occurred while processing your request.');
    $isAuth    = ($httpCode === 401);
    $isGone    = ($httpCode === 410);
    $errorId   = (string) ($this->errorId ?? '');
    $errorTime = (string) ($this->errorTime ?? '');
    ?>
    <div class="ept-err">
        <div class="ept-err__card">
            <div class="ept-err__badge"><?= $isAuth ? '🔒' : ($isGone ? '⌛' : '!'); ?></div>
            <div class="ept-err__code"><?= $this->escape($codeLabel); ?></div>
            <h1 class="ept-err__title"><?= $this->escape($this->translate->_($headline)); ?></h1>
            <p class="ept-err__sub"><?= $this->escape($this->translate->_($detail)); ?></p>

            <?php if ($errorId !== '' || $errorTime !== ''): ?>
                <div class="ept-err__meta">
                    <?php if ($errorId !== ''): ?>
                        <span class="ept-err__chip"><span><?= $this->translate->_('Error ID'); ?></span> <b><?= $this->escape($errorId); ?></b></span>
                    <?php endif; ?>
                    <?php if ($errorTime !== ''): ?>
                        <span class="ept-err__chip"><span><?= $this->translate->_('Time'); ?></span> <b><?= $this->escape($errorTime); ?></b></span>
                    <?php endif; ?>
                </div>
            <?php endif; ?>

            <div class="ept-err__actions">
                <?php if ($isAuth): ?>
                    <a class="ept-err__btn ept-err__btn--primary" href="/auth/index"><?= $this->translate->_('Sign in'); ?></a>
                <?php else: ?>
                    <a class="ept-err__btn ept-err__btn--primary" href="/"><?= $this->translate->_('Back to Home'); ?></a>
                <?php endif; ?>
                <a class="ept-err__btn ept-err__btn--ghost" href="javascript:history.back()"><?= $this->translate->_('Go Back'); ?></a>

                <?php if (!empty($this->canViewLogs)):
                    // Deep-link to the Log Viewer, prefiltered by this error ID so
                    // an authorized admin lands directly on the offending log line.
                    $logUrl = $this->url(['module' => 'admin', 'controller' => 'log-viewer', 'action' => 'index'], 'default', true)
                        . '?channel=app';
                    if ($errorId !== '') {
                        $logUrl .= '&q=' . rawurlencode($errorId);
                    }
                    ?>
                    <a class="ept-err__btn ept-err__btn--logs" href="<?= $this->escape($logUrl); ?>"><?= $this->translate->_('View Logs'); ?></a>
                <?php endif; ?>

                <?php if (!empty($this->canSearch)): ?>
                    <button type="button" id="spotlightTrigger" class="ept-err__btn ept-err__btn--ghost"><?= $this->translate->_('Search pages'); ?></button>
                <?php endif; ?>
            </div>

            <?php if (!empty($this->canSearch)): ?>
                <p class="ept-err__hint">
                    <?= $this->translate->_('Tip: press'); ?>
                    <kbd>Ctrl</kbd> + <kbd>K</kbd> <span style="opacity:.6">/</span> <kbd>&#8984;</kbd> + <kbd>K</kbd>
                    <?= $this->translate->_('to search anywhere.'); ?>
                </p>
            <?php endif; ?>

            <?php if (isset($this->exception) && $this->exception): ?>
                <details class="ept-err__details">
                    <summary><?= $this->translate->_('Technical details'); ?></summary>
                    <div class="ept-err__msg"><?= $this->escape($this->exception->getMessage()); ?></div>
                    <pre><?= $this->escape($this->exception->getTraceAsString()); ?></pre>
                    <?php if (isset($this->request)): ?>
                        <pre><?= $this->escape(var_export($this->request->getParams(), true)); ?></pre>
                    <?php endif; ?>
                </details>
            <?php endif; ?>
        </div>
    </div>

    <?php if (!empty($this->canSearch)): ?>
        <script src="<?= $this->baseUrl('js/jquery.min.js'); ?>"></script>
        <?php include APPLICATION_PATH . '/views/partials/spotlight.phtml'; ?>
    <?php endif; ?>
</body>
</html>
