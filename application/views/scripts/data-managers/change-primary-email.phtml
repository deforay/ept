<?php
$csrfNamespace = new Zend_Session_Namespace('csrf');
$result = $this->result ?? null;
if ($result && !empty($result['ok'])) { ?>
    <script type="text/javascript">
        if (window.parent && typeof window.parent.closeLayoutModal === 'function') {
            window.parent.closeLayoutModal();
            if (window.parent.location && typeof window.parent.location.reload === 'function') {
                window.parent.location.reload();
            }
        }
    </script>
<?php }

$user = $this->user ?? [];
$displayName = trim(($user['first_name'] ?? '') . ' ' . ($user['last_name'] ?? ''));
if ($displayName === '') {
    $displayName = $user['primary_email'] ?? '';
}
$institute = $user['institute'] ?? '';
$currentEmail = $user['primary_email'] ?? '';
?>
<link rel="stylesheet" type="text/css" href="<?php echo $this->baseUrl('css/toastify.min.css'); ?>">
<br>
<h4 class="modal-title">
    <?= $this->translate->_("Change Primary Email"); ?>
</h4>
<p style="margin-top:8px;">
    <strong><?= htmlspecialchars($displayName, ENT_QUOTES, 'UTF-8'); ?></strong>
    <?php if ($institute !== '') { ?>
        &mdash; <?= htmlspecialchars($institute, ENT_QUOTES, 'UTF-8'); ?>
    <?php } ?>
</p>
<p>
    <?= $this->translate->_("Current login email"); ?>:
    <code id="currentEmail"><?= htmlspecialchars($currentEmail, ENT_QUOTES, 'UTF-8'); ?></code>
</p>

<?php if ($result && empty($result['ok'])) { ?>
    <div class="alert alert-danger">
        <?= htmlspecialchars($result['message'] ?? $this->translate->_('Unable to change the email. Please try again.'), ENT_QUOTES, 'UTF-8'); ?>
    </div>
<?php } ?>

<form name="changeEmailForm" id="changeEmailForm" method="post"
    action="<?php echo $this->url(['module' => 'default', 'controller' => 'data-managers', 'action' => 'change-primary-email'], null, true); ?>">
    <div class="form-group">
        <label for="newEmail"><?= $this->translate->_("New primary email"); ?></label>
        <input type="email" id="newEmail" name="newEmail" class="form-control" autocomplete="off" required autofocus />
    </div>
    <div class="form-group">
        <label for="confirmEmail"><?= $this->translate->_("Confirm new primary email"); ?></label>
        <input type="email" id="confirmEmail" name="confirmEmail" class="form-control" autocomplete="off" required />
    </div>
    <input type="hidden" id="dmId" name="dmId" value="<?= (int)($user['dm_id'] ?? 0); ?>" />
    <input type="hidden" id="csrf_token" name="csrf_token" value="<?= htmlspecialchars($csrfNamespace->token ?? '', ENT_QUOTES, 'UTF-8'); ?>" />
    <button type="button" id="changeEmailBtn" class="btn btn-primary" onclick="askConfirmChangeEmail();">
        <?= $this->translate->_("Change Email"); ?>
    </button>
    <button type="button" class="btn btn-default" onclick="window.parent.closeLayoutModal();">
        <?= $this->translate->_("Cancel"); ?>
    </button>
</form>

<!-- Bootstrap 3 confirm modal (rendered inside the iframe) -->
<div class="modal fade" id="confirmEmailChangeModal" tabindex="-1" role="dialog" aria-labelledby="confirmEmailChangeLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="confirmEmailChangeLabel">
                    <?= $this->translate->_("Confirm email change"); ?>
                </h4>
            </div>
            <div class="modal-body">
                <p>
                    <?= $this->translate->_("You are about to change the login email for"); ?>
                    <strong><?= htmlspecialchars($displayName, ENT_QUOTES, 'UTF-8'); ?></strong>.
                </p>
                <p>
                    <?= $this->translate->_("From"); ?>:
                    <code><?= htmlspecialchars($currentEmail, ENT_QUOTES, 'UTF-8'); ?></code><br>
                    <?= $this->translate->_("To"); ?>:
                    <code id="confirmToEmail"></code>
                </p>
                <div class="alert alert-warning" style="margin-bottom:0;">
                    <?= $this->translate->_("After this change, the data manager will only be able to sign in using the new email. No verification or notification email will be sent — please share the new email with the user yourself."); ?>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">
                    <?= $this->translate->_("Cancel"); ?>
                </button>
                <button type="button" id="confirmEmailChangeBtn" class="btn btn-danger">
                    <?= $this->translate->_("Yes, change the email"); ?>
                </button>
            </div>
        </div>
    </div>
</div>

<script src="<?php echo $this->baseUrl('js/toastify-js.js'); ?>"></script>
<script type="text/javascript">
    function askConfirmChangeEmail() {
        var newEmail = ($('#newEmail').val() || '').trim();
        var confirmEmail = ($('#confirmEmail').val() || '').trim();
        var emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        if (!newEmail || !confirmEmail) {
            alert(<?= json_encode($this->translate->_('Please fill in both email fields.')); ?>);
            return;
        }
        if (!emailRe.test(newEmail)) {
            alert(<?= json_encode($this->translate->_('Please enter a valid email address.')); ?>);
            $('#newEmail').focus();
            return;
        }
        if (newEmail.toLowerCase() !== confirmEmail.toLowerCase()) {
            alert(<?= json_encode($this->translate->_('The two email addresses do not match.')); ?>);
            $('#confirmEmail').focus();
            return;
        }
        if (newEmail.toLowerCase() === ($('#currentEmail').text() || '').trim().toLowerCase()) {
            alert(<?= json_encode($this->translate->_('The new email is the same as the current email.')); ?>);
            return;
        }

        $('#confirmToEmail').text(newEmail);
        $('#confirmEmailChangeModal').modal('show');
    }

    $(function () {
        $('#confirmEmailChangeBtn').on('click', function () {
            $('#confirmEmailChangeModal').modal('hide');
            if (typeof $.blockUI === 'function') { $.blockUI(); }
            document.getElementById('changeEmailForm').submit();
        });
    });
</script>
