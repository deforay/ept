</div>

<script type="text/javascript" charset="utf-8">
    /* Table initialisation */
    var oTable = null;
    $(document).ready(function () {
        oTable = $('#participantsTable').dataTable({

            "bJQueryUI": false,
            "bAutoWidth": false,
            "bInfo": true,
            "bScrollCollapse": true,
            "sPaginationType": "full_numbers",
            "bRetrieve": false,
            "bDestroy": true,
            "aoColumns": [{
                "sClass": "center"
            },
            {
                "sClass": ""
            },
            {
                "sClass": "center"
            },
            {
                "sClass": "center"
            },
            {
                "sClass": "center"
            },
            {
                "sClass": "center"
            },
            {
                "sClass": ""
            },
            {
                "sClass": "center"
            },
            {
                "sClass": "center",
                "bSortable": false
            }
            ],
            "aaSorting": [
                [0, "asc"]
            ],
            "bProcessing": true,
            "bServerSide": true,
            "bAutoWidth": false,
            "bStateSave": true,
            "sAjaxSource": "<?php echo $this->url(array('module' => 'default', 'controller' => 'participant', 'action' => 'view', 'format' => 'html')); ?>",
            "fnServerParams": function (aoData) {
                aoData.push({
                    "name": "from",
                    "value": "participant"
                });
            },
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.ajax({
                    "dataType": 'json',
                    "type": "POST",
                    "url": sSource,
                    "data": aoData,
                    "success": fnCallback
                });
            },
             "fnRowCallback": function (nRow, aData) {
                // Highlight rows with no mapped data managers (the DM column emits
                // <em class="unmapped-tag">…</em> when the count is 0)
                if ($(nRow).find('.unmapped-tag').length > 0) {
                    $(nRow).addClass('row-unmapped');
                } else {
                    $(nRow).removeClass('row-unmapped');
                }
                return nRow;
            }
        });

         $("#mappingFilter").change(function () {
        oTable.fnDraw();
    });

    bindColSearch('#participantsTable', function (value, colIdx) {
        oTable.fnFilter(value, colIdx);
    });

     // Data Managers column — expand/collapse child row with on-demand AJAX fetch
        $('#participantsTable tbody').on('click', 'a.toggle-dm-row', function (e) {
            e.preventDefault();
            var $btn = $(this);
            var participantId = $btn.data('participant-id');
            var tr = $btn.closest('tr')[0];
            if (oTable.fnIsOpen(tr)) {
                oTable.fnClose(tr);
                $btn.removeClass('btn-success').addClass('btn-primary');
                return;
            }
            // Inject a placeholder child row, then populate via AJAX
            var placeholder = '<div style="padding:12px;color:#888;"><i class="icon-refresh"></i> <?= $this->translate->_("Loading data managers…"); ?></div>';
            oTable.fnOpen(tr, placeholder, 'dm-child-container');
            $btn.removeClass('btn-primary').addClass('btn-success');
            $.post(
                "<?php echo $this->url(array('module' => 'admin', 'controller' => 'participants', 'action' => 'view', 'format' => 'html')); ?>",
                { id: participantId },
                function (html) {
                    // fnOpen wraps our content in a td inside a tr — replace that td's content
                    var $childTr = $(tr).next('tr');
                    $childTr.find('td').first().html(html);
                }
            ).fail(function () {
                var $childTr = $(tr).next('tr');
                $childTr.find('td').first().html('<div style="padding:12px;color:#a94442;"><?= $this->translate->_("Failed to load data managers. Please try again."); ?></div>');
            });
        });

        // Inline filter for the expanded DM list (only present when > 5 mapped DMs)
        $('#participantsTable tbody').on('input', 'input.dm-filter-input', function () {
            var q = $(this).val().toLowerCase().trim();
            var $rows = $(this).closest('.dm-child-row').find('tr.dm-row');
            if (q === '') {
                $rows.show();
                return;
            }
            $rows.each(function () {
                var blob = $(this).attr('data-dm-search') || '';
                $(this).toggle(blob.indexOf(q) !== -1);
            });
        });


    });

    function downloadParticipantDetails() {
        $.blockUI();
        $.post("<?php echo $this->url(array('module' => 'default', 'controller' => 'participant', 'action' => 'export-participants-details', 'format' => 'html')); ?>",
            function (data) {
                $.unblockUI();
                if (data == "" || data == null || data == undefined || $.trim(data) == 'not-found' || !data) {
                    alert('<?= $this->translate->_("Unable to generate download"); ?>');
                } else {
                    window.open('/temporary/' + data, '_blank');
                }
            });
    }

    function deleteParticipant(id) {
        if (id > 0) {
            if (confirm("<?= $this->translate->_("Are you sure you want to delete this participant?"); ?> ")) {
                // $.blockUI();
                $.post("<?php echo $this->url(array('module' => 'default', 'controller' => 'participant', 'action' => 'delete-participant')); ?>", {
                    participantId: id,
                    format: "html"
                },
                    function (data) {
                        $.unblockUI();
                        if (data > 0) {
                            oTable.fnDraw();
                        }
                    });
            }
        } else {
            alert("<?= $this->translate->_("Someting went wrong Please try again later!"); ?> ")
        }
    }
</script>