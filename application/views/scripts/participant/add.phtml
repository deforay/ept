<script type="text/javascript" src="<?php echo $this->baseUrl('js/select2.min.js'); ?>"></script>
<script>
    $(document).ready(function() {
        $("#scheme").select2({
            placeholder: "<?= $this->jsTranslate("Select one or more schemes"); ?>",
            allowClear: true
        });

        $("#enrolledProgram").select2({
            placeholder: "<?= $this->jsTranslate("Select one or more enrolled programs"); ?>",
            allowClear: true
        });
        <?php if (!$this->isEditable) { ?>
            $("#participantEdit").find("input:enabled, select:enabled, textarea:enabled").attr("disabled", "disabled");
        <?php } ?>
    });

    function goto_testers() {
        window.history.back();
    }

    var duplicated = false;

    function checkDuplicate(tableName, fieldName, obj, fnct, msg) {
        $.post("<?php echo $this->url(array('module' => 'default', 'controller' => 'common', 'action' => 'check-duplicate')); ?>", {
                tableName: tableName,
                fieldName: fieldName,
                value: obj.value,
                fnct: fnct,
                format: "html"
            },
            function(data) {
                if (data > 0) {
                    alert(msg, "err");
                    duplicated = true;
                    $(obj).val('');
                } else {
                    duplicated = false;
                }
            });
    }

    function validateNow() {
        flag = deforayValidator.init({
            formId: 'participantEdit'
        });
        if (flag && !duplicated) {
            $.blockUI();
            document.getElementById('participantEdit').submit();
        }
    }

    function checkIndividualParticipant(obj) {
        if (obj.checked) {
            tag = '<?= $this->jsTranslate("Participant First Name"); ?> <span class="mandatory">*</span>';
            $("#lastNameLable").show();
            $("#lastNameLableTd").show();
            $("#pfname").attr("title", "<?= $this->jsTranslate("Please enter the participant's first name"); ?>");
            $("#pfname").attr("placeholder", "<?= $this->jsTranslate("First name"); ?>");
        } else {
            tag = '<?= $this->jsTranslate("Lab Name"); ?> <span class="mandatory">*</span>';
            $("#lastNameLable").hide();
            $("#lastNameLableTd").hide();
            $("#plname").val('');
            $("#pfname").attr("title", "<?= $this->jsTranslate("Please enter the lab name"); ?>");
            $("#pfname").attr("placeholder", "<?= $this->jsTranslate("Lab name"); ?>");

        }
        $("#firstNameLable").html(tag);
    }
</script>
