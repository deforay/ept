<script>
	var csTable = null;

	function currentSchemes() {
		csTable = $('#currentSchemeTable').dataTable({

			"bJQueryUI": false,
			"bAutoWidth": false,
			"bInfo": true,
			"bScrollCollapse": true,
			"sPaginationType": "full_numbers",
			"bRetrieve": false,
			"bDestroy": true,
			"bSortCellsTop": true,
			"aoColumns": [{
					"sClass": "center",
				},
				{
					"sClass": "center",
					"bSortable": false
				},
				{
					"sClass": "center",
					"bSortable": false
				},
				{
					"sClass": "center",
					"bSortable": false
				},
				{
					"sClass": "center",
					"bSortable": false
				},
				{
					"sClass": "center",
					"bSortable": false
				},
				{
					"sClass": "center",
					"bSortable": false
				},
				{
					"sClass": "center",
					"bSortable": false
				},
				{
					"sClass": "center",
					"bSortable": false
				},
				{
					"sClass": "center",
					"bSortable": false
				}
			],
			"order": [
				[7, "desc"],
				[3, "desc"]
			],
			"bProcessing": true,
			"bServerSide": true,
			"bAutoWidth": false,
			"bStateSave": false,
			"sAjaxSource": "<?php echo $this->url(array('module' => 'default', 'controller' => 'participant', 'action' => 'current-schemes', 'format' => 'html')); ?>",
			"fnServerParams": function(aoData) {
				aoData.push({
					"name": "currentType",
					"value": $('input[name=currentType]').filter(':checked').val()
				});
				aoData.push({
					"name": "shipmentCode",
					"value": $("#shipmentCode").val()
				});
				aoData.push({
					"name": "province",
					"value": $("#province").val()
				});
			},
			"fnServerData": function(sSource, aoData, fnCallback) {
				$.ajax({
					"dataType": 'json',
					"type": "POST",
					"url": sSource,
					"data": aoData,
					"success": fnCallback
				});
			},
			"fnRowCallback": function (nRow, aData) {
                // Highlight rows with no mapped data managers (the DM column emits
                // <em class="unmapped-tag">…</em> when the count is 0)
                if ($(nRow).find('.unmapped-tag').length > 0) {
                    $(nRow).addClass('row-unmapped');
                } else {
                    $(nRow).removeClass('row-unmapped');
                }
                return nRow;
            }
		});
	}


	$(document).ready(function() {

		$(".select2").select2({
			allowClear: true
		});

		currentSchemes();
		<?php foreach ($this->shipment as $shipment) {
			if (isset($shipment['response_switch']) && !empty($shipment['response_switch']) && $shipment['response_switch'] == 'on') { ?>
				$('#shipmentCode').append('<option value="<?php echo $shipment['shipment_code']; ?>"><?php echo $shipment['shipment_code']; ?></option>');
		<?php }
		} ?>

		$('#currentType1').click(function() {
			$('#shipmentCode').html('<option value="">--Select--</option>');
			<?php foreach ($this->shipment as $shipment) { ?>
				$('#shipmentCode').append('<option value="<?php echo $shipment['shipment_code']; ?>"><?php echo $shipment['shipment_code']; ?></option>');
			<?php } ?>
			currentSchemes();
		});
		$('#currentType2').click(function() {
			$('#shipmentCode').html('<option value="">--Select--</option>');
			<?php foreach ($this->shipment as $shipment) {
				if (isset($shipment['response_switch']) && !empty($shipment['response_switch']) && $shipment['response_switch'] == 'on') { ?>
					$('#shipmentCode').append('<option value="<?php echo $shipment['shipment_code']; ?>"><?php echo $shipment['shipment_code']; ?></option>');
			<?php }
			} ?>
			currentSchemes();
		});
		$('#currentType3').click(function() {
			$('#shipmentCode').html('<option value="">--Select--</option>');
			<?php foreach ($this->shipment as $shipment) {
				if (!isset($shipment['response_switch']) || empty($shipment['response_switch']) || $shipment['response_switch'] == 'off') { ?>
					$('#shipmentCode').append('<option value="<?php echo $shipment['shipment_code']; ?>"><?php echo $shipment['shipment_code']; ?></option>');
			<?php }
			} ?>
			currentSchemes();
		});

		 $("#mappingFilter").change(function () {
        csTable.fnDraw();
    });

    bindColSearch('#currentSchemeTable', function (value, colIdx) {
        csTable.fnFilter(value, colIdx);
    });

     // Data Managers column — expand/collapse child row with on-demand AJAX fetch
        $('#currentSchemeTable tbody').on('click', 'a.toggle-dm-row', function (e) {
            e.preventDefault();
            var $btn = $(this);
            var participantId = $btn.data('participant-id');
            var tr = $btn.closest('tr')[0];
            if (csTable.fnIsOpen(tr)) {
                csTable.fnClose(tr);
                $btn.removeClass('btn-success').addClass('btn-primary');
                return;
            }
            // Inject a placeholder child row, then populate via AJAX
            var placeholder = '<div style="padding:12px;color:#888;"><i class="icon-refresh"></i> <?= $this->translate->_("Loading data managers…"); ?></div>';
            csTable.fnOpen(tr, placeholder, 'dm-child-container');
            $btn.removeClass('btn-primary').addClass('btn-success');
            $.post(
                "<?php echo $this->url(array('module' => 'admin', 'controller' => 'participants', 'action' => 'mapped-data-managers', 'format' => 'html')); ?>",
                { id: participantId },
                function (html) {
                    // fnOpen wraps our content in a td inside a tr — replace that td's content
                    var $childTr = $(tr).next('tr');
                    $childTr.find('td').first().html(html);
                }
            ).fail(function () {
                var $childTr = $(tr).next('tr');
                $childTr.find('td').first().html('<div style="padding:12px;color:#a94442;"><?= $this->translate->_("Failed to load data managers. Please try again."); ?></div>');
            });
        });

        // Inline filter for the expanded DM list (only present when > 5 mapped DMs)
        $('#currentSchemeTable tbody').on('input', 'input.dm-filter-input', function () {
            var q = $(this).val().toLowerCase().trim();
            var $rows = $(this).closest('.dm-child-row').find('tr.dm-row');
            if (q === '') {
                $rows.show();
                return;
            }
            $rows.each(function () {
                var blob = $(this).attr('data-dm-search') || '';
                $(this).toggle(blob.indexOf(q) !== -1);
            });
        });
	});


	function removeSchemes(schemeType, mid, userConfiguration = 'no') {
		if (window.confirm("Are you sure you want to remove this response?\n This cannot be undone !")) {
			$.blockUI();
			$.post("<?php echo $this->url(array('module' => 'default', 'controller' => 'common', 'action' => 'delete-response')); ?>", {
					schemeType: schemeType,
					userConfig: userConfiguration,
					mid: mid,
					format: "html"
				},
				function(data) {
					alert("<?= $this->translate->_("Response removed successfully"); ?>");

					csTable.fnDraw();

					$.unblockUI();
				});
		}

	}

	function downloadPendingSites() {
		// $.blockUI();
		$.post("<?php echo $this->url(array('module' => 'default', 'controller' => 'participant', 'action' => 'download-pending-sites')); ?>", {
				currentType: $('input[name=currentType]').filter(':checked').val(),
				shipmentCode: $("#shipmentCode").val(),
				province: $("#province").val(),
				format: "html"
			},
			function(data) {
				if (data != '' && data != null && data != undefined) {
					document.location.href = '/temporary/' + data;
				} else {
					alert('There is no pending sites available.');
				}
				$.unblockUI();
			});

	}

	function reportFilter() {
		if ($("#shipmentCode").val() == "" ||
			$("#shipmentCode").val() == null ||
			$("#shipmentCode").val() == undefined ||
			$("#province").val() == "" ||
			$("#province").val() == null ||
			$("#province").val() == undefined) {
			if ($("#shipmentCode").val() != "") {
				csTable.fnDraw();
				return false;
			}
			if ($("#province").val() != "") {
				csTable.fnDraw();
				return false;

			}
			alert("<?= $this->translate->_("Please choose Shipment Code or Province to proceed"); ?>");
			return false;
		}
	}
</script>