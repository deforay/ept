$participants = is_array($this->rsUsersProfile) ? $this->rsUsersProfile : [];
$participantCount = count($participants);
if ($participantCount === 1) {
	$confirmTier = 'single';
} elseif ($participantCount <= 5) {
	$confirmTier = 'list';
} else {
	$confirmTier = 'table';
}

$renderMeta = static function (array $p): string {
	$bits = array_filter([
		$p['institute_name'] ?? null,
		$p['department_name'] ?? null,
		$p['country_name'] ?? null,
	], static fn($v) => $v !== null && $v !== '');
	return htmlspecialchars(implode(' · ', $bits), ENT_QUOTES, 'UTF-8');
};
