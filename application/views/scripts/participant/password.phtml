<script>
	<?php if ($forceProfileConfirmation && !$profileConfirmed && $confirmTier === 'table'): ?>
		$(document).ready(function () {
			$('#participantsTable').dataTable({
				"aaSorting": [[0, "asc"]],
				"bJQueryUI": false,
				"bAutoWidth": false,
				"bInfo": true,
				"bScrollCollapse": true,
				"sPaginationType": "full_numbers"
			});
		});
	<?php endif; ?>

	function validateChangePassword() {
		if ($('#oldpassword').val() == $('#newpassword1').val()) {
			alert('<?= $this->jsTranslate("Cannot reuse or reset to previous password. Please try something else."); ?>');
			return false;
		}

		if ($('#newpassword1').val() != $('#newpassword2').val()) {
			alert('<?= $this->jsTranslate("New passwords do not match. Please try again."); ?>');
			return false;
		}

		var flag = deforayValidator.init({ formId: 'passwordChange' });

		if (flag) {
			$.blockUI();
			var submitTimeout = setTimeout(function () {
				$.unblockUI();
				alert('<?= $this->jsTranslate("Password change timed out. You will be logged out for security reasons."); ?>');
				window.location.href = '<?= $this->url(["controller" => "auth", "action" => "logout"], null, true); ?>';
			}, 30000);

			document.getElementById('passwordChange').submit();

			$(document).ajaxComplete(function () { clearTimeout(submitTimeout); });
		}
	}

	function validPassword() {
		if ($('#newpassword1').val() != '') {
			$.post("<?= $this->url(['module' => 'default', 'controller' => 'common', 'action' => 'validate-password']); ?>", {
				name: "",
				email: "",
				password: $('#newpassword1').val(),
				format: "html"
			},
				function (data) {
					if (data == 'success') {
						validateChangePassword();
					} else {
						alert(data);
						return false;
					}
				})
				.fail(function () {
					alert('<?= $this->jsTranslate("Unable to process your request to reset password. Please try again."); ?>');
				});
		} else {
			validateChangePassword();
		}
	}

	function cancelPasswordChange() {
		<?php if ($forceProfileConfirmation): ?>
			if (confirm('<?= $this->jsTranslate("This will sign you out. You will need to log in again with the correct PT account. Continue?"); ?>')) {
				window.location.href = '<?= $this->url(["controller" => "auth", "action" => "logout"], null, true); ?>';
			}
		<?php else: ?>
			if (confirm('<?= $this->jsTranslate("Are you sure you want to cancel password change?"); ?>')) {
				window.history.back();
			}
		<?php endif; ?>
	}

	function cancelProfileConfirmation() {
		if (confirm('<?= $this->jsTranslate("This will sign you out. You will need to log in again with the correct PT account. Continue?"); ?>')) {
			window.location.href = '<?= $this->url(["controller" => "auth", "action" => "logout"], null, true); ?>';
		}
	}

	<?php if ($forceProfileConfirmation): ?>
		// Session timeout: log out after 10 min of inactivity during the forced
		// password reset flow so an abandoned tab doesn't leave the half-confirmed
		// account open.
		var sessionTimeout;
		var timeoutDuration = 10 * 60 * 1000;
		function resetSessionTimeout() {
			clearTimeout(sessionTimeout);
			sessionTimeout = setTimeout(function () {
				alert('<?= $this->jsTranslate("Session expired for security reasons. You will be logged out."); ?>');
				window.location.href = '<?= $this->url(["controller" => "auth", "action" => "logout"], null, true); ?>';
			}, timeoutDuration);
		}
		resetSessionTimeout();
		document.addEventListener('click', resetSessionTimeout);
		document.addEventListener('keypress', resetSessionTimeout);
		document.addEventListener('scroll', resetSessionTimeout);
	<?php endif; ?>
</script>
