<script type="text/javascript" src="<?php echo $this->baseUrl('js/select2.min.js'); ?>"></script>
<script type="text/javascript">
    var duplicated = false;

    $(document).ready(function() {
        $("#dataManager").select2({
            placeholder: "<?= $this->jsTranslate("Type a participant name to search"); ?>",
            minimumInputLength: 3,
            width: '100%',
            allowClear: true,
            ajax: {
                url: "<?php echo $this->url(array('module' => 'default', 'controller' => 'participant', 'action' => 'get-datamanager-names')); ?>",
                dataType: 'json',
                delay: 250,
                data: function(params) {
                    return {
                        search: params.term,
                        page: params.page
                    };
                },
                processResults: function(data, params) {
                    params.page = params.page || 1;
                    return {
                        results: data.result,
                        pagination: {
                            more: (params.page * 30) < data.total_count
                        }
                    };
                },
            },
            escapeMarkup: function(markup) {
                return markup;
            }
        });
        $('#enrolledProgram').selectpicker();
        $('#country').selectpicker();
        $('#scheme').selectpicker();
    });

    function checkDuplicate(tableName, fieldName, obj, fnct, msg) {
        $.post("<?php echo $this->url(array('module' => 'default', 'controller' => 'common', 'action' => 'check-duplicate')); ?>", {
                tableName: tableName,
                fieldName: fieldName,
                value: obj.value,
                fnct: fnct,
                format: "html"
            },
            function(data) {
                if (data > 0) {
                    alert(msg, "err");
                    duplicated = true;
                    $(obj).val('');
                } else {
                    duplicated = false;
                }
            });
    }

    function validateNow() {
        $(".bootstrap-select").removeClass('isRequired');

        if (($('#pid').val() || '').replace(/[^a-zA-Z0-9]/g, '').length < 3) {
            alert("<?= $this->jsTranslate("Participant ID must contain at least 3 letters or numbers."); ?>");
            $('#pid').focus();
            return false;
        }

        flag = deforayValidator.init({
            formId: 'editParticipantForm'
        });
        if (flag && !duplicated) {
            $.blockUI();
            document.getElementById('editParticipantForm').submit();
        }
    }

    function checkIndividualParticipant(obj) {
        if (obj.checked) {
            tag = '<label class="col-lg-4 control-label"><?= $this->jsTranslate("First Name"); ?><span class="mandatory">*</span></label><div class="col-lg-8"><input type="text" id="pfname" name="pfname" size="50" maxlength="255" class="isRequired form-control" title="<?= $this->jsTranslate("Please enter the first name"); ?>" placeholder="<?= $this->jsTranslate("First name"); ?>"/></div>';
            $("#lastNameDiv, #firstNameDiv").show();
            $("#lastNameDiv, #firstNameDiv").removeClass('hide');
        } else {
            tag = '<label class="col-lg-4 control-label"><?= $this->jsTranslate("Lab Name"); ?><span class="mandatory">*</span></label><div class="col-lg-8"><input type="text" id="pfname" name="pfname" size="50" maxlength="255" class="isRequired form-control" title="<?= $this->jsTranslate("Please enter the lab name"); ?>" placeholder="<?= $this->jsTranslate("Lab name"); ?>"/></div>';
            $("#lastNameDiv, #firstNameDiv").hide();
            $("#lastNameDiv, #firstNameDiv").addClass('hide');
            $("#plname").val('');
        }
        $("#firstNameDiv").html(tag);
    }

    <?php
    if (isset($this->participant['individual']) && trim($this->participant['individual']) == 'no') {
    ?>
        document.getElementById("individualParticipant").checked = false;
        tag = '<label class="col-lg-4 control-label"><?= $this->jsTranslate("Lab Name"); ?><span class="mandatory">*</span></label><div class="col-lg-8"><input type="text" id="pfname" name="pfname" size="50" maxlength="255" class="isRequired form-control" title="<?= $this->jsTranslate("Please enter the lab name"); ?>" placeholder="<?= $this->jsTranslate("Lab name"); ?>" value="<?php echo $this->participant['first_name']; ?>"/></div>';
        $("#lastNameDiv, #firstNameDiv").hide();
        $("#lastNameDiv, #firstNameDiv").addClass('hide');
