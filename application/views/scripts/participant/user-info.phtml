<script type="text/javascript">
    duplicated = false;

    function validateNow() {
        var blockedDomain = '<?php echo $blockedDomains; ?>';
        var secondaryEmail = $.trim($('#semail').val());
        var domains = [];
        var maildomain = [];

        if (blockedDomain !== '') {
            domains = $.map(blockedDomain.split(','), function (domain) {
                return $.trim(domain).toLowerCase();
            });
        }

        if (secondaryEmail !== '') {
            maildomain = secondaryEmail.toLowerCase().split('@');
        }

        // Only run the blocked-domain check once the email contains a domain part.
        // Otherwise the form validator should handle the malformed email input.
        if (domains.length > 0 && maildomain.length > 1 && maildomain[1] !== '') {
            if (jQuery.inArray(maildomain[1], domains) !== -1) {
                alert("<?= $this->jsTranslate("Please enter a valid email address. We will send the verification information to this address."); ?>");
                return false;
            }
        }

        flag = deforayValidator.init({
            formId: 'userInfoForm'
        });
        if (flag) {
            if (!duplicated) {
                $.blockUI();
                document.getElementById('userInfoForm').submit();
            }
        }
    }

    function checkDuplicate(tableName, fieldName, obj, fnct, msg) {
        objValue = $(obj).val();
        $.post("<?php echo $this->url(array('module' => 'default', 'controller' => 'common', 'action' => 'check-duplicate')); ?>", {
            tableName: tableName,
            fieldName: fieldName,
            value: objValue,
            fnct: fnct,
            format: "html"
        },
            function (data) {
                if (data > 0) {
                    alert(msg, "err");
                    duplicated = true;
                    $(obj).focus();
                    $(obj).val('');
                } else {
                    duplicated = false;
                }
                return duplicated;
            });
    }

    function reSentVerifyMail(email) {
        $.post("<?php echo $this->url(array('module' => 'default', 'controller' => 'participant', 'action' => 'resent-mail-verification')); ?>", {
            registeredEmail: email,
            oldEmail: $('#oldpemail').val(),
            format: "html"
        },
            function (data) {
                if (data > 0) {
                    $('.alert-success').fadeIn(500);
                    setTimeout(function () {
                        $('.alert-success').fadeOut(500);
                    }, 10000);
                }
            });
    }
</script>