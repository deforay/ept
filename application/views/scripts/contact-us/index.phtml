				</div>
				<div class="form-group">
					<label for="email" class="email col-sm-2 control-label" data-icon="u"> <?= $this->translate->_("Your Email"); ?> <span class="mandatory">*</span> </label>
					<div class="col-sm-10">
						<input id="email" name="email" class="isRequired form-control isEmail" title="<?= $this->htmlTranslate("Please enter your email address"); ?>" type="email" placeholder="<?= $this->htmlTranslate("you@example.com"); ?>" />
					</div>
				</div>
				<div class="form-group">
					<label for="phone" class="phone col-sm-2 control-label" data-icon="u"> <?= $this->translate->_("Your Phone/Mobile"); ?> <span class="mandatory">*</span></label>
					<div class="col-sm-10">
						<input id="phone" name="phone" class="isRequired form-control" title="<?= $this->htmlTranslate("Please enter your contact number"); ?>" type="tel" placeholder="<?= $this->htmlTranslate("Phone or mobile number"); ?>" />
					</div>
				</div>
				<div class="form-group">
					<label for="reasonId" class="agency col-sm-2 control-label" data-icon="u"><?= $this->translate->_("How can we help you?"); ?> <span class="mandatory">*</span></label>
					<div class="col-sm-10">
						<select name="reasonId" id="reasonId" onchange='fillreason()' class="form-control isRequired" title="<?= $this->htmlTranslate("Please choose an option"); ?>">
							<option value="">-- <?= $this->translate->_("Select"); ?> --</option>
							<option value="1" <?php echo (isset($this->from) && trim($this->from) == 'register') ? 'selected="selected"' : ''; ?>><?= $this->translate->_("Request to participate in the PT program"); ?></option>
							<option value="2"><?= $this->translate->_("Add a new tester to the current PT program"); ?></option>
							<option value="3"><?= $this->translate->_("Other"); ?></option>
						</select>
						<input type="hidden" name="reason" id="reason" />
					</div>
				</div>
				<div class="form-group">
					<label for="agency" class="agency col-sm-2 control-label" data-icon="u"> <?= $this->translate->_("Lab/Agency Name"); ?> </label>
					<div class="col-sm-10">
						<input id="agency" name="agency" class="form-control" title="<?= $this->htmlTranslate("Please enter your lab or agency name"); ?>" type="text" placeholder="<?= $this->htmlTranslate("Lab or agency name"); ?>" />
					</div>
				</div>
				<div class="form-group">
					<label for="additionalInfo" class="additionalInfo col-sm-2 control-label" data-icon="u"> <?= $this->translate->_("Additional Info"); ?> </label>
					<div class="col-sm-10">
						<textarea id="additionalInfo" name="additionalInfo" class="form-control" title="<?= $this->htmlTranslate("Please enter additional information"); ?>" placeholder="<?= $this->htmlTranslate("Add any additional information"); ?>"></textarea>
					</div>
				</div>
				<div class="form-group">
					<div class="col-sm-offset-2 col-sm-10">
						<div class="d-flex align-items-start" style="gap:10px;">
							<div class="d-flex flex-column align-items-center" style="flex-shrink:0;">
								<img id="capChaw" src="/captcha/<?php echo rand(); ?>" style="height:58px;width:auto;border-radius:4px;" alt="<?= $this->htmlTranslate("Security check"); ?>" />
								<button type="button" tabindex="-1" onclick="getCaptcha('capChaw');return false;" class="btn btn-link btn-sm text-muted p-0" style="font-size:12px;margin-top:2px;"><i class="icon-refresh"></i> <?= $this->translate->_("Get New Image"); ?></button>
							</div>
							<input type="text" id="challengeResponse" class="form-control isRequired" placeholder="<?= $this->htmlTranslate("Enter text from image"); ?>" title="<?= $this->htmlTranslate("Please enter the text from the image"); ?>" maxlength="40" style="width:240px;flex:none;">
