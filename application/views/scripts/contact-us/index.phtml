				</div>
				<div class="form-group">
					<label for="last_name" class="last_name col-sm-2 control-label" data-icon="u"> <?= $this->translate->_("Last Name"); ?> <span class="mandatory">*</span> </label>
					<div class="col-sm-10">
						<input id="last_name" name="last_name" class="isRequired form-control" title="<?= $this->htmlTranslate("Please enter your last name"); ?>" type="text" placeholder="<?= $this->htmlTranslate("Last name"); ?>" />
