<main class="form-signin">

    <form id="resetPassword" class="form-vertical" name="resetPassword" method="post" action="<?php echo $this->escape($this->userAgent()->getServerValue('request_uri')); ?>">
        <input type="text" name="website_url" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true">
        <input type="hidden" name="form_token" value="<?php echo $this->escape($this->formToken ?? ''); ?>">
        <div class="card mb-6">
            <div class="card-header bg-transparent" style="text-align:center;">
                <div class="login-logo"><span><?= $this->translate->_("Reset My New Password"); ?></span></div>
            </div>
            <div class="card-body">
                <div class="reset-account">
                    <div class="reset-account-label"><?= $this->translate->_("Resetting password for"); ?></div>
                    <div class="reset-account-email"><?php echo htmlspecialchars((string) ($this->email['primary_email'] ?? ''), ENT_QUOTES, 'UTF-8'); ?></div>
                </div>
                <?php $minLen = (int) ($this->passLength ?? 8); ?>
                <div class="form-floating">
                    <input id="password" pattern=".{<?php echo $minLen; ?>,}" name="password" class="isRequired form-control" title="<?= sprintf($this->htmlTranslate("Please enter a valid password (minimum %d characters)"), $minLen); ?>" type="password" placeholder="<?= $this->htmlTranslate("New password"); ?>" />
                    <label for="password"> <?= $this->translate->_("Enter your new password"); ?> </label>
                </div>
                <div class="form-floating">
                    <input id="confirmPassword" name="password" class="confirmPassword form-control" title="<?= $this->htmlTranslate("Please re-enter your password to confirm"); ?>" type="password" placeholder="<?= $this->htmlTranslate("Confirm password"); ?>" />
                    <label for="confirmPassword"> <?= $this->translate->_("Confirm your new password"); ?> </label>
                </div>
                <div class="form-group">
                    <div class="captcha-row challangeDiv">
                        <div class="captcha-col">
                            <img id="capChaw" class="captcha-img" src="/captcha/<?php echo rand(); ?>" alt="<?= $this->htmlTranslate("Security check"); ?>" />
                            <button type="button" tabindex="-1" onclick="getCaptcha('capChaw');return false;" class="get-img btn btn-link btn-sm captcha-refresh" style="padding:0;"><i class="bx bx-refresh"></i> <?= $this->translate->_("Get New Image"); ?></button>
                        </div>
                        <div class="form-floating">
                            <input type="text" id="challengeResponse" placeholder="<?= $this->htmlTranslate("Enter text from image"); ?>" class="isRequired form-control" title="<?= $this->htmlTranslate("Please enter the text from the image"); ?>" maxlength="40">
                            <label for="challengeResponse"> <?= $this->translate->_("Enter text from image"); ?> </label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent">
                <div class="form-group" style="text-align: center">
                    <button class="w-100 btn btn-lg btn-get-started signIn" type="submit" onclick="validatePasswordReset();return false;"><?= $this->translate->_("Save"); ?></button>
                    <a href="/auth/login" style="font-size:0.8em;color:red;"><?= $this->translate->_("No, I remember my password!"); ?></a>
                </div>
            </div>
        </div>
    </form>
</main>
<script type="text/javascript" src="<?php echo $this->baseUrl("js/jquery.blockUI.js"); ?>"></script>
<script type="text/javascript" src="<?php echo $this->baseUrl("js/deforayValidation.js"); ?>"></script>
<script type="text/javascript">
    $("#tableCss").remove();

    function validatePasswordReset() {
        flag = deforayValidator.init({
            formId: 'resetPassword'
        });
        if (flag) {
            challenge_field = document.getElementById("challengeResponse").value;
            if (challenge_field != "") {
                $.post("<?php echo $this->url(array(), 'checkCaptchaRoute', true); ?>", {
                        challenge_field: challenge_field,
                        format: "html"
                    },
                    function(data) {
                        if (data == 'fail') {
                            alert("<?= $this->jsTranslate("The text you entered from the image is incorrect. Please try again."); ?>");
                            getCaptcha('capChaw');
                            document.getElementById("challengeResponse").value = "";
                            return false;
                        } else {
                            $.blockUI();
                            document.getElementById('resetPassword').submit();
                        }
                    });
            } else {
                alert("<?= $this->jsTranslate("Please enter the text from the image to proceed."); ?>");
            }
        }
    }
</script>
