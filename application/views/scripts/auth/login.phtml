$attemptNs = new Zend_Session_Namespace('loginAttempts');
$attemptUser = $attemptNs->currentUser ?? null;
$attemptCounts = is_array($attemptNs->counts ?? null) ? $attemptNs->counts : [];
$attemptTimers = is_array($attemptNs->timers ?? null) ? $attemptNs->timers : [];
$attemptCount = ($attemptUser !== null) ? ($attemptCounts[$attemptUser] ?? 0) : 0;
$attemptTimer = ($attemptUser !== null) ? ($attemptTimers[$attemptUser] ?? null) : null;
?>
<script type="text/javascript">
	var countDownDate = new Date("<?php echo $attemptTimer; ?>").getTime();
	$(document).ready(function() {
		<?php if (
		    $attemptCount >= $this->maxAttemptTempBan
		    && $attemptTimer !== null
		    && strtotime($attemptTimer) >= strtotime('NOW')
		    && isset($this->loginBan) && !empty($this->loginBan) && $this->loginBan == 'yes'
		) { ?>
			$('.signIn').remove();
			$('.loginAttemptTimer').removeClass('hide');
			$('.get-img, .challangeDiv').css('display', 'none');
			$('#username, #password, #challengeResponse').attr("disabled", "disabled");

			var sec = <?php echo strtotime($attemptTimer) - strtotime('NOW'); ?>,
				countDiv = document.getElementById("showTimer"),
				secpass,
				countDown = setInterval(function() {
					'use strict';

					secpass();
				}, 1000);

			function secpass() {
				'use strict';
				var min = Math.floor(sec / 60),
					remSec = sec % 60;

				if (remSec < 10) {

					remSec = '0' + remSec;

				}
				if (min < 10) {

					min = '0' + min;

				}
				countDiv.innerHTML = min + ":" + remSec;

				if (sec > 0) {

					sec = sec - 1;

				} else {
					clearInterval(countDown);
					location.reload();
				}
			}
		<?php } else { ?>
			$('.loginAttemptTimer').remove();
		<?php } ?>
	});

	function validateLogin() {
		flag = deforayValidator.init({
			formId: 'loginForm'
		});
		if (flag) {
			challenge_field = document.getElementById("challengeResponse").value;
			if (challenge_field != "") {
				$.post("<?php echo $this->url([], 'checkCaptchaRoute', true); ?>", {
						challenge_field: challenge_field,
						format: "html"
					},
					function(data) {
						if (data == 'fail') {
							alert("<?= $this->jsTranslate('The text you entered from the image is incorrect. Please try again.'); ?>");
							getCaptcha('capChaw');
							document.getElementById("challengeResponse").value = "";
							return false;
						} else {
							$.blockUI();
							document.getElementById('loginForm').submit();
						}
					});
			} else {
				alert("<?= $this->jsTranslate('Please enter the text from the image to proceed.'); ?>");
			}
		}
	}
</script>
