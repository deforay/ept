#: application/languages/db-translation-strings.php:50
msgid ""
"Ensure expired test kit are not be used for testing. If test kits are not "
"available, please contact your superior."
msgstr ""
"Đảm bảo không sử dụng bộ kit xét nghiệm đã hết hạn để xét nghiệm. Nếu không "
"có bộ kit xét nghiệm, vui lòng liên hệ với cấp trên của bạn."

#: application/languages/db-translation-strings.php:52
msgid ""
"Ensure expired test type are not be used for testing. If test types are not "
"available, please contact your superior."
msgstr ""
"Đảm bảo không sử dụng các loại bài kiểm tra đã hết hạn để kiểm tra. Nếu "
"không có loại bài kiểm tra nào phù hợp, vui lòng liên hệ với cấp trên của "
"bạn."

#: application/languages/db-translation-strings.php:54
msgid "Ensure expiry date information is submitted for all performed tests."
msgstr ""
"Đảm bảo cung cấp thông tin về ngày hết hạn cho tất cả các xét nghiệm đã thực "
"hiện."

#: application/languages/db-translation-strings.php:56
msgid "Ensure test kit lot number is reported for all performed tests."
msgstr ""
"Đảm bảo ghi lại số lô của bộ dụng cụ xét nghiệm cho tất cả các xét nghiệm đã "
"thực hiện."

#: application/languages/db-translation-strings.php:58
msgid "Ensure test kit name is reported for all performed tests."
msgstr ""
"Đảm bảo tên bộ dụng cụ xét nghiệm được ghi lại cho tất cả các xét nghiệm đã "
"thực hiện."

#: application/languages/db-translation-strings.php:60
msgid "Ensure test type lot number is reported for all performed tests."
msgstr ""
"Đảm bảo số lô của loại xét nghiệm được ghi nhận cho tất cả các xét nghiệm đã "
"thực hiện."

#: application/languages/db-translation-strings.php:62
msgid "Ensure test type name is reported for all performed tests."
msgstr ""
"Đảm bảo tên loại kiểm tra được ghi lại cho tất cả các kiểm tra đã thực hiện."

#: application/languages/db-translation-strings.php:64
msgid "Ensure to provide sample rehydration date"
msgstr "Hãy đảm bảo cung cấp ngày tái hydrat hóa mẫu"

#: application/languages/db-translation-strings.php:66
msgid "Ensure to provide supervisor approval along with his name."
msgstr ""
"Hãy đảm bảo có sự chấp thuận của người giám sát kèm theo tên của người đó."

#: application/languages/db-translation-strings.php:68
msgid "Ensure to provide to provide panel receipt date."
msgstr "Hãy đảm bảo cung cấp ngày nhận bảng điều khiển."

#: application/languages/db-translation-strings.php:70
msgid "Ensure to provide to provide panel testing date."
msgstr "Hãy đảm bảo cung cấp ngày thử nghiệm bảng điều khiển."

