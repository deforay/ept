<link rel="stylesheet" href="<?php echo $this->baseUrl("css/jquery.dataTables.css"); ?>" type="text/css" media="all">
<h4 style="width:100%;height:50px;border-bottom:1px solid #777;">
    <div style="font-size:22.5px;line-height:36px;color:#333;float:left;">
        <?= $this->translate->_("PT Survey - Finalized Reports"); ?>
    </div>
</h4>

<table cellpadding="0" cellspacing="0" border="0" class="table table-striped table-bordered table-hover"
    id="distroTable">
    <thead>
        <tr>
            <th scope="col"><?= $this->translate->_("PT Survey Date"); ?></th>
            <th scope="col"><?= $this->translate->_("PT Survey Code"); ?></th>
            <th scope="col"><?= $this->translate->_("Shipment Code(s)"); ?></th>
            <th scope="col"><?= $this->translate->_("Status"); ?></th>
            <th scope="col"><?= $this->translate->_("Action"); ?></th>
        </tr>
         <tr class="column-search-row">
            <th scope="col"></th>
            <th scope="col"><input type="text" class="form-control input-sm col-search" data-col="1" placeholder="<?= $this->translate->_('Search Survey Code'); ?>" /></th>
            <th scope="col"><input type="text" class="form-control input-sm col-search" data-col="2" placeholder="<?= $this->translate->_('Search Code'); ?>" /></th>
            <th scope="col"></th>
            <th scope="col"></th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td colspan="5" class="dataTables_empty"><?= $this->translate->_("Loading data from server"); ?></td>
        </tr>
    </tbody>
</table>


<div id="shipments" style="clear:both;margin-top:30px;"></div>
<script type="text/javascript" src="<?php echo $this->baseUrl('js/toastify-js.js'); ?>"></script>
<script type="text/javascript" charset="utf-8">

    $('#myModal').on('hidden.bs.modal', function () {
        $(this).removeData('bs.modal');
    });
    /* Table initialisation */
    var oTable = null;
    var currentHighlighted = null;
    $(document).ready(function () {

        currentHighlighted = getCookie('disId');

        oTable = $('#distroTable').dataTable({

            "bJQueryUI": false,
            "bAutoWidth": false,
            "bInfo": true,
            "bScrollCollapse": true,
            "sPaginationType": "bootstrap",
            "bRetrieve": true,
            "aoColumns": [
                { "sClass": "center" },
                { "sClass": "center" },
                { "sClass": "center" },
                { "sClass": "center", "bSortable": false },
                { "sClass": "center", "bSortable": false }
            ],
            "aaSorting": [[0, "desc"]],
            "bProcessing": true,
            //"bSortClasses": false,
            "bServerSide": true,
            "sAjaxSource": "<?php echo $this->url(array('module' => 'reports', 'controller' => 'finalize', 'action' => 'shipments', 'format' => 'html')); ?>",
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.ajax({
                    "dataType": 'json',
                    "type": "POST",
                    "url": sSource,
                    "data": aoData,
                    "success": function (json) {
                        fnCallback(json);
                        if (currentHighlighted != null && currentHighlighted != "" && currentHighlighted != 0) {
                            $("#dist" + currentHighlighted + " td").addClass("highliter");
                            getShipmentInReports(currentHighlighted);
                        }
                    }

                });
            }
        });

    $("#mappingFilter").change(function () {
        oTable.fnDraw();
    });

    bindColSearch('#distroTable', function (value, colIdx) {
        oTable.fnFilter(value, colIdx);
    });

     // Data Managers column — expand/collapse child row with on-demand AJAX fetch
        $('#distroTable tbody').on('click', 'a.toggle-dm-row', function (e) {
            e.preventDefault();
            var $btn = $(this);
            var participantId = $btn.data('participant-id');
            var tr = $btn.closest('tr')[0];
            if (oTable.fnIsOpen(tr)) {
                oTable.fnClose(tr);
                $btn.removeClass('btn-success').addClass('btn-primary');
                return;
            }
            // Inject a placeholder child row, then populate via AJAX
            var placeholder = '<div style="padding:12px;color:#888;"><i class="icon-refresh"></i> <?= $this->translate->_("Loading data managers…"); ?></div>';
            oTable.fnOpen(tr, placeholder, 'dm-child-container');
            $btn.removeClass('btn-primary').addClass('btn-success');
            $.post(
                "<?php echo $this->url(array('module' => 'admin', 'controller' => 'finalize', 'action' => 'shipments', 'format' => 'html')); ?>",
                { id: participantId },
                function (html) {
                    // fnOpen wraps our content in a td inside a tr — replace that td's content
                    var $childTr = $(tr).next('tr');
                    $childTr.find('td').first().html(html);
                }
            ).fail(function () {
                var $childTr = $(tr).next('tr');
                $childTr.find('td').first().html('<div style="padding:12px;color:#a94442;"><?= $this->translate->_("Failed to load data managers. Please try again."); ?></div>');
            });
        });

        // Inline filter for the expanded DM list (only present when > 5 mapped DMs)
        $('#distroTable tbody').on('input', 'input.dm-filter-input', function () {
            var q = $(this).val().toLowerCase().trim();
            var $rows = $(this).closest('.dm-child-row').find('tr.dm-row');
            if (q === '') {
                $rows.show();
                return;
            }
            $rows.each(function () {
                var blob = $(this).attr('data-dm-search') || '';
                $(this).toggle(blob.indexOf(q) !== -1);
            });
        });


    });



    function getShipmentInReports(did) {
        $.blockUI();
        currentHighlighted = did;
        setCookie('disId', did);
        $("#distroTable tr td").removeClass("highliter");
        $("#dist" + currentHighlighted + " td").addClass("highliter");
        $.post("<?php echo $this->url(array('module' => 'reports', 'controller' => 'finalize', 'action' => 'get-finalized-shipments')); ?>", { did: did, format: "html" },
            function (data) {
                $("#shipments").html(data);
                $.unblockUI();
            });
    }

    function sendReportsInMail(sid) {
        $.blockUI();
        $.post("<?php echo $this->url(array('module' => 'reports', 'controller' => 'finalize', 'action' => 'send-report-mail')); ?>", { sid: sid, format: "html" },
            function (data) {
                if (data > 0) {
                    $('.send-report-btn-' + sid).removeClass('btn-warning');
                    $('.send-report-btn-' + sid).addClass('btn-default');
                    $('.send-report-btn-' + sid).attr('disabled', true);
                    Toastify({
                        text: "Report mail send to the participants",
                        duration: 3000,
                        style: {
                            background: "linear-gradient(to right, #00b09b, #96c93d)",
                        }
                    }).showToast();
                } else {
                    Toastify({
                        text: "Report mail already added to the queue",
                        duration: 3000,
                        style: {
                            background: "linear-gradient(to right, #f39c12, red)",
                        }
                    }).showToast();
                }
                $.unblockUI();
            });
    }

</script>