                            var tier = $('#vietnamTier').val() || '';
                            var kit  = $('#vietnamNonStandardKit').val() || '';
                            if (tier) { aoData.push({ "name": "vietnamTier", "value": tier }); }
                            if (kit)  { aoData.push({ "name": "vietnamNonStandardKit", "value": kit }); }
                        <?php } ?>
                    },
                    "fnServerData": function (sSource, aoData, fnCallback) {
                        $.ajax({
                            "dataType": "json",
                            "type": "POST",
                            "url": sSource,
                            "data": aoData,
                            "success": fnCallback
                        });
                    },
                    "aoColumns": [
                        { "bSortable": false },
                        { "sClass": "center" },
                        { "sClass": "" },
                        { "sClass": "" },
                        { "sClass": "center" },
                        { "sClass": "center" },
                        { "sClass": "center" },
                        { "sClass": "" },
                        { "sClass": "" },
                        { "sClass": "center", "bSortable": false },
                        { "sClass": "center", "bSortable": false },
                        { "sClass": "center" },
                        { "bSearchable": false, "bVisible": false }
                    ],
                    "aaSorting": [
                        [1, "asc"]
                    ]
                });
            });

            // Universal + per-scheme listing filters — redraw the DataTable; fnServerParams reads the dropdown values.
            function applyShipmentFilters() {
                var $t = $('#shipmentEvaluation');
                if ($t.length && $.fn.DataTable && $.fn.DataTable.isDataTable($t)) {
                    $t.dataTable().fnDraw();
                }
            }

            function fnFormatDetails(oTable, nTr) {
                var aData = oTable.fnGetData(nTr);
                var sOut = '<div class="text-center"><i class="icon-spinner icon-spin"></i> Loading...</div>';
                // map_id is in the hidden last column (index 12).
                var mapId = aData[12];
                $.ajax({
                    url: '/common/get-corrective-actions/mid/' + mapId,
                    data: {
                        format: 'html'
                    },
                    async: false,
                    success: function (html) {
                        sOut = '<div style="padding-left:50px;">' + html + '</div>';
                    },
                    error: function () {
                        sOut = '<div class="text-muted">Failed to load corrective actions</div>';
                    }
                });
                return sOut;
            }
