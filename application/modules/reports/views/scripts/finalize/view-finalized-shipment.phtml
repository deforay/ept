            $(document).ready(function () {

                $('#shipmentEvaluation').on('click', ".clicker", function () {
                    nTr = $(this).parents('tr')[0];
                    aData = oTable.fnGetData(nTr);
                    if (oTable.fnIsOpen(nTr)) {
                        /* This row is already open - close it */
                        $(this).find('i').addClass("icon-plus");
                        $(this).find('i').removeClass("icon-minus");
                        //$(this).removeClass('btn-danger');

                        // Preserve the original state color so excluded / not evaluated rows stay neutral.
                        $(this)
                            .removeClass('btn-success btn-danger btn-warning btn-default')
                            .addClass($(this).data('btn-class'));

                        oTable.fnClose(nTr);
                    } else {
                        /* Open this row */
                        $(this).find('i').addClass("icon-minus");
                        $(this).find('i').removeClass("icon-add");
                        //$(this).removeClass('btn-success');
                        //$(this).addClass('btn-danger');
                        oTable.fnOpen(nTr, fnFormatDetails(oTable, nTr), 'details');
                    }
                });



                oTable = $("#shipmentEvaluation").dataTable({
                    "bJQueryUI": false,
                    "bAutoWidth": false,
                    "bInfo": true,
                    "bScrollCollapse": true,
                    "sPaginationType": "bootstrap",
                    "bRetrieve": false,
                    "bDestroy": true,
                    "bProcessing": true,
                    "bServerSide": true,
                    "sAjaxSource": "<?php echo $this->url(['module' => 'reports', 'controller' => 'finalize', 'action' => 'view-finalized-shipment', 'sid' => base64_encode($this->shipmentId), 'format' => 'html']); ?>",
                    "fnServerParams": function (aoData) {
                        // Universal filters (all schemes / countries).
                        var rs = $('#filterResponseStatus').val() || '';
                        var rr = $('#filterResult').val() || '';
                        if (rs) { aoData.push({ "name": "filterResponseStatus", "value": rs }); }
                        if (rr) { aoData.push({ "name": "filterResult", "value": rr }); }
