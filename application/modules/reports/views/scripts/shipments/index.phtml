<script type="text/javascript" src="<?php echo $this->baseUrl('js/daterangepicker.js'); ?>"></script>
<script type="text/javascript" src="<?php echo $this->baseUrl('js/select2.min.js'); ?>"></script>
<script type="text/javascript">
	var startDate = "";
	var endDate = "";
	$(document).ready(function () {
		$("#dataManager").select2({
			placeholder: "Select PT participant login",
			allowClear: true
		});

		$('#dateRange').daterangepicker({
			locale: {
				cancelLabel: 'Clear',
				format: 'DD-MMM-YYYY',
				separator: ' to ',
			},
			autoApply: true,
			showDropdowns: true,
			alwaysShowCalendars: true,
			autoUpdateInput: false,
			// startDate: moment().subtract(366, 'days'),
			// endDate: moment(),
			// maxDate: moment(),
			ranges: {
				'This Month': [moment().startOf('month'), moment().endOf('month')],
				'Last Month': [moment().subtract(1, 'month').startOf('month'), moment().subtract(1, 'month').endOf('month')],
				'Last 60 Days': [moment().subtract(59, 'days'), moment()],
				'Last 90 Days': [moment().subtract(89, 'days'), moment()],
				'Last 180 Days': [moment().subtract(179, 'days'), moment()],
				'Last 12 Months': [moment().subtract(12, 'month'), moment()],
				'Last 18 Months': [moment().subtract(18, 'month'), moment()],
				'Previous Year': [moment().subtract(1, 'year').startOf('year'), moment().subtract(1, 'year').endOf('year')],
				'Current Year To Date': [moment().startOf('year'), moment()]
			}
		},
			function (start, end) {
				startDate = start.format('DD-MMM-YYYY');
				endDate = end.format('DD-MMM-YYYY');
			});

		getDrawable();
	});

	function getDrawable() {
		/* if ($("#dateRange").val() == '') {
			alert("Please select date range");
			return false;
		} else { */
		$.blockUI();
		drawTable();
		$.unblockUI();
		// }
	}

	function drawTable() {
		var dateRange = $("#dateRange").val();
		var _dateRange = dateRange.split(" to ");
		startDate = _dateRange[0];
		endDate = _dateRange[1];
		$("#shipmentTable").removeClass("hide");
		$.blockUI;
		oTable = $('#shipmentTable').dataTable({

			"bJQueryUI": false,
			"bAutoWidth": false,
			"bInfo": true,
			"bScrollCollapse": true,
			"sPaginationType": "bootstrap",
			"bRetrieve": false,
			"bDestroy": true,
			"bSortCellsTop": true,
			"aoColumns": [{
				"sClass": "center"
			},
			{
				"sClass": "center"
			},
			{
				"sClass": "center"
			},
			{
				"sClass": "center"
			},
			{
				"sClass": "center"
			},
			{
				"sClass": "center"
			},
			{
				"sClass": "center"
			},
			{
				"sClass": "center"
			},
			{
				"sClass": "center"
			},
			{
				"sClass": "center",
				"bSortable": false
			},
			{
				"sClass": "center",
				"bSortable": false
			}
			],
			"aaSorting": [
				[1, "desc"]
			],
			"bProcessing": true,
			"bServerSide": true,
			"sAjaxSource": "<?php echo $this->url(array('module' => 'reports', 'controller' => 'shipments', 'action' => 'index', 'format' => 'html')); ?>",
			"fnServerParams": function (aoData) {
				dateRange = $("#dateRange").val();
				dataManager = $("#dataManager").val();
				aoData.push({
					"name": "dateRange",
					"value": dateRange
				});
				aoData.push({
					"name": "startDate",
					"value": startDate
				});
				aoData.push({
					"name": "endDate",
					"value": endDate
				});
				aoData.push({
					"name": "dataManager",
					"value": dataManager
				});
			},
			"fnServerData": function (sSource, aoData, fnCallback) {
				$.ajax({
					"dataType": 'json',
					"type": "POST",
					"url": sSource,
					"data": aoData,
					"success": fnCallback
				});
			},
			"fnRowCallback": function (nRow, aData, iDisplayIndex) {
				$.unblockUI;
			},
		});

		// Per-column search inputs — debounced so we don't fire a request on every keystroke.
		// Re-bind each time drawTable() runs because bDestroy:true can reset header handlers.
		var colSearchTimer = null;
		$('#shipmentTable thead').off('keyup.colsearch change.colsearch').on('keyup.colsearch change.colsearch', '.col-search', function () {
			var $el = $(this);
			var colIdx = parseInt($el.data('col'), 10);
			var value = $el.val();
			clearTimeout(colSearchTimer);
			colSearchTimer = setTimeout(function () {
				if (oTable) {
					oTable.fnFilter(value, colIdx);
				}
			}, 400);
		});
		// DataTables binds sort directly on <th>, so delegation from <thead> would run
		// AFTER the sort fires — bind straight on the inputs.
		$('#shipmentTable thead .col-search').off('click.colsearch mousedown.colsearch focus.colsearch')
			.on('click.colsearch mousedown.colsearch focus.colsearch', function (e) {
				e.stopPropagation();
			});
	};

	function generateShipmentParticipantList(shipmentId, schemeType) {
		$.blockUI();
		$.post("<?php echo $this->url(array('module' => 'reports', 'controller' => 'shipments', 'action' => 'get-shipment-participant-list')); ?>", {
			shipmentId: shipmentId,
			schemeType: schemeType,
			format: "html"
		},
			function (data) {
				if (data != "") {
					//alert(data);$.unblockUI();return;
					document.location.href = '/temporary/' + data;
				}
				$.unblockUI();
			});
	}

	function downloadFeedbackReport(shipmentId) {
		$.blockUI();
		$.post("/admin/feedback-responses/get-feedback-response-report", {
			sid: shipmentId,
			format: "html"
		},
			function (data) {
				if (data != "") {
					document.location.href = '/temporary/' + data;
				} else {
					alert('<?= $this->translate->_("No feedback responses found for this shipment"); ?>');
				}
				$.unblockUI();
			});
	}

	function exportNotRespondedShipment(_shipmentCode, _shipmentDate) {
		$.blockUI();
		$.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'shipment', 'action' => 'export-shipment-not-responded-participants')); ?>", {
			shipmentCode: _shipmentCode,
			shipmentDate: _shipmentDate,
			format: "html"
		},
			function (data) {
				if (data == "" || data == null || data == undefined) {
					alert('<?= $this->translate->_("Unable to generate download"); ?>');
				} else {
					document.location.href = '/temporary/' + data;
				}
				$.unblockUI();
			});
	}
</script>