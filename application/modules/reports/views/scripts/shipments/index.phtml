<script type="text/javascript">
	var startDate = "";
	var endDate = "";
	var selectedShipments = []; // now stores [{id:'NTU=', scheme:'SYPH RDT'}, ...]

	function toggleShipmentSelect(obj) {
		var sid = obj.value;
		var scheme = $(obj).data('scheme');

		if ($(obj).is(':checked')) {
			if (!selectedShipments.find(function(s) {
					return s.id === sid;
				})) {
				selectedShipments.push({
					id: sid,
					scheme: scheme
				});
			}
		} else {
			selectedShipments = selectedShipments.filter(function(s) {
				return s.id !== sid;
			});
		}
		updateShipmentBulkUI();
	}

	function toggleAllShipments() {
		if ($("#masterShipmentCb").is(':checked')) {
			$(".checkShipment").each(function() {
				var sid = this.value;
				var scheme = $(this).data('scheme');
				$(this).prop('checked', true);
				if (!selectedShipments.find(function(s) {
						return s.id === sid;
					})) {
					selectedShipments.push({
						id: sid,
						scheme: scheme
					});
				}
			});
		} else {
			$(".checkShipment").each(function() {
				var sid = this.value;
				$(this).prop('checked', false);
				selectedShipments = selectedShipments.filter(function(s) {
					return s.id !== sid;
				});
			});
		}
		updateShipmentBulkUI();
	}

	function clearShipmentSelection() {
		selectedShipments = [];
		$(".checkShipment").prop('checked', false);
		$("#masterShipmentCb").prop('checked', false);
		updateShipmentBulkUI();
	}

	function updateShipmentBulkUI() {
		var count = selectedShipments.length;
		$("#bulkShipmentCount").text(count);
		$("#bulkShipmentBtn").prop('disabled', count === 0);
	}

	// fnDrawCallback: restore checked state on page change
	// (same as before but check by id field)
	function restoreShipmentCheckboxes() {
		$(".checkShipment").each(function() {
			var sid = this.value;
			var isSelected = selectedShipments.find(function(s) {
				return s.id === sid;
			});
			$(this).prop('checked', !!isSelected);
		});
		var total = $(".checkShipment").length;
		var checked = $(".checkShipment:checked").length;
		$("#masterShipmentCb")
			.prop('indeterminate', checked > 0 && checked < total)
			.prop('checked', total > 0 && checked === total);
		updateShipmentBulkUI();
	}

	function bulkDownloadShipments() {
		if (selectedShipments.length === 0) return;
		$.blockUI();
		$.post(
			"<?php echo $this->url(array('module' => 'reports', 'controller' => 'shipments', 'action' => 'bulk-download-shipment-report-excel')); ?>", {
				shipments: selectedShipments, // [{id, scheme}, ...]
				format: 'html'
			},
			function(data) {
				if (data && data !== '') {
					document.location.href = '/temporary/' + data;
				} else {
					alert("<?= $this->jsTranslate('Unable to generate bulk download'); ?>");
				}
				$.unblockUI();
			}
		);
	}
	$(document).ready(function() {
		$("#dataManager").select2({
			placeholder: "Select PT participant login",
			allowClear: true
		});

		$('#dateRange').daterangepicker({
				locale: {
					cancelLabel: 'Clear',
					format: 'DD-MMM-YYYY',
					separator: ' to ',
				},
				autoApply: true,
				showDropdowns: true,
				alwaysShowCalendars: true,
				autoUpdateInput: false,
				// startDate: moment().subtract(366, 'days'),
				// endDate: moment(),
				// maxDate: moment(),
				ranges: {
					'This Month': [moment().startOf('month'), moment().endOf('month')],
					'Last Month': [moment().subtract(1, 'month').startOf('month'), moment().subtract(1, 'month').endOf('month')],
					'Last 60 Days': [moment().subtract(59, 'days'), moment()],
					'Last 90 Days': [moment().subtract(89, 'days'), moment()],
					'Last 180 Days': [moment().subtract(179, 'days'), moment()],
					'Last 12 Months': [moment().subtract(12, 'month'), moment()],
					'Last 18 Months': [moment().subtract(18, 'month'), moment()],
					'Previous Year': [moment().subtract(1, 'year').startOf('year'), moment().subtract(1, 'year').endOf('year')],
					'Current Year To Date': [moment().startOf('year'), moment()]
				}
			},
			function(start, end) {
				startDate = start.format('DD-MMM-YYYY');
				endDate = end.format('DD-MMM-YYYY');
			});

		getDrawable();
	});

	function getDrawable() {
		/* if ($("#dateRange").val() == '') {
			alert("Please select date range");
			return false;
		} else { */
		$.blockUI();
		drawTable();
		$.unblockUI();
		// }
	}

	function drawTable() {
		var dateRange = $("#dateRange").val();
		var _dateRange = dateRange.split(" to ");
		startDate = _dateRange[0];
		endDate = _dateRange[1];
		$("#shipmentTable").removeClass("hide");
		$.blockUI;
		oTable = $('#shipmentTable').dataTable({

			"bJQueryUI": false,
			"bAutoWidth": false,
			"bInfo": true,
			"bScrollCollapse": true,
			"sPaginationType": "bootstrap",
			"bRetrieve": false,
			"bDestroy": true,
			"bSortCellsTop": true,
			"aoColumns": [{
					"sClass": "center",
					"bSortable": false
				}, // NEW: checkbox col
				{
					"sClass": "center"
				}, // PT Survey Code
				{
					"sClass": "center"
				}, // PT Survey Date
				{
					"sClass": "center"
				}, // Shipment Code
				{
					"sClass": "center"
				}, // Result Due Date
				{
					"sClass": "center"
				}, // Scheme
				{
					"sClass": "center"
				}, // Participants
				{
					"sClass": "center"
				}, // Responses
				{
					"sClass": "center"
				}, // Passed
				{
					"sClass": "center"
				}, // Status
				{
					"sClass": "center",
					"bSortable": false
				}, // Reports for Participants
				{
					"sClass": "center",
					"bSortable": false
				}, // Reports for PT Admin
			],
			"aaSorting": [
				[1, "desc"]
			],
			"bProcessing": true,
			"bServerSide": true,
			"sAjaxSource": "<?php echo $this->url(array('module' => 'reports', 'controller' => 'shipments', 'action' => 'index', 'format' => 'html')); ?>",
			"fnServerParams": function(aoData) {
				dateRange = $("#dateRange").val();
				dataManager = $("#dataManager").val();
				aoData.push({
					"name": "dateRange",
					"value": dateRange
				});
				aoData.push({
					"name": "startDate",
					"value": startDate
				});
				aoData.push({
					"name": "endDate",
					"value": endDate
				});
				aoData.push({
					"name": "dataManager",
					"value": dataManager
				});
			},
			"fnServerData": function(sSource, aoData, fnCallback) {
				$.ajax({
					"dataType": 'json',
					"type": "POST",
					"url": sSource,
					"data": aoData,
					"success": fnCallback
				});
			},
			"fnRowCallback": function(nRow, aData, iDisplayIndex) {
				$(".checkShipment").each(function() {
					if ($.inArray(this.value, selectedShipments) !== -1) {
						$(this).prop('checked', true);
					}
				});
				// Update master checkbox indeterminate state
				var total = $(".checkShipment").length;
				var checked = $(".checkShipment:checked").length;
				$("#masterShipmentCb").prop('indeterminate', checked > 0 && checked < total);
				$("#masterShipmentCb").prop('checked', total > 0 && checked === total);
				updateShipmentBulkUI();
				$.unblockUI;
			},
		});

		bindColSearch('#shipmentTable', function(value, colIdx) {
			if (oTable) {
				oTable.fnFilter(value, colIdx);
			}
		});
	};

	function generateShipmentParticipantList(shipmentId, schemeType) {
		$.blockUI();
		$.post("<?php echo $this->url(array('module' => 'reports', 'controller' => 'shipments', 'action' => 'get-shipment-participant-list')); ?>", {
				shipmentId: shipmentId,
				schemeType: schemeType,
				format: "html"
			},
			function(data) {
				if (data != "") {
					//alert(data);$.unblockUI();return;
					document.location.href = '/temporary/' + data;
				}
				$.unblockUI();
			});
	}

	function downloadFeedbackReport(shipmentId) {
		$.blockUI();
		$.post("/admin/feedback-responses/get-feedback-response-report", {
				sid: shipmentId,
				format: "html"
			},
			function(data) {
				if (data != "") {
					document.location.href = '/temporary/' + data;
				} else {
					alert("<?= $this->jsTranslate("No feedback responses found for this shipment"); ?>");
				}
				$.unblockUI();
			});
	}

	function exportNotRespondedShipment(_shipmentId, _shipmentCode, _shipmentDate) {
		$.blockUI();
		$.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'shipment', 'action' => 'export-shipment-not-responded-participants')); ?>", {
				shipmentId: atob(_shipmentId),
				shipmentCode: atob(_shipmentCode),
				shipmentDate: atob(_shipmentDate),
				format: "html"
			},
			function(data) {
				if (data == "" || data == null || data == undefined) {
					alert("<?= $this->jsTranslate("Unable to generate download"); ?>");
				} else {
					document.location.href = '/temporary/' + data;
				}
				$.unblockUI();
			});
	}
</script>