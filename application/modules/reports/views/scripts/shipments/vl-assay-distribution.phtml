<script type="text/javascript">
    var startDate = "";
    var endDate = "";
    var allTime = false;
    var paginate = true;

    function initShipmentSelect() {
        $("#shipmentId").select2({
            width: '100%',
            placeholder: '-- All shipments in range --',
            allowClear: true
        });
    }

    $(document).ready(function () {
        initShipmentSelect();
        $('#dateRange').daterangepicker({
            locale: {
                cancelLabel: 'Clear',
                format: 'DD-MMM-YYYY',
                separator: ' to ',
            },
            autoApply: true,
            showDropdowns: true,
            alwaysShowCalendars: true,
            autoUpdateInput: true,
            ranges: {
                'All Time': [moment('2000-01-01'), moment()],
                'This Month': [moment().startOf('month'), moment().endOf('month')],
                'Last Month': [moment().subtract(1, 'month').startOf('month'), moment().subtract(1, 'month').endOf('month')],
                'Last 60 Days': [moment().subtract(59, 'days'), moment()],
                'Last 90 Days': [moment().subtract(89, 'days'), moment()],
                'Last 180 Days': [moment().subtract(179, 'days'), moment()],
                'Last 12 Months': [moment().subtract(12, 'month'), moment()],
                'Last 18 Months': [moment().subtract(18, 'month'), moment()],
            }
        },
            function (start, end, label) {
                allTime = (label === 'All Time');
                startDate = start.format('DD-MMM-YYYY');
                endDate = end.format('DD-MMM-YYYY');
                getShipmentCodes();
            });
    });

    function getShipmentCodes() {
        schemeType = 'vl';
        if (startDate == "" || endDate == "") {
            alert('Please pick a date range to fetch shipment list');
            $('#dateRange').focus();
            return false;
        }
        $.blockUI();
        $.post("<?php echo $this->url(array('module' => 'reports', 'controller' => 'common', 'action' => 'get-shipments-by-scheme')); ?>", {
            schemeType: schemeType,
            startDate: startDate,
            endDate: endDate,
            format: "html"
        },
            function (data) {
                // Tear down Select2 before swapping the underlying <option> set, then re-init.
                $("#shipmentId").select2('destroy');
                if (data != 0) {
                    $("#shipmentId").html(data);
                    // Drop the "All shipments" placeholder option; multiselect uses an empty selection for that.
                    $("#shipmentId option[value='']").remove();
                } else {
                    $("#shipmentId").html('');
                }
                initShipmentSelect();
                $.unblockUI();
            });
    }

    function drawTable() {
        if ($("#dateRange").val() == "") {
            alert("Please pick a date range (or 'All Time') to proceed");
            return false;
        }
        var dateRange = $("#dateRange").val();
        var _dateRange = dateRange.split(" to ");
        startDate = _dateRange[0];
        endDate = _dateRange[1];
        //$("#shipmentTable").removeClass("hide");
        //$.blockUI;
