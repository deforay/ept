/**
 * Import Custom Test Page
 * -----------------------
 * $this->result is the decoded JSON export (tests[0]) normalised by the controller
 * into the same shape the edit page uses:
 *
 *   $this->result['schemeResult']   — mirrors scheme_list row
 *   $this->result['possibleResult'] — mirrors r_possibleresult rows
 *
 * Controller should do:
 *   $json = json_decode(file_get_contents($uploadedFile), true);
 *   $test = $json['tests'][0];
 *   $userConfig = $test['scheme']['user_test_config'];   // already array
 *
 *   $this->view->result = [
 *       'schemeResult' => [
 *           'scheme_id'        => $test['scheme']['scheme_id'],
 *           'scheme_name'      => $test['scheme']['scheme_name'],
 *           'status'           => $test['scheme']['status'],
 *           'user_test_config' => json_encode($userConfig),   // keep as JSON string
 *       ],
 *       'possibleResult' => $test['possibleResults'],   // array of rows as-is
 *   ];
 */

// ── Decode user_test_config (same as edit.phtml) ──────────────────────────────
$jsonConfig = [];
if (!empty($this->result['schemeResult']['user_test_config'])) {
    $jsonConfig = Zend_Json_Decoder::decode($this->result['schemeResult']['user_test_config'], true);
}

// ── Group & sort possibleResult by sub_scheme (same as edit.phtml) ────────────
$qualitativeRows = [];
if (!empty($this->result['possibleResult'])) {
    foreach ($this->result['possibleResult'] as $row) {
        $qualitativeRows[$row['sub_scheme']][] = $row;
    }
    foreach ($qualitativeRows as $subScheme => &$rows) {
        usort($rows, function ($a, $b) {
            $order  = ['TEST' => 0, 'FINAL' => 1];
            $aOrder = $order[$a['scheme_sub_group']] ?? 2;
            $bOrder = $order[$b['scheme_sub_group']] ?? 2;
            if ($aOrder !== $bOrder) return $aOrder - $bOrder;
            return ($a['sort_order'] ?? 0) - ($b['sort_order'] ?? 0);
        });
    }
    unset($rows);
}

$schemeCodeValue = $this->result['schemeResult']['scheme_id']   ?? '';
$schemeNameValue = $this->result['schemeResult']['scheme_name'] ?? '';
