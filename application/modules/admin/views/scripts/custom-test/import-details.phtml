<script type="text/javascript" src="<?php echo $this->baseUrl('js/select2.min.js'); ?>"></script>
<script type="text/javascript" src="<?php echo $this->baseUrl('js/bootstrap-select.min.js'); ?>"></script>
<script type="text/javascript" src="<?php echo $this->baseUrl('js/jquery.multi-select.js'); ?>"></script>
<script type="text/javascript">
    var duplicated = false;
    var codeDuplicated = false;
    var schemeCodeCheckTimer = null;
    var schemeCodeExclude = '';
    var cloneSourceCode = '';
    var sampleCounter = <?php echo !empty($this->result['possibleResult']) ? count($this->result['possibleResult']) : 1; ?>;

    function checkDuplicate(tableName, fieldName, obj, fnct, msg) {
        $.post("<?php echo $this->url(['module' => 'default', 'controller' => 'common', 'action' => 'check-duplicate']); ?>", {
            tableName: tableName,
            fieldName: fieldName,
            value: obj.value,
            fnct: fnct,
            format: 'html'
        }, function(data) {
            if (data > 0) {
                alert(msg, 'err');
                duplicated = true;
                $(obj).val('');
            } else {
                duplicated = false;
            }
        });
    }

    function validateQualitativeResults() {
        var qualitativeVisible = false;
        $('.qualitative-div').each(function() {
            if (!$(this).hasClass('hide')) qualitativeVisible = true;
        });
        if (!qualitativeVisible) return true;

        var resultsByType = {
            'test-result': [],
            'final-interpretation': []
        };
        var allResultCodes = [];
        var valid = true;

        $('.resultTypeInput').each(function() {
            if (!valid) return false;
            var resultType = $(this).val();
            if (!resultType) return;
            var row = $(this).closest('tr');
            var expectedResult = row.find('input[name*="[expectedResult]"]').val();
            if (expectedResult && expectedResult.trim() !== '') {
                var norm = expectedResult.trim().toLowerCase();
                if (resultsByType[resultType] && resultsByType[resultType].includes(norm)) {
                    alert('Duplicate expected result "' + expectedResult + '" found for Result Type "' + (resultType === 'test-result' ? 'Test Result' : 'Final Interpretation') + '". Each expected result must be unique within a result type.');
                    valid = false;
                    return false;
                }
                if (resultsByType[resultType]) resultsByType[resultType].push(norm);
            }
            var resultCode = row.find('input[name*="[resultCode]"]').val();
            if (resultCode && resultCode.trim() !== '') {
                var normCode = resultCode.trim().toUpperCase();
                if (allResultCodes.includes(normCode)) {
                    alert('Duplicate Result Code "' + resultCode + '" found. Each result code must be unique.');
                    valid = false;
                    return false;
                }
                allResultCodes.push(normCode);
            }
        });
        return valid;
    }

    function validateNow() {
        var flag = deforayValidator.init({
            formId: 'importGenericTestForm'
        });
        if (flag && !duplicated && !codeDuplicated) {
            if (!validateQualitativeResults()) return false;
            $.blockUI();
            document.getElementById('importGenericTestForm').submit();
        }
    }

    function addQualitativeRow(obj, row1, row2) {
        $(obj).attr('disabled', true);
        var html = '<tr align="center">' +
            '<td><input type="text" name="qualitative[expectedResult][' + row1 + '][' + row2 + ']" class="form-control qualitative-input-' + row1 + row2 + ' input-sm" placeholder="Enter the expected result" title="Please enter the expected result" /></td>' +
            '<td><div class="input-group input-group-sm"><span class="input-group-addon resultCodePrefix" style="display:none;padding:6px 8px;"></span><input type="text" class="form-control isRequired qualitative-input-' + row1 + row2 + ' input-sm resultCodeSuffix" placeholder="Code" maxlength="20" title="Please enter the result code"/></div><input type="hidden" name="qualitative[resultCode][' + row1 + '][' + row2 + ']" class="resultCodeHidden" /></td>' +
            '<td><select id="resultType' + row1 + row2 + '" name="qualitative[resultType][' + row1 + '][' + row2 + ']" class="form-control isRequired qualitative-input-' + row1 + row2 + ' input-sm resultTypeInput" title="Please select the result type" onchange="resultTypeChange(' + row1 + ',' + row2 + ')"><option value="">-- <?= $this->translate->_("Select"); ?> --</option><option value="test-result"><?= $this->translate->_("Test Result"); ?></option><option value="final-interpretation"><?= $this->translate->_("Final Interpretation"); ?></option></select></td>' +
            '<td><select id="displayContext' + row1 + row2 + '" name="qualitative[displayContext][' + row1 + '][' + row2 + ']" class="form-control qualitative-input-' + row1 + row2 + ' input-sm" title="Please select the displayed context"><option value=""> -- <?= $this->translate->_("Select"); ?> -- </option><option value="participant"><?= $this->translate->_("Participant"); ?></option><option value="admin"><?= $this->translate->_("Admin"); ?></option><option value="all"><?= $this->translate->_("All"); ?></option></select></td>' +
            '<td><input type="text" name="qualitative[sortOrder][' + row1 + '][' + row2 + ']" class="form-control qualitative-input-' + row1 + row2 + ' input-sm" placeholder="Enter the sort order" title="Please enter the sort order" /></td>' +
            '<td><a href="javascript:void(0);" onclick="addQualitativeRow(this,' + row1 + ',' + (row2 + 1) + ');" class="btn btn-xs btn-info qualitative-insrow-' + row1 + row2 + '"><i class="icon-plus"></i></a>&nbsp;&nbsp;<a href="javascript:void(0);" onclick="removeQualitativeRow(this,' + row1 + ',' + (row2 - 1) + ')" class="btn btn-xs btn-danger" title="Remove this row completely"><i class="icon-minus"></i></a></td>' +
            '</tr>';
        $(obj.parentNode.parentNode).after(html);
    }

    function addNewRow(obj) {
        $('.firstSubTest').removeClass('hide');
        $('#resultSubGroup1').addClass('isRequired');
        sampleCounter++;
        // (same addNewRow html as original add.phtml — omitted for brevity, copy from original)
        $(obj.parentNode.parentNode).after('<!-- addNewRow html here -->');
        $(".datepicker").datepicker({
            dateFormat: '<?php echo $this->defaultDateFormat(); ?>'
        });
    }

    $(document).ready(function() {
        $(".datepicker").datepicker({
            dateFormat: '<?php echo $this->defaultDateFormat(); ?>'
        });

        $('#captureAdditionalDetails').on('change', function() {
            if ($(this).val() == 'yes') {
                $('#additionalDetailLabelGroup').show();
                $('#additionalDetailLabel').addClass('isRequired');
            } else {
                $('#additionalDetailLabelGroup').hide();
                $('#additionalDetailLabel').removeClass('isRequired');
            }
        });

        $(document).on('input', '.resultCodeSuffix', function() {
            updateResultCode($(this).closest('tr'));
        });

        $('#schemeCode').on('input', function() {
            toggleTestsSection();
            clearTimeout(schemeCodeCheckTimer);
            schemeCodeCheckTimer = setTimeout(checkSchemeCodeDuplicate, 400);
            $('.resultCodeSuffix').each(function() {
                updateResultCode($(this).closest('tr'));
            });
        });
        $('#schemeCode').on('blur', function() {
            clearTimeout(schemeCodeCheckTimer);
            checkSchemeCodeDuplicate();
        });

        toggleTestsSection();

        // Init result-code rows (strips prefix from pre-filled full codes)
        $('.resultCodeSuffix').each(function() {
            initResultCodeRow($(this).closest('tr'));
        });

        // Show/hide qualitative vs quantitative for each pre-filled sub-group
        $('.test-type').each(function(index) {
            setTestFormatType($(this).val(), index + 1);
        });
    });

    function removeQualitativeRow(obj, row1, row2) {
        $('.qualitative-insrow-' + row1 + row2).attr('disabled', false);
        $(obj.parentNode.parentNode).fadeOut('normal', function() {
            $(this).remove();
        });
    }

    function removeRow(obj) {
        $(obj.parentNode.parentNode).fadeOut('normal', function() {
            $(this).remove();
        });
    }

    function setTestFormatType(id, row) {
        if (id == 'qualitative') {
            $('.quantitative-input' + row).removeClass('isRequired');
            $('#qualitativeRow' + row).removeClass('hide');
            $('.qualitative-input' + row).addClass('isRequired');
            $('#quantitativeRow' + row).addClass('hide');
            $('#quantitativeWarning' + row).addClass('hide');
        } else if (id == 'quantitative') {
            $('.qualitative-input' + row).removeClass('isRequired');
            $('#quantitativeRow' + row).removeClass('hide');
            $('#quantitativeWarning' + row).removeClass('hide');
            $('.quantitative-input' + row).addClass('isRequired');
            $('#qualitativeRow' + row).addClass('hide');
        }
    }

    function checkSchemeCodeDuplicate() {
        var $code = $('#schemeCode'),
            $fb = $('#schemeCodeFeedback');
        var value = ($code.val() || '').trim();
        if (value === '') {
            codeDuplicated = false;
            $code.removeClass('input-dup-error');
            $fb.hide().text('');
            return;
        }
        $.post("<?php echo $this->url(['module' => 'default', 'controller' => 'common', 'action' => 'check-duplicate']); ?>", {
            tableName: 'scheme_list',
            fieldName: 'scheme_id',
            value: value,
            fnct: schemeCodeExclude,
            format: 'html'
        }, function(data) {
            if (parseInt(data, 10) > 0) {
                codeDuplicated = true;
                $code.addClass('input-dup-error');
                $fb.removeClass('text-success').addClass('text-danger').html('<i class="icon-warning-sign"></i> This code is already in use. Please choose a different one.').show();
            } else {
                codeDuplicated = false;
                $code.removeClass('input-dup-error');
                $fb.removeClass('text-danger').addClass('text-success').html('<i class="icon-ok"></i> This code is available.').show();
            }
        });
    }

    function toggleTestsSection() {
        ($('#schemeCode').val() || '').trim() !== '' ? $('#testsSection').show() : $('#testsSection').hide();
    }

    function getResultCodePrefix(row) {
        var schemeCode = ($('#schemeCode').val() || '').toUpperCase().trim();
        var resultType = row.find('.resultTypeInput').val();
        if (!schemeCode) return '';
        if (resultType === 'test-result') return schemeCode + '-T-';
        if (resultType === 'final-interpretation') return schemeCode + '-F-';
        return schemeCode + '-';
    }

    function updateResultCode(row) {
        var prefix = getResultCodePrefix(row);
        var $suffix = row.find('.resultCodeSuffix');
        var raw = ($suffix.val() || '').toUpperCase().replace(/[^A-Z0-9]/g, '');
        if ($suffix.val() !== raw) $suffix.val(raw);
        var $addon = row.find('.resultCodePrefix');
        if (prefix) {
            $addon.text(prefix).show();
        } else {
            $addon.text('').hide();
        }
        row.find('.resultCodeHidden').val(raw ? prefix + raw : '');
    }

    function initResultCodeRow(row) {
        var $suffix = row.find('.resultCodeSuffix');
        var raw = ($suffix.val() || '').toUpperCase();
        var prefix = getResultCodePrefix(row);
        if (prefix && raw.indexOf(prefix) === 0) {
            $suffix.val(raw.substring(prefix.length));
        } else {
            var schemeCode = ($('#schemeCode').val() || '').toUpperCase().trim() || cloneSourceCode;
            if (schemeCode && raw.indexOf(schemeCode + '-') === 0) {
                var rest = raw.substring(schemeCode.length + 1).replace(/^[TF]-/, '');
                $suffix.val(rest);
            }
        }
        updateResultCode(row);
    }

    function resultTypeChange(rrow, srow) {
        var resultType = $('#resultType' + rrow + srow).val();
        if (resultType == 'test-result') $('#displayContext' + rrow + srow).val('participant');
        updateResultCode($('#resultType' + rrow + srow).closest('tr'));
    }

    $(function() {
        $("#customTestkit").select2({
            placeholder: 'Please Choose Test Kit',
            minimumInputLength: 0,
            width: '100%',
            allowClear: true,
            ajax: {
                url: "<?php echo $this->url(['module' => 'reports', 'controller' => 'common', 'action' => 'testkit-list'], 'default', true); ?>",
                dataType: 'json',
                delay: 250,
                data: function(p) {
                    return {
                        q: p.term,
                        page: p.page
                    };
                },
                processResults: function(data, p) {
                    p.page = p.page || 1;
                    return {
                        results: data.result,
                        pagination: {
                            more: (p.page * 30) < data.total_count
                        }
                    };
                }
            },
            escapeMarkup: function(m) {
                return m;
            }
        });
    });
</script>