            <div id="respond" style="margin:0 auto;text-align:center;" class="form-group col-lg-11" align="center">
                <input name="submitbtn" class="btn btn-primary" type="submit" tabindex="7" value="<?= $this->translate->_("Add"); ?>" />
                <input class="btn btn-danger" type="button" onclick="window.location.href='/admin/custom-test';" tabindex="8" value="<?= $this->translate->_("Cancel"); ?>" />
            </div>

