        ['label' => 'SD',            'key' => 'manualSd',           'val' => 'manual_sd',             'sys' => 'sd'],
        ['label' => 'CV',            'key' => 'manualCv',           'val' => 'manual_cv',             'sys' => null],
        ['label' => 'Q1',            'key' => 'manualQ1',           'val' => 'manual_q1',             'sys' => null],
        ['label' => 'Q3',            'key' => 'manualQ3',           'val' => 'manual_q3',             'sys' => null],
        ['label' => 'IQR',           'key' => 'manualIqr',          'val' => 'manual_iqr',            'sys' => null],
        ['label' => 'Quartile Low',  'key' => 'manualQuartileLow',  'val' => 'manual_quartile_low',   'sys' => null],
        ['label' => 'Quartile High', 'key' => 'manualQuartileHigh', 'val' => 'manual_quartile_high',  'sys' => null],
        ['label' => 'Low Limit',     'key' => 'manualLowLimit',     'val' => 'manual_low_limit',      'sys' => 'low_limit'],
        ['label' => 'High Limit',    'key' => 'manualHighLimit',    'val' => 'manual_high_limit',     'sys' => 'high_limit'],
