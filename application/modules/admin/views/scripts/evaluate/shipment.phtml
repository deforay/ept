	<script type="text/javascript" charset="utf-8">
		var oTable = null;
		var nTr = null;
		$(document).ready(function () {
			let overrideStatus = '<?php echo (isset($overrideStatus) && $overrideStatus != "") ? $overrideStatus : true; ?>';
			if (overrideStatus != 'yes') {
				$('#overrideTable').hide();
			}
			$('#shipmentEvaluation').on('click', ".clicker", function () {
				nTr = $(this).parents('tr')[0];
				aData = oTable.fnGetData(nTr);
				if (oTable.fnIsOpen(nTr)) {
					//console.log(aData[5]);
					/* This row is already open - close it */
					$(this).find('i').addClass("icon-plus");
					$(this).find('i').removeClass("icon-minus");
					//$(this).removeClass('btn-danger');

					// Preserve the original state color so excluded / not evaluated rows stay neutral.
					$(this)
						.removeClass('btn-success btn-danger btn-warning btn-default')
						.addClass($(this).data('btn-class'));

					oTable.fnClose(nTr);
				} else {
					/* Open this row */
					$(this).find('i').addClass("icon-minus");
					$(this).find('i').removeClass("icon-add");
					//$(this).removeClass('btn-success');
					//$(this).addClass('btn-danger');
					oTable.fnOpen(nTr, fnFormatDetails(oTable, nTr), 'details');
				}
			});

			oTable = $("#shipmentEvaluation").dataTable({
				"bJQueryUI": false,
				"bAutoWidth": false,
				"bInfo": true,
				"bScrollCollapse": true,
				"sPaginationType": "bootstrap",
				"bRetrieve": false,
				"bDestroy": true,
				"bProcessing": true,
				"bServerSide": true,
				"sAjaxSource": "<?php echo $this->url(['module' => 'admin', 'controller' => 'evaluate', 'action' => 'shipment', 'sid' => $this->id, 'format' => 'html']); ?>",
				"fnServerParams": function (aoData) {
					<?php if (!empty($this->override)) { ?>
						aoData.push({ "name": "override", "value": "<?= $this->override; ?>" });
					<?php } ?>
				},
				"fnServerData": function (sSource, aoData, fnCallback) {
					$.ajax({
						"dataType": "json",
						"type": "POST",
						"url": sSource,
						"data": aoData,
						"success": fnCallback
					});
				},
				"aoColumns": [
					{ "bSortable": false },
					{ "sClass": "" },
					{ "sClass": "center" },
					{ "sClass": "center" },
					{ "sClass": "center" },
					{ "sClass": "" },
					{ "sClass": "" },
					{ "sClass": "center" },
					{ "bSearchable": false, "bVisible": false },
					{ "sClass": "center", "bSortable": false }
				],
				"aaSorting": [
					[1, "asc"]
				]
			});
		});

		function scheduleShipmentEvaluation(sid) {
			$.blockUI();
			$.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'evaluate', 'action' => 'schedule-evaluation'), 'default', true); ?>", {
				sid: sid,
				format: "html"
			},
				function (data) {
					$.unblockUI();
					alert("<?= $this->jsTranslate('Shipment has been added to the queue. It will be evaluated shortly.'); ?>");
					document.location.href = "/admin/evaluate";
				});
		}

		function manualOverride(value) {
			$.blockUI();
			var url = '/admin/evaluate/shipment/sid/<?php echo $this->id; ?>';
			val = '';
			if (value == 'yes') {
				val = "eWVz";
			}
			if (value == 'no') {
				val = "bm8=";
			}
			if (val != '') {
				window.location.href = url + "/override/" + val;
			} else {
				window.location.href = url;
			}
			$.unblockUI();
		}

		function fnFormatDetails(oTable, nTr) {
			var aData = oTable.fnGetData(nTr);
			var sOut = '<div class="text-center"><i class="icon-spinner icon-spin"></i> Loading...</div>';
			// map_id is in the hidden column at index 8.
			var mapId = aData[8];
			// Load corrective actions via AJAX
			$.ajax({
				url: '/common/get-corrective-actions/mid/' + mapId,
				data: { format: 'html' },
				async: false,
				success: function (html) {
					sOut = '<div style="padding-left:50px;">' + html + '</div>';
				},
				error: function () {
					sOut = '<div class="text-muted">Failed to load corrective actions</div>';
				}
			});
			return sOut;
		}


		// One-time bindings for the delete-confirm modal. Per-row params are stored on the
		// modal's submit button via data() so handlers don't need to be rewired on each open.
		$(function () {
			var $modal = $('#deleteResponseConfirmModal');
			if ($modal.length === 0) { return; }

			// Escape the wrapping stacking context once so the backdrop never traps clicks.
			if ($modal.parent().get(0) !== document.body) {
				$modal.appendTo('body');
			}

			var $input = $('#deleteResponseConfirmInput');
			var $btn = $('#deleteResponseConfirmBtn');
			var $mismatch = $('#deleteResponseMismatch');

			$input.on('input keyup', function () {
				var expected = ($btn.data('uniqueId') || '').toString();
				var matches = $(this).val().trim() === expected;
				$btn.prop('disabled', !matches);
				if (matches) { $mismatch.hide(); }
			});

			$btn.on('click', function () {
				if ($btn.prop('disabled')) { return; }
				var expected = ($btn.data('uniqueId') || '').toString();
				if ($input.val().trim() !== expected) {
					$mismatch.show();
					return;
				}
				var schemeType = $btn.data('schemeType');
				var mid = $btn.data('mid');
				var userConfig = $btn.data('userConfig');
				$modal.modal('hide');
				doRemoveScheme(schemeType, mid, userConfig);
			});

			$modal.on('shown.bs.modal', function () {
				$('.modal-backdrop').last().addClass('delete-response-backdrop');
				$input.trigger('focus');
			});
		});

		function removeSchemes(schemeType, mid, userConfiguration, participantName, uniqueId) {
			if (typeof userConfiguration === 'undefined') { userConfiguration = 'no'; }
			uniqueId = (uniqueId || '').toString();
			participantName = (participantName || '').toString();

			// Fallback for callers that didn't pass a uniqueId — keep the old single-confirm.
			if (uniqueId === '') {
				if (!window.confirm("<?= $this->jsTranslate('Are you sure you want to remove this response? This cannot be undone!'); ?>")) {
					return;
				}
				doRemoveScheme(schemeType, mid, userConfiguration);
				return;
			}

			$('#deleteResponseParticipant').text(participantName);
			$('#deleteResponseUniqueId').text(uniqueId);
			$('#deleteResponseConfirmInput').val('');
			$('#deleteResponseMismatch').hide();
			$('#deleteResponseConfirmBtn')
				.prop('disabled', true)
				.data('schemeType', schemeType)
				.data('mid', mid)
				.data('userConfig', userConfiguration)
				.data('uniqueId', uniqueId);

			$('#deleteResponseConfirmModal').modal('show');
		}

		function doRemoveScheme(schemeType, mid, userConfiguration) {
			$.blockUI();
			$.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'evaluate', 'action' => 'delete-dts-response'), 'default', true); ?>", {
				mid: mid,
				schemeType: schemeType,
				userConfig: userConfiguration,
				format: "html"
			})
				.done(function (data) {
					alert("<?= $this->jsTranslate('Response has been removed successfully. Reloading this evaluation.'); ?>");
					window.location.reload();
				})
				.fail(function (xhr) {
					$.unblockUI();
					alert("<?= $this->jsTranslate('Failed to delete the response. Please try again or contact the administrator.'); ?>");
				});
		}

		function mailNonParticipants(sid) {
			if (window.confirm("<?= $this->jsTranslate('Are you sure you want to send an email reminder to participants who have not yet responded?'); ?>")) {
				$.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'shipment', 'action' => 'not-participated-mail')); ?>", {
					sid: sid,
					format: "html"
				},
					function (data) {
						if (data > 0) {
							alert("<?= $this->jsTranslate('Mail Sent successfully'); ?>");
						}
						oTable.fnDraw();
					});
			}

		}
	</script>
	</div>

<?php } else { ?>

	<br /><br /><br />
	<h3 style="text-align: center"><?= $this->htmlTranslate('No Shipment to evaluate.'); ?> <a
			href="<?php echo $this->url(array('module' => 'admin', 'controller' => 'evaluate', 'action' => 'index'), 'default', true); ?>"><?= $this->htmlTranslate('Click here to go back'); ?></a></h3>

<?php } ?>