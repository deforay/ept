<h4 style="width:100%;height:50px;border-bottom:1px solid #777;">
    <div style="font-size:22.5px;line-height:36px;color:#333;float:left;"><?= $this->translate->_("Feedback Form"); ?>
    </div>
    <div style="margin-top:10px;"><a
            href="<?php echo $this->url(array('module' => 'admin', 'controller' => 'feedback-responses', 'action' => 'feedback-form'), 'default', true); ?>"
            class="btn btn-primary" style="float:right;"><i
                class="icon-plus"></i>&nbsp;&nbsp;<?= $this->translate->_("Create New Feedback Form"); ?></a></div>
</h4>
<table cellpadding="0" cellspacing="0" border="0" class="table table-striped table-bordered table-hover"
    id="feedbackResponse">
    <thead>
        <tr>
            <th scope="col" style="width:20%;"><?= $this->translate->_("Shipment Code"); ?></th>
            <th scope="col" style="width:20%;"><?= $this->translate->_("Scheme Name"); ?></th>
            <th scope="col" style="width:30%;"><?= $this->translate->_("Number of Question Mapped"); ?></th>
            <th scope="col" style="width:10%;"><?= $this->translate->_("Action"); ?></th>
        </tr>
        <tr class="column-search-row">
            <th scope="col"><input type="text" class="form-control input-sm col-search" data-col="0" placeholder="<?= $this->translate->_('Search Survey Code'); ?>" /></th>
            <th scope="col"><input type="text" class="form-control input-sm col-search" data-col="1" placeholder="<?= $this->translate->_('Search Code'); ?>" /></th>
            <th scope="col"></th>
            <th scope="col"></th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td colspan="4" class="dataTables_empty"><?= $this->translate->_("Loading data from server"); ?></td>
        </tr>
    </tbody>
</table>

<script type="text/javascript" charset="utf-8">
    /* Table initialisation */
    var oTable = null;
    $(document).ready(function () {
        oTable = $('#feedbackResponse').dataTable({

            "bJQueryUI": false,
            "bAutoWidth": false,
            "bInfo": true,
            "bScrollCollapse": true,
            "sPaginationType": "bootstrap",
            "bRetrieve": true,
            "aoColumns": [{
                "sClass": "center"
            },
            {
                "sClass": "center",
            },
            {
                "sClass": "center",
            },
            {
                "sClass": "center",
                "bSortable": false
            }
            ],
            "aaSorting": [
                [0, "ASC"]
            ],
            "bProcessing": true,
            "bServerSide": true,
            "sAjaxSource": "<?php echo $this->url(array('module' => 'admin', 'controller' => 'feedback-responses', 'action' => 'shipment-questions', 'format' => 'html')); ?>",
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.ajax({
                    "dataType": 'json',
                    "type": "POST",
                    "url": sSource,
                    "data": aoData,
                    "success": fnCallback
                });
            },
             "fnRowCallback": function (nRow, aData) {
                // Highlight rows with no mapped data managers (the DM column emits
                // <em class="unmapped-tag">…</em> when the count is 0)
                if ($(nRow).find('.unmapped-tag').length > 0) {
                    $(nRow).addClass('row-unmapped');
                } else {
                    $(nRow).removeClass('row-unmapped');
                }
                return nRow;
            }
        });

    $("#mappingFilter").change(function () {
        oTable.fnDraw();
    });

    bindColSearch('#feedbackResponse', function (value, colIdx) {
        oTable.fnFilter(value, colIdx);
    });

     // Data Managers column — expand/collapse child row with on-demand AJAX fetch
        $('#feedbackResponse tbody').on('click', 'a.toggle-dm-row', function (e) {
            e.preventDefault();
            var $btn = $(this);
            var participantId = $btn.data('participant-id');
            var tr = $btn.closest('tr')[0];
            if (oTable.fnIsOpen(tr)) {
                oTable.fnClose(tr);
                $btn.removeClass('btn-success').addClass('btn-primary');
                return;
            }
            // Inject a placeholder child row, then populate via AJAX
            var placeholder = '<div style="padding:12px;color:#888;"><i class="icon-refresh"></i> <?= $this->translate->_("Loading data managers…"); ?></div>';
            oTable.fnOpen(tr, placeholder, 'dm-child-container');
            $btn.removeClass('btn-primary').addClass('btn-success');
            $.post(
                "<?php echo $this->url(array('module' => 'admin', 'controller' => 'feedback-responses', 'action' => 'shipment-questions', 'format' => 'html')); ?>",
                { id: participantId },
                function (html) {
                    // fnOpen wraps our content in a td inside a tr — replace that td's content
                    var $childTr = $(tr).next('tr');
                    $childTr.find('td').first().html(html);
                }
            ).fail(function () {
                var $childTr = $(tr).next('tr');
                $childTr.find('td').first().html('<div style="padding:12px;color:#a94442;"><?= $this->translate->_("Failed to load data managers. Please try again."); ?></div>');
            });
        });

        // Inline filter for the expanded DM list (only present when > 5 mapped DMs)
        $('#feedbackResponse tbody').on('input', 'input.dm-filter-input', function () {
            var q = $(this).val().toLowerCase().trim();
            var $rows = $(this).closest('.dm-child-row').find('tr.dm-row');
            if (q === '') {
                $rows.show();
                return;
            }
            $rows.each(function () {
                var blob = $(this).attr('data-dm-search') || '';
                $(this).toggle(blob.indexOf(q) !== -1);
            });
        });


    });

    function generateFeedbackResponseReports(shipmentId) {
        // $.blockUI();
        $.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'feedback-responses', 'action' => 'get-feedback-response-report')); ?>", {
            sid: shipmentId,
            format: "html"
        },
            function (data) {
                if (data != "") {
                    $.unblockUI();
                    document.location.href = '/temporary/' + data;
                } else {
                    alert("Response not found for this shipment");
                }
                $.unblockUI();
            });
    }
</script>