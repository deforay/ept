<script type="text/javascript">
    function updateAvatarPreview() {
        var f = ($('#first_name').val() || '').trim();
        var l = ($('#last_name').val() || '').trim();
        var initials = (f ? f[0].toUpperCase() : '') + (l ? l[0].toUpperCase() : '');
        $('#avatarCircle').text(initials || 'AD');
        $('#avatarName').text(((f + ' ' + l).trim()) || 'Admin User');
    }

    function checkPasswordMatch() {
        var np = $('#new_password').val();
        var cp = $('#confirm_password').val();
        var hint = $('#pwMatchHint');
        if (cp.length === 0) {
            hint.removeClass('pw-match-ok pw-match-fail')
                .text('<?= $this->translate->_("Must match the new password."); ?>');
            return;
        }
        if (np === cp) {
            hint.removeClass('pw-match-fail').addClass('pw-match-ok')
                .text('<?= $this->translate->_("Passwords match."); ?>');
        } else {
            hint.removeClass('pw-match-ok').addClass('pw-match-fail')
                .text('<?= $this->translate->_("Passwords do not match."); ?>');
        }
    }

    function validateProfileForm() {
        var np = $('#new_password').val();
        var cp = $('#confirm_password').val();

        if (np !== '' || cp !== '') {
            if ($('#old_password').val() === '') {
                alert('<?= $this->translate->_("Please enter your current password to change it."); ?>');
                $('#old_password').focus();
                return false;
            }
            if (!validatePassword('#new_password')) return false;
            if (np !== cp) {
                alert('<?= $this->translate->_("New password and confirm password must match."); ?>');
                $('#confirm_password').focus();
                return false;
            }
        }

        var flag = deforayValidator.init({
            formId: 'adminProfileForm'
        });
        if (flag) {
            $.blockUI();
            document.getElementById('adminProfileForm').submit();
        }
    }

    function toggleRadios(obj) {
        var sel = $(obj).data('title');
        var tog = $(obj).data('toggle');
        $('#' + tog).prop('value', sel);
        $('a[data-toggle="' + tog + '"]').removeClass('active').addClass('notActive');
        $('a[data-toggle="' + tog + '"][data-title="' + sel + '"]').removeClass('notActive').addClass('active');
    }
</script>