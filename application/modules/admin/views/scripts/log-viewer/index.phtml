    .logv-tabs a.is-active { background: #2b6cb0; color: #fff; }
    .logv-tabs a + a { border-left: 1px solid #e2e8f0; }

    .logv-controls { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; margin-bottom: 14px; }
    .logv-controls select, .logv-controls input[type="text"], .logv-controls input[type="number"] {
        height: 36px; padding: 0 12px; border: 1px solid #e2e8f0; border-radius: 6px; background: #f7fafc; font-size: 13px; color: #2d3748;
    }
    .logv-controls input[type="text"] { min-width: 240px; flex: 1; }
    .logv-controls input[type="number"] { width: 90px; }
    .logv-controls .btn { height: 36px; padding: 0 14px; border: none; border-radius: 6px; background: #2b6cb0; color: #fff; font-size: 13px; cursor: pointer; }
    .logv-controls .btn:hover { background: #2c5282; }
    .logv-controls .btn.ghost { background: #edf2f7; color: #2d3748; }
    .logv-controls .btn.ghost:hover { background: #e2e8f0; }

    .logv-meta { font-size: 12px; color: #718096; margin: 6px 0 14px; min-height: 18px; }
    .logv-meta .pill { display: inline-block; padding: 2px 8px; border-radius: 999px; background: #edf2f7; color: #2d3748; margin-right: 6px; }

    .logv-rows { border: 1px solid #e2e8f0; border-radius: 8px; background: #fff; overflow: hidden; }
    .logv-row { display: grid; grid-template-columns: 170px 90px 1fr; gap: 12px; padding: 8px 12px; border-bottom: 1px solid #f1f5f9; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 12.5px; align-items: flex-start; }
    .logv-row:last-child { border-bottom: none; }
    .logv-row:hover { background: #f7fafc; }
    .logv-row .time { color: #718096; }
    .logv-row .level { font-weight: 600; text-transform: uppercase; font-size: 11px; letter-spacing: 0.4px; padding: 2px 6px; border-radius: 4px; align-self: flex-start; display: inline-block; }
    .level-DEBUG    { background: #edf2f7; color: #4a5568; }
    .level-INFO     { background: #ebf8ff; color: #2b6cb0; }
    .level-WARNING  { background: #fefcbf; color: #975a16; }
    .level-ERROR    { background: #fed7d7; color: #c53030; }
    .level-CRITICAL { background: #c53030; color: #fff; }
    .logv-row .msg { white-space: pre-wrap; word-break: break-word; color: #2d3748; }
    .logv-row details { margin-top: 4px; }
    .logv-row summary { color: #718096; font-size: 11.5px; cursor: pointer; }
