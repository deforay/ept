    .logv-empty, .logv-loading { padding: 30px; text-align: center; color: #a0aec0; }
</style>

<div class="logv-page">
    <div class="logv-header">
        <div>
            <h1><?= $this->translate->_('Log Viewer'); ?></h1>
            <div class="logv-summary" id="logvSummary"></div>
        </div>
        <div class="logv-tabs">
            <?php foreach ($this->channels as $key => $label): ?>
                <a href="<?= $this->url(['module' => 'admin', 'controller' => 'log-viewer', 'action' => 'index'], 'default', true); ?>?channel=<?= htmlspecialchars($key, ENT_QUOTES); ?>"
                    class="<?= $key === $this->channel ? 'is-active' : ''; ?>">
                    <?= htmlspecialchars($label); ?>
                </a>
            <?php endforeach; ?>
        </div>
    </div>

    <div class="logv-controls">
        <select id="logvFile">
            <?php if (empty($this->files)): ?>
                <option value=""><?= $this->translate->_('No log files yet'); ?></option>
            <?php else: ?>
                <?php foreach ($this->files as $f): ?>
                    <option value="<?= htmlspecialchars($f['name'], ENT_QUOTES); ?>">
                        <?= htmlspecialchars($f['date']); ?>
                        (<?= number_format($f['size'] / 1024, 1); ?> KB)
                    </option>
                <?php endforeach; ?>
            <?php endif; ?>
        </select>

        <select id="logvLevel">
            <?php foreach ($this->levels as $lvl): ?>
                <option value="<?= htmlspecialchars($lvl, ENT_QUOTES); ?>">
                    <?= $lvl === '' ? $this->translate->_('All levels') : htmlspecialchars($lvl); ?>
                </option>
            <?php endforeach; ?>
        </select>

        <input type="text" id="logvQ" placeholder="<?= $this->translate->_('Search text (case-insensitive)…'); ?>">
        <input type="number" id="logvLimit" min="50" max="5000" step="50" value="500" title="<?= $this->translate->_('Max lines'); ?>">

        <button class="btn" id="logvRefresh"><i class="fa fa-sync"></i> <?= $this->translate->_('Refresh'); ?></button>
        <button class="btn ghost" id="logvClear"><?= $this->translate->_('Clear filters'); ?></button>
    </div>

    <div class="logv-meta" id="logvMeta"></div>

    <div class="logv-rows" id="logvRows">
        <div class="logv-loading"><?= $this->translate->_('Loading…'); ?></div>
    </div>
</div>

<script>
(function () {
    var feedUrl = "<?= $this->url(['module' => 'admin', 'controller' => 'log-viewer', 'action' => 'feed'], 'default', true); ?>";
    var channel = "<?= htmlspecialchars($this->channel, ENT_QUOTES); ?>";
    var fileSel  = document.getElementById('logvFile');
    var levelSel = document.getElementById('logvLevel');
    var qInput   = document.getElementById('logvQ');
    var limitIn  = document.getElementById('logvLimit');
    var rowsEl   = document.getElementById('logvRows');
    var metaEl   = document.getElementById('logvMeta');
    var sumEl    = document.getElementById('logvSummary');

    function el(tag, opts, children) {
        var node = document.createElement(tag);
        if (opts && opts.className) { node.className = opts.className; }
        if (opts && opts.text != null) { node.textContent = opts.text; }
        if (opts && opts.title) { node.title = opts.title; }
        if (children) {
            for (var i = 0; i < children.length; i++) {
                if (children[i]) { node.appendChild(children[i]); }
            }
        }
        return node;
    }
    function clear(node) { while (node.firstChild) { node.removeChild(node.firstChild); } }

    function prettyContext(ctx) {
        if (!ctx) { return ''; }
        try {
            var trimmed = ctx.trim();
            if (trimmed.charAt(0) === '{' || trimmed.charAt(0) === '[') {
                return JSON.stringify(JSON.parse(trimmed), null, 2);
            }
        } catch (e) { /* fall through */ }
        return ctx;
    }

    function buildRow(row) {
        var time = el('div', { className: 'time', text: row.time || '' });
        var level = el('div', null, [
            el('span', { className: 'level level-' + (row.level || 'INFO'), text: row.level || '' })
        ]);
        var msg = el('div', { className: 'msg', text: row.message || '' });
        var body = el('div', null, [msg]);
        var ctx = prettyContext(row.context);
        if (ctx) {
            var details = el('details', null, [
                el('summary', { text: 'context' }),
                el('pre', { text: ctx })
            ]);
            body.appendChild(details);
        }
        return el('div', { className: 'logv-row' }, [time, level, body]);
    }

    function render(payload) {
        clear(rowsEl);
        clear(metaEl);
        clear(sumEl);
        if (!payload.file) {
            rowsEl.appendChild(el('div', { className: 'logv-empty', text: 'No log file selected.' }));
            return;
        }
        var strong = el('strong', { text: payload.file });
        sumEl.appendChild(strong);

        var m = payload.meta || {};
        var pills = [
            (m.count || 0) + ' lines (cap ' + (m.limit || 0) + ')',
            ((m.size || 0) / 1024).toFixed(1) + ' KB',
            'Last write: ' + (m.mtime || '')
        ];
        for (var i = 0; i < pills.length; i++) {
            metaEl.appendChild(el('span', { className: 'pill', text: pills[i] }));
        }

        var lines = payload.lines || [];
        if (!lines.length) {
            rowsEl.appendChild(el('div', { className: 'logv-empty', text: 'No matching lines.' }));
            return;
        }
        var frag = document.createDocumentFragment();
        for (var j = 0; j < lines.length; j++) {
            frag.appendChild(buildRow(lines[j]));
        }
        rowsEl.appendChild(frag);
    }

    function load() {
        clear(rowsEl);
        rowsEl.appendChild(el('div', { className: 'logv-loading', text: 'Loading…' }));
        var params = new URLSearchParams({
            channel: channel,
            file: fileSel.value || '',
            level: levelSel.value || '',
            q: qInput.value || '',
            limit: limitIn.value || '500'
        });
        fetch(feedUrl + '?' + params.toString(), { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(render)
            .catch(function () {
                clear(rowsEl);
                rowsEl.appendChild(el('div', { className: 'logv-empty', text: 'Failed to load.' }));
            });
    }

    document.getElementById('logvRefresh').addEventListener('click', load);
    document.getElementById('logvClear').addEventListener('click', function () {
        levelSel.value = '';
        qInput.value = '';
        limitIn.value = '500';
        load();
    });
    fileSel.addEventListener('change', load);
    levelSel.addEventListener('change', load);
    var qTimer;
    qInput.addEventListener('input', function () {
        clearTimeout(qTimer);
        qTimer = setTimeout(load, 300);
    });
    limitIn.addEventListener('change', load);

    load();
})();
</script>
