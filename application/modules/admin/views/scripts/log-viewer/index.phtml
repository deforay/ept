    .logv-page { max-width: 1280px; margin: 0 auto; padding: 8px 4px 48px; font-size: 14px; color: #2d3748; }
    .logv-header { display: flex; align-items: center; justify-content: space-between; gap: 18px; border-bottom: 1px solid #e2e8f0; padding-bottom: 14px; margin-bottom: 16px; flex-wrap: wrap; }
