<?php
// Ambient "needs re-evaluation" nudge for the Evaluate landing page.
// Lists shipments whose scores are out of date because responses arrived after they
// were evaluated (see Application_Service_Evaluation::getShipmentsNeedingReEvaluation).
// Reuses the shared scheme-re-evaluate/re-evaluate AJAX endpoint, one shipment at a time.
// Expects: $this->staleShipments - array of {shipment_id, shipment_code, scheme_type, reports_generated}
// 'Not now' sets the reeval_nudge_dismissed cookie (see JS below) to mute the banner
// for a day, mirroring the dashboard email-health alert's dismiss behaviour.
$staleShipments = $this->staleShipments ?? [];
if (!empty($staleShipments) && !isset($_COOKIE['reeval_nudge_dismissed'])):
    $total = count($staleShipments);
    $anyReports = false;
    foreach ($staleShipments as $s) {
        if (!empty($s['reports_generated'])) {
            $anyReports = true;
            break;
        }
    }
?>
<style>
    #reEvalStaleBanner { margin: 0 0 18px; background: #fffbf2; border: 1px solid #f0e2c4; border-left: 4px solid #e6a23c; border-radius: 6px; }
    #reEvalStaleBanner .rsb-row { display: flex; align-items: center; gap: 16px; padding: 14px 18px; flex-wrap: wrap; }
    #reEvalStaleBanner .rsb-icon { flex: 0 0 auto; width: 34px; height: 34px; border-radius: 50%; background: #fbeccd; color: #c77c12; display: flex; align-items: center; justify-content: center; }
    #reEvalStaleBanner .rsb-icon svg { width: 18px; height: 18px; display: block; }
    #reEvalStaleBanner .rsb-text { flex: 1 1 260px; min-width: 0; }
    #reEvalStaleBanner .rsb-title { font-size: 14px; font-weight: 600; color: #6b4e0f; }
    #reEvalStaleBanner .rsb-detail { margin-top: 2px; font-size: 13px; color: #8a7340; }
    #reEvalStaleBanner .rsb-chips { margin-top: 7px; display: flex; flex-wrap: wrap; gap: 8px; }
    #reEvalStaleBanner .rsb-chip { display: inline-flex; align-items: center; gap: 6px; background: #fff; border: 1px solid #ead9b0; border-radius: 14px; padding: 3px 11px 3px 9px; font-size: 13px; font-weight: 600; color: #6b4e0f; cursor: default; user-select: none; }
    #reEvalStaleBanner label.rsb-chip { cursor: pointer; }
    #reEvalStaleBanner .rsb-chip input { margin: 0; cursor: pointer; }
    #reEvalStaleBanner .rsb-chip.unchecked { opacity: 0.5; font-weight: 400; }
    #reEvalStaleBanner .rsb-note { margin-top: 6px; font-size: 12px; color: #a78a52; }
    #reEvalStaleBanner .rsb-actions { flex: 0 0 auto; display: flex; align-items: center; gap: 12px; }
    #reEvalStaleBanner .rsb-btn { background: #e6952c; border: 0; color: #fff; font-weight: 600; font-size: 13px; padding: 8px 18px; border-radius: 4px; cursor: pointer; white-space: nowrap; }
    #reEvalStaleBanner .rsb-btn:hover { background: #cf8420; }
    #reEvalStaleBanner .rsb-btn:disabled { background: #e7d6b3; cursor: not-allowed; }
    #reEvalStaleBanner .rsb-link { background: none; border: 0; color: #9a814a; font-size: 13px; cursor: pointer; white-space: nowrap; }
    #reEvalStaleBanner .rsb-link:hover { color: #6b4e0f; text-decoration: underline; }
</style>
<div id="reEvalStaleBanner" role="alert">
    <div class="rsb-row">
        <div class="rsb-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
        </div>
        <div class="rsb-text">
            <div class="rsb-title">
                <?php if ($total > 1): ?>
                    <?= sprintf($this->htmlTranslate("%d shipments need re-evaluation"), $total); ?>
                <?php else: ?>
                    <?= $this->htmlTranslate("1 shipment needs re-evaluation"); ?>
                <?php endif; ?>
            </div>
            <div class="rsb-detail">
                <?php if ($total > 1): ?>
                    <?= $this->htmlTranslate("New responses arrived after they were last evaluated. Pick which ones to re-evaluate:"); ?>
                <?php else: ?>
                    <?= $this->htmlTranslate("New responses arrived after it was last evaluated:"); ?>
                <?php endif; ?>
            </div>
            <div class="rsb-chips">
                <?php foreach ($staleShipments as $s): ?>
                    <?php if ($total > 1): ?>
                        <label class="rsb-chip" data-id="<?= (int) $s['shipment_id']; ?>" data-scheme="<?= htmlspecialchars($s['scheme_type']); ?>">
                            <input type="checkbox" class="rsb-check" checked>
                            <span><?= htmlspecialchars($s['shipment_code']); ?></span>
                        </label>
                    <?php else: ?>
                        <span class="rsb-chip" data-id="<?= (int) $s['shipment_id']; ?>" data-scheme="<?= htmlspecialchars($s['scheme_type']); ?>"><?= htmlspecialchars($s['shipment_code']); ?></span>
                    <?php endif; ?>
                <?php endforeach; ?>
            </div>
            <?php if ($anyReports): ?>
                <div class="rsb-note">
                    <?= $this->htmlTranslate("Shipments that already have reports will go back to the evaluated state, so you will need to make their reports again."); ?>
                </div>
            <?php endif; ?>
        </div>
        <div class="rsb-actions">
            <button type="button" class="rsb-btn" id="reEvalStaleRun"><?= $total > 1 ? $this->htmlTranslate("Re-evaluate selected") : $this->htmlTranslate("Re-evaluate"); ?></button>
            <button type="button" class="rsb-link" id="reEvalStaleNotNow"><?= $this->htmlTranslate("Not now"); ?></button>
        </div>
    </div>
</div>
<script type="text/javascript">
    (function () {
        var $banner = $('#reEvalStaleBanner');
        if (!$banner.length) { return; }
        var reEvalUrl = '<?php echo $this->url(array("module" => "admin", "controller" => "scheme-re-evaluate", "action" => "re-evaluate"), "default", true); ?>';
        var selTpl = "<?= Pt_Commons_TranslateUtility::jsTranslate("Re-evaluate selected (%d)"); ?>";

        // Style the blockUI box into a compact centered card (its default is a wide bare slab).
        var blockCss = {
            width: '340px', top: '40%', left: '50%', marginLeft: '-170px',
            padding: '26px 28px', border: 'none', borderRadius: '10px',
            boxShadow: '0 14px 44px rgba(0,0,0,0.25)', backgroundColor: '#fff',
            textAlign: 'center', cursor: 'default'
        };
        var overlayCss = { backgroundColor: '#1b2430', opacity: 0.55 };

        // Multi-shipment banners get per-shipment checkboxes; a single shipment is just a
        // plain chip with a static "Re-evaluate" button (nothing to pick from).
        var multi = $banner.find('.rsb-check').length > 0;

        function checkedItems() {
            var items = [];
            $banner.find('.rsb-chip').each(function () {
                var $chip = $(this);
                var $cb = $chip.find('.rsb-check');
                if ($cb.length && !$cb.prop('checked')) { return; }
                items.push({ id: parseInt($chip.data('id'), 10), scheme: String($chip.data('scheme')) });
            });
            return items;
        }

        function updateSelection() {
            if (!multi) { return; }
            var n = $banner.find('.rsb-check:checked').length;
            $('#reEvalStaleRun').prop('disabled', n === 0).text(selTpl.replace('%d', n));
        }

        $(function () {
            updateSelection();

            $banner.on('change', '.rsb-check', function () {
                $(this).closest('.rsb-chip').toggleClass('unchecked', !this.checked);
                updateSelection();
            });

            $('#reEvalStaleNotNow').on('click', function () {
                var expires = new Date();
                expires.setTime(expires.getTime() + (24 * 60 * 60 * 1000)); // 1 day
                document.cookie = "reeval_nudge_dismissed=1; expires=" + expires.toUTCString() + "; path=/; SameSite=Strict";
                $banner.slideUp(150);
            });

            $('#reEvalStaleRun').on('click', function () {
                var items = checkedItems();
                if (items.length === 0) { return; }
                runReEval(items);
            });
        });

        function runReEval(items) {
            var total = items.length;
            var done = 0;
            var failed = 0;
            var failedLabel = "<?= Pt_Commons_TranslateUtility::jsTranslate("failed"); ?>";

            // Block the UI ONCE, then mutate only the counter text in place. Re-blocking
            // per shipment tore down and rebuilt the box, making it flicker/"reload".
            $.blockUI({
                message: "<div id='reEvalStaleBox'>" +
                    "<h4 style='margin:0;font-size:16px;color:#2c3e50;font-weight:600;'><?= Pt_Commons_TranslateUtility::jsTranslate("Queuing shipments for re-evaluation"); ?>&hellip;</h4>" +
                    "<p id='reEvalStaleProgress' style='margin:10px 0 0;font-size:14px;color:#555;'></p>" +
                    "</div>",
                css: blockCss,
                overlayCSS: overlayCss
            });

            function renderProgress() {
                $('#reEvalStaleProgress').text(done + " / " + total + (failed > 0 ? " (" + failed + " " + failedLabel + ")" : ""));
            }

            function next() {
                if (items.length === 0) {
                    // Swap the box contents in place (no unblock/re-block) so it does not
                    // flicker. Rendered inside the blockUI box (topmost layer, no backdrop)
                    // because bootbox's .modal-backdrop is stacked above its dialog in this
                    // theme and traps the OK button.
                    var doneMsg =
                        "<div style='margin:0 auto 14px;width:48px;height:48px;border-radius:50%;background:#eef8f1;line-height:48px;'>" +
                            "<svg width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='#36a45c' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' style='vertical-align:middle;'><polyline points='20 6 9 17 4 12'></polyline></svg>" +
                        "</div>" +
                        "<h4 style='margin:0;font-size:17px;color:#2c3e50;font-weight:600;'><?= Pt_Commons_TranslateUtility::jsTranslate("Re-evaluation queued."); ?></h4>" +
                        "<p style='margin:8px 0 0;font-size:14px;color:#555;'>" + (done - failed) + " / " + total +
                        (failed > 0 ? " (" + failed + " <?= Pt_Commons_TranslateUtility::jsTranslate("failed"); ?>)" : "") + "</p>" +
                        "<p style='margin:8px 0 0;font-size:12px;color:#999;'><?= Pt_Commons_TranslateUtility::jsTranslate("They will be processed in the background shortly."); ?></p>" +
                        "<button type='button' id='reEvalStaleOk' style='margin-top:18px;background:#e6952c;color:#fff;border:0;padding:9px 30px;border-radius:5px;font-weight:600;font-size:14px;cursor:pointer;'><?= Pt_Commons_TranslateUtility::jsTranslate("OK"); ?></button>";
                    $('#reEvalStaleBox').html(doneMsg);
                    $('#reEvalStaleOk').on('click', function () { window.location.reload(); });
                    return;
                }
                var item = items.shift();
                $.post(reEvalUrl, { shipmentId: item.id, scheme: item.scheme }, function (resp) {
                    if (!resp || resp.status === 'error') {
                        failed++;
                    }
                }, 'json').fail(function () {
                    failed++;
                }).always(function () {
                    done++;
                    renderProgress();
                    next();
                });
            }

            renderProgress();
            next();
        }
    })();
</script>
<?php endif; ?>
