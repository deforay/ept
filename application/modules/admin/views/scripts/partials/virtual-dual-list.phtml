<?php
/**
 * Virtual-scroll dual-list widget bound to a native <select multiple>.
 *
 * Usage:
 *   1. Render this partial ONCE on the page (emits CSS + window.VirtualDualList):
 *        <?php echo $this->render('partials/virtual-dual-list.phtml'); ?>
 *   2. Keep the existing <select id="foo" name="foo[]" multiple> in the DOM
 *      (hide it with style="display:none;"). The widget mirrors its options
 *      and keeps the native select in sync on every move, so existing form
 *      submit code (reading #foo.val()) continues to work unchanged.
 *   3. Place a container div where the widget should render:
 *        <div id="fooWidget"></div>
 *   4. On document ready:
 *        VirtualDualList.bind('#foo', {
 *            container: '#fooWidget',
 *            unselectedLabel: 'Unselected Participants',
 *            selectedLabel:   'Selected Participants',
 *            filterPlaceholder: 'Type Participant Name To Filter'
 *        });
 *   5. After replacing the select's options via AJAX, refresh the widget:
 *        VirtualDualList.get('#foo').reload();
 */
?>
<style>
    .vdl-wrapper { width: 100%; box-sizing: border-box; }
    .vdl-legend { margin: 0 0 8px 0; font-size: 12px; color: #555; display: flex; gap: 16px; flex-wrap: wrap; align-items: center; }
    .vdl-legend .vdl-legend-item { display: inline-flex; align-items: center; gap: 6px; }
    .vdl-legend .vdl-legend-swatch { display: inline-block; width: 12px; height: 12px; border-radius: 50%; }
    .vdl-dual { display: flex; gap: 20px; align-items: stretch; width: 100%; }
    .vdl-dual .vdl-pane { flex: 1 1 0; border: 1px solid #ccc; background: #fff; display: flex; flex-direction: column; min-width: 0; }
    .vdl-dual .vdl-pane-header { padding: 8px; border-bottom: 1px solid #eee; background: #f7f7f7; }
    .vdl-dual .vdl-pane-header input { width: 100%; box-sizing: border-box; }
    .vdl-dual .vdl-pane-scroll { position: relative; height: 360px; overflow-y: auto; background: #fff; }
    .vdl-dual .vdl-pane-inner { position: relative; width: 100%; }
    .vdl-dual .vdl-row { position: absolute; left: 0; right: 0; height: 30px; line-height: 30px; padding: 0 12px 0 28px; cursor: pointer; border-bottom: 1px solid #f0f0f0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 13px; box-sizing: border-box; }
    .vdl-dual .vdl-row:hover { background: #337ab7; color: #fff; }
    .vdl-dual .vdl-row::before { content: ''; position: absolute; left: 8px; top: 50%; transform: translateY(-50%); width: 14px; height: 14px; line-height: 14px; text-align: center; font-size: 11px; font-weight: 700; border-radius: 50%; color: #fff; }
    .vdl-dual .vdl-row.vdl-row-added { background: #e8f5e9; border-left: 3px solid #2e7d32; padding-left: 26px; }
    .vdl-dual .vdl-row.vdl-row-added::before { content: '+'; background: #2e7d32; }
    .vdl-dual .vdl-row.vdl-row-removed { background: #fff3e0; border-left: 3px solid #ef6c00; padding-left: 26px; }
    .vdl-dual .vdl-row.vdl-row-removed::before { content: '\2212'; background: #ef6c00; }
    .vdl-dual .vdl-row.vdl-row-saved::before { content: '\2713'; background: #607d8b; }
    .vdl-dual .vdl-pane-footer { padding: 10px; background: #2c3e50; color: #fff; text-align: center; font-weight: 600; font-size: 13px; }
    .vdl-dual .vdl-pane-footer .vdl-diff { display: inline-block; margin-left: 8px; padding: 1px 8px; border-radius: 10px; font-size: 11px; font-weight: 600; }
    .vdl-dual .vdl-pane-footer .vdl-diff-added { background: #2e7d32; }
    .vdl-dual .vdl-pane-footer .vdl-diff-removed { background: #ef6c00; }
    .vdl-dual .vdl-arrows { display: flex; flex-direction: column; justify-content: center; align-items: center; color: #888; font-size: 22px; padding: 0 4px; user-select: none; flex: 0 0 auto; }
</style>
<script>
(function() {
    if (window.VirtualDualList) return;

    var ROW_HEIGHT = 30;
    var OVERSCAN = 6;

    function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, function(c) {
            return ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[c];
        });
    }

    function Instance($select, opts) {
        this.$select = $select;
        this.opts = opts || {};
        this.state = { left: [], right: [] };
        this.panes = {};
        this._build();
        this.reload();
    }

    Instance.prototype._build = function() {
        var $container;
        if (this.opts.container) {
            $container = $(this.opts.container);
        }
        if (!$container || !$container.length) {
            $container = $('<div></div>').insertBefore(this.$select);
        }
        $container.addClass('vdl-wrapper').empty();

        var filterPh  = this.opts.filterPlaceholder || 'Type to filter';
        var leftLbl   = this.opts.unselectedLabel    || 'Unselected';
        var rightLbl  = this.opts.selectedLabel      || 'Selected';
        var pendingAddLbl    = this.opts.pendingAddLabel    || 'pending add';
        var pendingRemoveLbl = this.opts.pendingRemoveLabel || 'pending remove';
        var showLegend = this.opts.showLegend !== false;
        var legendSaved   = this.opts.legendSaved   || 'Saved (already selected)';
        var legendAdded   = this.opts.legendAdded   || 'Pending add (save to apply)';
        var legendRemoved = this.opts.legendRemoved || 'Pending remove (save to apply)';

        var legendHtml = '';
        if (showLegend) {
            legendHtml =
                '<div class="vdl-legend">' +
                    '<span class="vdl-legend-item"><span class="vdl-legend-swatch" style="background:#607d8b;"></span>' + escapeHtml(legendSaved) + '</span>' +
                    '<span class="vdl-legend-item"><span class="vdl-legend-swatch" style="background:#2e7d32;"></span>' + escapeHtml(legendAdded) + '</span>' +
                    '<span class="vdl-legend-item"><span class="vdl-legend-swatch" style="background:#ef6c00;"></span>' + escapeHtml(legendRemoved) + '</span>' +
                '</div>';
        }

        var html =
            legendHtml +
            '<div class="vdl-dual">' +
                '<div class="vdl-pane" data-side="left">' +
                    '<div class="vdl-pane-header"><input type="text" class="form-control" autocomplete="off" placeholder="' + escapeHtml(filterPh) + '"></div>' +
                    '<div class="vdl-pane-scroll"><div class="vdl-pane-inner"></div></div>' +
                    '<div class="vdl-pane-footer">' + escapeHtml(leftLbl) + ' (<span class="vdl-count">0</span>)<span class="vdl-diff vdl-diff-removed" style="display:none;">&minus; <span class="vdl-diff-count">0</span> ' + escapeHtml(pendingRemoveLbl) + '</span></div>' +
                '</div>' +
                '<div class="vdl-arrows">&#8646;</div>' +
                '<div class="vdl-pane" data-side="right">' +
                    '<div class="vdl-pane-header"><input type="text" class="form-control" autocomplete="off" placeholder="' + escapeHtml(filterPh) + '"></div>' +
                    '<div class="vdl-pane-scroll"><div class="vdl-pane-inner"></div></div>' +
                    '<div class="vdl-pane-footer">' + escapeHtml(rightLbl) + ' (<span class="vdl-count">0</span>)<span class="vdl-diff vdl-diff-added" style="display:none;">+ <span class="vdl-diff-count">0</span> ' + escapeHtml(pendingAddLbl) + '</span></div>' +
                '</div>' +
            '</div>';

        $container.html(html);
        this.$container = $container;

        var self = this;
        $container.find('.vdl-pane').each(function() {
            self._initPane($(this).attr('data-side'), this);
        });
    };

    Instance.prototype._initPane = function(side, paneEl) {
        var self = this;
        var $pane = $(paneEl);
        var pane = {
            side: side,
            $scroll: $pane.find('.vdl-pane-scroll'),
            $inner:  $pane.find('.vdl-pane-inner'),
            $search: $pane.find('.vdl-pane-header input'),
            $count:  $pane.find('.vdl-count'),
            $diff:   $pane.find('.vdl-diff'),
            $diffCount: $pane.find('.vdl-diff-count'),
            filter: '',
            filtered: []
        };
        pane.$scroll.on('scroll', function() { self._render(pane); });
        pane.$search.on('input', function() {
            pane.filter = pane.$search.val().toLowerCase();
            self._recompute(pane);
            pane.$scroll.scrollTop(0);
            self._render(pane);
        });
        pane.$inner.on('click', '.vdl-row', function() {
            self._move(side, $(this).attr('data-id'));
        });
        self.panes[side] = pane;
    };

    Instance.prototype._recompute = function(pane) {
        var src = this.state[pane.side];
        if (!pane.filter) {
            pane.filtered = src;
        } else {
            var f = pane.filter;
            pane.filtered = [];
            for (var i = 0; i < src.length; i++) {
                if (src[i]._lc.indexOf(f) !== -1) pane.filtered.push(src[i]);
            }
        }
        pane.$count.text(pane.filtered.length);
        pane.$inner.css('height', (pane.filtered.length * ROW_HEIGHT) + 'px');
        this._updateDiff(pane);
    };

    Instance.prototype._updateDiff = function(pane) {
        if (!pane.$diff || pane.$diff.length === 0) return;
        var src = this.state[pane.side];
        var diffCount = 0;
        if (pane.side === 'right') {
            for (var i = 0; i < src.length; i++) if (!src[i].savedRight) diffCount++;
        } else {
            for (var j = 0; j < src.length; j++) if (src[j].savedRight) diffCount++;
        }
        pane.$diffCount.text(diffCount);
        pane.$diff.toggle(diffCount > 0);
    };

    function rowClass(it, side) {
        if (side === 'right') {
            return it.savedRight ? 'vdl-row-saved' : 'vdl-row-added';
        }
        return it.savedRight ? 'vdl-row-removed' : '';
    }

    Instance.prototype._render = function(pane) {
        var st = pane.$scroll.scrollTop();
        var h  = pane.$scroll.height();
        var first = Math.max(0, Math.floor(st / ROW_HEIGHT) - OVERSCAN);
        var last  = Math.min(pane.filtered.length, Math.ceil((st + h) / ROW_HEIGHT) + OVERSCAN);
        var parts = [];
        for (var i = first; i < last; i++) {
            var it = pane.filtered[i];
            var cls = rowClass(it, pane.side);
            parts.push('<div class="vdl-row' + (cls ? ' ' + cls : '') + '" style="top:' + (i * ROW_HEIGHT) + 'px" data-id="' + escapeHtml(it.id) + '">' + escapeHtml(it.label) + '</div>');
        }
        pane.$inner.html(parts.join(''));
    };

    Instance.prototype._refreshBoth = function() {
        this._recompute(this.panes.left);
        this._recompute(this.panes.right);
        this._render(this.panes.left);
        this._render(this.panes.right);
    };

    Instance.prototype._move = function(fromSide, id) {
        var toSide = fromSide === 'left' ? 'right' : 'left';
        var arr = this.state[fromSide];
        for (var i = 0; i < arr.length; i++) {
            if (String(arr[i].id) === String(id)) {
                var item = arr.splice(i, 1)[0];
                this.state[toSide].push(item);
                break;
            }
        }
        this._syncSelect();
        this._refreshBoth();
    };

    Instance.prototype._syncSelect = function() {
        var sel = {};
        for (var i = 0; i < this.state.right.length; i++) sel[String(this.state.right[i].id)] = true;
        this.$select.find('option').each(function() {
            this.selected = !!sel[String($(this).val())];
        });
        // Optional callback fired after every selection change (move / select-all /
        // deselect-all / setSelectedIds). Backward-compatible: no-op unless provided.
        if (typeof this.opts.onChange === 'function') this.opts.onChange(this);
    };

    Instance.prototype.reload = function() {
        this.state = { left: [], right: [] };
        var self = this;
        // If caller provided savedIds, use that as the source of truth for what's
        // "actually saved" — otherwise fall back to the option's selected state.
        // Needed for flows like ship-it on a fresh shipment, where the view
        // pre-selects suggestions that aren't yet persisted.
        var savedMap = null;
        if (this.opts.savedIds && this.opts.savedIds.length !== undefined) {
            savedMap = {};
            for (var k = 0; k < this.opts.savedIds.length; k++) {
                savedMap[String(this.opts.savedIds[k])] = true;
            }
        }
        this.$select.find('option').each(function() {
            var $o = $(this);
            var id = $o.val();
            if (id === '' || id == null) return;
            var label = $o.text();
            var isSelected = !!this.selected;
            var isSaved = savedMap ? !!savedMap[String(id)] : isSelected;
            var item = { id: id, label: label, _lc: String(label).toLowerCase(), savedRight: isSaved };
            if (isSelected) self.state.right.push(item);
            else self.state.left.push(item);
        });
        if (self.panes.left)  { self.panes.left.$search.val('');  self.panes.left.filter  = ''; self.panes.left.$scroll.scrollTop(0); }
        if (self.panes.right) { self.panes.right.$search.val(''); self.panes.right.filter = ''; self.panes.right.$scroll.scrollTop(0); }
        self._refreshBoth();
    };

    Instance.prototype.selectAll = function() {
        var visible = {};
        for (var i = 0; i < this.panes.left.filtered.length; i++) visible[this.panes.left.filtered[i].id] = true;
        var keep = [];
        for (var j = 0; j < this.state.left.length; j++) {
            if (visible[this.state.left[j].id]) this.state.right.push(this.state.left[j]);
            else keep.push(this.state.left[j]);
        }
        this.state.left = keep;
        this._syncSelect();
        this._refreshBoth();
    };

    Instance.prototype.deselectAll = function() {
        var visible = {};
        for (var i = 0; i < this.panes.right.filtered.length; i++) visible[this.panes.right.filtered[i].id] = true;
        var keep = [];
        for (var j = 0; j < this.state.right.length; j++) {
            if (visible[this.state.right[j].id]) this.state.left.push(this.state.right[j]);
            else keep.push(this.state.right[j]);
        }
        this.state.right = keep;
        this._syncSelect();
        this._refreshBoth();
    };

    Instance.prototype.setSelectedIds = function(ids) {
        var want = {};
        for (var i = 0; i < ids.length; i++) want[String(ids[i])] = true;
        var newLeft = [], newRight = [];
        var all = this.state.left.concat(this.state.right);
        for (var j = 0; j < all.length; j++) {
            if (want[String(all[j].id)]) newRight.push(all[j]);
            else newLeft.push(all[j]);
        }
        this.state.left = newLeft;
        this.state.right = newRight;
        this._syncSelect();
        this._refreshBoth();
    };

    Instance.prototype.addSelectedIds = function(ids) {
        var want = {};
        for (var i = 0; i < ids.length; i++) want[String(ids[i])] = true;
        var keep = [];
        for (var j = 0; j < this.state.left.length; j++) {
            if (want[String(this.state.left[j].id)]) this.state.right.push(this.state.left[j]);
            else keep.push(this.state.left[j]);
        }
        this.state.left = keep;
        this._syncSelect();
        this._refreshBoth();
    };

    Instance.prototype.getSelectedIds = function() {
        var ids = [];
        for (var i = 0; i < this.state.right.length; i++) ids.push(this.state.right[i].id);
        return ids;
    };

    window.VirtualDualList = {
        bind: function(selectSelector, opts) {
            var $sel = $(selectSelector);
            if (!$sel.length) return null;
            var existing = $sel.data('vdl');
            if (existing) return existing;
            var inst = new Instance($sel, opts);
            $sel.data('vdl', inst);
            return inst;
        },
        get: function(selectSelector) {
            return $(selectSelector).data('vdl') || null;
        }
    };
})();
</script>
