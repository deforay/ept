<?php
// Post-save re-evaluation nudge, shared by the scheme settings pages.
// Expects two view vars (set by the controller only on the request right after a save):
//   $this->reEvalScheme        - scheme_type string (e.g. 'dts', 'vl', custom-test code)
//   $this->reEvalShipmentIds   - int[] of shipment ids scored under the old settings
$reEvalScheme = $this->reEvalScheme ?? '';
$reEvalIds = $this->reEvalShipmentIds ?? [];
?>
<script type="text/javascript">
    (function () {
        var reEvalScheme = <?php echo json_encode($reEvalScheme); ?>;
        var reEvalIds = <?php echo json_encode($reEvalIds); ?>;
        var reEvalUrl = '<?php echo $this->url(array("module" => "admin", "controller" => "scheme-re-evaluate", "action" => "re-evaluate"), "default", true) ?>';

        if (!reEvalScheme || !reEvalIds || reEvalIds.length === 0) {
            return;
        }

        $(document).ready(function () {
            var total = reEvalIds.length;
            bootbox.confirm(
                "Settings saved. <strong>" + total + "</strong> already-evaluated shipment" +
                (total > 1 ? "s were" : " was") + " scored using the previous settings.<br><br>" +
                "Re-evaluate " + (total > 1 ? "them" : "it") + " now so the scores reflect the new settings?" +
                "<br><br><small class='text-muted'>Finalized shipments are left untouched. " +
                "Shipments whose reports were already generated will return to the &quot;evaluated&quot; " +
                "state and will need their reports regenerated.</small>",
                function (result) {
                    if (result) {
                        runReEvaluation();
                    }
                }
            );
        });

        // Style the blockUI box into a compact centered card (its default is a wide bare slab).
        var blockCss = {
            width: '340px', top: '40%', left: '50%', marginLeft: '-170px',
            padding: '26px 28px', border: 'none', borderRadius: '10px',
            boxShadow: '0 14px 44px rgba(0,0,0,0.25)', backgroundColor: '#fff',
            textAlign: 'center', cursor: 'default'
        };
        var overlayCss = { backgroundColor: '#1b2430', opacity: 0.55 };

        function runReEvaluation() {
            var ids = reEvalIds.slice();
            var total = ids.length;
            var done = 0;
            var failed = 0;

            function progressHtml() {
                return "<h4 style='margin:0;font-size:16px;color:#2c3e50;font-weight:600;'><?= $this->translate->_("Queuing shipments for re-evaluation"); ?>&hellip;</h4>" +
                    "<p style='margin:10px 0 0;font-size:14px;color:#555;'>" + done + " / " + total +
                    (failed > 0 ? " (" + failed + " failed)" : "") + "</p>";
            }

            function next() {
                if (ids.length === 0) {
                    // Render the result inside the blockUI box (topmost layer, no backdrop):
                    // bootbox's .modal-backdrop is stacked above its dialog in this theme and
                    // traps the OK button.
                    var doneMsg =
                        "<div style='margin:0 auto 14px;width:48px;height:48px;border-radius:50%;background:#eef8f1;line-height:48px;'>" +
                            "<svg width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='#36a45c' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' style='vertical-align:middle;'><polyline points='20 6 9 17 4 12'></polyline></svg>" +
                        "</div>" +
                        "<h4 style='margin:0;font-size:17px;color:#2c3e50;font-weight:600;'><?= $this->translate->_("Re-evaluation queued."); ?></h4>" +
                        "<p style='margin:8px 0 0;font-size:14px;color:#555;'>" + (done - failed) + " / " + total + " <?= $this->translate->_("queued"); ?>" +
                        (failed > 0 ? ", " + failed + " <?= $this->translate->_("could not be queued"); ?>" : "") + "</p>" +
                        "<p style='margin:8px 0 0;font-size:12px;color:#999;'><?= $this->translate->_("They will be processed in the background shortly."); ?></p>" +
                        "<button type='button' id='reEvalNudgeOk' style='margin-top:18px;background:#e6952c;color:#fff;border:0;padding:9px 30px;border-radius:5px;font-weight:600;font-size:14px;cursor:pointer;'><?= $this->translate->_("OK"); ?></button>";
                    $.blockUI({ message: doneMsg, css: blockCss, overlayCSS: overlayCss });
                    $('#reEvalNudgeOk').on('click', function () { $.unblockUI(); });
                    return;
                }
                $.blockUI({ message: progressHtml(), css: blockCss, overlayCSS: overlayCss });
                var sid = ids.shift();
                $.post(reEvalUrl, { shipmentId: sid, scheme: reEvalScheme }, function (resp) {
                    if (!resp || resp.status === 'error') {
                        failed++;
                    }
                }, 'json').fail(function () {
                    failed++;
                }).always(function () {
                    done++;
                    next();
                });
            }

            next();
        }
    })();
</script>
