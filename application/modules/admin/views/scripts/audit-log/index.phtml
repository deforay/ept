<script type="text/javascript" src="<?php echo $this->baseUrl('js/moment.min.js'); ?>"></script>
<script type="text/javascript" src="<?php echo $this->baseUrl('js/daterangepicker.js'); ?>"></script>
<script type="text/javascript">
(function() {
    var feedUrl = "<?php echo $this->url(['module' => 'admin', 'controller' => 'audit-log', 'action' => 'feed']); ?>";

    var state = {
        page: 1,
        pageSize: 25,
        startDate: '',
        endDate: '',
        type: '',
        createdBy: '',
        search: ''
    };

    var actionIcons = {
        create:   'fa-plus',
        delete:   'fa-trash-alt',
        update:   'fa-pencil-alt',
        import:   'fa-file-import',
        download: 'fa-download',
        message:  'fa-paper-plane',
        other:    'fa-circle'
    };

    var $feed = $('#auditFeed');
    var $summary = $('#auditSummary');
    var $pagination = $('#auditPagination');
    var $pageInfo = $('#pageInfo');
    var $prev = $('#prevBtn');
    var $next = $('#nextBtn');
    var fetchSeq = 0;
    var searchDebounce = null;

    function escapeHtml(text) {
        if (text === null || text === undefined) return '';
        return String(text)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function highlight(text, term) {
        var safe = escapeHtml(text);
        if (!term) return safe;
        var trimmed = term.trim();
        if (!trimmed) return safe;
        var parts = trimmed.split(/\s+/).map(function(p) {
            return p.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        }).filter(Boolean);
        if (!parts.length) return safe;
        var re = new RegExp('(' + parts.join('|') + ')', 'gi');
        return safe.replace(re, '<mark>$1</mark>');
    }

    function parseUserAgent(ua) {
        if (!ua) return '';
        var browser = 'Unknown';
        var os = '';
        if (/Edg\//.test(ua)) browser = 'Edge';
        else if (/OPR\/|Opera/.test(ua)) browser = 'Opera';
        else if (/Chrome\//.test(ua)) browser = 'Chrome';
        else if (/Safari\//.test(ua) && !/Chrome/.test(ua)) browser = 'Safari';
        else if (/Firefox\//.test(ua)) browser = 'Firefox';
        else if (/MSIE|Trident/.test(ua)) browser = 'IE';
        if (/Windows NT 10/.test(ua)) os = 'Windows 10';
        else if (/Windows NT 11/.test(ua)) os = 'Windows 11';
        else if (/Windows/.test(ua)) os = 'Windows';
        else if (/Mac OS X/.test(ua)) os = 'macOS';
        else if (/Android/.test(ua)) os = 'Android';
        else if (/iPhone|iPad|iOS/.test(ua)) os = 'iOS';
        else if (/Linux/.test(ua)) os = 'Linux';
        return os ? browser + ' on ' + os : browser;
    }

    function roleSlug(role) {
        if (!role) return 'system';
        var r = String(role).toLowerCase();
        if (r === 'data manager') return 'datamanager';
        return r;
    }

    function renderItem(item, term) {
        var iconClass = actionIcons[item.actionType] || actionIcons.other;
        var contextHtml = item.context
            ? '<span class="audit-context">' + escapeHtml(item.context) + '</span>'
            : '';
        var roleHtml = item.userRole
            ? '<span class="audit-role ' + roleSlug(item.userRole) + '">' + escapeHtml(item.userRole) + '</span>'
            : '';
        var ipHtml = item.ipAddress
            ? '<span class="audit-ip" title="IP address">' + escapeHtml(item.ipAddress) + '</span>'
            : '';
        var uaShort = parseUserAgent(item.userAgent);
        var uaHtml = uaShort
            ? '<span class="audit-ua" title="' + escapeHtml(item.userAgent) + '">' + escapeHtml(uaShort) + '</span>'
            : '';
        return ''
            + '<div class="audit-item">'
            +   '<div class="audit-icon ' + escapeHtml(item.actionType) + '">'
            +     '<i class="fas ' + iconClass + '"></i>'
            +   '</div>'
            +   '<div class="audit-body">'
            +     '<div class="audit-action">' + highlight(item.action, term) + '</div>'
            +     '<div class="audit-meta">'
            +       '<span class="audit-user" title="' + escapeHtml(item.userEmail) + '">'
            +         '<span class="audit-avatar">' + escapeHtml(item.userInitials) + '</span>'
            +         '<span class="audit-user-name">' + highlight(item.userName, term) + '</span>'
            +       '</span>'
            +       roleHtml
            +       contextHtml
            +       ipHtml
            +       uaHtml
            +     '</div>'
            +   '</div>'
            +   '<div class="audit-time">' + escapeHtml(item.time) + '</div>'
            + '</div>';
    }

    function renderFeed(payload) {
        if (!payload.items || payload.items.length === 0) {
            $feed.html(''
                + '<div class="empty-state">'
                +   '<i class="far fa-folder-open"></i>'
                +   'No audit entries match the current filters.'
                + '</div>');
            $summary.html('<strong>0</strong> entries');
            $pagination.hide();
            return;
        }

        var groups = [];
        var current = null;
        payload.items.forEach(function(item) {
            if (!current || current.key !== item.dateKey) {
                current = { key: item.dateKey, label: item.dateLabel, items: [] };
                groups.push(current);
            }
            current.items.push(item);
        });

        var term = state.search;
        var html = '';
        groups.forEach(function(g) {
            html += '<div class="day-group">';
            html +=   '<div class="day-header">' + escapeHtml(g.label) + ' <span class="count">' + g.items.length + '</span></div>';
            g.items.forEach(function(it) { html += renderItem(it, term); });
            html += '</div>';
        });

        $feed.html(html);

        var start = (payload.page - 1) * payload.pageSize + 1;
        var end = Math.min(start + payload.items.length - 1, payload.total);
        $summary.html('<strong>' + payload.total.toLocaleString() + '</strong> entries');
        $pageInfo.html('Showing <strong>' + start + '</strong>–<strong>' + end + '</strong> of <strong>' + payload.total.toLocaleString() + '</strong>');
        $prev.prop('disabled', payload.page <= 1);
        $next.prop('disabled', payload.page >= payload.totalPages);
        $pagination.show();
    }

    function fetchFeed() {
        var seq = ++fetchSeq;
        $feed.html('<div class="loading-state"><i class="fas fa-circle-notch fa-spin"></i>Loading…</div>');
        $.ajax({
            url: feedUrl,
            type: 'POST',
            dataType: 'json',
            data: {
                page: state.page,
                pageSize: state.pageSize,
                startDate: state.startDate,
                endDate: state.endDate,
                type: state.type,
                createdBy: state.createdBy,
                search: state.search
            }
        }).done(function(payload) {
            if (seq !== fetchSeq) return;
            renderFeed(payload);
        }).fail(function() {
            if (seq !== fetchSeq) return;
            $feed.html(''
                + '<div class="empty-state">'
                +   '<i class="fas fa-exclamation-triangle"></i>'
                +   'Failed to load audit log. Please retry.'
                + '</div>');
            $pagination.hide();
        });
    }

    $(document).ready(function() {
        $('#dateRange').daterangepicker({
            locale: { cancelLabel: 'Clear', format: 'DD-MMM-YYYY', separator: ' to ' },
            autoApply: true,
            showDropdowns: true,
            alwaysShowCalendars: true,
            autoUpdateInput: false,
            ranges: {
                'This Month': [moment().startOf('month'), moment().endOf('month')],
                'Last Month': [moment().subtract(1, 'month').startOf('month'), moment().subtract(1, 'month').endOf('month')],
                'Last 30 Days': [moment().subtract(29, 'days'), moment()],
                'Last 90 Days': [moment().subtract(89, 'days'), moment()],
                'Last 120 Days': [moment().subtract(119, 'days'), moment()],
                'Last 180 Days': [moment().subtract(179, 'days'), moment()]
            }
        }, function(start, end) {
            state.startDate = start.format('DD-MMM-YYYY');
            state.endDate = end.format('DD-MMM-YYYY');
            state.page = 1;
            $('#dateRange').val(state.startDate + ' to ' + state.endDate);
            fetchFeed();
        });

        $('#dateRange').on('cancel.daterangepicker', function() {
            $(this).val('');
            state.startDate = '';
            state.endDate = '';
            state.page = 1;
            fetchFeed();
        });

        $('#type').on('change', function() {
            state.type = $(this).val();
            state.page = 1;
            fetchFeed();
        });

        $('#createdBy').on('change', function() {
            state.createdBy = $(this).val();
            state.page = 1;
            fetchFeed();
        });

        $('#searchBox').on('input', function() {
            var val = $(this).val();
            $('#searchWrap').toggleClass('has-value', val.length > 0);
            clearTimeout(searchDebounce);
            searchDebounce = setTimeout(function() {
                state.search = val;
                state.page = 1;
                fetchFeed();
            }, 250);
        });

        $('#clearSearch').on('click', function() {
            $('#searchBox').val('').focus();
            $('#searchWrap').removeClass('has-value');
            state.search = '';
            state.page = 1;
            fetchFeed();
        });

        $('#pageSize').on('change', function() {
            state.pageSize = parseInt($(this).val(), 10) || 25;
            state.page = 1;
            fetchFeed();
        });

        $prev.on('click', function() {
            if (state.page > 1) {
                state.page -= 1;
                fetchFeed();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        });

        $next.on('click', function() {
            state.page += 1;
            fetchFeed();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        $('#resetBtn').on('click', function() {
            $('#dateRange').val('');
            $('#type').val('');
            $('#createdBy').val('');
            $('#searchBox').val('');
            $('#searchWrap').removeClass('has-value');
