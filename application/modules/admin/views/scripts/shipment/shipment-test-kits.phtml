<script type="text/javascript" src="<?php echo $this->baseUrl("js/jquery.quicksearch.js"); ?>"></script>

<script type="text/javascript">
    (function() {

        /* ── Data from PHP ─────────────────────────────────────────── */
        var testKits = <?php echo json_encode(array_values($this->testKits), JSON_UNESCAPED_UNICODE); ?>;

        /* ── Translated strings ────────────────────────────────────── */
        var i18n = {
            test1: '<?= addslashes($this->translate->_("Test 1")); ?>',
            test2: '<?= addslashes($this->translate->_("Test 2")); ?>',
            test3: '<?= addslashes($this->translate->_("Test 3")); ?>',
            position: '<?= addslashes($this->translate->_("Position")); ?>',
            noKits: '<?= addslashes($this->translate->_("No kits assigned")); ?>',
            unselHdr: '<?= addslashes($this->translate->_("Available Test Kits")); ?>',
            selHdr: '<?= addslashes($this->translate->_("Assigned Test Kits")); ?>',
            searchPh: '<?= addslashes($this->translate->_("Type kit name to filter...")); ?>'
        };

        /* ── State ─────────────────────────────────────────────────── */
        var assignments = {
            testkit_1: [],
            testkit_2: [],
            testkit_3: []
        };

        // Pre-populate from existing testkit_1/2/3 flags
        testKits.forEach(function(k) {
            if (k.testkit_1 === '1') assignments.testkit_1.push(k.TESTKITNAMEID);
            if (k.testkit_2 === '1') assignments.testkit_2.push(k.TESTKITNAMEID);
            if (k.testkit_3 === '1') assignments.testkit_3.push(k.TESTKITNAMEID);
        });

        var currentPos = null;
        var msInstance = false; // track if multiSelect has been init'd

        /* ── Helpers ───────────────────────────────────────────────── */
        function getKit(id) {
            return testKits.find(function(k) {
                return k.TESTKITNAMEID === id;
            });
        }

        function displayName(k) {
            return k.scheme_type === 'dts' ? k.TESTKITNAME + ' [DTS]' : k.TESTKITNAME;
        }

        function posLabel(pos) {
            return {
                testkit_1: i18n.test1,
                testkit_2: i18n.test2,
                testkit_3: i18n.test3
            } [pos] || pos;
        }

        /* ── Rebuild <option> list for current position ────────────── */
        function rebuildOptions() {
            var assigned = assignments[currentPos] || [];
            var $sel = $('#testKitMultiSelect');
            $sel.empty();
            testKits.forEach(function(k) {
                var isSelected = assigned.indexOf(k.TESTKITNAMEID) !== -1;
                $sel.append(
                    $('<option>', {
                        value: k.TESTKITNAMEID,
                        text: displayName(k),
                        selected: isSelected
                    })
                );
            });
        }

        /* ── Init / re-init jquery.multi-select ────────────────────── */
        function initMultiSelect() {
            var $sel = $('#testKitMultiSelect');

            // Destroy previous instance if any
            if (msInstance) {
                $sel.multiSelect('destroy');
                msInstance = false;
            }

            $sel.multiSelect({
                selectableFooter: "<div class='custom-header'>" + i18n.unselHdr + " (<span id='msUnselCount'></span>)</div>",
                selectionFooter: "<div class='custom-header'>" + i18n.selHdr + " (<span id='msSelCount'></span>)</div>",
                selectableHeader: "<input type='text' class='search-input form-control' autocomplete='off' placeholder='" + i18n.searchPh + "'>",
                selectionHeader: "<input type='text' class='search-input form-control' autocomplete='off' placeholder='" + i18n.searchPh + "'>",
                afterInit: function(ms) {
                    var that = this;
                    var $selectableSearch = that.$selectableUl.prev();
                    var $selectionSearch = that.$selectionUl.prev();
                    var selectableStr = '#' + that.$container.attr('id') + ' .ms-elem-selectable:not(.ms-selected)';
                    var selectionStr = '#' + that.$container.attr('id') + ' .ms-elem-selection.ms-selected';

                    that.qs1 = $selectableSearch.quicksearch(selectableStr).on('keydown', function(e) {
                        if (e.which === 40) {
                            that.$selectableUl.focus();
                            return false;
                        }
                    });
                    that.qs2 = $selectionSearch.quicksearch(selectionStr).on('keydown', function(e) {
                        if (e.which === 40) {
                            that.$selectionUl.focus();
                            return false;
                        }
                    });
                    updateCountBadges();
                },
                afterSelect: function() {
                    this.qs1.cache();
                    this.qs2.cache();
                    syncAssignments();
                    updateCountBadges();
                    updateSummary();
                },
                afterDeselect: function() {
                    this.qs1.cache();
                    this.qs2.cache();
                    syncAssignments();
                    updateCountBadges();
                    updateSummary();
                }
            });

            msInstance = true;

            // Wire Select All / Deselect All buttons
            $('#msSelectAll').off('click').on('click', function() {
                $sel.multiSelect('select_all');
                return false;
            });
            $('#msDeselectAll').off('click').on('click', function() {
                $sel.multiSelect('deselect_all');
                return false;
            });

            updateCountBadges();
        }

        /* ── Keep assignments[] in sync with what multiSelect shows ── */
        function syncAssignments() {
            if (!currentPos) return;
            assignments[currentPos] = $('#testKitMultiSelect').val() || [];
        }

        /* ── Update count badges in the multiSelect footers ───────── */
        function updateCountBadges() {
            var total = testKits.length;
            var assigned = ($('#testKitMultiSelect').val() || []).length;
            $('#msUnselCount').text(total - assigned);
            $('#msSelCount').text(assigned);
        }

        /* ── Position dropdown change ──────────────────────────────── */
        window.onPositionChange = function() {
            var pos = document.getElementById('testPosition').value;
            if (!pos) {
                document.getElementById('msSection').style.display = 'none';
                return;
            }

            // Save current selection before switching position
            if (currentPos) syncAssignments();

            currentPos = pos;
            document.getElementById('msPosLabel').textContent = i18n.position + ': ' + posLabel(pos);
            document.getElementById('msSection').style.display = 'block';

            rebuildOptions();
            initMultiSelect();
            updateSummary();
        };

        /* ── Summary panel ─────────────────────────────────────────── */
        function updateSummary() {
            var sec = document.getElementById('msSummarySection');
            var grid = document.getElementById('msSummaryGrid');
            var any = Object.keys(assignments).some(function(p) {
                return assignments[p].length > 0;
            });
            sec.style.display = any ? 'block' : 'none';
            grid.innerHTML = '';

            ['testkit_1', 'testkit_2', 'testkit_3'].forEach(function(pos) {
                var ids = assignments[pos];
                var card = document.createElement('div');
                card.className = 'ms-summary-card';

                // Title — pinned, never scrolls
                var title = document.createElement('div');
                title.className = 'ms-summary-title';
                title.textContent = posLabel(pos) + ' (' + ids.length + ')';
                card.appendChild(title);

                // Scrollable rows container
                var rowsContainer = document.createElement('div');
                rowsContainer.className = 'ms-summary-rows';

                if (!ids.length) {
                    var empty = document.createElement('div');
                    empty.className = 'ms-empty-note';
                    empty.textContent = i18n.noKits;
                    rowsContainer.appendChild(empty);
                } else {
                    ids.forEach(function(id) {
                        var k = getKit(id);
                        if (!k) return;
                        var row = document.createElement('div');
                        row.className = 'ms-summary-row';
                        row.textContent = k.TESTKITNAME;
                        if (k.scheme_type === 'dts') {
                            var b = document.createElement('span');
                            b.className = 'ms-badge-dts';
                            b.textContent = 'DTS';
                            row.appendChild(b);
                        }
                        rowsContainer.appendChild(row);
                    });
                }

                card.appendChild(rowsContainer);
                grid.appendChild(card);
            });
        }

        /* ── Populate hidden inputs before form submit ─────────────── 
           Call msPopulateHiddenInputs() inside validateProfileForm()
           just before document.getElementById('testKitsForm').submit()
        ──────────────────────────────────────────────────────────────── */
        window.msPopulateHiddenInputs = function() {
            // Sync latest state first
            syncAssignments();
            document.getElementById('msHidden1').value = assignments.testkit_1.join(',');
            document.getElementById('msHidden2').value = assignments.testkit_2.join(',');
            document.getElementById('msHidden3').value = assignments.testkit_3.join(',');
        };

        /* ── Init: show summary for pre-existing data on page load ─── */
        updateSummary();

    }());

    function validateNow() {
        var flag = deforayValidator.init({
            formId: 'testKitsForm'
        });
        if (flag) {
            $.blockUI();
            document.getElementById('testKitsForm').submit();
        }
    }
</script>