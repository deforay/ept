<script type="text/javascript">
    var sampleCounter = <?php echo $isEditMode && count($samples) > 0 ? count($samples) : 1; ?>;
    var isSampleDilutedVisible = <?php echo $renderSampleDilutedSection ? 'true' : 'false'; ?>;
    var initialSampleDilutedVisible = <?php echo $showSampleDiluted ? 'true' : 'false'; ?>;
    var dtsSavedSettings = <?php echo json_encode($savedSettings); ?>;
    var dtsConfigSettings = <?php echo json_encode($configSettings); ?>;

    $(document).ready(function() {
        function getEffectiveSetting(settingKey) {
            var selector = $('.dts-setting-source[data-setting-key="' + settingKey + '"]');
            var source = selector.length ? selector.val() : 'saved';
            var sourceValues = source === 'config' ? dtsConfigSettings : dtsSavedSettings;
            var fallbackValues = source === 'config' ? dtsSavedSettings : dtsConfigSettings;
            if (typeof sourceValues[settingKey] !== 'undefined' && sourceValues[settingKey] !== null) {
                return sourceValues[settingKey];
            }
            if (typeof fallbackValues[settingKey] !== 'undefined' && fallbackValues[settingKey] !== null) {
                return fallbackValues[settingKey];
            }
            return '';
        }

        function applyEffectiveSetting(settingKey) {
            var effectiveValue = getEffectiveSetting(settingKey);
            var targetId = $('.dts-setting-source[data-setting-key="' + settingKey + '"]').first().data('target-id');
            if (!targetId) {
                return;
            }
            $('#' + targetId).val(effectiveValue);
            if (targetId === 'screeningTest') {
                screeningTestPanel(effectiveValue);
            }
            if (targetId === 'dtsSampleType') {
                $('#dtsSampleType').trigger('change');
            }
        }

        function refreshDtsSettingVisibility() {
            var schemeType = $('#dtsSchemeType').val();
            var screeningTest = $('#screeningTest').val();
            var sampleType = $('#dtsSampleType').val();
            var enableSyphilis = $('#enableSyphilis').val();
            var enableRtri = $('#enableRtri').val();

            $('[data-scheme-section]').each(function() {
                var allowedSchemes = String($(this).data('scheme-section')).split(' ');
                $(this).toggle($.inArray(schemeType, allowedSchemes) !== -1);
            });

            $('.dtsTestPanelType').toggle($.inArray(schemeType, ['updated-3-tests', 'vietnam']) !== -1 && screeningTest === 'no');
            $('.syphilis-input').toggle(schemeType === 'ghana' && enableSyphilis === 'yes');
            $('.rtri-input').toggle(schemeType === 'updated-3-tests' && enableRtri === 'yes');

            if (isSampleDilutedVisible) {
                $('.sample-diluted-input').toggle(schemeType === 'vietnam' && sampleType === 'plasma');
            } else {
                $('.sample-diluted-input').hide();
            }
        }

        $('#toggleAdvancedDtsSettings').on('click', function() {
            $('#advancedDtsSettingsPanel').slideToggle();
            $('.advanced-config-source').slideToggle();
        });

        $('.dts-setting-source').on('change', function() {
            applyEffectiveSetting($(this).data('setting-key'));
            refreshDtsSettingVisibility();
        });

        $("#dtsSampleType").change(function() {
            refreshDtsSettingVisibility();
            if (!$(".sample-diluted-input").is(':visible')) {
                $("select[name='isSampleDiluted[]']").val('');
            }
        });

        <?php if ($isEditMode && count($samples) > 0): ?>
            // EDIT mode: Initialize modals for existing samples (blocks are already in HTML)
        <?php else: ?>
            // ADD mode: Create initial EIA block
            addNewEiaBlock('1');
        <?php endif; ?>

        // Initialize datepickers
        $(".datepicker").datepicker({
            dateFormat: '<?php echo $dtFormat; ?>'
        });

        // Syphilis toggle
        $("#enableSyphilis").change(function() {
            if ($(this).val() == "yes") {
                $(".syphilis-input").show();
                $("select[name='possibleSyphilisResults[]']").addClass("isRequired");
            } else {
                $(".syphilis-input").hide();
                $("select[name='possibleSyphilisResults[]']").removeClass("isRequired");
            }
        });

        // RTRI toggle
        $("#enableRtri").change(function() {
            if ($(this).val() == "yes") {
                $(".rtri-input").show();
            } else {
                $(".rtri-input").hide();
            }
        });
        if (initialSampleDilutedVisible) {
            $(".sample-diluted-input").show();
        }

        refreshDtsSettingVisibility();
    });

