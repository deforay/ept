<!-- Cancel / Expire shipment confirmation -->
<div class="modal fade" id="cancelShipmentModal" tabindex="-1" role="dialog" aria-labelledby="cancelShipmentLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="cancelShipmentLabel"><i class="icon-ban-circle"></i> <?= $this->htmlTranslate("Cancel / Expire Shipment"); ?> <span id="cancelShipmentCode"></span></h4>
            </div>
            <div class="modal-body">
                <p class="text-muted"><?= $this->htmlTranslate("Cancelling permanently locks this shipment. Participants can no longer submit or edit results, and no further admin actions are possible on it. This cannot be undone."); ?></p>
                <div class="form-group">
                    <label for="cancelReason"><?= $this->htmlTranslate("Reason for cancelling"); ?> <span class="mandatory">*</span></label>
                    <textarea id="cancelReason" class="form-control" rows="3" placeholder="<?= $this->htmlTranslate('e.g. Created in error, or replaced by a corrected shipment'); ?>"></textarea>
                </div>
                <div class="form-group">
                    <label for="cancelConfirm"><?= $this->htmlTranslate("Type"); ?> <code>CANCEL</code> <?= $this->htmlTranslate("to confirm"); ?></label>
                    <input type="text" id="cancelConfirm" class="form-control" autocomplete="off" placeholder="CANCEL" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal"><?= $this->htmlTranslate("Close"); ?></button>
                <button type="button" class="btn btn-danger" id="cancelShipmentConfirmBtn" disabled onclick="submitCancelShipment();"><i class="icon-ban-circle"></i> <?= $this->htmlTranslate("Cancel Shipment"); ?></button>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript" charset="utf-8">
    /* Table initialisation */
    var oTable = null;
    var duplicated = false;
    var cancelShipmentSid = null;

    function cancelShipment(sid, code) {
        cancelShipmentSid = sid;
        $('#cancelShipmentCode').text(code ? '(' + code + ')' : '');
        $('#cancelReason').val('');
        $('#cancelConfirm').val('');
        $('#cancelShipmentConfirmBtn').prop('disabled', true);
        // Reparent to <body> so the modal isn't trapped under the DataTables/column
        // stacking context (otherwise the table overlay renders on top of it).
        $('#cancelShipmentModal').appendTo('body').modal('show');
    }

    function validateCancelShipment() {
        var reasonOk = $.trim($('#cancelReason').val()) !== '';
        var tokenOk = $.trim($('#cancelConfirm').val()).toUpperCase() === 'CANCEL';
        $('#cancelShipmentConfirmBtn').prop('disabled', !(reasonOk && tokenOk));
    }

    function submitCancelShipment() {
        if (cancelShipmentSid == null) {
            return;
        }
        $.blockUI();
        $.post("<?php echo $this->url(['module' => 'admin', 'controller' => 'shipment', 'action' => 'cancel'], 'default', true); ?>", {
                sid: cancelShipmentSid,
                reason: $('#cancelReason').val(),
                confirmToken: $('#cancelConfirm').val(),
                format: "html"
            },
            function(data) {
                $.unblockUI();
                $('#cancelShipmentModal').modal('hide');
                alert(data);
                drawTable();
            });
    }

    function checkDuplicate(tableName, fieldName, obj, fnct, msg) {
        if (obj.val() == "" || obj.val() == null) {
            return;
        }
        $.post("<?php echo $this->url(array('module' => 'default', 'controller' => 'common', 'action' => 'check-duplicate')); ?>", {
                tableName: tableName,
                fieldName: fieldName,
                value: obj.val(),
                fnct: fnct,
                format: "html"
            },
            function(data) {
                if (data > 0) {
                    alert(msg, "err");
                    duplicated = true;
                    $(obj).val('');
                } else {
                    duplicated = false;
                }
            });
    }


    $(document).ready(function() {

        $("body").on("change", 'select.controlOrNot', function() {
            var scoreElem = $(this).parent().parent().find('.score');
            if ($(this).val() == 1) {
                $(scoreElem).val(0);
                $(scoreElem).attr('readonly', 'readonly');
            } else {
                $(scoreElem).removeAttr('readonly');
            }

        });

        $('#captureAdditionalDetails').on("change", function() {
            if ($(this).val() == 'yes') {
                $("#additionalDetailLabel").attr("disabled", false);
                $("#additionalDetailLabel").addClass("isRequired");
            } else {
                $("#additionalDetailLabel").attr("disabled", true);
                $("#additionalDetailLabel").removeClass("isRequired");
            }

        });

        $('#shipmentCode').on('input', function(event) {
            allowOnlyAlphaNumericAndHyphen('#shipmentCode');
        });

        $('#cancelReason, #cancelConfirm').on('input', validateCancelShipment);

        //drawTable();
        schemeSelected($("#scheme").val());
        $(".datepicker").datepicker({
            dateFormat: '<?php echo $this->defaultDateFormat(); ?>'
        });

        // Response deadline: single date + time picker (exact close time).
        if ($('#lastDate').length && $.fn.daterangepicker) {
            $('#lastDate').daterangepicker({
                singleDatePicker: true,
                timePicker: true,
                timePicker24Hour: true,
                autoUpdateInput: false,
                startDate: ($('#lastDate').val() ? moment($('#lastDate').val(), 'DD-MMM-YYYY HH:mm') : moment().hour(23).minute(59).second(0)),
                locale: { format: 'DD-MMM-YYYY HH:mm', cancelLabel: 'Clear' }
            });
            $('#lastDate').on('apply.daterangepicker', function(ev, picker) {
                $(this).val(picker.startDate.format('DD-MMM-YYYY HH:mm'));
            });
            $('#lastDate').on('cancel.daterangepicker', function() {
                $(this).val('');
            });
        }

        $('#currentType1, #currentType2, #currentType3').click(function() {
            drawTable();
        });

        bindColSearch('#shipmentTable', function (value, colIdx) {
            if (oTable) {
                oTable.fnFilter(value, colIdx);
            }
        });
    });

    function validateNow() {
        allowOnlyAlphaNumericAndHyphen('#shipmentCode');
        flag = deforayValidator.init({
            formId: 'shipmentForm'
        });
        if (flag) {
            $.blockUI();
            document.getElementById('shipmentForm').submit();
        }
    }

    function schemeSelected(scheme) {
        drawTable();
        $("#schemeId").val(scheme)
        $("#configShipment").hide();
        if (scheme != "" && scheme != null) {
            <?php if (isset($this->unshippedDistro) && count($this->unshippedDistro) > 0 && $this->unshippedDistro != '') { ?>
                $("#enrollBtn span").text("New Shipment : " + $("#scheme option:selected").text());
                $("#btnSpan").fadeIn();
            <?php } else { ?>
                $("#btnSpan").fadeOut();
            <?php } ?>
        } else {
            $("#btnSpan").fadeOut();
        }

    }

    function responseSwitch(switchStatus, sid) {
        if (window.confirm("<?= $this->translate->_("Are you sure you wish to switch this shipment"); ?> " + switchStatus + " ?")) {
            $.blockUI();
            $.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'shipment', 'action' => 'response-switch')); ?>", {
                    sid: sid,
                    switchStatus: switchStatus,
                    format: "html"
                },
                function(data) {
                    alert(data);
                    drawTable();
                    $.unblockUI();
                });
        } else {
            drawTable();
        }

    }

    function removeShipment(sid) {
        if (window.confirm("<?= $this->translate->_("Are you sure you wish to delete? This cannot be undone!"); ?>")) {
            $.blockUI();
            $.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'shipment', 'action' => 'remove')); ?>", {
                    sid: sid,
                    format: "html"
                },
                function(data) {
                    alert(data);
                    drawTable();
                    $.unblockUI();
                });
        }

    }

    function drawTable() {
        oTable = $('#shipmentTable').dataTable({
            "oLanguage": {
                "sEmptyTable": "<?= $this->translate->_("No shipment schemes under this Distribution yet"); ?>"
            },
            "bJQueryUI": false,
            "bAutoWidth": false,
            "bInfo": true,
            "bScrollCollapse": true,
            "sPaginationType": "bootstrap",
            "bRetrieve": false,
            "bDestroy": true,
            "bSortCellsTop": true,
            "aoColumns": [{
                    "sClass": "center"
                },
                {
                    "sClass": "center"
                },
                {
                    "sClass": "center"
                },
                {
                    "sClass": "center"
                },
                {
                    "sClass": "center"
                },
                {
                    "sClass": "center"
                },
                {
                    "sClass": "center"
                },
                {
                    "sClass": "center",
                    "bSortable": false
                },
                {
                    "sClass": "center"
                },
                //                {"sClass": "center"},
                {
                    "sClass": "center",
                    "bSortable": false
                }
            ],
            "aaSorting": [
                [3, "desc"]
            ],
            "bProcessing": true,
            "bServerSide": true,
            "sAjaxSource": "<?php echo $this->url(array('module' => 'admin', 'controller' => 'shipment', 'action' => 'index', 'format' => 'html')); ?>",
            "fnServerParams": function(aoData) {
                schemeId = $("#scheme").val();
                aoData.push({
                    "name": "scheme",
                    "value": schemeId
                });
                aoData.push({
                    "name": "userconfig",
                    "value": $("#scheme").find(':selected').data('userconfig'),
                });
                aoData.push({
                    "name": "distribution",
                    "value": '<?php echo $this->selectedDistribution ?>'
                });
                aoData.push({
                    "name": "currentType",
                    "value": $('input[name=currentType]').filter(':checked').val()
                });
            },
            "fnServerData": function(sSource, aoData, fnCallback) {
                $.ajax({
                    "dataType": 'json',
                    "type": "POST",
                    "url": sSource,
                    "data": aoData,
                    "success": fnCallback
                });
            },
            "fnRowCallback": function(nRow, aData, iDisplayIndex) {
                /* Append the grade to the default row class name */

                $('td.sorting_1').addClass('goga');
            },
        });



        <?php
        if (isset($this->searchData) && $this->searchData != '') {
        ?>
            oTable.fnFilter('<?php echo $this->searchData; ?>');
        <?php
        }
        ?>

    };

    function newShipment() {
        getSampleForm();
        $("#configShipment").fadeIn('fast', function() {
            $('html, body').animate({
                scrollTop: ($("#configShipment").offset().top - 50)
            }, 600, function() {
                $("#configShipment").effect("highlight", 2000);
                $("#shipmentCode").val('');
                $.blockUI();
                $.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'shipment', 'action' => 'get-shipment-code')); ?>", {
                        sid: $("#scheme").val(),
                        userconfig: $("#scheme").find(':selected').data('userconfig'),
                        format: "html"
                    },
                    function(data) {
                        $("#shipmentCode").val(data);
                        $.unblockUI();

                    });
                $.unblockUI();
            });

        });
    }

    function getSampleForm() {
        if ($("#scheme").val() == "tb") {
            $(".tb-fields").show();
        }
        $('#userConfig').val($("#scheme").find(':selected').data('userconfig'));
        if ($("#scheme").val() == "generic-test") {
            $(".generic-test-inputs").addClass("isRequired");
            $(".generic-test-fields").show();
        } else {
            $(".generic-test-fields").val('');
            $(".generic-test-fields").hide();
            $(".generic-test-inputs").removeClass("isRequired");
        }
        $.blockUI();
        $.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'shipment', 'action' => 'get-sample-form')); ?>", {
                sid: $("#scheme").val(),
                userconfig: $("#scheme").find(':selected').data('userconfig'),
                format: "html"
            },
            function(data) {
                $("#sampleFormFragment").html(data);
                $.unblockUI();

            });
    }

    function mailShipment(sid) {
        if (window.confirm("Are you sure you want to send announcement mail to all participants ?")) {
            $.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'shipment', 'action' => 'new-shipment-mail')); ?>", {
                    sid: sid,
                    format: "html"
                },
                function(data) {
                    if (data > 0) {
                        alert("<?= $this->translate->_("Mail Sent successfully"); ?>");
                    }
                    oTable.fnDraw();
                });
        }

    }

    function generateTBFormsPDF(sid) {
        if (window.confirm("<?= $this->translate->_("Are you sure you want to generate TB forms for this shipment?"); ?>")) {
            $.post("<?php echo $this->url(['module' => 'admin', 'controller' => 'shipment', 'action' => 'generate-tb-form']); ?>", {
                    sid: sid,
                    format: "html"
                },
                function(data) {
                    if (data > 0) {
                        alert("<?= $this->translate->_("Generating TB forms"); ?>");
                    }
                    oTable.fnDraw();
                });
        }

    }
</script>