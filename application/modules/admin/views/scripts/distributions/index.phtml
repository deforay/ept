                "bSortable": false
            }
            ],
            "aaSorting": [
                [2, "desc"]
            ],
            "bProcessing": true,
            "bServerSide": true,
            "sAjaxSource": "<?php echo $this->url(array('module' => 'admin', 'controller' => 'distributions', 'action' => 'index', 'format' => 'html')); ?>",
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.ajax({
                    "dataType": 'json',
                    "type": "POST",
                    "url": sSource,
                    "data": aoData,
                    "success": fnCallback
                });
            }
        });

        <?php if (isset($this->searchData) && $this->searchData != '') { ?>
            oTable.fnFilter('<?php echo $this->searchData; ?>');
        <?php } ?>
    });

    function shipDistribution(did) {
        var choice = confirm("<?= $this->translate->_("Are you sure you want to ship this PT Survey?"); ?> \n <?= $this->translate->_("You cannot undo this!"); ?>")
        if (!choice) {
            return false;
        }
        $.blockUI();
        $.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'distributions', 'action' => 'ship-distribution')); ?>", {
            did: did,
            format: "html"
        },
            function (data) {
                alert(data);
                oTable.fnDraw();
                $.unblockUI();
            });
    }

    // Type-to-confirm delete for a PT Survey. Per-row params are stored on the modal's
    // submit button via data() so the click handler is wired only once.
    $(function () {
        var $modal = $('#deleteDistributionConfirmModal');
        if ($modal.length === 0) { return; }

        if ($modal.parent().get(0) !== document.body) {
            $modal.appendTo('body');
        }

        var $input = $('#deleteDistributionConfirmInput');
        var $btn = $('#deleteDistributionConfirmBtn');
        var $mismatch = $('#deleteDistributionMismatch');

        $input.on('input keyup', function () {
            var expected = ($btn.data('expectedCode') || '').toString();
            var matches = $(this).val().trim() === expected;
            $btn.prop('disabled', !matches);
            if (matches) { $mismatch.hide(); }
        });

        $btn.on('click', function () {
            if ($btn.prop('disabled')) { return; }
            var expected = ($btn.data('expectedCode') || '').toString();
            if ($input.val().trim() !== expected) {
                $mismatch.show();
                return;
            }
            var did = $btn.data('did');
            $modal.modal('hide');
            $.blockUI();
            $.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'distributions', 'action' => 'delete')); ?>", {
                did: did,
                format: "html"
            })
                .done(function (data) {
                    $.unblockUI();
                    var msg = (data || '').toString().trim();
                    if (msg === 'OK') {
                        oTable.fnDraw();
                    } else {
                        alert(msg || "<?= $this->translate->_('Failed to delete the PT Survey. Please try again or contact the administrator.'); ?>");
                    }
                })
                .fail(function () {
                    $.unblockUI();
                    alert("<?= $this->translate->_('Failed to delete the PT Survey. Please try again or contact the administrator.'); ?>");
                });
        });

        $modal.on('shown.bs.modal', function () {
            $('.modal-backdrop').last().addClass('delete-distribution-backdrop');
            $input.trigger('focus');
        });
    });

    function confirmDeleteDistribution(did, distributionCode) {
        distributionCode = (distributionCode || '').toString();
        $('#deleteDistributionCode').text(distributionCode);
        $('#deleteDistributionConfirmInput').val('');
        $('#deleteDistributionMismatch').hide();
        $('#deleteDistributionConfirmBtn')
            .prop('disabled', true)
            .data('did', did)
            .data('expectedCode', distributionCode);
        $('#deleteDistributionConfirmModal').modal('show');
    }
</script>