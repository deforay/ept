<?php
$result = '';
$stage = $this->testkitStage;
$isPosition = in_array($stage, ['testkit_1', 'testkit_2', 'testkit_3'], true);
foreach ($this->testkitList as $testkitList) {
    $selected = "";
    if ($isPosition) {
        if (!empty($testkitList[$stage]) && $testkitList[$stage] == 1) {
            $selected = "selected='selected'";
        }
    } elseif (!empty($testkitList['scheme_type']) && $testkitList['scheme_type'] == $stage) {
        $selected = "selected='selected'";
    }
    $result .= '<option value="' . $testkitList['TESTKITNAMEID'] . '"' . $selected . '>' . $testkitList['TESTKITNAME'] . '</option>';
}
echo $result;
