<script type="text/javascript">
	var duplicated = false;
	$(document).ready(function() {
		$(".multiselect").select2({
			placeholder: "<?= $this->translate->_("Choose one or more options"); ?>",
			width: '100%'
		});
		selectStages();
	});
	additionalInfoFun($('#additionalInfo').val());

	function checkDuplicate(tableName, fieldName, obj, fnct, msg) {
		$.post("<?php echo $this->url(array('module' => 'default', 'controller' => 'common', 'action' => 'check-duplicate')); ?>", {
				tableName: tableName,
				fieldName: fieldName,
				value: obj.value,
				fnct: fnct,
				format: "html"
			},
			function(data) {
				if (data > 0) {
					alert(msg, "err");
					duplicated = true;
					$(obj).val('');
				} else {
					duplicated = false;
				}
			});
	}

	function validateNow() {
		flag = deforayValidator.init({
			formId: 'editTestkitForm'
		});
		if (flag && !duplicated) {
			$.blockUI();
			document.getElementById('editTestkitForm').submit();
		}
	}

	function additionalInfoFun(value) {
		if (value == '1') {
			$('.additionalInfo').removeClass('hide');
		} else {
			$('.additionalInfo').addClass('hide');
		}
	}

	function selectStages() {
		let list = $('[name="scheme[]"]').val();

		const multiStageSchemes = ['covid19', 'dbs', 'eid', 'recency', 'tb', 'vl'];

		let showStages = false;
		let isDts = false;

		$(list).each(function(i, data) {
			if (data == 'dts') {
				showStages = true;
				isDts = true;
			} else if (!$.inArray(data, multiStageSchemes) !== -1) {
				showStages = true;
			}
		});

		if (showStages) {
			$('.testStages').removeClass('hide');
			$('#testStages').addClass('isRequired');

			if (isDts) {
				// DTS — show all 3 options
				$('.showDtsHint').removeClass('hide');
				$('#testStages').html(`
                <option value=""> -- <?= $this->translate->_("Select"); ?> -- </option>
                <option value="testkit_1"><?= $this->translate->_("Test 1"); ?></option>
                <option value="testkit_2"><?= $this->translate->_("Test 2"); ?></option>
                <option value="testkit_3"><?= $this->translate->_("Test 3"); ?></option>
            `);
			} else {
				$('.showDtsHint').addClass('hide');
				// Other schemes — show only Test 1
				$('#testStages').html(`
                <option value=""> -- <?= $this->translate->_("Select"); ?> -- </option>
                <option value="testkit_1"><?= $this->translate->_("Test 1"); ?></option>
            `);
				$('#testStages').val('').trigger('change');
			}
		} else {
			// Hide stages if no matching scheme
			$('#testStages').removeClass('isRequired');
			$('.testStages').addClass('hide');
		}
	}
</script>