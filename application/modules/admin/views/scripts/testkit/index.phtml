<script type="text/javascript" charset="utf-8">
    /* Table initialisation */
    var oTable = null;
    $(document).ready(function () {
        drawTable();
    });

    function getApproval(status) {
        if (status == 'pending') {
            $('.status-field').removeClass('hide');
        } else {
            $('.status-field').addClass('hide');
        }
        $('#status').val(status);
        drawTable();
    }

    function drawTable() {
        oTable = $('#testkitTable').dataTable({

            "bJQueryUI": false,
            "bAutoWidth": false,
            "bInfo": true,
            "bScrollCollapse": true,
            "sPaginationType": "bootstrap",
            "bRetrieve": false,
            "bDestroy": true,
            "aoColumns": [{
                "sClass": ""
            },
            {
                "sClass": ""
            },
            {
                "sClass": ""
            },
            {
                "sClass": "center"
            },
            {
                "sClass": "center"
            },
            {
                "sClass": "center"
            },
            {
                "sClass": "center"
            },
            {
                "sClass": "center",
                "bSortable": false
            }
            ],
            "aaSorting": [
                [0, "asc"]
            ],
            /* "fnDrawCallback": function() {
                var checkBoxes = document.getElementsByName("subchk[]");
                len = checkBoxes.length;
                for (c = 0; c < len; c++) {
                    if (jQuery.inArray(checkBoxes[c].id, selectedKit) != -1) {
                        checkBoxes[c].setAttribute("checked", true);
                    }
                }

            }, */
            "bProcessing": true,
            "bServerSide": true,
            "sAjaxSource": "<?php echo $this->url(array('module' => 'admin', 'controller' => 'testkit', 'action' => 'index', 'format' => 'html')); ?>",
            "fnServerParams": function (aoData) {
                aoData.push({ "name": "status", "value": $("#status").val() });
                aoData.push({ "name": "scheme", "value": $("#schemeFilter").val() });
                aoData.push({ "name": "mohApproved", "value": $("#mohFilter").val() });
                aoData.push({ "name": "ptValidated", "value": $("#ptFilter").val() });
            },
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.ajax({
                    "dataType": 'json',
                    "type": "POST",
                    "url": sSource,
                    "data": aoData,
                    "success": fnCallback
                });
            }
        });
    }

    /* function addKit(kitId, obj) {
        if (obj.checked == true) {
            if ($.inArray(kitId, selectedKit) == -1) {
                selectedKit.push(kitId);
            }
        } else {
            selectedKit.remove(kitId);
        }
        $("#testkitId").val(selectedKit);
    } */
    function updateAll() {
        if (confirm("Are you sure you want to update the status?\n This cannot be undone !")) {
            $.blockUI();
            $.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'testkit', 'action' => 'update-status')); ?>", {
                status: $('#updateStatus').val(),
                format: "html"
            },
                function (data) {
                    alert("<?= $this->translate->_("Status updated successfully"); ?>");
                    oTable.fnDraw();
                    $.unblockUI();
                });
        }

    }
</script>