$o = $this->overview;
$fmt = static function ($date) {
    if (empty($date) || $date === '0000-00-00') {
        return '—';
    }
    $ts = strtotime($date);
    return $ts ? date('d-M-Y', $ts) : $date;
};
$num = static fn($n) => number_format((int) $n);

$describeEdge = static function ($row) use ($fmt) {
    if (empty($row) || empty($row['shipment_date'])) {
        return ['date' => '—', 'code' => null, 'scheme' => null];
    }
    return [
        'date'   => $fmt($row['shipment_date']),
        'code'   => $row['shipment_code'] ?? null,
        'scheme' => !empty($row['scheme_name'])
            ? ucwords($row['scheme_name'])
            : (isset($row['scheme_type']) ? strtoupper($row['scheme_type']) : null),
    ];
};
$oldest = $describeEdge($o['oldest_shipment']);
$latest = $describeEdge($o['latest_shipment']);
$edgeText = static function ($e) {
    $parts = [$e['date']];
    if (!empty($e['code'])) {
        $parts[] = $e['code'];
    }
    if (!empty($e['scheme'])) {
        $parts[] = $e['scheme'];
    }
    return implode(' — ', $parts);
};

$activeSchemeNames = array_map(static function ($s) {
    return ucwords($s['scheme_name']);
