<script>
    (function () {
        var richBtn = document.getElementById('ept-overview-copy-btn');
        var plainBtn = document.getElementById('ept-overview-copy-plain-btn');
        var copySource = document.getElementById('ept-overview-copy-source');
        var ta = document.getElementById('ept-overview-copy-text');
        if (!richBtn || !plainBtn || !copySource || !ta) return;

        var label = richBtn.querySelector('.copy-btn-label');
        var flashCopied = function () {
            if (!label) return;
            var orig = label.textContent;
            label.textContent = 'Copied';
            setTimeout(function () { label.textContent = orig; }, 1500);
        };

        var copyViaSelection = function () {
            // Temporarily make the off-screen source selectable
            var prevLeft = copySource.style.left;
            copySource.style.left = '0';
            copySource.style.opacity = '0';
            var sel = window.getSelection();
            var range = document.createRange();
            range.selectNodeContents(copySource);
            sel.removeAllRanges();
            sel.addRange(range);
            try { document.execCommand('copy'); } catch (e) {}
            sel.removeAllRanges();
            copySource.style.left = prevLeft || '-99999px';
            copySource.style.opacity = '';
        };

        richBtn.addEventListener('click', function () {
            var html = copySource.innerHTML;
            var text = ta.value;
            if (window.ClipboardItem && navigator.clipboard && navigator.clipboard.write) {
                var item = new ClipboardItem({
                    'text/html': new Blob([html], { type: 'text/html' }),
                    'text/plain': new Blob([text], { type: 'text/plain' })
                });
                navigator.clipboard.write([item]).then(flashCopied, function () {
                    copyViaSelection();
                    flashCopied();
                });
            } else {
                copyViaSelection();
                flashCopied();
            }
        });

        plainBtn.addEventListener('click', function () {
            var text = ta.value;
            var done = function () {
                var orig = plainBtn.textContent;
                plainBtn.textContent = 'Copied';
                setTimeout(function () { plainBtn.textContent = orig; }, 1500);
            };
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(done, function () {
                    ta.select(); document.execCommand('copy'); done();
                });
            } else {
                ta.select(); document.execCommand('copy'); done();
            }
        });
    })();
</script>
