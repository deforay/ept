            <div class="virt-pane-scroll"><div class="virt-pane-inner"></div></div>
            <div class="virt-pane-footer"><?= $this->htmlTranslate('Selected Participants'); ?> (<span class="virt-count">0</span>)<span class="virt-diff virt-diff-added" style="display:none;">+ <span class="virt-diff-count">0</span> <?= $this->htmlTranslate("pending add"); ?></span></div>
