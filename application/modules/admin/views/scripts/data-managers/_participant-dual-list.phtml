<script>
    var PDL_GET_PARTICIPANT_URL = "<?php echo $this->url(array('module' => 'admin', 'controller' => 'participants', 'action' => 'get-participant')); ?>";
    var PDL_DM_ID = <?= $dmIdForMap; ?>;
    var PDL_PRESELECTED = <?= json_encode(array_values(array_map('intval', $preSelected))); ?>;

    var ParticipantDualList = (function() {
        var ROW_HEIGHT = 30;
        var OVERSCAN = 6;
        var state = { left: [], right: [] };
        var panes = {};

        function escapeHtml(s) {
            return String(s).replace(/[&<>"']/g, function(c) {
                return ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[c];
            });
        }

        function initPane(sideKey, paneEl) {
            var $pane = $(paneEl);
            var pane = {
                sideKey: sideKey,
                $scroll: $pane.find('.virt-pane-scroll'),
                $inner: $pane.find('.virt-pane-inner'),
                $search: $pane.find('.virt-pane-header input'),
                $count: $pane.find('.virt-count'),
                $diff: $pane.find('.virt-diff'),
                $diffCount: $pane.find('.virt-diff-count'),
                filter: '',
                filtered: []
            };
            pane.$scroll.on('scroll', function() { render(pane); });
            pane.$search.on('input', function() {
                pane.filter = pane.$search.val().toLowerCase();
                recomputeFiltered(pane);
                pane.$scroll.scrollTop(0);
                render(pane);
            });
            pane.$inner.on('click', '.virt-row', function() {
                moveItem(pane.sideKey, $(this).attr('data-id'));
            });
            panes[sideKey] = pane;
        }

        function recomputeFiltered(pane) {
            var src = state[pane.sideKey];
            if (!pane.filter) {
                pane.filtered = src;
            } else {
                var f = pane.filter;
                pane.filtered = [];
                for (var i = 0; i < src.length; i++) {
                    if (src[i]._lc.indexOf(f) !== -1) pane.filtered.push(src[i]);
                }
            }
            pane.$count.text(pane.filtered.length);
            pane.$inner.css('height', (pane.filtered.length * ROW_HEIGHT) + 'px');
            updateDiffBadge(pane);
        }

        function updateDiffBadge(pane) {
            if (!pane.$diff || pane.$diff.length === 0) return;
            var src = state[pane.sideKey];
            var diffCount = 0;
            if (pane.sideKey === 'right') {
                for (var i = 0; i < src.length; i++) if (!src[i].savedRight) diffCount++;
            } else {
                for (var j = 0; j < src.length; j++) if (src[j].savedRight) diffCount++;
            }
            pane.$diffCount.text(diffCount);
            pane.$diff.toggle(diffCount > 0);
        }

        function rowClass(it, sideKey) {
            if (sideKey === 'right') {
                return it.savedRight ? 'virt-row-saved' : 'virt-row-added';
            }
            return it.savedRight ? 'virt-row-removed' : '';
        }

        function render(pane) {
            var scrollTop = pane.$scroll.scrollTop();
            var h = pane.$scroll.height();
            var first = Math.max(0, Math.floor(scrollTop / ROW_HEIGHT) - OVERSCAN);
            var last = Math.min(pane.filtered.length, Math.ceil((scrollTop + h) / ROW_HEIGHT) + OVERSCAN);
            var parts = [];
            for (var i = first; i < last; i++) {
                var it = pane.filtered[i];
                var cls = rowClass(it, pane.sideKey);
                parts.push('<div class="virt-row' + (cls ? ' ' + cls : '') + '" style="top:' + (i * ROW_HEIGHT) + 'px" data-id="' + escapeHtml(it.id) + '">' + escapeHtml(it.label) + '</div>');
            }
            pane.$inner.html(parts.join(''));
        }

        function moveItem(fromSide, id) {
            var toSide = fromSide === 'left' ? 'right' : 'left';
            var arr = state[fromSide];
            for (var i = 0; i < arr.length; i++) {
                if (String(arr[i].id) === String(id)) {
                    var item = arr.splice(i, 1)[0];
                    state[toSide].push(item);
                    break;
                }
            }
            refresh();
        }

        function refresh() {
            recomputeFiltered(panes.left);
            recomputeFiltered(panes.right);
            render(panes.left);
            render(panes.right);
        }

        function load(items) {
            state.left = [];
            state.right = [];
            for (var i = 0; i < items.length; i++) {
                var it = items[i];
                it._lc = String(it.label).toLowerCase();
                it.savedRight = !!it.selected;
                if (it.selected) state.right.push(it);
                else state.left.push(it);
            }
            if (panes.left) { panes.left.$search.val(''); panes.left.filter = ''; panes.left.$scroll.scrollTop(0); }
            if (panes.right) { panes.right.$search.val(''); panes.right.filter = ''; panes.right.$scroll.scrollTop(0); }
            refresh();
        }

        function selectAll() {
            var visibleIds = {};
            for (var i = 0; i < panes.left.filtered.length; i++) visibleIds[panes.left.filtered[i].id] = true;
            var keep = [];
            for (var j = 0; j < state.left.length; j++) {
                if (visibleIds[state.left[j].id]) state.right.push(state.left[j]);
                else keep.push(state.left[j]);
            }
            state.left = keep;
            refresh();
        }

        function deselectAll() {
            var visibleIds = {};
            for (var i = 0; i < panes.right.filtered.length; i++) visibleIds[panes.right.filtered[i].id] = true;
            var keep = [];
            for (var j = 0; j < state.right.length; j++) {
                if (visibleIds[state.right[j].id]) state.left.push(state.right[j]);
                else keep.push(state.right[j]);
            }
            state.right = keep;
            refresh();
        }

        function getSelectedIds() {
            var ids = [];
            for (var i = 0; i < state.right.length; i++) ids.push(state.right[i].id);
            return ids;
        }

        return {
            init: initPane,
            load: load,
            selectAll: selectAll,
            deselectAll: deselectAll,
            getSelectedIds: getSelectedIds
        };
    })();

    var PDL_I18N = {
        showFilters: "<?= $this->jsTranslate('Show advanced filters'); ?>",
        hideFilters: "<?= $this->jsTranslate('Hide advanced filters'); ?>",
        confirmMulti: "<?= $this->jsTranslate('You have selected {COUNT} participants. This Data Manager will be able to access the data of ALL {COUNT} selected participants. Are you sure you want to continue?'); ?>"
    };

    function pdlAdvFilter() {
        var $box = $('.pdl-wrapper .advFilter');
        $box.toggle();
        var $btn = $('.pdl-filter-btn');
        $btn.text($box.is(':visible') ? PDL_I18N.hideFilters : PDL_I18N.showFilters);
    }

    function pdlGetStates(cid) {
        $.blockUI();
        $.post("<?php echo $this->url(array('module' => 'default', 'controller' => 'common', 'action' => 'get-country-wise-states')); ?>", { cid: cid, format: "html" },
            function(data) {
                if (data) { $('#pdl_province').html(data); }
                $.unblockUI();
            });
    }

    function pdlGetDistricts(pid) {
        $.blockUI();
        $.post("<?php echo $this->url(array('module' => 'default', 'controller' => 'common', 'action' => 'get-state-wise-districts')); ?>", { pid: pid, format: "html" },
            function(data) {
                if (data) { $('#pdl_district').html(data); }
                $.unblockUI();
            });
    }

    function pdlGetInstitutes() {
        $.blockUI();
        $.post("<?php echo $this->url(array('module' => 'default', 'controller' => 'common', 'action' => 'get-state-districts-wise-institute')); ?>", {
                pid: $('#pdl_province').val(),
                did: $('#pdl_district').val(),
                format: "html"
            },
            function(data) {
                if (data) { $('#pdl_institute').html(data); }
                $.unblockUI();
            });
    }

    function pdlLoad() {
        $.blockUI();
        $.ajax({
            url: PDL_GET_PARTICIPANT_URL,
            type: 'POST',
            dataType: 'json',
            data: {
                datamanagerId: PDL_DM_ID || '',
                country: $('#pdl_country').val() || '',
                province: $('#pdl_province').val() || '',
                district: $('#pdl_district').val() || '',
                network: $('#pdl_networkTier').val() || '',
                affiliation: $('#pdl_affiliation').val() || '',
                institute: $('#pdl_institute').val() || '',
                format: 'html'
            }
        }).done(function(items) {
            items = items || [];
            if (!PDL_DM_ID && PDL_PRESELECTED && PDL_PRESELECTED.length) {
                var preMap = {};
                for (var i = 0; i < PDL_PRESELECTED.length; i++) preMap[PDL_PRESELECTED[i]] = true;
                for (var j = 0; j < items.length; j++) {
                    if (preMap[parseInt(items[j].id, 10)]) items[j].selected = true;
                }
            }
            ParticipantDualList.load(items);
        }).always(function() {
            $.unblockUI();
        });
    }

    function pdlInjectHiddenInputs() {
        var ids = ParticipantDualList.getSelectedIds();
        var $holder = $('#pdl-hidden-inputs');
        $holder.empty();
        // Single JSON-encoded hidden input avoids PHP max_input_vars
        // truncating the list when many participants are selected.
        $holder.append('<input type="hidden" name="allparticipant" value="' +
            $('<div/>').text(JSON.stringify(ids)).html() + '" />');
        return ids.length;
    }

    function pdlFlashError() {
        var $right = $('.pdl-wrapper .virt-pane[data-side="right"]');
        $right.addClass('pdl-error');
        $('html, body').animate({ scrollTop: $right.offset().top - 80 }, 300);
        setTimeout(function () { $right.removeClass('pdl-error'); }, 2500);
    }

    function pdlConfirmMulti() {
        var count = ParticipantDualList.getSelectedIds().length;
        if (count <= 1) return true;
        return confirm(PDL_I18N.confirmMulti.replace(/\{COUNT\}/g, count));
    }

    $(document).ready(function() {
        if ($.fn.select2) {
            $('.pdl-select2').select2({ allowClear: true, placeholder: "<?= $this->jsTranslate('All'); ?>" });
        }
        $('.pdl-wrapper .virt-pane').each(function() {
            ParticipantDualList.init($(this).attr('data-side'), this);
        });
        $('#pdl-select-all').on('click', function(e) { e.preventDefault(); ParticipantDualList.selectAll(); });
        $('#pdl-deselect-all').on('click', function(e) { e.preventDefault(); ParticipantDualList.deselectAll(); });
        pdlLoad();
    });
</script>
