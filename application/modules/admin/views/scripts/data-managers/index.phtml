<script type="text/javascript" charset="utf-8">
    $('#myModal').on('hidden.bs.modal', function() {

        $(this).removeData('bs.modal');
    });
    /* Table initialisation */
    var oTable = null;
    $(document).ready(function() {
        oTable = $('#usersTable').dataTable({

            "bJQueryUI": false,
            "bAutoWidth": false,
            "bInfo": true,
            "bScrollCollapse": true,
            "sPaginationType": "bootstrap",
            "bRetrieve": true,
            "bSortCellsTop": true,
            "aoColumns": [{
                    "sClass": "center",
                    "bSortable": false,
                    "bSearchable": false
                },
                {
                    "sClass": ""
                },
                <?php if (!isset($ptcc) || empty($ptcc) || $ptcc != 1) { ?> {
                        "sClass": ""
                    },
                <?php } ?> {
                    "sClass": "center"
                },
                {
                    "sClass": "center"
                },
                {
                    "sClass": "center"
                },
                {
                    "sClass": "center"
                },
                <?php if (isset($ptcc) && !empty($ptcc) && $ptcc == 1) { ?> {
                        "sClass": "center"
                    },
                    {
                        "sClass": "center"
                    },
                    {
                        "sClass": "center"
                    },
                <?php } ?> {
                    "sClass": "center",
                    "bSortable": false
                },
                {
                    "sClass": "center",
                    "bSortable": false
                }
            ],
            "aaSorting": [
                [1, "asc"]
            ],
            "bProcessing": true,
            "bServerSide": true,
            "sAjaxSource": "<?php echo $this->url(array('module' => 'admin', 'controller' => 'data-managers', 'action' => 'index', 'format' => 'html')); ?>",
            "fnServerParams": function(aoData) {
                schemeType = $("#scheme").val();
                dateRange = $("#dateRange").val();
                dataManager = $("#dataManager").val();
                aoData.push({
                    "name": "ptcc",
                    "value": <?php echo $ptcc; ?>
                });
                aoData.push({
                    "name": "statusFilter",
                    "value": $("#statusFilter").val()
                });
                aoData.push({
                    "name": "mappingFilter",
                    "value": $("#mappingFilter").val() || ""
                });
            },
            "fnServerData": function(sSource, aoData, fnCallback) {
                $.ajax({
                    "dataType": 'json',
                    "type": "POST",
                    "url": sSource,
                    "data": aoData,
                    "success": fnCallback
                });
            },
            "fnRowCallback": function(nRow, aData) {
                // Highlight rows with no mapped participants (the column emits
                // <em class="unmapped-tag">…</em> when the count is 0)
                if ($(nRow).find('.unmapped-tag').length > 0) {
                    $(nRow).addClass('row-unmapped');
                } else {
                    $(nRow).removeClass('row-unmapped');
                }
                return nRow;
            }
        });

        $("#statusFilter").change(function() {
            oTable.fnDraw();
        });

        $("#mappingFilter").change(function() {
            oTable.fnDraw();
        });

        bindColSearch('#usersTable', function(value, colIdx) {
            oTable.fnFilter(value, colIdx);
        });

        // Mapped Participants column — expand/collapse child row with on-demand AJAX fetch
        $('#usersTable tbody').on('click', 'a.toggle-participant-row', function(e) {
            e.preventDefault();
            var $btn = $(this);
            var dmId = $btn.data('dm-id');
            var tr = $btn.closest('tr')[0];
            if (oTable.fnIsOpen(tr)) {
                oTable.fnClose(tr);
                return;
            }
            // Close any OTHER open child row in the table — only one expanded at a time.
            // Skip the current row: fnOpen below closes the existing child on this row atomically.
            $('#usersTable tbody tr').each(function() {
                if (this !== tr && oTable.fnIsOpen(this)) {
                    oTable.fnClose(this);
                }
            });
            var placeholder = '<div style="padding:12px;color:#888;"><i class="icon-refresh"></i> <?= $this->translate->_("Loading participants…"); ?></div>';
            oTable.fnOpen(tr, placeholder, 'participant-child-container');
            $.post(
                "<?php echo $this->url(array('module' => 'admin', 'controller' => 'data-managers', 'action' => 'mapped-participants', 'format' => 'html')); ?>", {
                    id: dmId
                },
                function(html) {
                    var $childTr = $(tr).next('tr');
                    $childTr.find('td').first().html(html);
                }
            ).fail(function() {
                var $childTr = $(tr).next('tr');
                $childTr.find('td').first().html('<div style="padding:12px;color:#a94442;"><?= $this->translate->_("Failed to load participants. Please try again."); ?></div>');
            });
        });

        // Hook called by reset-password / change-primary-email modals on success.
        // Redraw the data-managers table in place so the updated email/status shows
        // without reloading the whole page.
        window.afterDmActionSuccess = function() {
            // Bulk modal also calls this after completion — clear selection too.
            selectedDmIds.clear();
            updateBulkUi();
            oTable.fnDraw(false);
        };

        /* Bulk selection: track dm_ids across paging since rows get re-rendered. */
        var selectedDmIds = new Set();

        function updateBulkUi() {
            var count = selectedDmIds.size;
            $('#bulkResetCount').text(count);
            // Show the bulk action bar only when at least one row is selected.
            $('#bulkActionBar').toggle(count > 0);
            // Sync the header "select all" checkbox state with this page.
            var $pageBoxes = $('#usersTable tbody input.dm-select');
            var visible = $pageBoxes.length;
            var checkedHere = $pageBoxes.filter(':checked').length;
            var $all = $('#dmSelectAll');
            $all.prop('checked', visible > 0 && checkedHere === visible);
            // indeterminate when partial
            $all.prop('indeterminate', checkedHere > 0 && checkedHere < visible);
        }

        // Restore checkbox state after each redraw (paging, filter, search).
        $('#usersTable').on('draw.dt', function() {
            $('#usersTable tbody input.dm-select').each(function() {
                this.checked = selectedDmIds.has(parseInt(this.value, 10));
            });
            updateBulkUi();
        });

        // Header "select all on this page" toggles every visible row's checkbox.
        $('#dmSelectAll').on('change', function() {
            var checked = this.checked;
            $('#usersTable tbody input.dm-select').each(function() {
                var id = parseInt(this.value, 10);
                this.checked = checked;
                if (checked) {
                    selectedDmIds.add(id);
                } else {
                    selectedDmIds.delete(id);
                }
            });
            updateBulkUi();
        });

        $('#usersTable tbody').on('change', 'input.dm-select', function() {
            var id = parseInt(this.value, 10);
            if (this.checked) {
                selectedDmIds.add(id);
            } else {
                selectedDmIds.delete(id);
            }
            updateBulkUi();
        });

        $('#bulkClearBtn').on('click', function() {
            selectedDmIds.clear();
            $('#usersTable tbody input.dm-select').prop('checked', false);
            updateBulkUi();
        });

        $('#bulkResetBtn').on('click', function() {
            if (selectedDmIds.size === 0) {
                return;
            }
            var ids = Array.from(selectedDmIds).join(',');
            // URL stays well under typical limits for the realistic batch sizes here.
            layoutModal('/admin/data-managers/bulk-reset-password/ids/' + encodeURIComponent(ids), '720', '600');
        });

        $('#bulkByListBtn').on('click', function() {
            layoutModal('/admin/data-managers/bulk-reset-by-list', '720', '640');
        });

        // Inline filter for the expanded participants list (only present when > 5 mapped)
        $('#usersTable tbody').on('input', 'input.participant-filter-input', function() {
            var q = $(this).val().toLowerCase().trim();
            var $rows = $(this).closest('.participant-child-row').find('tr.participant-row');
            if (q === '') {
                $rows.show();
                return;
            }
            $rows.each(function() {
                var blob = $(this).attr('data-p-search') || '';
                $(this).toggle(blob.indexOf(q) !== -1);
            });
        });

    });

    function generatePtccExport(type) {
        $.blockUI();
        $.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'data-managers', 'action' => 'export-ptcc')); ?>", {
                type: type,
                format: "html"
            },
            function(data) {
                if (data != "") {
                    //alert(data);$.unblockUI();return;
                    document.location.href = '/temporary/' + data;
                }
                $.unblockUI();
            });
    }
</script>