                },
                {
                    "sClass": "center"
                },
                {
                    "sClass": "center"
                },
                <?php if (isset($ptcc) && !empty($ptcc) && $ptcc == 1) { ?> {
                        "sClass": "center"
                    },
                    {
                        "sClass": "center"
                    },
                    {
                        "sClass": "center"
                    },
                <?php } ?> {
                    "sClass": "center",
                    "bSortable": false
                }
            ],
            "aaSorting": [
                [0, "asc"]
            ],
            "bProcessing": true,
            "bServerSide": true,
            "sAjaxSource": "<?php echo $this->url(array('module' => 'admin', 'controller' => 'data-managers', 'action' => 'index', 'format' => 'html')); ?>",
            "fnServerParams": function (aoData) {
                schemeType = $("#scheme").val();
                dateRange = $("#dateRange").val();
                dataManager = $("#dataManager").val();
                aoData.push({
                    "name": "ptcc",
                    "value": <?php echo $ptcc; ?>
                });
                aoData.push({
                    "name": "statusFilter",
                    "value": $("#statusFilter").val()
                });
            },
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.ajax({
                    "dataType": 'json',
                    "type": "POST",
                    "url": sSource,
                    "data": aoData,
                    "success": fnCallback
                });
            }
        });

        $("#statusFilter").change(function () {
            oTable.fnDraw();
        });

    });

    function generatePtccExport(type) {
        $.blockUI();
        $.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'data-managers', 'action' => 'export-ptcc')); ?>", {
            type: type,
            format: "html"
        },
            function (data) {
                if (data != "") {
                    //alert(data);$.unblockUI();return;
                    document.location.href = '/temporary/' + data;
                }
                $.unblockUI();
            });
    }
</script>