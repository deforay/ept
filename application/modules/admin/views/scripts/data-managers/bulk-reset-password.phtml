                <?= $this->translate->_('Submitting will queue the reset to run in the background.'); ?>
            </div>
            <button type="button" id="bulkSubmitBtn" class="btn btn-primary" onclick="submitBulkReset();">
                <i class="icon-envelope"></i> <span id="bulkSubmitLabel"><?= $this->translate->_('Queue Reset & Email'); ?></span>
            </button>
            <button type="button" class="btn btn-link" onclick="window.parent.closeLayoutModal();">
                <?= $this->translate->_('Cancel'); ?>
            </button>
        </div>

    <?php } ?>
</form>

<script type="text/javascript">
    function updateBulkButton() {
        var send = document.getElementById('sendEmail').checked;
        var $btn = $('#bulkSubmitBtn');
        var $label = $('#bulkSubmitLabel');
        $('#recipientsBlock').toggle(send);
        if (send) {
            $btn.removeClass('btn-info').addClass('btn-primary')
                .find('i').attr('class', 'icon-envelope');
            $label.text(<?= json_encode($this->translate->_('Queue Reset & Email')); ?>);
        } else {
            $btn.removeClass('btn-primary').addClass('btn-info')
                .find('i').attr('class', 'icon-key');
            $label.text(<?= json_encode($this->translate->_('Queue Reset (no email)')); ?>);
        }
    }

    function submitBulkReset() {
        var n = <?= count($dms); ?>;
        var send = document.getElementById('sendEmail').checked;
        var msg = send
            ? <?= json_encode($this->translate->_('Queue password reset and credentials email for %d data manager(s)?')); ?>
            : <?= json_encode($this->translate->_('Queue password reset for %d data manager(s) without sending email?')); ?>;
        msg = msg.replace('%d', n);
        if (!confirm(msg)) {
            return;
        }
        $.blockUI({ message: <?= json_encode('<h4>' . $this->translate->_('Queueing…') . '</h4>'); ?> });
        document.getElementById('bulkResetForm').submit();
    }

    $(function () {
        $('#sendEmail').on('change', updateBulkButton);
        updateBulkButton();
    });
</script>
