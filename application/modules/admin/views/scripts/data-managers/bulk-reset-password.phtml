        </button>
    <?php } else { ?>

        <div class="form-group">
            <label><?= $this->translate->_('Selected data managers'); ?></label>
            <div class="dm-list">
                <?php foreach ($dms as $dm) {
                    $isActive = strtolower((string) $dm['status']) === 'active';
                    $name = trim(($dm['first_name'] ?? '') . ' ' . ($dm['last_name'] ?? ''));
                    ?>
                    <div class="dm-row <?= $isActive ? '' : 'inactive'; ?>">
                        <strong><?= htmlspecialchars($name ?: '—', ENT_QUOTES, 'UTF-8'); ?></strong>
                        &nbsp;<span style="color:#666;">&lt;<?= htmlspecialchars((string) $dm['primary_email'], ENT_QUOTES, 'UTF-8'); ?>&gt;</span>
                        <span class="label-status"><?= htmlspecialchars(ucfirst((string) $dm['status']), ENT_QUOTES, 'UTF-8'); ?></span>
                    </div>
                <?php } ?>
            </div>
            <div class="help-line">
                <?= $this->translate->_('A unique random password will be generated for each user.'); ?>
            </div>
        </div>

        <input type="hidden" name="dmIds" value="<?= htmlspecialchars(implode(',', array_map(fn($d) => (int) $d['dm_id'], $dms)), ENT_QUOTES, 'UTF-8'); ?>" />
        <input type="hidden" name="loginUrl" value="<?= htmlspecialchars((string) ($this->loginUrl ?? ''), ENT_QUOTES, 'UTF-8'); ?>" />
