<?php

$csrfNamespace = new Zend_Session_Namespace('csrf');
$adminEmail = trim((string) Application_Service_Common::getConfig('admin_email'));
$dms = $this->dms ?? [];
$result = $this->result ?? null;

if (!empty($result)) { ?>
    <div style="padding: 12px 4px;">
        <h4 class="modal-title" style="margin-bottom: 14px;">
            <?= $this->translate->_('Bulk Reset Queued'); ?>
        </h4>
        <?php if (!empty($result['error'])) { ?>
            <div class="alert alert-danger">
                <?= htmlspecialchars((string) $result['error'], ENT_QUOTES, 'UTF-8'); ?>
            </div>
        <?php } else { ?>
            <div class="alert alert-info" style="margin-bottom: 12px;">
                <i class="icon-time"></i>
                <strong><?= (int) $result['queued']; ?></strong>
                <?= $this->translate->_('data manager(s) queued for password reset.'); ?>
                <?php if (!empty($result['emailed'])) { ?>
                    <?= $this->translate->_('Each user will be emailed their new credentials.'); ?>
                <?php } ?>
            </div>
            <div class="help-block" style="color:#666;">
                <?= $this->translate->_('The job runs in the background and typically starts within a minute. You can close this dialog and continue working.'); ?>
            </div>
        <?php } ?>
        <div style="margin-top: 14px;">
            <button type="button" class="btn btn-primary" onclick="window.parent.afterDmActionSuccess && window.parent.afterDmActionSuccess(); window.parent.closeLayoutModal();">
                <?= $this->translate->_('Close'); ?>
            </button>
        </div>
    </div>
    <?php
    return;
} ?>
