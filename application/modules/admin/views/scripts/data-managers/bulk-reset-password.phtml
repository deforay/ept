        <div class="form-group" style="margin-top: 14px;">
            <label class="checkbox-inline">
                <input type="checkbox" id="sendEmail" name="sendEmail" value="1" checked>
                <?= $this->translate->_('Email each user their new credentials'); ?>
            </label>
            <br>
            <label class="checkbox-inline" style="margin-top:6px;">
                <input type="checkbox" id="forcePasswordReset" name="forcePasswordReset" value="1" checked>
                <?= $this->translate->_('Force password change on next login'); ?>
            </label>
        </div>

        <div id="recipientsBlock" class="recipients-line">
            <div class="form-group">
                <label for="emailCc"><?= $this->translate->_('Cc'); ?> <span style="color:#999;font-size:11px;"><?= $this->translate->_('(optional, comma-separated, applied to every email)'); ?></span></label>
                <input type="text" id="emailCc" name="emailCc" class="form-control input-sm" value="" placeholder="" />
            </div>
            <div class="form-group" style="margin-bottom:0;">
                <label for="emailBcc"><?= $this->translate->_('Bcc'); ?> <span style="color:#999;font-size:11px;"><?= $this->translate->_('(optional, comma-separated)'); ?></span></label>
                <input type="text" id="emailBcc" name="emailBcc" class="form-control input-sm"
