$adminEmail = trim((string) Application_Service_Common::getConfig('admin_email'));
$step = $this->step ?? 'paste';
$matched = $this->matched ?? [];
$unresolved = $this->unresolved ?? [];
$pastedText = $this->pastedText ?? '';
$loginUrl = $this->loginUrl ?? '';
$result = $this->result ?? null;

$formAction = $this->url(['module' => 'admin', 'controller' => 'data-managers', 'action' => 'bulk-reset-by-list'], null, true);
?>
<style>
