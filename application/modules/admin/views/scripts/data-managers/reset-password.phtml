<script type="text/javascript">
    var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    var PASS_MIN = <?= $passLen; ?>;

    function getMode() {
        return $('#resetMode').val() || 'email';
    }

    function setMode(mode) {
        $('#resetMode').val(mode);
        $('.mode-group label').removeClass('active');
        $('.mode-group label[data-mode="' + mode + '"]').addClass('active');
        $('.mode-group label[data-mode="' + mode + '"] input').prop('checked', true);

        if (mode === 'email') {
            $('#recipientsBlock').show();
            $('#primaryActionBtn').removeClass('btn-info').addClass('btn-primary')
                .find('i').attr('class', 'icon-envelope');
            $('#primaryActionLabel').text(<?= json_encode($this->translate->_('Reset & Email to user')); ?>);
        } else if (mode === 'copy_email') {
            $('#recipientsBlock').hide();
            $('#primaryActionBtn').removeClass('btn-primary').addClass('btn-info')
                .find('i').attr('class', 'icon-copy');
            $('#primaryActionLabel').text(<?= json_encode($this->translate->_('Reset & Copy email content')); ?>);
        } else {
            $('#recipientsBlock').hide();
            $('#primaryActionBtn').removeClass('btn-primary').addClass('btn-info')
                .find('i').attr('class', 'icon-key');
            $('#primaryActionLabel').text(<?= json_encode($this->translate->_('Reset & Copy password')); ?>);
        }
    }

    function checkPasswordStrength(pwd) {
        var regex = new RegExp('^(?=.*[0-9])(?=.*[a-zA-Z])([a-zA-Z0-9!@#\\$%\\^\\&*\\)\\(+=. _-]+){' + PASS_MIN + ',}$');
        return regex.test(pwd);
    }

    function buildEmailBody() {
        var pwd = $('#password').val();
        var loginId = $('#primaryMail').val();
        var loginUrl = $('#loginUrl').val();
        return "Dear Participant,\n\n" +
            "Please use the following to log in to ePT\n\n" +
            "URL : " + loginUrl + "\n" +
            "Login ID : " + loginId + "\n" +
            "Password : " + pwd + "\n\n" +
            "Thanks\n" +
            "ePT Support";
    }

    function copyTextToClipboard(text) {
        var t = document.createElement("textarea");
        t.style.position = "fixed";
        t.style.left = "0";
        t.style.top = "0";
        t.style.opacity = "0";
        t.value = text;
        document.body.appendChild(t);
        t.focus();
        t.select();
        var ok = false;
        try { ok = document.execCommand("copy"); } catch (e) { ok = false; }
        document.body.removeChild(t);
        return ok;
    }

    function submitReset() {
        var pwd = ($('#password').val() || '').trim();
        var cpwd = ($('#confirmPassword').val() || '').trim();
        if (!pwd) {
            alert(<?= json_encode($this->translate->_('Please enter or generate a password.')); ?>);
            $('#password').focus();
            return;
        }
        if (!checkPasswordStrength(pwd)) {
            alert(<?= json_encode($this->translate->_('Password too weak — see the requirements below the input.')); ?>);
            $('#password').focus();
            return;
        }
        if (pwd !== cpwd) {
            alert(<?= json_encode($this->translate->_('Password and Confirm Password do not match.')); ?>);
            $('#confirmPassword').focus();
            return;
        }

        var mode = getMode();

        if (mode === 'email') {
            var to = ($('#emailTo').val() || '').trim();
            if (!to) {
                alert(<?= json_encode($this->translate->_('Please enter at least one recipient in the To field.')); ?>);
                $('#emailTo').focus();
                return;
            }
            // Quick syntax check on the first To address
            var firstTo = to.split(',')[0].trim();
            if (!EMAIL_RE.test(firstTo)) {
                alert(<?= json_encode($this->translate->_('The To address does not look like a valid email.')); ?>);
                $('#emailTo').focus();
                return;
            }
        }

        if (mode === 'copy_pass') {
            var okp = copyTextToClipboard(pwd);
            if (okp && typeof Toastify === 'function') {
                Toastify({ text: <?= json_encode($this->translate->_('Password copied to clipboard')); ?>, duration: 2000 }).showToast();
            } else if (!okp) {
                window.prompt(<?= json_encode($this->translate->_('Copy the password below:')); ?>, pwd);
            }
        } else if (mode === 'copy_email') {
            var oke = copyTextToClipboard(buildEmailBody());
            if (oke && typeof Toastify === 'function') {
                Toastify({ text: <?= json_encode($this->translate->_('Email content copied to clipboard')); ?>, duration: 2000 }).showToast();
            } else if (!oke) {
                window.prompt(<?= json_encode($this->translate->_('Copy the email content below:')); ?>, buildEmailBody());
            }
        }

        $.blockUI();
        document.getElementById('resetForm').submit();
    }

    function passwordType() {
        $.post("<?php echo $this->url(array('module' => 'reports', 'controller' => 'common', 'action' => 'generate-password', 'format' => 'html')); ?>", {
            csrf_token: $("#csrf_token").val(),
            size: 16
        }, function (data) {
            $("#password").val(data);
            $("#confirmPassword").val(data);
            if (typeof Toastify === 'function') {
                Toastify({ text: <?= json_encode($this->translate->_('Random password generated')); ?>, duration: 2000 }).showToast();
            }
        });
    }

    $(function () {
        $('.mode-group label').on('click', function () {
            var m = $(this).data('mode');
            setMode(m);
        });

        setMode('copy_pass');
    });
</script>
