<script type="text/javascript">
    function validateNow() {
        $(".bootstrap-select").removeClass('isRequired');
        var flag = deforayValidator.init({ formId: 'bulkParticipantForm' });
        if (flag && !duplicated) {
            $.blockUI();
            document.getElementById('bulkParticipantForm').submit();
        }
    }

    function showHideResetPassword(value) {
        if (value == 'update-on-unique-id-match') {
            $('.reset-password').removeClass('hide');
            $("#resetPassword").val('no');
            $('#resetPassword').addClass('isRequired');
        } else {
            $('#resetPassword').removeClass('isRequired');
            $("#resetPassword").val('yes');
            $('.reset-password').addClass('hide');
        }
    }

    function formatBytes(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / 1024 / 1024).toFixed(2) + ' MB';
    }

    $(document).ready(function() {
        showHideResetPassword($('#bulkUploadDuplicateSkip').val());

        var $drop = $('#biDrop');
        var $input = $('#fileName');
        var $card = $('#biFileCard');
        var $name = $('#biFileName');
        var $size = $('#biFileSize');

        function showFile(file) {
            if (!file) {
                $card.removeClass('active');
                $drop.show();
                return;
            }
            $name.text(file.name);
            $size.text(formatBytes(file.size));
            $card.addClass('active');
            $drop.hide();
        }

        $input.on('change', function() {
            showFile(this.files && this.files[0]);
        });

        $('#biReplace').on('click', function(e) {
            e.preventDefault();
            $input.trigger('click');
        });

        $('#biRemove').on('click', function(e) {
            e.preventDefault();
            $input.val('');
            showFile(null);
        });

        $drop.on('dragover dragenter', function(e) {
            e.preventDefault(); e.stopPropagation();
            $(this).addClass('dragover');
        }).on('dragleave dragend drop', function(e) {
            e.preventDefault(); e.stopPropagation();
            $(this).removeClass('dragover');
        }).on('drop', function(e) {
            var files = e.originalEvent.dataTransfer && e.originalEvent.dataTransfer.files;
            if (files && files.length) {
                $input[0].files = files;
                showFile(files[0]);
            }
        });
    });
</script>
