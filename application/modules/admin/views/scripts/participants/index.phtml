<script type="text/javascript" charset="utf-8">
    /* Table initialisation */
    var oTable = null;
    $(document).ready(function() {
        oTable = $('#participantsTable').dataTable({

            "bJQueryUI": false,
            "bAutoWidth": false,
            "bInfo": true,
            "bScrollCollapse": true,
            "sPaginationType": "bootstrap",
            "bRetrieve": true,
            "bSortCellsTop": true,
            "aoColumns": [{
                    "sClass": "center"
                },
                {
                    "sClass": ""
                },
                {
                    "sClass": "center"
                },
                {
                    "sClass": "center"
                },
                {
                    "sClass": "center"
                },
                {
                    "sClass": ""
                },
                {
                    "sClass": "center"
                },
                {
                    "sClass": "center",
                    "bSortable": false
                },
                {
                    "sClass": "center",
                    "bSortable": false
                },
                {
                    "sClass": "center",
                    "bSortable": false
                }
            ],
            "aaSorting": [
                [0, "asc"]
            ],
            "bProcessing": true,
            "bServerSide": true,
            "sAjaxSource": "<?php echo $this->url(array('module' => 'admin', 'controller' => 'participants', 'action' => 'index', 'format' => 'html')); ?>",
            "fnServerParams": function(aoData) {
                labName = $("#labId").val();
                country = $("#country").val();
                aoData.push({
                    "name": "pid",
                    "value": labName
                });
                aoData.push({
                    "name": "country",
                    "value": country
                });
                aoData.push({
                    "name": "pstatus",
                    "value": $("#statusFilter").val() || ""
                });
                aoData.push({
                    "name": "mappingFilter",
                    "value": $("#mappingFilter").val() || ""
                });
            },
            "fnServerData": function(sSource, aoData, fnCallback) {
                $.ajax({
                    "dataType": 'json',
                    "type": "POST",
                    "url": sSource,
                    "data": aoData,
                    "success": fnCallback
                });
            },
            "fnRowCallback": function(nRow, aData) {
                // Highlight rows with no mapped data managers (the DM column emits
                // <em class="unmapped-tag">…</em> when the count is 0)
                if ($(nRow).find('.unmapped-tag').length > 0) {
                    $(nRow).addClass('row-unmapped');
                } else {
                    $(nRow).removeClass('row-unmapped');
                }
                return nRow;
            }
        });

        $("#statusFilter").change(function() {
            oTable.fnDraw();
        });

        $("#mappingFilter").change(function() {
            oTable.fnDraw();
        });

        bindColSearch('#participantsTable', function(value, colIdx) {
            oTable.fnFilter(value, colIdx);
        });

        // Data Managers column — expand/collapse child row with on-demand AJAX fetch
        function loadDmChildRow(tr, participantId) {
            $.post(
                "<?php echo $this->url(array('module' => 'admin', 'controller' => 'participants', 'action' => 'mapped-data-managers', 'format' => 'html')); ?>", {
                    id: participantId
                },
                function(html) {
                    // fnOpen wraps our content in a td inside a tr — replace that td's content
                    var $childTr = $(tr).next('tr');
                    $childTr.find('td').first().html(html);
                }
            ).fail(function() {
                var $childTr = $(tr).next('tr');
                $childTr.find('td').first().html('<div style="padding:12px;color:#a94442;"><?= $this->translate->_("Failed to load data managers. Please try again."); ?></div>');
            });
        }

        $('#participantsTable tbody').on('click', 'a.toggle-dm-row', function(e) {
            e.preventDefault();
            var $btn = $(this);
            var participantId = $btn.data('participant-id');
            var tr = $btn.closest('tr')[0];
            var $childTr = $(tr).next('tr');
            var mineOpen = oTable.fnIsOpen(tr) && $childTr.find('.dm-child-row').length > 0;
            if (mineOpen) {
                oTable.fnClose(tr);
                return;
            }
            // Close any OTHER open child row in the table — only one expanded at a time.
            // Skip the current row: fnOpen below closes the existing child on this row atomically.
            $('#participantsTable tbody tr').each(function() {
                if (this !== tr && oTable.fnIsOpen(this)) {
                    oTable.fnClose(this);
                }
            });
            // Inject a placeholder child row, then populate via AJAX
            var placeholder = '<div style="padding:12px;color:#888;"><i class="icon-refresh"></i> <?= $this->translate->_("Loading data managers…"); ?></div>';
            oTable.fnOpen(tr, placeholder, 'dm-child-container');
            loadDmChildRow(tr, participantId);
        });

        // Hook called by reset-password / change-primary-email modals on success.
        // Redraw the participants table in place — fnDraw closes expanded child
        // rows by design, so the user re-expands if they need to inspect.
        window.afterDmActionSuccess = function() {
            oTable.fnDraw(false);
        };

        // Inline filter for the expanded DM list (only present when > 5 mapped DMs)
        $('#participantsTable tbody').on('input', 'input.dm-filter-input', function() {
            var q = $(this).val().toLowerCase().trim();
            var $rows = $(this).closest('.dm-child-row').find('tr.dm-row');
            if (q === '') {
                $rows.show();
                return;
            }
            $rows.each(function() {
                var blob = $(this).attr('data-dm-search') || '';
                $(this).toggle(blob.indexOf(q) !== -1);
            });
        });

        // Shipments column — expand/collapse child row with on-demand AJAX fetch.
        // DataTables allows only one child row per parent, so if the row already
        // has a different child (e.g. data managers) we close it before opening
        // ours. Toggling our own button collapses.
        function loadShipmentsChildRow(tr, participantId) {
            $.post(
                "<?php echo $this->url(array('module' => 'admin', 'controller' => 'participants', 'action' => 'participant-shipments', 'format' => 'html')); ?>", {
                    id: participantId
                },
                function(html) {
                    var $childTr = $(tr).next('tr');
                    $childTr.find('td').first().html(html);
                }
            ).fail(function() {
                var $childTr = $(tr).next('tr');
                $childTr.find('td').first().html('<div style="padding:12px;color:#a94442;"><?= $this->translate->_("Failed to load shipments. Please try again."); ?></div>');
            });
        }

        $('#participantsTable tbody').on('click', 'a.toggle-shipments-row', function(e) {
            e.preventDefault();
            var $btn = $(this);
            var participantId = $btn.data('participant-id');
            var tr = $btn.closest('tr')[0];
            var $childTr = $(tr).next('tr');
            var mineOpen = oTable.fnIsOpen(tr) && $childTr.find('.shipments-child-row').length > 0;
            if (mineOpen) {
                oTable.fnClose(tr);
                return;
            }
            // Close any OTHER open child row in the table — only one expanded at a time.
            // Skip the current row: fnOpen below closes the existing child on this row atomically.
            $('#participantsTable tbody tr').each(function() {
                if (this !== tr && oTable.fnIsOpen(this)) {
                    oTable.fnClose(this);
                }
            });
            var placeholder = '<div style="padding:12px;color:#888;"><i class="icon-refresh"></i> <?= $this->translate->_("Loading shipments…"); ?></div>';
            oTable.fnOpen(tr, placeholder, 'shipments-child-container');
            loadShipmentsChildRow(tr, participantId);
        });

        // Inline filtering for the expanded shipments child row. Applies the universal
        // search + per-dimension dropdowns + date range together. Re-run on any input.
        function applyShipmentsFilters($container) {
            var $rows = $container.find('tr.shipment-row');
            var q = ($container.find('input.shipments-filter-input').val() || '').toLowerCase().trim();
            var dateFrom = $container.find('input.shipments-filter-date-from').val() || '';
            var dateTo = $container.find('input.shipments-filter-date-to').val() || '';
            var scheme = $container.find('select.shipments-filter-scheme').val() || '';
            var shipStatus = $container.find('select.shipments-filter-ship-status').val() || '';
            var responseStatus = $container.find('select.shipments-filter-response-status').val() || '';
            var finalResult = $container.find('select.shipments-filter-final-result').val() || '';

            var shown = 0;
            $rows.each(function() {
                var $row = $(this);
                var ok = true;
                if (q !== '') {
                    var blob = $row.attr('data-shipment-search') || '';
                    if (blob.indexOf(q) === -1) ok = false;
                }
                if (ok && scheme !== '' && $row.attr('data-scheme') !== scheme) ok = false;
                if (ok && shipStatus !== '' && $row.attr('data-ship-status') !== shipStatus) ok = false;
                if (ok && responseStatus !== '' && $row.attr('data-response-status') !== responseStatus) ok = false;
                if (ok && finalResult !== '' && ($row.attr('data-final-result') || '') !== finalResult) ok = false;
                if (ok && (dateFrom !== '' || dateTo !== '')) {
                    var d = $row.attr('data-shipment-date') || '';
                    if (d === '') {
                        ok = false;
                    } else {
                        if (dateFrom !== '' && d < dateFrom) ok = false;
                        if (ok && dateTo !== '' && d > dateTo) ok = false;
                    }
                }
                $row.toggleClass('is-hidden-by-filter', !ok);
                if (ok) shown++;
            });

            var anyFilterActive = (q !== '' || dateFrom !== '' || dateTo !== '' || scheme !== '' || shipStatus !== '' || responseStatus !== '' || finalResult !== '');
            var $count = $container.find('.shipments-filter-count');
            if (anyFilterActive) {
                $count.text('— ' + shown + ' <?= $this->translate->_("match(es)"); ?>').show();
            } else {
                $count.hide().text('');
            }
            $container.find('tr.shipments-no-matches-row').toggle(anyFilterActive && shown === 0);
        }

        $('#participantsTable tbody').on(
            'input change',
            '.shipments-child-row input.shipments-filter-input, ' +
            '.shipments-child-row input.shipments-filter-date-from, ' +
            '.shipments-child-row input.shipments-filter-date-to, ' +
            '.shipments-child-row select.shipments-filter-scheme, ' +
            '.shipments-child-row select.shipments-filter-ship-status, ' +
            '.shipments-child-row select.shipments-filter-response-status, ' +
            '.shipments-child-row select.shipments-filter-final-result',
            function() {
                applyShipmentsFilters($(this).closest('.shipments-child-row'));
            }
        );

        $('#participantsTable tbody').on('click', '.shipments-child-row button.shipments-filter-reset', function() {
            var $container = $(this).closest('.shipments-child-row');
            $container.find('input.shipments-filter-input, input.shipments-filter-date-from, input.shipments-filter-date-to').val('');
            $container.find('select.shipments-filter-scheme, select.shipments-filter-ship-status, select.shipments-filter-response-status, select.shipments-filter-final-result').val('');
            applyShipmentsFilters($container);
        });

        $("#country").select2({
            placeholder: "<?= $this->translate->_("Choose one or more Countries"); ?>",
            minimumInputLength: 3,
            width: '100%',
            allowClear: true,
            ajax: {
                placeholder: "<?= $this->translate->_("Type Country name to search"); ?>",
                url: "<?php echo $this->url(array('module' => 'default', 'controller' => 'common', 'action' => 'get-all-countries')); ?>",
                dataType: 'json',
                delay: 250,
                data: function(params) {
                    return {
                        search: params.term, // search term
                        page: params.page
                    };
                },
                processResults: function(data, params) {
                    params.page = params.page || 1;
                    return {
                        results: data.result,
                        pagination: {
                            more: (params.page * 30) < data.total_count
                        }
                    };
                },
                //cache: true
            },
            escapeMarkup: function(markup) {
                return markup;
            }
        });

        $("#labId").select2({
            placeholder: "<?= $this->translate->_("Choose one or more option(s)"); ?>",
            minimumInputLength: 3,
            width: '100%',
            allowClear: true,
            id: function(bond) {
                return bond._id;
            },
            ajax: {
                placeholder: "<?= $this->translate->_("Type list to search"); ?>",
                url: "<?php echo $this->url(array('module' => 'reports', 'controller' => 'common', 'action' => 'get-ajax-drop-downs')); ?>",
                dataType: 'json',
                delay: 250,
                data: function(params) {
                    return {
                        tableName: 'participant',
                        returnId: 'institute_name',
                        fieldNames: 'institute_name',
                        concat: 'institute_name',
                        search: params.term, // search term
                        page: params.page
                    };
                },
                processResults: function(data, params) {
                    params.page = params.page || 1;
                    return {
                        results: data.result,
                        pagination: {
                            more: (params.page * 30) < data.total_count
                        }
                    };
                },
                //cache: true
            },
            escapeMarkup: function(markup) {
                return markup;
            }
        });
    });

    function downloadParticipantDetails() {
        $.blockUI();
        $.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'participants', 'action' => 'export-participants-details', 'format' => 'html')); ?>",
            function(data) {
                $.unblockUI();
                if (data == "" || data == null || data == undefined || $.trim(data) == 'not-found' || !data) {
                    alert('<?= $this->translate->_("Unable to generate download"); ?>');
                } else {
                    window.open('/temporary/' + data, '_blank');
                }
            });
    }

    function deleteParticipant(id) {
        if (id > 0) {
            if (confirm("<?= $this->translate->_("Are you sure you want to delete this participant?"); ?> ")) {
                // $.blockUI();
                $.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'participants', 'action' => 'delete-participant')); ?>", {
                        participantId: id,
                        format: "html"
                    },
                    function(data) {
                        $.unblockUI();
                        if (data > 0) {
                            oTable.fnDraw();
                        }
                    });
            }
        } else {
            alert("<?= $this->translate->_("Someting went wrong Please try again later!"); ?> ")
        }
    }

    function getDrawable() {
        $.blockUI();
        oTable.fnDraw();
        $.unblockUI();
    }
</script>