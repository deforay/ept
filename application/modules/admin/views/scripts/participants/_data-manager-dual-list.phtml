<script>
    var DML_ITEMS = <?= json_encode($dmItems, JSON_UNESCAPED_UNICODE); ?>;
    var DML_DIRECT_PARTICIPANT_LOGIN = <?= $directParticipantLoginYes ? 'true' : 'false'; ?>;
    var DML_CREATE_URL = "<?php echo $this->url(['module' => 'admin', 'controller' => 'data-managers', 'action' => 'quick-create']); ?>";

    var DataManagerDualList = (function () {
        var state = { left: [], right: [] };
        var panes = {};

        function escapeHtml(s) {
            return String(s).replace(/[&<>"']/g, function (c) {
                return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c];
            });
        }

        function initPane(sideKey, paneEl) {
            var $pane = $(paneEl);
            var pane = {
                sideKey: sideKey,
                $scroll: $pane.find('.dml-pane-scroll'),
                $search: $pane.find('.dml-pane-header input'),
                $count: $pane.find('.dml-count'),
                filter: ''
            };
            pane.$search.on('input', function () { pane.filter = pane.$search.val().toLowerCase(); render(pane); });
            pane.$scroll.on('click', '.dml-row', function () { moveItem(pane.sideKey, $(this).attr('data-id')); });
            panes[sideKey] = pane;
        }

        function filteredItems(pane) {
            var src = state[pane.sideKey];
            if (!pane.filter) return src;
            var f = pane.filter;
            return src.filter(function (it) { return it._lc.indexOf(f) !== -1; });
        }

        function render(pane) {
            var items = filteredItems(pane);
            var html = '';
            for (var i = 0; i < items.length; i++) {
                html += '<div class="dml-row" data-id="' + escapeHtml(items[i].id) + '">' + escapeHtml(items[i].label) + '</div>';
            }
            pane.$scroll.html(html);
            pane.$count.text(items.length);
        }

        function moveItem(fromSide, id) {
            var toSide = fromSide === 'left' ? 'right' : 'left';
            var arr = state[fromSide];
            for (var i = 0; i < arr.length; i++) {
                if (String(arr[i].id) === String(id)) { state[toSide].push(arr.splice(i, 1)[0]); break; }
            }
            renderAll();
        }

        function renderAll() { render(panes.left); render(panes.right); }

        function load(items) {
            state.left = []; state.right = [];
            items.forEach(function (it) {
                it._lc = String(it.label).toLowerCase();
                if (it.selected) state.right.push(it); else state.left.push(it);
            });
            renderAll();
        }

        function addAndSelect(item) {
            item._lc = String(item.label).toLowerCase();
            state.right.push(item);
            renderAll();
        }

        function selectAll() {
            var visible = filteredItems(panes.left);
            var visibleIds = {};
            visible.forEach(function (it) { visibleIds[it.id] = true; });
            var keep = [];
            state.left.forEach(function (it) { if (visibleIds[it.id]) state.right.push(it); else keep.push(it); });
            state.left = keep;
            renderAll();
        }

        function deselectAll() {
            var visible = filteredItems(panes.right);
            var visibleIds = {};
            visible.forEach(function (it) { visibleIds[it.id] = true; });
            var keep = [];
            state.right.forEach(function (it) { if (visibleIds[it.id]) state.left.push(it); else keep.push(it); });
            state.right = keep;
            renderAll();
        }

        function getSelectedIds() {
            return state.right.map(function (it) { return it.id; });
        }

        return { init: initPane, load: load, addAndSelect: addAndSelect, selectAll: selectAll, deselectAll: deselectAll, getSelectedIds: getSelectedIds };
    })();

    function dmlInjectHiddenInputs() {
        var ids = DataManagerDualList.getSelectedIds();
        var $h = $('#dml-hidden-inputs');
        $h.empty();
        ids.forEach(function (id) {
            $h.append('<input type="hidden" name="dataManager[]" value="' + id + '" />');
        });
        return ids.length;
    }

    function dmlValidateRequired() {
        var n = dmlInjectHiddenInputs();
        if (DML_DIRECT_PARTICIPANT_LOGIN) return true;
        if (n === 0) {
            var $right = $('#dmlSection .dml-pane[data-side="right"]');
            $right.addClass('dml-error');
            try { $right[0].scrollIntoView({ behavior: 'smooth', block: 'center' }); } catch (e) {}
            setTimeout(function () { $right.removeClass('dml-error'); }, 2500);
            return false;
        }
        return true;
    }

    $(document).ready(function () {
        $('#dmlSection .dml-pane').each(function () {
            DataManagerDualList.init($(this).attr('data-side'), this);
        });
        DataManagerDualList.load(DML_ITEMS);
        $('#dml-select-all').on('click', function (e) { e.preventDefault(); DataManagerDualList.selectAll(); });
        $('#dml-deselect-all').on('click', function (e) { e.preventDefault(); DataManagerDualList.deselectAll(); });

        $('#dmlCreateModal').appendTo('body');
        $('#dmlCreateModal').on('shown.bs.modal', function () {
            $('.modal-backdrop').last().addClass('dml-create-backdrop');
            $('#dmlNewEmail').trigger('focus');
        });

        $('#dml-create-btn').on('click', function () {
            $('#dmlCreateError').hide().text('');
            $('#dmlNewEmail').val('');
            $('#dmlNewPassword').val('');
            $('#dmlNewFirstName').val($('#pfname').val() || '');
            $('#dmlNewLastName').val($('#plname').val() || '');
            $('#dmlNewInstitute').val($('#instituteName').val() || '');
            $('#dmlCreateModal').modal('show');
        });

        $('#dmlCreateSave').on('click', function () {
            var email = $.trim($('#dmlNewEmail').val());
            var password = $('#dmlNewPassword').val();
            var firstName = $.trim($('#dmlNewFirstName').val());
            var lastName = $.trim($('#dmlNewLastName').val());
            var institute = $.trim($('#dmlNewInstitute').val());

            if (!email || !password) {
                $('#dmlCreateError').text("<?= $this->jsTranslate('Email and password are required.'); ?>").show();
                return;
            }
            var minLen = <?= $dmlPassLen; ?>;
            if (password.length < minLen) {
                $('#dmlCreateError').text("<?= $this->jsTranslate('Password must be at least'); ?> " + minLen + " <?= $this->jsTranslate('characters'); ?>").show();
                return;
            }

            $.blockUI();
            $.post(DML_CREATE_URL, {
                email: email, password: password, first_name: firstName, last_name: lastName, institute: institute, format: 'json'
            }).done(function (resp) {
                if (resp && resp.status === 'success' && resp.dm) {
                    DataManagerDualList.addAndSelect({
                        id: parseInt(resp.dm.dm_id, 10),
                        label: resp.dm.label,
                        selected: true
                    });
                    $('#dmlCreateModal').modal('hide');
                } else {
                    $('#dmlCreateError').text((resp && resp.message) || "<?= $this->jsTranslate('Failed to create Data Manager.'); ?>").show();
                }
            }).fail(function (xhr) {
                var msg = "<?= $this->jsTranslate('Failed to create Data Manager.'); ?>";
                try { var j = JSON.parse(xhr.responseText); if (j && j.message) msg = j.message; } catch (e) { }
                $('#dmlCreateError').text(msg).show();
            }).always(function () {
                $.unblockUI();
            });
        });
    });
</script>
