<?php
/**
 * Dual-list Data Manager picker for participant add/edit.
 * Expects:
 *   $this->dataManagers                 (array) all candidate DMs
 *   $this->participant['data_manager']  (csv of selected dm_ids; edit only)
 *   $this->directParticipantLogin       (string) 'yes' / 'no'
 *   $this->passLength                   (int) min password length
 */
$selectedDmIds = [];
if (isset($this->participant['data_manager']) && $this->participant['data_manager'] !== '') {
    foreach (explode(',', $this->participant['data_manager']) as $sid) {
        $sid = trim($sid);
        if ($sid !== '') {
            $selectedDmIds[(int)$sid] = true;
        }
    }
}
$dmItems = [];
if (!empty($this->dataManagers)) {
    foreach ($this->dataManagers as $dm) {
        $first = (string)($dm['first_name'] ?? '');
        $last  = (string)($dm['last_name'] ?? '');
        $institute = (string)($dm['institute'] ?? '');
        $email = (string)($dm['primary_email'] ?? '');
        $parts = [];
        $name = trim($first . ' ' . $last);
        if ($name !== '') $parts[] = $name;
        if ($institute !== '') $parts[] = $institute;
        if ($email !== '') $parts[] = $email;
        $dmItems[] = [
            'id'       => (int)$dm['dm_id'],
            'label'    => implode(', ', $parts),
            'selected' => isset($selectedDmIds[(int)$dm['dm_id']]),
        ];
    }
}
$directParticipantLoginYes = (isset($this->directParticipantLogin) && $this->directParticipantLogin == 'yes');
$dmlPassLen = (int)($this->passLength ?? 8);
if ($dmlPassLen <= 0) {
    $dmlPassLen = 8;
}
?>
