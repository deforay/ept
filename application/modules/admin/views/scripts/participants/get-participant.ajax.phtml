<?php
$mapIds = [];
if (!isset($this->type) || empty($this->type) || $this->type != 'shipment') {
    foreach ($this->mappedParticipant as $mappedParticipant) {
        $mapIds[$mappedParticipant['participant_id']] = true;
    }
}
$out = [];
foreach ($this->participants as $participant) {
    $name = trim($participant['first_name'] . ' ' . $participant['last_name']);
    $label = ($name !== '' ? $name . ' ' : '') . '(' . $participant['unique_identifier'] . ')';
    $out[] = [
        'id'       => $participant['participant_id'],
        'label'    => $label,
        'selected' => isset($mapIds[$participant['participant_id']]),
    ];
}
header('Content-Type: application/json');
echo json_encode($out);
