            }
            .shipments-child-row .shipments-filter-bar label {
                display: flex;
                flex-direction: column;
                margin: 0;
                font-weight: 600;
                color: #555;
            }
            .shipments-child-row .shipments-filter-bar label > span {
                font-size: 11px;
                line-height: 1.2;
                margin-bottom: 2px;
                text-transform: uppercase;
                letter-spacing: .03em;
            }
            .shipments-child-row .shipments-filter-bar .form-control {
                min-width: 130px;
            }
            .shipments-child-row .shipments-filter-bar .shipments-filter-reset {
                align-self: flex-end;
                margin-bottom: 1px;
            }
            .shipments-child-row tr.shipment-row.is-hidden-by-filter {
                display: none;
            }
            .shipments-child-row .shipments-no-matches {
                padding: 10px;
                text-align: center;
                color: #888;
                font-style: italic;
            }
        </style>
        <div class="shipments-list-wrap" style="max-height:320px;overflow-y:auto;">
            <table class="table table-condensed table-bordered table-striped" style="margin:0;">
                <thead>
                    <tr>
                        <th scope="col"><?= $this->translate->_('Shipment Date'); ?></th>
                        <th scope="col"><?= $this->translate->_('Shipment Code'); ?></th>
                        <th scope="col"><?= $this->translate->_('Scheme'); ?></th>
                        <th scope="col"><?= $this->translate->_('Shipment Status'); ?></th>
                        <th scope="col"><?= $this->translate->_('Response Status'); ?></th>
                        <th scope="col"><?= $this->translate->_('Final Result'); ?></th>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($rowsView as $row) {
                        $searchBlob = strtolower(
                            $row['shipment_code'] . ' '
                            . $row['scheme'] . ' '
                            . $row['ship_status_disp'] . ' '
                            . $row['response_status'] . ' '
                            . $row['final_result']
                        );
                    ?>
                        <tr class="shipment-row"
                            data-shipment-search="<?= htmlspecialchars($searchBlob, ENT_QUOTES, 'UTF-8'); ?>"
                            data-shipment-date="<?= htmlspecialchars($row['ship_date_raw'], ENT_QUOTES, 'UTF-8'); ?>"
                            data-scheme="<?= htmlspecialchars($row['scheme'], ENT_QUOTES, 'UTF-8'); ?>"
                            data-ship-status="<?= htmlspecialchars($row['ship_status_disp'], ENT_QUOTES, 'UTF-8'); ?>"
                            data-response-status="<?= htmlspecialchars($row['response_status'], ENT_QUOTES, 'UTF-8'); ?>"
                            data-final-result="<?= htmlspecialchars($row['final_result'], ENT_QUOTES, 'UTF-8'); ?>">
                            <td><?= htmlspecialchars($row['ship_date_disp'], ENT_QUOTES, 'UTF-8'); ?></td>
                            <td><?= htmlspecialchars($row['shipment_code'], ENT_QUOTES, 'UTF-8'); ?></td>
                            <td><?= htmlspecialchars($row['scheme'], ENT_QUOTES, 'UTF-8'); ?></td>
                            <td><?= htmlspecialchars($row['ship_status_disp'], ENT_QUOTES, 'UTF-8'); ?></td>
                            <td><?= htmlspecialchars($row['response_status'], ENT_QUOTES, 'UTF-8'); ?></td>
                            <td><?= $row['final_result_html']; ?></td>
                        </tr>
                    <?php } ?>
                    <tr class="shipments-no-matches-row" style="display:none;">
                        <td colspan="6" class="shipments-no-matches"><?= $this->translate->_('No shipments match the current filters.'); ?></td>
                    </tr>
                </tbody>
