<?php
$shipments = $this->shipments ?? [];
$shipmentCount = count($shipments);

// Pre-compute the rendered values for each row so the filter dropdowns and the
// table cells stay in lockstep. Mirrors the per-row logic below.
$rowsView = [];
$schemeOptions = [];
$shipStatusOptions = [];
$responseStatusOptions = [];
$finalResultOptions = [];
foreach ($shipments as $sh) {
    $shipDateRaw = '';
    $shipDateDisplay = '';
    if (!empty($sh['shipment_date']) && $sh['shipment_date'] !== '0000-00-00') {
        $shipDateRaw = (string) $sh['shipment_date'];
        $shipDateDisplay = Pt_Commons_DateUtility::humanReadableDateFormat($sh['shipment_date']);
    }

    $shipStatusRaw = (string)($sh['shipment_status'] ?? '');
    $shipStatusDisplay = ucwords(str_replace('_', ' ', $shipStatusRaw));

    if (!empty($sh['is_excluded']) && strtolower($sh['is_excluded']) === 'yes') {
        $responseStatus = 'Excluded';
    } else {
        $rs = strtolower((string)($sh['response_status'] ?? ''));
        $hasTestDate = !empty($sh['shipment_test_date'])
            && $sh['shipment_test_date'] !== '0000-00-00'
            && strtolower((string)$sh['shipment_test_date']) !== 'null';
        if ($rs === 'responded' || $hasTestDate) {
            $responseStatus = 'Responded';
        } elseif ($rs === 'noresponse' || $rs === '') {
            $responseStatus = 'No Response';
        } else {
            $responseStatus = ucwords(str_replace('_', ' ', $rs));
        }
    }

    $finalResultRaw = trim((string)($sh['final_result'] ?? ''));
    $finalResultMap = [
        '1' => ['Pass',     'label-success'],
        '2' => ['Fail',     'label-danger'],
        '3' => ['Excluded', 'label-warning'],
    ];
    if ($finalResultRaw === '' || $finalResultRaw === '0') {
        $finalResultText = '';
        $finalResultHtml = '<span class="text-muted">&mdash;</span>';
    } elseif (isset($finalResultMap[$finalResultRaw])) {
        [$frText, $frClass] = $finalResultMap[$finalResultRaw];
        $finalResultText = $frText;
        $finalResultHtml = '<span class="label ' . $frClass . '">' . htmlspecialchars($this->translate->_($frText), ENT_QUOTES, 'UTF-8') . '</span>';
    } else {
        $finalResultText = $finalResultRaw;
        $finalResultHtml = htmlspecialchars($finalResultRaw, ENT_QUOTES, 'UTF-8');
    }

    $scheme = (string)($sh['scheme_name'] ?? '');

    if ($scheme !== '') {
        $schemeOptions[$scheme] = true;
    }
    if ($shipStatusDisplay !== '') {
        $shipStatusOptions[$shipStatusDisplay] = true;
    }
    if ($responseStatus !== '') {
        $responseStatusOptions[$responseStatus] = true;
    }
    if ($finalResultText !== '') {
        $finalResultOptions[$finalResultText] = true;
    }

    $rowsView[] = [
        'shipment_code'    => (string)($sh['shipment_code'] ?? ''),
        'scheme'           => $scheme,
        'ship_date_raw'    => $shipDateRaw,
        'ship_date_disp'   => $shipDateDisplay,
        'ship_status_disp' => $shipStatusDisplay,
        'response_status'  => $responseStatus,
        'final_result'     => $finalResultText,
        'final_result_html' => $finalResultHtml,
    ];
}
ksort($schemeOptions);
ksort($shipStatusOptions);
ksort($responseStatusOptions);
ksort($finalResultOptions);
?>
<div class="shipments-child-row">
    <?php if ($shipmentCount === 0) { ?>
        <em class="text-muted"><?= $this->translate->_('This participant is not part of any shipments.'); ?></em>
    <?php } else { ?>
        <div class="child-row-header">
            <i class="icon-truck"></i>
            <span><?= sprintf($this->translate->_('%d Shipment(s)'), $shipmentCount); ?></span>
            <span class="shipments-filter-count text-muted" style="margin-left:6px;display:none;"></span>
            <?php if ($shipmentCount > 5) { ?>
                <input type="text" class="form-control input-sm shipments-filter-input" placeholder="<?= $this->translate->_('Filter by code, scheme, status…'); ?>" />
            <?php } ?>
        </div>
        <?php if ($shipmentCount > 1) { ?>
            <div class="shipments-filter-bar">
                <label>
                    <span><?= $this->translate->_('From'); ?></span>
                    <input type="date" class="form-control input-sm shipments-filter-date-from" />
                </label>
                <label>
                    <span><?= $this->translate->_('To'); ?></span>
                    <input type="date" class="form-control input-sm shipments-filter-date-to" />
                </label>
                <?php if (count($schemeOptions) > 1) { ?>
                    <label>
                        <span><?= $this->translate->_('Scheme'); ?></span>
                        <select class="form-control input-sm shipments-filter-scheme">
                            <option value=""><?= $this->translate->_('All'); ?></option>
                            <?php foreach (array_keys($schemeOptions) as $opt) { ?>
                                <option value="<?= htmlspecialchars($opt, ENT_QUOTES, 'UTF-8'); ?>"><?= htmlspecialchars($opt, ENT_QUOTES, 'UTF-8'); ?></option>
                            <?php } ?>
                        </select>
                    </label>
                <?php } ?>
                <?php if (count($shipStatusOptions) > 1) { ?>
                    <label>
                        <span><?= $this->translate->_('Shipment Status'); ?></span>
                        <select class="form-control input-sm shipments-filter-ship-status">
                            <option value=""><?= $this->translate->_('All'); ?></option>
                            <?php foreach (array_keys($shipStatusOptions) as $opt) { ?>
                                <option value="<?= htmlspecialchars($opt, ENT_QUOTES, 'UTF-8'); ?>"><?= htmlspecialchars($opt, ENT_QUOTES, 'UTF-8'); ?></option>
                            <?php } ?>
                        </select>
                    </label>
                <?php } ?>
                <?php if (count($responseStatusOptions) > 1) { ?>
                    <label>
                        <span><?= $this->translate->_('Response Status'); ?></span>
                        <select class="form-control input-sm shipments-filter-response-status">
                            <option value=""><?= $this->translate->_('All'); ?></option>
                            <?php foreach (array_keys($responseStatusOptions) as $opt) { ?>
                                <option value="<?= htmlspecialchars($opt, ENT_QUOTES, 'UTF-8'); ?>"><?= htmlspecialchars($opt, ENT_QUOTES, 'UTF-8'); ?></option>
                            <?php } ?>
                        </select>
                    </label>
                <?php } ?>
                <?php if (count($finalResultOptions) > 1) { ?>
                    <label>
                        <span><?= $this->translate->_('Final Result'); ?></span>
                        <select class="form-control input-sm shipments-filter-final-result">
                            <option value=""><?= $this->translate->_('All'); ?></option>
                            <?php foreach (array_keys($finalResultOptions) as $opt) { ?>
                                <option value="<?= htmlspecialchars($opt, ENT_QUOTES, 'UTF-8'); ?>"><?= htmlspecialchars($this->translate->_($opt), ENT_QUOTES, 'UTF-8'); ?></option>
                            <?php } ?>
                        </select>
                    </label>
                <?php } ?>
                <button type="button" class="btn btn-default btn-xs shipments-filter-reset"><?= $this->translate->_('Reset'); ?></button>
            </div>
        <?php } ?>
        <style>
            .shipments-child-row .shipments-list-wrap .table > thead > tr > th,
            .shipments-child-row .shipments-list-wrap .table > tbody > tr > td {
                text-align: center;
                vertical-align: middle;
            }
            .shipments-child-row .shipments-filter-bar {
                display: flex;
