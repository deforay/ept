<?php
$shipments = $this->shipments ?? [];
$shipmentCount = count($shipments);
?>
<div class="shipments-child-row" style="padding:10px 15px;background:#fafbfc;border-left:4px solid #5cb85c;">
    <?php if ($shipmentCount === 0) { ?>
        <em class="text-muted"><?= $this->translate->_('This participant is not part of any shipments.'); ?></em>
    <?php } else { ?>
        <div style="margin-bottom:6px;">
            <strong><?= sprintf($this->translate->_('%d Shipment(s)'), $shipmentCount); ?></strong>
            <?php if ($shipmentCount > 5) { ?>
                <input type="text" class="form-control input-sm shipments-filter-input" placeholder="<?= $this->translate->_('Filter by code, scheme, status…'); ?>" style="max-width:280px;display:inline-block;margin-left:10px;" />
            <?php } ?>
        </div>
        <style>
            .shipments-child-row .shipments-list-wrap .table > thead > tr > th,
            .shipments-child-row .shipments-list-wrap .table > tbody > tr > td {
                text-align: center;
                vertical-align: middle;
            }
        </style>
        <div class="shipments-list-wrap" style="max-height:320px;overflow-y:auto;border:1px solid #e5e5e5;border-radius:3px;background:#fff;">
            <table class="table table-condensed table-bordered table-striped" style="margin:0;">
                <thead>
                    <tr>
                        <th><?= $this->translate->_('Shipment Date'); ?></th>
                        <th><?= $this->translate->_('Shipment Code'); ?></th>
                        <th><?= $this->translate->_('Scheme'); ?></th>
                        <th><?= $this->translate->_('Shipment Status'); ?></th>
                        <th><?= $this->translate->_('Response Status'); ?></th>
                        <th><?= $this->translate->_('Final Result'); ?></th>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($shipments as $sh) {
                        $shipDate = '';
                        if (!empty($sh['shipment_date']) && $sh['shipment_date'] !== '0000-00-00') {
                            $shipDate = Pt_Commons_DateUtility::humanReadableDateFormat($sh['shipment_date']);
                        }

                        $shipStatus = (string)($sh['shipment_status'] ?? '');

                        if (!empty($sh['is_excluded']) && strtolower($sh['is_excluded']) === 'yes') {
                            $responseStatus = 'Excluded';
                        } else {
                            $rs = strtolower((string)($sh['response_status'] ?? ''));
                            $hasTestDate = !empty($sh['shipment_test_date'])
                                && $sh['shipment_test_date'] !== '0000-00-00'
                                && strtolower((string)$sh['shipment_test_date']) !== 'null';
                            if ($rs === 'responded' || $hasTestDate) {
                                $responseStatus = 'Responded';
                            } elseif ($rs === 'noresponse' || $rs === '') {
                                $responseStatus = 'No Response';
                            } else {
                                $responseStatus = ucwords(str_replace('_', ' ', $rs));
                            }
                        }

                        $finalResultRaw = trim((string)($sh['final_result'] ?? ''));
                        $finalResultMap = [
                            '1' => ['Pass',     'label-success'],
                            '2' => ['Fail',     'label-danger'],
                            '3' => ['Excluded', 'label-warning'],
                        ];
                        if ($finalResultRaw === '' || $finalResultRaw === '0') {
                            $finalResult = '<span class="text-muted">&mdash;</span>';
                        } elseif (isset($finalResultMap[$finalResultRaw])) {
                            [$frText, $frClass] = $finalResultMap[$finalResultRaw];
                            $finalResult = '<span class="label ' . $frClass . '">' . htmlspecialchars($this->translate->_($frText), ENT_QUOTES, 'UTF-8') . '</span>';
                        } else {
                            $finalResult = htmlspecialchars($finalResultRaw, ENT_QUOTES, 'UTF-8');
                        }

                        $searchBlob = strtolower(
                            ($sh['shipment_code'] ?? '') . ' '
                            . ($sh['scheme_name'] ?? '') . ' '
                            . $shipStatus . ' '
                            . $responseStatus
                        );
                    ?>
                        <tr class="shipment-row" data-shipment-search="<?= htmlspecialchars($searchBlob, ENT_QUOTES, 'UTF-8'); ?>">
                            <td><?= htmlspecialchars($shipDate, ENT_QUOTES, 'UTF-8'); ?></td>
                            <td><?= htmlspecialchars($sh['shipment_code'] ?? '', ENT_QUOTES, 'UTF-8'); ?></td>
                            <td><?= htmlspecialchars($sh['scheme_name'] ?? '', ENT_QUOTES, 'UTF-8'); ?></td>
                            <td><?= htmlspecialchars(ucwords(str_replace('_', ' ', $shipStatus)), ENT_QUOTES, 'UTF-8'); ?></td>
                            <td><?= htmlspecialchars($responseStatus, ENT_QUOTES, 'UTF-8'); ?></td>
                            <td><?= $finalResult; ?></td>
                        </tr>
                    <?php } ?>
                </tbody>
            </table>
        </div>
    <?php } ?>
</div>
