<?php
$this->response['data'] = $this->response['data'] ?? [];
$this->response['error-data'] = $this->response['error-data'] ?? [];
$savedCount = count($this->response['data']);
$errorCount = count($this->response['error-data']);

$duplicateCount = 0;
$otherErrorCount = 0;
$mergedRows = [];

foreach ($this->response['data'] as $row) {
    $mergedRows[] = [
        'status' => 'ok',
        's_no' => $row['s_no'] ?? '',
        'participant_id' => $row['participant_id'] ?? '',
        'name' => trim(($row['participant_lab_name'] ?? '') . ' ' . ($row['participant_last_name'] ?? '')),
        'email' => $row['participant_email'] ?? '',
        'mobile' => $row['mobile_number'] ?? '',
        'institute' => $row['institute_name'] ?? '',
        'district' => $row['district'] ?? '',
        'country' => $row['country'] ?? '',
        'reason' => '',
    ];
}

foreach ($this->response['error-data'] as $row) {
    $errMsg = (string)($row['error'] ?? '');
    $isDup = stripos($errMsg, 'duplicate') !== false || stripos($errMsg, 'already exist') !== false;
    if ($isDup) { $duplicateCount++; } else { $otherErrorCount++; }
    $mergedRows[] = [
        'status' => $isDup ? 'dup' : 'err',
        's_no' => $row['s_no'] ?? '',
        'participant_id' => $row['participant_id'] ?? '',
        'name' => trim(($row['participant_lab_name'] ?? '') . ' ' . ($row['participant_last_name'] ?? '')),
        'email' => $row['participant_email'] ?? '',
        'mobile' => $row['mobile_number'] ?? '',
        'institute' => $row['institute_name'] ?? '',
        'district' => $row['district'] ?? '',
        'country' => $row['country'] ?? '',
        'reason' => $errMsg,
    ];
}

usort($mergedRows, function ($a, $b) {
    return (int)$a['s_no'] <=> (int)$b['s_no'];
});

$totalCount = count($mergedRows);
?>

