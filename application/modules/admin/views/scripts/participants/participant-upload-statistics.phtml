<script type="text/javascript" src="<?php echo $this->baseUrl("assets/plugins/datatables/jquery.dataTables.min.js"); ?>"></script>
<script type="text/javascript" charset="utf-8">
    $(document).ready(function() {
        <?php if ($totalCount > 0): ?>
            $('#resultsTable').dataTable({
                "order": [[0, "asc"]]
            });
        <?php endif; ?>

        $('#biExportErrors').on('click', function() {
            var headers = [
                'Row', 'Status', 'Unique ID', 'Name', 'Email',
                'Mobile', 'Institute', 'District', 'Country', 'Reason'
            ];
            var rows = [headers];
            <?php foreach ($mergedRows as $r):
                if ($r['status'] === 'ok') continue;
                $label = $r['status'] === 'dup' ? 'duplicate' : 'failed';
            ?>
            rows.push([
                <?= json_encode((string)$r['s_no']) ?>,
                <?= json_encode($label) ?>,
                <?= json_encode((string)$r['participant_id']) ?>,
                <?= json_encode((string)$r['name']) ?>,
                <?= json_encode((string)$r['email']) ?>,
                <?= json_encode((string)$r['mobile']) ?>,
                <?= json_encode((string)$r['institute']) ?>,
                <?= json_encode((string)$r['district']) ?>,
                <?= json_encode((string)$r['country']) ?>,
                <?= json_encode((string)$r['reason']) ?>
            ]);
            <?php endforeach; ?>

            var csv = rows.map(function(r) {
                return r.map(function(cell) {
                    var s = (cell == null ? '' : String(cell));
                    if (/[",\n\r]/.test(s)) { s = '"' + s.replace(/"/g, '""') + '"'; }
                    return s;
                }).join(',');
            }).join('\r\n');

            var blob = new Blob(["﻿" + csv], { type: 'text/csv;charset=utf-8;' });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            var stamp = new Date().toISOString().slice(0, 19).replace(/[:T]/g, '-');
            a.href = url;
            a.download = 'participant-import-errors-' + stamp + '.csv';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        });
    });
</script>
