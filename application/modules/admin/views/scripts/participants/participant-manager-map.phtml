                format: "html"
            },
            function(data) {
                if (data != "" && data != undefined) { $('#institute').html(data); }
                $.unblockUI();
            });
    }

    var MAP_I18N = {
        uploadFileRequired: "<?= $this->jsTranslate("Please upload the file to process."); ?>",
        selectDmRequired: "<?= $this->jsTranslate("Please select PT Login to map the participants"); ?>",
        confirmEmpty: "<?= $this->jsTranslate("No participants are selected. Saving now will remove ALL participant mappings for this PT Login. Continue?"); ?>",
        saved: "<?= $this->jsTranslate("Mapping saved"); ?>",
        saveFailed: "<?= $this->jsTranslate("Save failed. Please try again, or contact support if it keeps happening."); ?>",
        networkError: "<?= $this->jsTranslate("Could not reach the server. Check your connection and try again."); ?>",
        sessionExpired: "<?= $this->jsTranslate("Your session has expired. Please log in again and retry."); ?>",
        serverError: "<?= $this->jsTranslate("The server reported an error while saving."); ?>",
        traceIdLabel: "<?= $this->jsTranslate("Reference"); ?>"
    };

    function validateNow() {
        if ($('#bulkForm').is(":visible") == true) {
            if ($('#bulkMap').val() != "") {
                document.getElementById('submitParticipantMap').submit();
                return false;
            } else {
                alert(MAP_I18N.uploadFileRequired);
                return false;
            }
        }
        if ($('#alldatamangers').val() == "" || $('#alldatamangers').val() == null) {
            alert(MAP_I18N.selectDmRequired);
            return false;
        }

        var flag = deforayValidator.init({ formId: 'submitParticipantMap' });
        if (flag) {
            var selectedIds = DualList.getSelectedIds();
            if (selectedIds.length === 0) {
                if (!confirm(MAP_I18N.confirmEmpty)) {
                    return;
                }
                $('#submitParticipantMap').find('input[name="allowEmptyMapping"]').remove();
                $('<input>').attr({ type: 'hidden', name: 'allowEmptyMapping', value: '1' }).appendTo('#submitParticipantMap');
            }
            $("#selectedForMapping").val(JSON.stringify(selectedIds));
            saveMappingAjax();
        }
    }

    function saveMappingAjax() {
        var form = document.getElementById('submitParticipantMap');
        var fd = new FormData(form);
        $.blockUI();
        $.ajax({
            url: form.action,
            type: 'POST',
            data: fd,
            processData: false,
            contentType: false,
            dataType: 'json',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        }).done(function(resp) {
            $.unblockUI();
            if (resp && resp.success) {
                showMappingFlash(resp.message || MAP_I18N.saved, 'success');
                loadParticipants();
            } else {
                var msg = (resp && resp.message) ? resp.message : MAP_I18N.saveFailed;
                if (resp && resp.trace_id) {
                    msg += ' (' + MAP_I18N.traceIdLabel + ': ' + resp.trace_id + ')';
                }
                showMappingFlash(msg, 'danger');
            }
        }).fail(function(xhr) {
            $.unblockUI();
            showMappingFlash(humanizeAjaxFailure(xhr), 'danger');
        });
    }

    function humanizeAjaxFailure(xhr) {
        if (!xhr || xhr.status === 0) return MAP_I18N.networkError;
        if (xhr.status === 401 || xhr.status === 403) return MAP_I18N.sessionExpired;
        // Server returned a JSON payload with a friendly message
        if (xhr.responseJSON && xhr.responseJSON.message) {
            var msg = xhr.responseJSON.message;
            if (xhr.responseJSON.trace_id) {
                msg += ' (' + MAP_I18N.traceIdLabel + ': ' + xhr.responseJSON.trace_id + ')';
            }
            return msg;
        }
        return MAP_I18N.serverError + ' (HTTP ' + xhr.status + ')';
    }

    function showMappingFlash(msg, level) {
        var cls = level === 'danger' ? 'alert-danger' : 'alert-success';
        var $flash = $('#mappingFlash');
        if ($flash.length === 0) {
            $flash = $('<div id="mappingFlash" class="alert" style="margin:10px auto;max-width:1100px;"></div>')
                .insertBefore('#mapForm');
        }
        $flash.removeClass('alert-success alert-danger').addClass(cls).text(msg).show();
        clearTimeout(showMappingFlash._t);
        // Errors stay visible longer so the user can read the trace id
        var ttl = level === 'danger' ? 10000 : 3500;
        showMappingFlash._t = setTimeout(function() { $flash.fadeOut(300); }, ttl);
    }

    function loadParticipants() {
        var dmId = $('#alldatamangers').val();
        if (!dmId) return;
        $('#datamanagerId').val(dmId);
        $.blockUI();
        $.ajax({
            url: GET_PARTICIPANT_URL,
            type: 'POST',
            dataType: 'json',
            data: {
                datamanagerId: dmId,
                country: $('#country').val(),
                province: $('#province').val(),
                district: $('#district').val(),
                network: $('#networkTier').val(),
                affiliation: $('#affiliation').val(),
                institute: $('#institute').val(),
                format: 'html'
            }
        }).done(function(items) {
            $('.singleMap').removeClass('hide');
            $('#bulkForm').hide();
            DualList.load(items || []);
        }).always(function() {
            $.unblockUI();
        });
    }

    function getParticipants(datamanagerId) { loadParticipants(); }
    function getDataManager() { loadParticipants(); }

    function bulkShowHide() {
        $('#bulkForm').toggle();
        if ($('#bulkForm').is(':visible') == true) {
            $('.singleMap').addClass('hide');
        }
    }

    function generateParticipantMapExport() {
        $.blockUI();
        $.post("<?php echo $this->url(array('module' => 'admin', 'controller' => 'participants', 'action' => 'export-participants-map')); ?>", { format: "html" },
            function(data) {
                if (data != "") {
                    document.location.href = '/temporary/' + data;
                }
                $.unblockUI();
            });
    }

    $(document).ready(function() {
        $("#country").select2({ allowClear: true, placeholder: "<?= $this->translate->_("Select Country"); ?>" });
        $("#province").select2({ allowClear: true, placeholder: "<?= $this->translate->_("Select Province"); ?>" });
        $("#district").select2({ allowClear: true, placeholder: "<?= $this->translate->_("Select District"); ?>" });
        $("#networkTier").select2({ allowClear: true, placeholder: "<?= $this->translate->_("Select Network Tier"); ?>" });
        $("#affiliation").select2({ allowClear: true, placeholder: "<?= $this->translate->_("Select Affiliation"); ?>" });
        $("#institute").select2({ allowClear: true, placeholder: "<?= $this->translate->_("Select Institute"); ?>" });

        <?php if (empty($this->isModal)) { ?>
        $("#alldatamangers").select2({
            placeholder: "<?= $this->translate->_("Select PT Login"); ?>",
            allowClear: true,
            minimumInputLength: 1,
            ajax: {
                url: GET_DM_NAMES_URL,
                dataType: 'json',
                delay: 250,
                data: function(params) {
                    var term = (params && params.term) ? params.term : '';
                    return { search: term };
                },
                results: function(data) { return { results: (data && data.result) ? data.result : [] }; },
                processResults: function(data) { return { results: (data && data.result) ? data.result : [] }; },
                cache: true
            }
        }).on('change', function() { loadParticipants(); });
        <?php } ?>

        $('.virt-pane').each(function() {
            DualList.init($(this).attr('data-side'), this);
        });

        $('#select-all-participant').on('click', function(e) {
            e.preventDefault();
            DualList.selectAll();
        });
        $('#deselect-all-participant').on('click', function(e) {
            e.preventDefault();
            DualList.deselectAll();
        });

        <?php if (!empty($this->preselectedDmId)) { ?>
            $('#datamanagerId').val('<?php echo (int) $this->preselectedDmId; ?>');
            loadParticipants();
        <?php } ?>
    });
</script>
