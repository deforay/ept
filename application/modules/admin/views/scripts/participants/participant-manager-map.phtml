<script type="text/javascript" src="<?php echo $this->baseUrl('js/select2.min.js'); ?>"></script>
<script>
    var GET_PARTICIPANT_URL = "<?php echo $this->url(array('module' => 'admin', 'controller' => 'participants', 'action' => 'get-participant')); ?>";
    var GET_DM_NAMES_URL = "<?php echo $this->url(array('module' => 'admin', 'controller' => 'participants', 'action' => 'get-datamanager-names')); ?>";

    var DualList = (function() {
        var ROW_HEIGHT = 30;
        var OVERSCAN = 6;
        var state = { left: [], right: [] };
        var panes = {};

        function escapeHtml(s) {
            return String(s).replace(/[&<>"']/g, function(c) {
                return ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[c];
            });
        }

        function initPane(sideKey, paneEl) {
            var $pane = $(paneEl);
            var pane = {
                sideKey: sideKey,
                $scroll: $pane.find('.virt-pane-scroll'),
                $inner: $pane.find('.virt-pane-inner'),
                $search: $pane.find('.virt-pane-header input'),
                $count: $pane.find('.virt-count'),
                $diff: $pane.find('.virt-diff'),
                $diffCount: $pane.find('.virt-diff-count'),
                filter: '',
                filtered: []
            };
            pane.$scroll.on('scroll', function() { render(pane); });
            pane.$search.on('input', function() {
                pane.filter = pane.$search.val().toLowerCase();
                recomputeFiltered(pane);
                pane.$scroll.scrollTop(0);
                render(pane);
            });
            pane.$inner.on('click', '.virt-row', function() {
                moveItem(pane.sideKey, $(this).attr('data-id'));
            });
            panes[sideKey] = pane;
        }

        function recomputeFiltered(pane) {
            var src = state[pane.sideKey];
            if (!pane.filter) {
                pane.filtered = src;
            } else {
                var f = pane.filter;
                pane.filtered = [];
                for (var i = 0; i < src.length; i++) {
                    if (src[i]._lc.indexOf(f) !== -1) pane.filtered.push(src[i]);
                }
            }
            pane.$count.text(pane.filtered.length);
            pane.$inner.css('height', (pane.filtered.length * ROW_HEIGHT) + 'px');
            updateDiffBadge(pane);
        }

        function updateDiffBadge(pane) {
            if (!pane.$diff || pane.$diff.length === 0) return;
            var src = state[pane.sideKey];
            var diffCount = 0;
            if (pane.sideKey === 'right') {
                for (var i = 0; i < src.length; i++) if (!src[i].savedRight) diffCount++;
            } else {
                for (var j = 0; j < src.length; j++) if (src[j].savedRight) diffCount++;
            }
            pane.$diffCount.text(diffCount);
            pane.$diff.toggle(diffCount > 0);
        }

        function rowClass(it, sideKey) {
            if (sideKey === 'right') {
                return it.savedRight ? 'virt-row-saved' : 'virt-row-added';
            }
            return it.savedRight ? 'virt-row-removed' : '';
        }

        function render(pane) {
            var scrollTop = pane.$scroll.scrollTop();
            var h = pane.$scroll.height();
            var first = Math.max(0, Math.floor(scrollTop / ROW_HEIGHT) - OVERSCAN);
            var last = Math.min(pane.filtered.length, Math.ceil((scrollTop + h) / ROW_HEIGHT) + OVERSCAN);
            var parts = [];
            for (var i = first; i < last; i++) {
                var it = pane.filtered[i];
                var cls = rowClass(it, pane.sideKey);
                parts.push(
                    '<div class="virt-row' + (cls ? ' ' + cls : '') + '" style="top:' + (i * ROW_HEIGHT) + 'px" data-id="' +
                    escapeHtml(it.id) + '">' + escapeHtml(it.label) + '</div>'
                );
            }
            pane.$inner.html(parts.join(''));
        }

        function moveItem(fromSide, id) {
            var toSide = fromSide === 'left' ? 'right' : 'left';
            var arr = state[fromSide];
            for (var i = 0; i < arr.length; i++) {
                if (String(arr[i].id) === String(id)) {
                    var item = arr.splice(i, 1)[0];
                    state[toSide].push(item);
                    break;
                }
            }
            refresh();
        }

        function refresh() {
            recomputeFiltered(panes.left);
            recomputeFiltered(panes.right);
            render(panes.left);
            render(panes.right);
        }

        function load(items) {
            state.left = [];
            state.right = [];
            for (var i = 0; i < items.length; i++) {
                var it = items[i];
                it._lc = String(it.label).toLowerCase();
                it.savedRight = !!it.selected;
                if (it.selected) state.right.push(it);
                else state.left.push(it);
            }
            if (panes.left) { panes.left.$search.val(''); panes.left.filter = ''; panes.left.$scroll.scrollTop(0); }
            if (panes.right) { panes.right.$search.val(''); panes.right.filter = ''; panes.right.$scroll.scrollTop(0); }
            refresh();
        }

        function selectAll() {
            state.right = state.right.concat(state.left);
            state.left = [];
            refresh();
        }

        function deselectAll() {
            state.left = state.left.concat(state.right);
            state.right = [];
            refresh();
        }

        function getSelectedIds() {
            var ids = [];
            for (var i = 0; i < state.right.length; i++) ids.push(state.right[i].id);
            return ids;
        }

        return {
            init: initPane,
            load: load,
            selectAll: selectAll,
            deselectAll: deselectAll,
            getSelectedIds: getSelectedIds
        };
    })();

    function advFilter() {
        $('.advFilter').toggle();
        if ($('.filter-btn').text() == 'Show advanced filters') {
            $('.filter-btn').text('Hide advanced filters');
        } else {
            $('.filter-btn').text('Show advanced filters');
        }
    }

    function getStats(cid) {
