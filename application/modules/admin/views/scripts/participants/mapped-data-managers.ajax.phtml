<?php
$mappedDms = $this->mappedDms ?? [];
$dmCount = count($mappedDms);
?>
<div class="dm-child-row" style="padding:10px 15px;background:#fafbfc;border-left:4px solid #337ab7;">
    <?php if ($dmCount === 0) { ?>
        <em class="text-muted"><?= $this->translate->_('No data managers are currently mapped to this participant.'); ?></em>
    <?php } else { ?>
        <div style="margin-bottom:6px;">
            <strong><?= sprintf($this->translate->_('%d Data Manager(s) mapped'), $dmCount); ?></strong>
            <?php if ($dmCount > 5) { ?>
                <input type="text" class="form-control input-sm dm-filter-input" placeholder="<?= $this->translate->_('Filter by name or email…'); ?>" style="max-width:280px;display:inline-block;margin-left:10px;" />
            <?php } ?>
        </div>
        <div class="dm-list-wrap" style="max-height:260px;overflow-y:auto;border:1px solid #e5e5e5;border-radius:3px;background:#fff;">
            <table class="table table-condensed" style="margin:0;">
                <thead>
                    <tr>
                        <th><?= $this->translate->_('Data Manager'); ?></th>
                        <th><?= $this->translate->_('Primary Email'); ?></th>
                        <th><?= $this->translate->_('Status'); ?></th>
                        <th style="text-align:right;"><?= $this->translate->_('Action'); ?></th>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($mappedDms as $dm) {
                        $name = trim(($dm['first_name'] ?? '') . ' ' . ($dm['last_name'] ?? ''));
                        if ($name === '') {
                            $name = $dm['primary_email'] ?? '';
                        }
                        $isPtcc = isset($dm['data_manager_type']) && $dm['data_manager_type'] === 'ptcc';
                        $editUrl = '/admin/data-managers/edit/id/' . (int)$dm['dm_id'] . ($isPtcc ? '/ptcc/1' : '');
                        $resetUrl = '/admin/data-managers/reset-password/id/' . (int)$dm['dm_id'];
                        $searchBlob = strtolower($name . ' ' . ($dm['primary_email'] ?? ''));
                    ?>
                        <tr class="dm-row" data-dm-search="<?= htmlspecialchars($searchBlob, ENT_QUOTES, 'UTF-8'); ?>">
                            <td>
                                <?= htmlspecialchars($name, ENT_QUOTES, 'UTF-8'); ?>
                                <?php if (!empty($dm['institute'])) { ?>
                                    <br><small class="text-muted"><?= htmlspecialchars($dm['institute'], ENT_QUOTES, 'UTF-8'); ?></small>
                                <?php } ?>
                                <?php if ($isPtcc) { ?>
                                    <span class="label label-info" style="margin-left:4px;">PTCC</span>
                                <?php } ?>
                            </td>
                            <td><?= htmlspecialchars($dm['primary_email'] ?? '', ENT_QUOTES, 'UTF-8'); ?></td>
                            <td><?= htmlspecialchars(ucwords($dm['status'] ?? ''), ENT_QUOTES, 'UTF-8'); ?></td>
                            <td style="text-align:right;white-space:nowrap;">
                                <a href="<?= $editUrl; ?>" class="btn btn-warning btn-xs" style="margin-right:2px;"><i class="icon-pencil"></i> <?= $this->translate->_('Edit'); ?></a>
                                <a href="javascript:void(0);" class="btn btn-info btn-xs" onclick="layoutModal('<?= $resetUrl; ?>','980','500');"><?= $this->translate->_('Reset Password'); ?></a>
                            </td>
                        </tr>
                    <?php } ?>
                </tbody>
            </table>
        </div>
    <?php } ?>
</div>
