<script type="text/javascript" charset="utf-8">
    /* Table initialisation */
    var oTable = null;
    $(document).ready(function () {
        drawTable();
    });

    function getApproval(status) {
        if (status == 'pending') {
            $('.status-field').removeClass('hide');
        } else {
            $('.status-field').addClass('hide');
        }
        $('#status').val(status);
        drawTable();
    }

    function drawTable() {
        oTable = $('#possibleResultsTable').dataTable({

            "bJQueryUI": false,
            "bAutoWidth": false,
            "bInfo": true,
            "bScrollCollapse": true,
            "sPaginationType": "bootstrap",
            "bRetrieve": false,
            "bDestroy": true,
            "aoColumns": [{
                "sClass": "left"
            },
            {
                "sClass": "center"
            },
            {
                "sClass": "center"
            },
            {
                "sClass": "center",
                "bSortable": false
            }
            ],
            "aaSorting": [
                [0, "asc"]
            ],
            /* "fnDrawCallback": function() {
                var checkBoxes = document.getElementsByName("subchk[]");
                len = checkBoxes.length;
                for (c = 0; c < len; c++) {
                    if (jQuery.inArray(checkBoxes[c].id, selectedKit) != -1) {
                        checkBoxes[c].setAttribute("checked", true);
                    }
                }

            }, */
            "bProcessing": true,
            "bServerSide": true,
            "sAjaxSource": "<?php echo $this->url(array('module' => 'admin', 'controller' => 'schemes', 'action' => 'test-results', 'format' => 'html')); ?>",
            "fnServerParams": function (aoData) {
                approvalStatus = $("#status").val();
                aoData.push({
                    "name": "status",
                    "value": approvalStatus
                });
            },
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.ajax({
                    "dataType": 'json',
                    "type": "POST",
                    "url": sSource,
                    "data": aoData,
                    "success": fnCallback
                });
            }
        });
    }
</script>