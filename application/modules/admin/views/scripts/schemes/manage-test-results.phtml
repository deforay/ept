<script type="text/javascript">
	var duplicated = false;

	var IS_USER_CONFIGURED = <?= $isUserConfigured ? 'true' : 'false'; ?>;
	var SCHEME_CODE = <?= json_encode($schemeId); ?>;

	/* ── Prefix helpers ──────────────────────────────────────────────────── */

	function getPrefix(resultTypeValue) {
		if (!SCHEME_CODE) return '';
		if (resultTypeValue === 'TEST') return SCHEME_CODE + '-T-';
		if (resultTypeValue === 'FINAL') return SCHEME_CODE + '-F-';
		return SCHEME_CODE + '-';
	}

	function updateResultCodeForRow(tr) {
		if (!IS_USER_CONFIGURED) return;

		var $tr = $(tr);
		var type = $tr.find('.js-result-type').val();
		var prefix = getPrefix(type);
		var $addon = $tr.find('.js-code-prefix');
		var $suffix = $tr.find('.js-code-suffix');
		var $hidden = $tr.find('.js-code-hidden');

		var raw = ($suffix.val() || '').toUpperCase().replace(/[^A-Z0-9]/g, '');
		if ($suffix.val() !== raw) $suffix.val(raw);

		if (prefix) {
			$addon.text(prefix).show();
		} else {
			$addon.text('').hide();
		}

		$hidden.val(raw ? prefix + raw : '');
	}

	function initAllPrefixes() {
		if (!IS_USER_CONFIGURED) return;
		$('#rowsBody tr').each(function() {
			updateResultCodeForRow(this);
		});
	}

	/* ── Row building ────────────────────────────────────────────────────── */

	function buildResultCodeCell() {
		if (IS_USER_CONFIGURED) {
			return '<div class="input-group input-group-sm">' +
				'<span class="input-group-addon result-code-prefix-addon js-code-prefix" style="padding:6px 8px;"></span>' +
				'<input type="text" class="form-control isRequired js-code-suffix input-sm"' +
				'   placeholder="<?= $this->translate->_("e.g. P"); ?>" maxlength="20"' +
				'   title="<?= $this->translate->_("Please enter the result code suffix"); ?>" />' +
				'</div>' +
				'<input type="hidden" name="resultCode[]" class="js-code-hidden" />';
		} else {
			return '<input type="text" name="resultCode[]" class="form-control isRequired"' +
				'   placeholder="<?= $this->translate->_("e.g. POS"); ?>" required' +
				'   onblur="checkDuplicate(\'r_possibleresult\',\'result_code\',this,null,\'<?= $this->translate->_("This result code already exists. Please try something else."); ?>\')" />';
		}
	}

	function buildRow() {
		var tr = document.createElement('tr');
		tr.innerHTML =
			'<td class="row-num"></td>' +
			'<td>' +
			'<select name="resultType[]" class="form-control isRequired' + (IS_USER_CONFIGURED ? ' js-result-type' : '') + '" required>' +
			'<option value="">-- <?= $this->translate->_("Select"); ?> --</option>' +
			'<option value="TEST"><?= $this->translate->_("Test Result"); ?></option>' +
			'<option value="FINAL"><?= $this->translate->_("Final Interpretation"); ?></option>' +
			'</select>' +
			'</td>' +
			'<td>' +
			'<input type="text" name="response[]" class="form-control isRequired"' +
			'   placeholder="<?= $this->translate->_("Enter response"); ?>" required />' +
			'</td>' +
			'<td>' + buildResultCodeCell() + '</td>' +
			'<td><input type="text" name="sortOrder[]" class="form-control" placeholder="0" /></td>' +
			'<td class="action-cell">' +
			'<button type="button" class="btn-row-add" title="<?= $this->translate->_("Add row below"); ?>" onclick="insertRowAfter(this)">+</button> ' +
			'<button type="button" class="btn-row-remove" title="<?= $this->translate->_("Remove row"); ?>" onclick="removeRow(this)">&#8722;</button>' +
			'</td>';
		return tr;
	}

	/* ── Row management ──────────────────────────────────────────────────── */

	function appendNewRow() {
		var tbody = document.getElementById('rowsBody');
		var newRow = buildRow();
		tbody.appendChild(newRow);
		reindex();
		if (IS_USER_CONFIGURED) updateResultCodeForRow(newRow);
	}

	function insertRowAfter(btn) {
		var currentRow = btn.closest('tr');
		var newRow = buildRow();
		currentRow.parentNode.insertBefore(newRow, currentRow.nextSibling);
		reindex();
		if (IS_USER_CONFIGURED) updateResultCodeForRow(newRow);
	}

	function removeRow(btn) {
		var tbody = document.getElementById('rowsBody');
		if (tbody.rows.length <= 1) {
			alert('<?= $this->translate->_("At least one row is required."); ?>');
			return;
		}
		btn.closest('tr').remove();
		reindex();
	}

	function reindex() {
		document.querySelectorAll('#rowsBody tr').forEach(function(tr, i) {
			tr.querySelector('.row-num').textContent = i + 1;
		});
	}

	/* ── Event delegation ────────────────────────────────────────────────── */

	$(document).on('change', '#rowsBody .js-result-type', function() {
		updateResultCodeForRow($(this).closest('tr')[0]);
	});

	$(document).on('input', '#rowsBody .js-code-suffix', function() {
		updateResultCodeForRow($(this).closest('tr')[0]);
	});

	/* ── Duplicate check ─────────────────────────────────────────────────── */

	function checkDuplicate(tableName, fieldName, obj, fnct, msg) {
		$.post("<?php echo $this->url(array('module' => 'default', 'controller' => 'common', 'action' => 'check-duplicate')); ?>", {
			tableName: tableName,
			fieldName: fieldName,
			value: obj.value,
			fnct: fnct,
			format: 'html'
		}, function(data) {
			if (data > 0) {
				alert(msg, 'err');
				duplicated = true;
				$(obj).val('');
			} else {
				duplicated = false;
			}
		});
	}

	/* ── Validation & submit ─────────────────────────────────────────────── */

	function validateNow() {
		if (IS_USER_CONFIGURED) {
			var valid = true;
			$('#rowsBody .js-code-hidden').each(function() {
				if (!$(this).val()) {
					alert('<?= $this->translate->_("Please enter a result code for all rows."); ?>');
					valid = false;
					return false;
				}
			});
			if (!valid) return false;
		}

		var flag = deforayValidator.init({
			formId: 'updatePossibleResultsForm'
		});
		if (flag && !duplicated) {
			$.blockUI();
			document.getElementById('updatePossibleResultsForm').submit();
		}
	}

	/* ── Init ────────────────────────────────────────────────────────────── */

	$(document).ready(function() {
		if ($('#rowsBody tr').length === 0) appendNewRow();
		reindex();
		initAllPrefixes();
	});
</script>