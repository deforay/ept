									$storedCode    = $row['result_code'];
									$displaySuffix = $storedCode;
									if ($isUserConfigured && $schemeId !== '') {
										$prefixTest    = $schemeId . '-T-';
										$prefixFinal   = $schemeId . '-F-';
										$prefixGeneric = $schemeId . '-';
										if (strpos($storedCode, $prefixTest) === 0) {
											$displaySuffix = substr($storedCode, strlen($prefixTest));
										} elseif (strpos($storedCode, $prefixFinal) === 0) {
											$displaySuffix = substr($storedCode, strlen($prefixFinal));
										} elseif (strpos($storedCode, $prefixGeneric) === 0) {
											$displaySuffix = substr($storedCode, strlen($prefixGeneric));
										}
									}

									// A row is LOCKED for two reasons. Locked rows can only have their sort order
									// and "displayed to" edited; those post under separate locked* names so the save
									// path updates just those two columns and never touches scheme_sub_group /
									// response / result_code.
									//
									// 1. In-use  = belongs to a shipment that is not yet finalized.
									// 2. Pre-defined sub-test = a scheme_sub_group richer than the plain
									//    "{SCHEME}_TEST/FINAL" (built-in) or bare "TEST/FINAL" (user-configured)
									//    forms -- e.g. DTS_SYP_TEST, RECENCY_FINAL, TB_MOLECULAR_FINAL. This flat
									//    Test/Final form cannot represent those, so editing would flatten them and
									//    destroy the sub-test grouping. Detection is structural (no hardcoded list),
									//    so sub-tests added for other schemes in future are protected automatically.
									$subGroup    = strtoupper(trim((string) $row['scheme_sub_group']));
									$plainGroups = $isUserConfigured
										? ['TEST', 'FINAL']
										: [$schemeId . '_TEST', $schemeId . '_FINAL'];
									$isSubTest   = ($subGroup !== '') && !in_array($subGroup, $plainGroups, true);

