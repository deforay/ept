<script type="text/javascript">
	var isDirty = false;
	var isSubmitting = false;

	var IS_USER_CONFIGURED = <?= $isUserConfigured ? 'true' : 'false'; ?>;
	var SCHEME_CODE = <?= json_encode($schemeId); ?>;

	/* ── Result-code prefix helpers (user-configured schemes) ──────────────── */

	function getPrefix(resultTypeValue) {
		if (!SCHEME_CODE) return '';
		if (resultTypeValue === 'TEST') return SCHEME_CODE + '-T-';
		if (resultTypeValue === 'FINAL') return SCHEME_CODE + '-F-';
		return SCHEME_CODE + '-';
	}

	function updateResultCodeForRow(tr) {
		if (!IS_USER_CONFIGURED) return;
		var $tr = $(tr);
		var type = $tr.find('.js-type').val();
		var prefix = getPrefix(type);
		var $addon = $tr.find('.js-code-prefix');
		var $suffix = $tr.find('.js-code-suffix');
		var $hidden = $tr.find('.js-code-hidden');

		var raw = ($suffix.val() || '').toUpperCase().replace(/[^A-Z0-9]/g, '');
		if ($suffix.val() !== raw) $suffix.val(raw);

		if (prefix) { $addon.text(prefix).show(); } else { $addon.text('').hide(); }
		$hidden.val(raw ? prefix + raw : '');
	}

	function initAllPrefixes() {
		if (!IS_USER_CONFIGURED) return;
		$('#rowsBody tr').each(function () { updateResultCodeForRow(this); });
		// keep the add-bar prefix addon in sync with the chosen type
		updateAddPrefix();
	}

	function updateAddPrefix() {
		if (!IS_USER_CONFIGURED) return;
		var prefix = getPrefix($('#addType').val());
		var $addon = $('#addCodePrefix');
		if (prefix) { $addon.text(prefix).show(); } else { $addon.text('').hide(); }
	}

	/* ── Sorting: Test Results first, then Final Interpretations, by sort order ── */

	function typeRank(t) { return t === 'TEST' ? 0 : (t === 'FINAL' ? 1 : 2); }

	function rowKey(tr) {
		var $tr = $(tr);
		var so = parseInt($tr.find('.js-sort').val(), 10);
		return { rank: typeRank($tr.find('.js-type').val()), so: isNaN(so) ? Number.POSITIVE_INFINITY : so };
	}

	// true when key a should sort strictly before key b
	function keyLess(a, b) {
		if (a.rank !== b.rank) return a.rank < b.rank;
		return a.so < b.so;
	}

	function insertSorted(newTr) {
		var rows = $('#rowsBody tr').not(newTr).toArray();
		var nk = rowKey(newTr);
		for (var i = 0; i < rows.length; i++) {
			if (keyLess(nk, rowKey(rows[i]))) {
				rows[i].parentNode.insertBefore(newTr, rows[i]);
				reindex();
				return;
			}
		}
		document.getElementById('rowsBody').appendChild(newTr);
		reindex();
	}

	function applyTypeClass(tr) {
		var t = $(tr).find('.js-type').val();
		var cls = t === 'TEST' ? 'row-type-test' : (t === 'FINAL' ? 'row-type-final' : 'row-type-other');
		$(tr).removeClass('row-type-test row-type-final row-type-other').addClass(cls);
	}

	/* ── Row template (for client-added rows) ──────────────────────────────── */

	function buildResultCodeCell() {
		if (IS_USER_CONFIGURED) {
			return '<div class="input-group input-group-sm" style="display:flex;">' +
				'<span class="input-group-addon result-code-prefix-addon js-code-prefix" style="display:inline-table;"></span>' +
				'<input type="text" class="form-control isRequired js-code-suffix input-sm" placeholder="<?= $this->translate->_("e.g. P"); ?>" maxlength="20" />' +
				'</div>' +
				'<input type="hidden" name="resultCode[]" class="js-code-hidden" />';
		}
		return '<input type="text" name="resultCode[]" class="form-control isRequired js-code-plain" placeholder="<?= $this->translate->_("e.g. POS"); ?>" required />';
	}

	function buildRow() {
		var tr = document.createElement('tr');
		tr.innerHTML =
			'<td class="row-num"></td>' +
			'<td>' +
			'<select name="resultType[]" class="form-control isRequired js-type' + (IS_USER_CONFIGURED ? ' js-result-type' : '') + '" required>' +
			'<option value="">-- <?= $this->translate->_("Select"); ?> --</option>' +
			'<option value="TEST"><?= $this->translate->_("Test Result"); ?></option>' +
			'<option value="FINAL"><?= $this->translate->_("Final Interpretation"); ?></option>' +
			'</select>' +
			'</td>' +
			'<td><input type="text" name="response[]" class="form-control isRequired" placeholder="<?= $this->translate->_("Enter response"); ?>" required /></td>' +
			'<td>' + buildResultCodeCell() + '</td>' +
			'<td>' +
			'<select name="displayContext[]" class="form-control">' +
			'<option value="all"><?= $this->translate->_("All"); ?></option>' +
			'<option value="participant"><?= $this->translate->_("Participant"); ?></option>' +
			'<option value="admin"><?= $this->translate->_("Admin"); ?></option>' +
			'<option value="none"><?= $this->translate->_("None"); ?></option>' +
			'</select>' +
			'</td>' +
			'<td><input type="text" name="sortOrder[]" class="form-control js-sort" placeholder="0" /></td>' +
			'<td class="action-cell">' +
			'<button type="button" class="btn-row-remove" title="<?= $this->translate->_("Remove row"); ?>" onclick="removeRow(this)">&#8722;</button>' +
			'</td>';
		return tr;
	}

	/* ── Add a new result from the top bar ─────────────────────────────────── */

	function addNewResult() {
		var type = $('#addType').val();
		var response = $.trim($('#addResponse').val());
		var dc = $('#addDisplayContext').val();
		var sort = $.trim($('#addSortOrder').val());
		var code, suffix;

		if (IS_USER_CONFIGURED) {
			suffix = ($('#addCodeSuffix').val() || '').toUpperCase().replace(/[^A-Z0-9]/g, '');
			code = suffix;
		} else {
			code = $.trim($('#addCode').val());
		}

		if (!type) { alert('<?= $this->translate->_("Please select a result type."); ?>'); return; }
		if (!response) { alert('<?= $this->translate->_("Please enter a response."); ?>'); return; }
		if (!code) { alert('<?= $this->translate->_("Please enter a result code."); ?>'); return; }

		var candidateCode = IS_USER_CONFIGURED ? normVal(getPrefix(type) + suffix) : normVal(code);
		var addDup = findTypeDup(type, normVal(response), candidateCode, null);
		if (addDup.response || addDup.code) { alert(dupMessage(addDup)); return; }

		var tr = buildRow();
		$(tr).find('.js-type').val(type);
		$(tr).find('input[name="response[]"]').val(response);
		$(tr).find('select[name="displayContext[]"]').val(dc);
		$(tr).find('.js-sort').val(sort);

		if (IS_USER_CONFIGURED) {
			$(tr).find('.js-code-suffix').val(suffix);
			updateResultCodeForRow(tr);
		} else {
			$(tr).find('input[name="resultCode[]"]').val(code);
		}

		applyTypeClass(tr);
		insertSorted(tr);
		markDirty();

		// reset the add bar
		$('#addType').val('');
		$('#addResponse').val('');
		$('#addDisplayContext').val('all');
		$('#addSortOrder').val('');
		if (IS_USER_CONFIGURED) { $('#addCodeSuffix').val(''); updateAddPrefix(); } else { $('#addCode').val(''); }
		$('#addType').focus();
	}

	/* ── Row management ────────────────────────────────────────────────────── */

	function removeRow(btn) {
		$(btn).closest('tr').remove();
		reindex();
		markDirty();
	}

	function reindex() {
		document.querySelectorAll('#rowsBody tr').forEach(function (tr, i) {
			var cell = tr.querySelector('.row-num');
			if (cell) cell.textContent = i + 1;
		});
	}

	/* ── Dirty tracking + unsaved warning ──────────────────────────────────── */

	function markDirty() {
		if (isDirty) return;
		isDirty = true;
		$('#unsavedBanner').addClass('show');
		$('#floatingButtons').addClass('dirty');
	}

	function clearDirty() {
		isDirty = false;
		$('#unsavedBanner').removeClass('show');
		$('#floatingButtons').removeClass('dirty');
	}

	window.addEventListener('beforeunload', function (e) {
		if (isDirty && !isSubmitting) {
			e.preventDefault();
			e.returnValue = '';
			return '';
		}
	});

	/* ── Event delegation ──────────────────────────────────────────────────── */

	$(document).on('change input', '#rowsBody select, #rowsBody input', function () {
		markDirty();
	});

	$(document).on('change', '#rowsBody .js-result-type', function () {
		updateResultCodeForRow($(this).closest('tr')[0]);
	});

	$(document).on('input', '#rowsBody .js-code-suffix', function () {
		updateResultCodeForRow($(this).closest('tr')[0]);
	});

	// When type or sort order of an existing row changes, re-stripe and re-position it.
	$(document).on('change', '#rowsBody .js-type', function () {
		var tr = $(this).closest('tr')[0];
		applyTypeClass(tr);
		insertSorted(tr);
	});

	$(document).on('change', '#rowsBody .js-sort', function () {
		insertSorted($(this).closest('tr')[0]);
	});

	// Editing an existing row into a same-type duplicate is not allowed -> revert the field.
	$(document).on('change', '#rowsBody input[name^="response"]', function () {
		var tr = $(this).closest('tr')[0];
		if (findTypeDup(rowTypeVal(tr), normVal(this.value), '', tr).response) {
			alert(dupMessage({ response: true, code: false }));
			$(this).val('').focus();
		}
	});

	$(document).on('change', '#rowsBody .js-code-plain', function () {
		var tr = $(this).closest('tr')[0];
		if (findTypeDup(rowTypeVal(tr), '', normVal(this.value), tr).code) {
			alert(dupMessage({ response: false, code: true }));
			$(this).val('').focus();
		}
	});

	$(document).on('change', '#rowsBody .js-code-suffix', function () {
		var tr = $(this).closest('tr')[0];
		// the 'input' handler above has already recomputed the hidden full code
		if (findTypeDup(rowTypeVal(tr), '', rowCodeVal(tr), tr).code) {
			alert(dupMessage({ response: false, code: true }));
			$(this).val('').trigger('input').focus();
		}
	});

	// Keep the add-bar prefix addon synced
	$('#addType').on('change', updateAddPrefix);
	$('#addCodeSuffix').on('input', function () {
		this.value = (this.value || '').toUpperCase().replace(/[^A-Z0-9]/g, '');
	});

	// Cancel = intentional discard; don't double-prompt
	$(document).on('click', '.js-cancel', function () { isDirty = false; });

	/* ── Duplicate prevention (scoped to this scheme + result type) ─────────── */

	function normVal(v) { return (v == null ? '' : String(v)).trim().toUpperCase(); }

	function rowTypeVal(tr) { return $(tr).find('.js-type').val(); }
	function rowRespVal(tr) { return normVal($(tr).find('input[name^="response"]').val()); }
	function rowCodeVal(tr) {
		if (IS_USER_CONFIGURED) return normVal($(tr).find('.js-code-hidden').val());
		return normVal($(tr).find('.js-code-plain').val());
	}

	// Within the same result type, is this response / result code already taken?
	function findTypeDup(type, response, code, excludeTr) {
		var dup = { response: false, code: false };
		$('#rowsBody tr').each(function () {
			if (excludeTr && this === excludeTr) return;
			if (rowTypeVal(this) !== type) return;
			if (response && rowRespVal(this) === response) dup.response = true;
			if (code && rowCodeVal(this) === code) dup.code = true;
		});
		return dup;
	}

	function dupMessage(dup) {
		if (dup.response && dup.code) return '<?= $this->translate->_("Another result of this type already uses this response and result code."); ?>';
		if (dup.response) return '<?= $this->translate->_("Another result of this type already uses this response."); ?>';
		return '<?= $this->translate->_("Another result of this type already uses this result code."); ?>';
	}

	/* ── Validation & submit ───────────────────────────────────────────────── */

	function validateNow() {
		// Don't silently drop a half-entered result still sitting in the Add box.
		var pendingResp = $.trim($('#addResponse').val());
		var pendingCode = IS_USER_CONFIGURED ? $.trim($('#addCodeSuffix').val()) : $.trim($('#addCode').val());
		if (pendingResp || pendingCode) {
			alert('<?= $this->translate->_("You have a result in the Add box that has not been added yet. Click \"Add\" to include it, or clear it before saving."); ?>');
			return false;
		}

		if (IS_USER_CONFIGURED) {
			var valid = true;
			$('#rowsBody .js-code-hidden').each(function () {
				if (!$(this).val()) {
					alert('<?= $this->translate->_("Please enter a result code for all rows."); ?>');
					valid = false;
					return false;
				}
			});
			if (!valid) return false;
		}

		var flag = deforayValidator.init({ formId: 'updatePossibleResultsForm' });
		if (flag) {
			isSubmitting = true;
			clearDirty();
			$.blockUI();
			document.getElementById('updatePossibleResultsForm').submit();
		}
	}

	/* ── Init ──────────────────────────────────────────────────────────────── */

	$(document).ready(function () {
		reindex();
		initAllPrefixes();
		$('#rowsBody tr').each(function () { applyTypeClass(this); });
	});
</script>
