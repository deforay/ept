# ePT Docker Configuration
# Copy this file to .env and adjust values as needed.

# Host port to expose the application on (default: 80)
APP_PORT=80

# Application URL (include trailing slash)
APP_DOMAIN=http://localhost/

# Database credentials
DB_HOST=ept-db
DB_USER=root
DB_PASSWORD=ept_secret
DB_NAME=mtbept

# MySQL root password (should match DB_PASSWORD if using root)
MYSQL_ROOT_PASSWORD=ept_secret

# SSL (only needed with --profile ssl)
# Domain name for SSL certificate
#APP_HOSTNAME=ept.example.org

# Optional AI translation prefill for refresh-translations.php
# Set these only if you want empty PO entries to be pre-translated automatically.
# The endpoint must support an OpenAI-compatible chat completions API.
#EPT_AI_API_URL=https://api.deepseek.com/chat/completions
#EPT_AI_API_KEY=your_api_key_here
#EPT_AI_MODEL=deepseek-chat

# Non-production mail trap.
# On any APPLICATION_ENV other than 'production', outgoing mail is gated:
#   - If MAIL_DEV_DSN is set, all mail is routed here (DB SMTP creds are ignored).
#   - If unset, mail is blocked: send-emails.php marks pending rows as 'skipped',
#     and Application_Service_Common::sendMail() returns false.
# Run Mailpit locally to catch mail in a web UI: http://localhost:8025
# Ubuntu:
#   sudo bash < <(curl -sL https://raw.githubusercontent.com/axllent/mailpit/develop/install.sh)
#   mailpit &    # or set up a systemd unit
# Docker (any OS):
#   docker run -d --name mailpit -p 1025:1025 -p 8025:8025 axllent/mailpit
# macOS:
#   brew install mailpit && brew services start mailpit
#MAIL_DEV_DSN=smtp://127.0.0.1:1025
