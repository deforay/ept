# ePT Docker Configuration
# Copy this file to .env and adjust values as needed.

# Host port to expose the application on (default: 80)
APP_PORT=80

# Application URL (include trailing slash)
APP_DOMAIN=http://localhost/

# Database credentials
DB_HOST=db
DB_USER=root
DB_PASSWORD=ept_secret
DB_NAME=ept

# MySQL root password (should match DB_PASSWORD if using root)
MYSQL_ROOT_PASSWORD=ept_secret

# SSL (only needed with --profile ssl)
# Domain name for SSL certificate
#APP_HOSTNAME=ept.example.org
