{
    "name": "deforay/ept",
    "description": "Open Source Online PT Management System",
    "homepage": "https://github.com/deforay/ept",
    "license": "AGPL-3.0-only",
    "type": "project",
    "authors": [
        {
            "name": "Deforay",
            "email": "hello@deforay.com",
            "homepage": "https://deforay.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "amitdugar/db-tools": "^3.0",
        "crunzphp/crunz": "^3.9",
        "gregwar/captcha": "^1.3",
        "hackzilla/password-generator": "^1.7",
        "league/commonmark": "^2.8",
        "maennchen/zipstream-php": "^2.4",
        "mitoteam/jpgraph": "^10.5",
        "monolog/monolog": "^3.10",
        "mpdf/mpdf": "^8.3",
        "mpdf/psr-http-message-shim": "^1.0",
        "myclabs/php-enum": "^1.8",
        "nesbot/carbon": "^3.11",
        "phpmyadmin/sql-parser": "^6.0",
        "phpoffice/phpspreadsheet": "^5.7",
        "phpoffice/phpword": "^1.4",
        "psr/http-message": "^1.1",
        "setasign/fpdf": "^1.9",
        "setasign/fpdi": "^2.6",
        "shardj/zf1-future": "^1.25",
        "symfony/console": "^8.1",
        "symfony/mailer": "^8.0",
        "symfony/uid": "^8.0",
        "tecnickcom/tcpdf": "^6.11"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "secure-http": true,
        "platform": {
            "php": "8.4.1",
            "php-64bit": "8.4.1"
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1",
        "symfony/var-dumper": "^5.4"
    },
    "scripts": {
        "db-backup": "@php vendor/bin/db-tools backup",
        "tasks": "@php vendor/bin/crunz schedule:run",
        "collation": "@php vendor/bin/db-tools collation",
        "migrate": [
            "@php bin/migrate.php -yq",
            "@collation"
        ],
        "generate-salt": "@php bin/generate-salt.php",
        "phpstan": "@php vendor/bin/phpstan analyse --memory-limit=2G",
        "phpstan:baseline": "@php vendor/bin/phpstan analyse --generate-baseline phpstan-baseline.neon --memory-limit=2G",
        "cs-check": "@php vendor/bin/php-cs-fixer fix --dry-run --diff",
        "cs-fix": "@php vendor/bin/php-cs-fixer fix",
        "post-update": [
            "@migrate",
            "@generate-salt"
        ]
    }
}